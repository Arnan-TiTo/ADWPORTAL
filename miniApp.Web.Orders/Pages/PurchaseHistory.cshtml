@page
@model miniApp.WebOrders.Pages.PurchaseHistoryModel
@{
    ViewData["Title"] = "Purchase History";
}

<div class="h-full min-h-0">
    <div class="max-w-md w-full mx-auto px-2 pt-2 pb-2 h-full min-h-0 flex flex-col">


    <!-- Header -->
    <div class="flex items-center justify-between mb-2 py-2 shrink-0">
        <a asp-page="/Orders/History" class="text-xl">&#8592;</a>
        <h1 class="text-lg font-semibold flex-1 text-center">Purchase History</h1>
        <span class="w-6"></span>
    </div>

    <!-- Search -->
    <form method="get" class="relative mb-2 shrink-0">
        <input type="text" name="Query" value="@Model.Query" placeholder="Search by Order No"
                class="w-full bg-gray-100 border border-gray-300 rounded-xl px-4 py-2 text-sm" />
        <input type="hidden" name="SortField" value="@Model.SortField" />
        <input type="hidden" name="SortDir" value="@Model.SortDir" />
        <button type="submit"
                class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500 text-sm">
            🔍
        </button>
    </form>

    <!-- Button bar -->
    <div class="flex flex-wrap items-center gap-2 mb-3 shrink-0">
        <!-- Sort -->
        <form method="get" class="flex gap-2 items-center">
            <select name="SortField" class="border rounded px-1 py-0 text-xs h-7 w-24">
                @foreach (var (value, label) in Model.SortFields)
                {
                    <option value="@value" selected="@(Model.SortField == value ? "selected" : null)">
                        @label
                    </option>
                }
            </select>
            <select name="SortDir" class="border rounded px-1 py-0 text-xs h-7">
                <option value="asc" selected="@(Model.SortDir == "asc" ? "selected" : null)">▲</option>
                <option value="desc" selected="@(Model.SortDir == "desc" ? "selected" : null)">▼</option>
            </select>
            <input type="hidden" name="Query" value="@Model.Query" />
            <input type="hidden" name="ProductFilter" value="@Model.ProductFilter" />
            <input type="hidden" name="OrderNoFilter" value="@Model.OrderNoFilter" />
            <input type="hidden" name="UnitPriceFilter" value="@Model.UnitPriceFilter" />
            <button type="submit" class="ml-1 text-xs bg-green-50 rounded px-2 py-0 border border-green-200 h-7">
                Sort
            </button>
        </form>

        <!-- Filter -->
        <button type="button" onclick="toggleFilter()"
                class="px-2 py-0 rounded border flex items-center gap-1 text-gray-700 text-sm bg-gray-50 h-7">
            <span>Filter</span>
        </button>
    </div>

    <!-- Filter bar (Toggle) -->
    <form method="get" id="filterForm" class="mb-3 @(Model.ShowFilter ? "" : "hidden") shrink-0">
            <div class="grid grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">From</label>
            <input id="fromDate" name="FromDate" type="text"
                   value="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                   class="w-full bg-gray-100 border border-gray-300 rounded-xl px-2 py-1 text-sm" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">To</label>
            <input id="toDate" name="ToDate" type="text"
                   value="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
                   class="w-full bg-gray-100 border border-gray-300 rounded-xl px-2 py-1 text-sm" />
          </div>
        </div>

        <div class="grid grid-cols-3 gap-2">
            <input type="text" name="ProductFilter" value="@Model.ProductFilter" placeholder="Product Name"
                   class="bg-gray-100 border border-gray-300 rounded-xl px-2 py-1 text-sm" />
            <input type="text" name="OrderNoFilter" value="@Model.OrderNoFilter" placeholder="Order No"
                   class="bg-gray-100 border border-gray-300 rounded-xl px-2 py-1 text-sm" />
            <input type="text" name="UnitPriceFilter" value="@Model.UnitPriceFilter" placeholder="Unit Price"
                   class="bg-gray-100 border border-gray-300 rounded-xl px-2 py-1 text-sm" />
        </div>

        <input type="hidden" name="Query" value="@Model.Query" />
        <input type="hidden" name="SortField" value="@Model.SortField" />
        <input type="hidden" name="SortDir" value="@Model.SortDir" />

        <div class="mt-2 flex gap-2">
            <button type="submit" class="px-4 py-1 rounded bg-green-500 text-white w-full text-sm">
                Apply Filter
            </button>
            <button type="button" onclick="clearFilter()"
                    class="px-4 py-1 rounded border w-full text-sm">
                Clear
            </button>
        </div>
    </form>

    <!-- Scrollable Table (horizontal) -->
    <div class="flex-1 min-h-0">
        <div class="-mx-2 px-2 overflow-x-hidden">
            <table class="table-fixed w-full text-xs border-collapse">
                <colgroup>
                    <col style="width:16%">
                    <col style="width:16%">
                    <col style="width:20%">
                    <col style="width:18%">
                    <col style="width:7%">
                    <col style="width:9%">
                    <col style="width:7%">
                    <col style="width:8%">
                </colgroup>

                <thead class="bg-gray-100 sticky top-0 z-10">
                    <tr>
                        <th class="p-0.5 text-left">Order No</th>
                            <th class="p-0.5 text-left">Order Date</th>
                            <th class="0.5 text-left">Customer</th>
                            <th class="0.5 text-left">Item</th>
                            <th class="0.5 text-center">Qty</th>
                            <th class="0.5 text-center">Unit</th>
                            <th class="0.5 text-center">Disc</th>
                            <th class="0.5 text-center">Total</th>
                    </tr>
                    </thead>

                <tbody>
                    @if (Model.Orders.Any())
                    {
                        foreach (var order in Model.Orders)
                        {
                            <tr class="bg-green-50">
                                <td class="0.5"><div class=" rounded px-2 py-1 font-semibold break-words">@order.OrderNo</div></td>
                                <td class="0.5">
                                    <div class="rounded px-2 py-1">
                                        <div>@order.OrderDate.ToString("dd/MM/yyyy")</div>
                                    </div>
                                </td>
                                <td class="p-0.5"><div class="rounded px-2 py-1 break-words">@order.CustomerName</div></td>
                                <td class="p-0.5" colspan="5"><div class="rounded px-2 py-1"></div></td>
                            </tr>

                            @foreach (var item in order.Items)
                            {
                                <tr class="even:bg-gray-50">
                                    <td class="p-0.5"></td>
                                    <td class="p-0.5"></td>
                                    <td class="p-0.5"></td>
                                    <td class="p-0.5"><div class="rounded px-2 py-1 break-words">@item.ProductName</div></td>
                                    <td class="p-0.5 text-center tabular-nums"><div class="rounded px-2 py-1">@item.Quantity</div></td>
                                    <td class="p-0.5 text-center tabular-nums"><div class="rounded px-2 py-1">@item.UnitPrice.ToString("N0")</div></td>
                                    <td class="p-0.5 text-center tabular-nums"><div class="rounded px-2 py-1">@item.Discount.ToString("N0")</div></td>
                                    <td class="p-0.5 text-center tabular-nums"><div class="rounded px-2 py-1">@((item.UnitPrice - item.Discount).ToString("N0"))</div></td>
                                </tr>
                            }
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-gray-400 text-center py-4">No purchase history found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


 </div>
</div>

@section Scripts {
    <script>
        flatpickr("#fromDate", {
          altInput: true, 
          altFormat: "d-m-Y",
          dateFormat: "Y-m-d",
          allowInput: true
        });
        flatpickr("#toDate", {
          altInput: true,
          altFormat: "d-m-Y",
          dateFormat: "Y-m-d",
          allowInput: true
        });
    </script>

    <script>
        function toggleFilter() {
        var el = document.getElementById('filterForm');
        if (el) el.classList.toggle('hidden');
        }

        function clearFilter() {
            const setEmpty = (name) => {
              const el = document.querySelector(`#filterForm [name="${name}"]`);
              if (el) el.value = "";
            };
            setEmpty("ProductFilter");
            setEmpty("OrderNoFilter");
            setEmpty("UnitPriceFilter");

            if (window.fromFp) {
              fromFp.clear();
              fromFp.set("maxDate", null);
            }
            if (window.toFp) {
              toFp.clear();
              toFp.set("minDate", null);
            }
          }

        // Flatpickr dd-MM-yyyy (ส่งค่า yyyy-MM-dd)
        if (window.flatpickr?.l10ns?.th) { flatpickr.localize(flatpickr.l10ns.th); }
        window.fromFp = flatpickr("#fromDate", {
          altInput:true, altFormat:"d-m-Y", dateFormat:"Y-m-d", allowInput:true,
          maxDate:"today", onChange:(sel)=>{ if(sel && sel[0]) toFp.set("minDate", sel[0]); }
        });
        window.toFp = flatpickr("#toDate", {
          altInput:true, altFormat:"d-m-Y", dateFormat:"Y-m-d", allowInput:true,
          maxDate:"today", onChange:(sel)=>{ if(sel && sel[0]) fromFp.set("maxDate", sel[0]); }
        });
    </script>
}
