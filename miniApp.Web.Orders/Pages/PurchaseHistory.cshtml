@page
@using System.Text.Json
@model miniApp.WebOrders.Pages.PurchaseHistoryModel
@{
    ViewData["Title"] = "Purchase History";
}

<div class="h-full min-h-0">
    <div class="max-w-md w-full mx-auto px-2 pt-2 pb-2 h-full min-h-0 flex flex-col">

        <!-- Header -->
        <div class="flex items-center justify-between mb-2 py-2 shrink-0">
            <a asp-page="/Orders/History" class="text-xl">&#8592;</a>
            <h1 class="text-lg font-semibold flex-1 text-center">Purchase History</h1>
            <span class="w-6"></span>
        </div>

        <!-- Search -->
        <form method="get" class="relative mb-2 shrink-0">
            <input type="text" name="Query" value="@Model.Query" placeholder="Search by Order No"
                   class="w-full bg-gray-100 border border-gray-300 rounded-xl px-4 py-2 text-sm" />
            <input type="hidden" name="SortField" value="@Model.SortField" />
            <input type="hidden" name="SortDir" value="@Model.SortDir" />
            <button type="submit"
                    class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500 text-sm">
                🔍
            </button>
        </form>

        <!-- Button bar -->
        <div class="flex flex-wrap items-center gap-2 mb-3 shrink-0">
            <div class="flex gap-2 items-center">
                <label class="text-xs text-gray-600">Sort by</label>
                <select id="sortField" class="border rounded px-1 py-0 text-xs h-7 w-28">
                    @foreach (var (value, label) in Model.SortFields)
                    {
                        <option value="@value" selected="@(Model.SortField == value ? "selected" : null)">
                            @label
                        </option>
                    }
                </select>

                <!-- ปุ่มเดียว สลับทิศทาง -->
                <button id="sortToggle" type="button"
                        class="text-xs bg-green-50 rounded px-2 py-0 border border-green-200 h-7 flex items-center gap-1">
                    <span id="sortIcon">@(Model.SortDir == "desc" ? "▼" : "▲")</span>
                    <span>Sort</span>
                </button>
            </div>

            <!-- Filter -->
            <button type="button" onclick="toggleFilter()"
                    class="px-2 py-0 rounded border flex items-center gap-1 text-gray-700 text-sm bg-gray-50 h-7">
                <span>Filter</span>
            </button>
        </div>

        <!-- Filter bar (Toggle) -->
        <form method="get" id="filterForm" class="mb-3 @(Model.ShowFilter ? "" : "hidden") shrink-0">
            <div class="grid grid-cols-2 gap-3 mb-3">
                <div>
                    <label class="block text-xs text-gray-500 mb-1">From</label>
                    <input id="fromDate" name="FromDate" type="text"
                           value="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                           class="w-full bg-gray-100 border border-gray-300 rounded-xl px-2 py-1 text-sm" />
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">To</label>
                    <input id="toDate" name="ToDate" type="text"
                           value="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
                           class="w-full bg-gray-100 border border-gray-300 rounded-xl px-2 py-1 text-sm" />
                </div>
            </div>

            <div class="grid grid-cols-3 gap-2">
                <input type="text" name="ProductFilter" value="@Model.ProductFilter" placeholder="Product Name"
                       class="bg-gray-100 border border-gray-300 rounded-xl px-2 py-1 text-sm" />
                <input type="text" name="OrderNoFilter" value="@Model.OrderNoFilter" placeholder="Order No"
                       class="bg-gray-100 border border-gray-300 rounded-xl px-2 py-1 text-sm" />
                <input type="text" name="UnitPriceFilter" value="@Model.UnitPriceFilter" placeholder="Unit Price"
                       class="bg-gray-100 border border-gray-300 rounded-xl px-2 py-1 text-sm" />
            </div>

            <input type="hidden" name="Query" value="@Model.Query" />
            <input type="hidden" name="SortField" value="@Model.SortField" />
            <input type="hidden" name="SortDir" value="@Model.SortDir" />

            <div class="mt-2 flex gap-2">
                <button type="submit" class="px-4 py-1 rounded bg-green-500 text-white w-full text-sm">
                    Apply Filter
                </button>
                <button type="button" onclick="clearFilter()"
                        class="px-4 py-1 rounded border w-full text-sm">
                    Clear
                </button>
            </div>
        </form>

        <!-- Table -->
        <div class="flex-1 min-h-0">
            <div class="-mx-2 px-2 overflow-x-hidden">
                <table class="table-fixed w-full text-xs border-collapse">
                    <colgroup>
                        <col style="width:20%">  <!-- Order No -->
                        <col style="width:22%">  <!-- Order Date / Item -->
                        <col style="width:18%">  <!-- Customer -->
                        <col style="width:7%">   <!-- Qty -->
                        <col style="width:10%">  <!-- UnitPrice -->
                        <col style="width:13%">  <!-- Discount -->
                        <col style="width:11%">  <!-- Total -->
                    </colgroup>

                    <thead>
                        <tr class="bg-green-100 font-bold">
                            <th class="p-2 text-left">Order No</th>
                            <th class="p-2 text-left">Order Date</th>
                            <th class="p-2 text-left">Customer</th>
                            <th class="p-2 text-right"></th>
                            <th class="p-2 text-right"></th>
                            <th class="p-2 text-right"></th>
                            <th class="p-2 text-right"></th>
                        </tr>
                        <tr class="bg-green-100 font-bold">
                            <th class="p-2 text-left"></th>
                            <th class="p-2 text-left">Item</th>
                            <th class="p-2 text-left"></th>
                            <th class="p-2 text-right">Qty</th>
                            <th class="p-2 text-right">Price</th>
                            <th class="p-2 text-right">Discount</th>
                            <th class="p-2 text-right">Total</th>
                        </tr>
                    </thead>

                    <tbody id="orders-tbody">
                        @* <td> เขียนทับด้วย JS*@
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function toggleFilter() {
          var el = document.getElementById('filterForm');
          if (el) el.classList.toggle('hidden');
        }
        function clearFilter() {
          const setEmpty = (name) => {
            const el = document.querySelector(`#filterForm [name="${name}"]`);
            if (el) el.value = "";
          };
          setEmpty("ProductFilter");
          setEmpty("OrderNoFilter");
          setEmpty("UnitPriceFilter");

          if (window.fromFp) { fromFp.clear(); fromFp.set("maxDate", null); }
          if (window.toFp)   { toFp.clear();   toFp.set("minDate", null); }
        }

        // Flatpickr
        if (window.flatpickr?.l10ns?.th) { flatpickr.localize(flatpickr.l10ns.th); }
        window.fromFp = flatpickr("#fromDate", {
          altInput:true, altFormat:"d-m-Y", dateFormat:"Y-m-d", allowInput:true,
          maxDate:"today",
          onChange:(sel)=>{ if(sel && sel[0]) toFp.set("minDate", sel[0]); }
        });
        window.toFp = flatpickr("#toDate", {
          altInput:true, altFormat:"d-m-Y", dateFormat:"Y-m-d", allowInput:true,
          maxDate:"today",
          onChange:(sel)=>{ if(sel && sel[0]) fromFp.set("maxDate", sel[0]); }
        });
    </script>

    @* ฝังข้อมูล Orders เป็น JSON ครั้งเดียว *@
    <script id="orders-json" type="application/json">
        @Html.Raw(JsonSerializer.Serialize(Model.Orders, new JsonSerializerOptions { PropertyNamingPolicy = null }))
    </script>

    <script>
        // สถานะ sort จาก JS ปัจจุบัน
        let SORT_DIR = '@(Model.SortDir?.ToLower() ?? "desc")'; // 'asc' | 'desc'
        const ordersRaw = JSON.parse(document.getElementById('orders-json').textContent || '[]');

        const collator = new Intl.Collator('th-TH', { sensitivity: 'base', numeric: true });
        const fmtInt   = n => Number(n ?? 0).toLocaleString();
        const fmtDate  = iso => {
          const d = new Date(iso);
          if (isNaN(d)) return '';
          const dd = String(d.getDate()).padStart(2,'0');
          const mm = String(d.getMonth()+1).padStart(2,'0');
          const yyyy = d.getFullYear();
          return `${dd}/${mm}/${yyyy}`;
        };

        function sortData(data, field, dir) {
          const copy = data.slice();
          copy.sort((a,b) => {
            let r = 0;
            if (field === 'OrderNo') {
              r = collator.compare(a.OrderNo ?? '', b.OrderNo ?? '');
            } else if (field === 'CustomerName') {
              r = collator.compare(a.CustomerName ?? '', b.CustomerName ?? '');
            } else {
              // OrderDate
              r = (new Date(a.OrderDate)) - (new Date(b.OrderDate));
            }
            if (r === 0) r = collator.compare(a.OrderNo ?? '', b.OrderNo ?? '');
            return dir === 'desc' ? -r : r;
          });
          return copy;
        }

        function renderTable() {
          const field = document.getElementById('sortField').value || 'OrderDate';
          const data  = sortData(ordersRaw, field, SORT_DIR);
          const tb    = document.getElementById('orders-tbody');
          tb.innerHTML = '';

          for (const o of data) {
            const trHead = document.createElement('tr');
            trHead.className = 'bg-green-50 font-semibold';
            trHead.innerHTML = `
              <td class="p-2 text-left">${o.OrderNo ?? ''}</td>
              <td class="p-2 text-left">${fmtDate(o.OrderDate)}</td>
              <td class="p-2 text-left" colspan="5">${o.CustomerName ?? ''}</td>`;
            tb.appendChild(trHead);

            const items = Array.isArray(o.Items) ? o.Items : [];
            for (const it of items) {
              const price = Number(it.UnitPrice ?? 0);
              const disc  = Number(it.Discount ?? 0);
              const total = price - disc;

              const tr = document.createElement('tr');
              tr.className = 'even:bg-white';
              tr.innerHTML = `
                <td class="p-2 text-left"></td>
                <td class="p-2 text-left break-words hyphens-auto" colspan="2">${it.ProductName ?? ''}</td>
                <td class="p-2 text-right tabular-nums">${fmtInt(it.Quantity)}</td>
                <td class="p-2 text-right tabular-nums">${fmtInt(price)}</td>
                <td class="p-2 text-right tabular-nums">${fmtInt(disc)}</td>
                <td class="p-2 text-right tabular-nums">${fmtInt(total)}</td>`;
              tb.appendChild(tr);
            }
          }
        }

        document.addEventListener('DOMContentLoaded', () => {
          const sf   = document.getElementById('sortField');
          const icon = document.getElementById('sortIcon');

          if (sf)   sf.value = '@Model.SortField';
          if (icon) icon.textContent = (SORT_DIR === 'desc' ? '▼' : '▲');

          renderTable();

          document.getElementById('sortToggle')?.addEventListener('click', () => {
            SORT_DIR = (SORT_DIR === 'asc') ? 'desc' : 'asc';
            if (icon) icon.textContent = (SORT_DIR === 'desc' ? '▼' : '▲');
            renderTable();
          });

          document.getElementById('sortField')?.addEventListener('change', renderTable);
        });
    </script>
}
