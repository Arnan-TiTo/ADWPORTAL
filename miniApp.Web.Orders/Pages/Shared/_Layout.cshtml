@using Microsoft.AspNetCore.Http
@using Tailwind

@inject IHttpContextAccessor HttpContextAccessor

@{
    var token = HttpContextAccessor.HttpContext?.Session.GetString("JWT");
    var isAuthenticated = !string.IsNullOrEmpty(token);
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sale Report</title>
    @* <script src="https://cdn.tailwindcss.com"></script> *@
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/tailwind.input.css" asp-append-version="true"/>
    <link rel="stylesheet" href="/css/flatpickr.min.css">
    <script src="~/js/flatpickr.js"></script>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const overlay = document.getElementById("overlay");
            const isHidden = sidebar.classList.contains("hidden");

            if (isHidden) {
                sidebar.classList.remove("hidden");
                overlay.classList.remove("hidden");
            } else {
                sidebar.classList.add("hidden");
                overlay.classList.add("hidden");
            }
        }
    </script>



</head>
@* <body class="h-full min-h-screen bg-white text-black"> *@
<body class="h-full min-h-[100svh] bg-white text-black">

    @if (isAuthenticated)
    {
        <div class="flex h-full">
            <!-- Sidebar -->
            <div id="sidebar" class="fixed top-0 left-0 bg-white w-64 md:w-80 max-w-full h-full shadow-lg z-50 hidden transition duration-300">
                @await Html.PartialAsync("_Sidebar")
            </div>

            <!-- Overlay (mobile & desktop) -->
            <div id="overlay" class="fixed inset-0 bg-black bg-opacity-40 z-40 hidden" onclick="toggleSidebar()"></div>

            <!-- Main Content Area -->
            <div class="flex flex-col flex-1 h-full">
                <!-- Navbar -->
                <div class="flex justify-between items-center px-4 py-3 shadow-md bg-white sticky top-0 z-30">
                    <button onclick="toggleSidebar()" class="text-2xl">☰</button>
                    <div class="flex items-center gap-2 text-sm text-gray-700 font-medium">
                        <a asp-page="/Profile"
                           class="inline-flex items-center gap-2 px-3 py-2 rounded hover:bg-green-100 truncate max-w-[260px]">
                            <span>Welcome :</span>
                            <span class="inline-flex items-center gap-1">
                                👤 @HttpContextAccessor.HttpContext?.Session.GetString("FULLNAME")
                            </span>
                        </a>

                        <form method="post" asp-page="/Logout" class="m-0 p-0">
                            <button type="submit" title="Logout"
                                    class="inline-flex items-center justify-center w-8 h-8 rounded hover:bg-red-100 text-red-600">
                                🚪
                            </button>
                        </form>
                    </div>
                </div>

                <script>
                    (function () {
                      const KEY = '__open_tabs_ids__';
                      // gen tab id ต่อแท็บ
                      const myId = sessionStorage.getItem('TAB_ID') ||
                                   (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2));
                      sessionStorage.setItem('TAB_ID', myId);

                      function getSet() {
                        const raw = localStorage.getItem(KEY) || '';
                        return new Set(raw.split(',').filter(Boolean));
                      }
                      function saveSet(set) {
                        localStorage.setItem(KEY, Array.from(set).join(','));
                      }

                      // mark opened
                      const open = getSet(); open.add(myId); saveSet(open);

                      function onClosing() {
                        const s = getSet(); s.delete(myId); saveSet(s);

                        // หน่วงให้หน้าใหม่มีเวลาบันทึกไอดี
                        setTimeout(() => {
                          const remain = (localStorage.getItem(KEY) || '').split(',').filter(Boolean).length;
                          if (remain === 0) {
                            try {
                              const blob = new Blob([], { type: 'application/octet-stream' });
                              navigator.sendBeacon('/session/close', blob);
                            } catch {
                              fetch('/session/close', { method: 'POST', keepalive: true, credentials: 'include' });
                            }
                          }
                        }, 700);
                      }

                      window.addEventListener('pagehide', (ev) => { if (!ev.persisted) onClosing(); });
                    })();
                </script>


                <!-- Content and Footer -->
                <div class="flex flex-col flex-1 relative">
                    <main class="flex-1 px-0 py-2 overflow-y-auto w-full min-h-0 overscroll-contain"
                          style="padding-bottom: calc(64px + env(safe-area-inset-bottom, 0px));">
                        @RenderBody()
                    </main>

                    <footer class="fixed left-0 right-0 bg-white border-t shadow-md z-50 h-16"
                            style="bottom: env(safe-area-inset-bottom, 0px); padding-bottom: env(safe-area-inset-bottom, 0px);">
                        @await Html.PartialAsync("_FooterMenu")
                    </footer>
                </div>
            </div>
        </div>


    }
    else
    {
        <!-- Layout สำหรับหน้า Login/Register -->
        <main class="flex-1 px-0 py-8 pb-[88px] overflow-y-auto w-full min-h-0 overscroll-contain">
            @RenderBody()
        </main>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>

