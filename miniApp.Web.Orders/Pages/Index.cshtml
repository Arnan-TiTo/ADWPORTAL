@page
@model miniApp.WebOrders.Pages.IndexModel
@{
    ViewData["Title"] = "Menu";
}
<div class="flex flex-col bg-white text-black font-sans h-full">

    <!-- Top Menu -->
    <div class="max-w-md w-full mx-auto px-4 mt-4">
        <input type="text" placeholder="🔍 Search"
               class="w-full bg-gray-100 rounded-xl px-4 py-2 text-sm focus:outline-none" />
    </div>

    <!-- Logo -->
    <div class="flex justify-center my-6">
        <img src="/images/logo.png" alt="Logo" class="w-28 h-auto" />
    </div>

    <!-- Buttons -->
    <div class="max-w-md w-full mx-auto flex flex-col items-center space-y-4 px-4 pb-8">
        <a href="/ProductSearch"
           class="bg-gray-200 w-full rounded-xl p-6 border text-center shadow hover:bg-gray-300">
            <img src="/images/icons/productSearch.png" class="w-8 h-8 mx-auto mb-2" />
            <p class="font-medium">View Product</p>
        </a>

        <a href="/History"
           class="bg-gray-200 w-full rounded-2xl p-6 text-center hover:bg-gray-300">
            <img src="/images/icons/history.png" class="w-8 h-8 mx-auto mb-2" />
            <p class="font-medium">History</p>
        </a>
    </div>
</div>
