@page
@model miniApp.WebOrders.Pages.ProductSearchModel
@using Microsoft.AspNetCore.Antiforgery
@using System.Text.Json
@inject IAntiforgery Anti

@{
    ViewData["Title"] = "Product";

    var apiBase = ViewData["APIBASEURL"];
    var token = ViewData["AUTHTOKEN"];
    var userId = ViewData["USERID"];

    var antif = Anti.GetAndStoreTokens(HttpContext);

    var toastMsg = TempData["ShowToast"] as string;
}

@functions {
    string Img(string? url, string folder = "products")
    {
        if (string.IsNullOrWhiteSpace(url)) return $"/images/{folder}/default.png";
        var u = url.Replace("\\", "/").Trim();
        if (u.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            u.StartsWith("https://", StringComparison.OrdinalIgnoreCase)) return u;
        while (u.StartsWith("/")) u = u[1..];
        if (u.StartsWith("images/", StringComparison.OrdinalIgnoreCase)) return "/" + u;
        if (u.StartsWith($"{folder}/", StringComparison.OrdinalIgnoreCase)) return "/images/" + u;
        return $"/images/{folder}/{u}";
    }
}

@if (!string.IsNullOrEmpty(toastMsg))
{
    <div id="toast" class="fixed top-6 left-1/2 -translate-x-1/2 bg-green-600 text-white px-4 py-2 rounded shadow-lg z-50">
        @toastMsg
    </div>
    <script> setTimeout(()=>document.getElementById("toast")?.remove(),2500); </script>
}

<div class="max-w-md w-full mx-auto my-auto px-2 py-2">

    <!-- Navbar -->
    <div class="bg-white py-4 px-4 border-b shadow-sm flex items-center justify-between">
        <form id="searchForm" onsubmit="return doSearch(event)" class="flex-1 ml-4 relative">
            <input id="searchInput" type="text" placeholder="Search by name or SKU"
                   class="w-full bg-gray-100 rounded-xl px-4 py-2 text-sm pr-10" />
            <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-600 text-sm">🔍</button>
        </form>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="bg-green-100 text-green-800 text-sm rounded px-3 py-2 mb-2">@TempData["Message"]</div>
    }

    <!-- Category -->
    <div>
        <div class="flex items-center justify-between mb-1">
            <span class="text-sm font-semibold">Product Category</span>
            <div class="space-x-2">
                <button type="button" onclick="scrollCategory(-1)">‹</button>
                <button type="button" onclick="scrollCategory(1)">›</button>
            </div>
        </div>
        <div id="categoryScroll" class="flex space-x-4 overflow-x-auto scroll-smooth">
            @foreach (var cat in Model.Categories)
            {
                <form method="get">
                    <input type="hidden" name="categoryId" value="@cat.Id" />
                    <button type="submit" class="flex flex-col items-center min-w-[80px] focus:outline-none">
                        <img src="@Img(cat.ImageUrl)" alt="@cat.Name" class="w-14 h-14 rounded-full border" />
                        <span class="text-xs mt-1 text-center">@cat.Name</span>
                    </button>
                </form>
            }
        </div>
    </div>

    <!-- Product List -->
    <div>
        <div class="flex items-center justify-between mb-1">
            <span class="text-sm font-semibold">All Product</span>
        </div>
        <div id="productScroll" class="grid grid-cols-1 sm:grid-cols-2 gap-4 overflow-hidden">
            @foreach (var p in Model.Products)
            {
                <div class="border rounded-xl p-2 text-center shadow-sm min-w-[40%]">
                    <img src="@Img(p.ImageUrl)" class="w-75 h-75  rounded mb-2 object-cover" />
                    <div class="text-xs text-gray-500">@p.BrandName</div>
                    <div class="font-semibold text-sm">@p.Name</div>
                    <div class="text-sm text-black font-bold">@p.Price.ToString("N0") Baht</div>

                    <form method="post" asp-page-handler="AddToCart">
                        <input type="hidden" name="LocationId" value="@Model.LocationId" />
                        <input type="hidden" name="ProductId" value="@p.Id" />
                        <input type="hidden" name="ProductName" value="@p.Name" />
                        <input type="hidden" name="Price" value="@p.Price" />
                        <input type="hidden" name="ImageUrl" value="@p.ImageUrl" />

                        <!-- NEW: Available -->
                        <div class="text-xs text-gray-600 mt-0.5">
                            พร้อมขาย: <span class="font-semibold" data-avail-for="@p.Id">-</span>
                        </div>
                        <button type="submit"
                                class="mt-2 w-full bg-yellow-500 text-white text-sm rounded-lg py-1 hover:bg-yellow-600">
                            ➕ เพิ่มลงตะกร้า
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const APIBASEURL  = '@apiBase';
        const AUTHTOKEN   = '@token';
        const USERID      = @userId;
        const LOCATION_ID = @Model.LocationId;

        // property จาก model .cs
        const VISIBLE_IDS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.VisibleProductIds));

        const AF_NAME  = '@antif.FormFieldName';
        const AF_TOKEN = '@antif.RequestToken';

        function scrollCategory(dir){ document.getElementById("categoryScroll").scrollLeft += dir * 120; }
        function scrollProduct(dir){  document.getElementById("productScroll").scrollLeft  += dir * 300; }

        function resolveImg(url, folder='products'){
            if(!url) return `/images/${folder}/default.png`;
            url = String(url).replace(/\\/g,'/').trim();
            if(/^https?:\/\//i.test(url)) return url;
            url = url.replace(/^\/+/, '');
            if(/^images\//i.test(url)) return '/' + url;
            if(new RegExp(`^${folder}/`,'i').test(url)) return `/images/${url}`;
            return `/images/${folder}/${url}`;
        }

        // ------- Toast -------
        function showToast(message, variant = "error") {
          let box = document.getElementById("__toast");
          if (!box) {
            box = document.createElement("div");
            box.id = "__toast";
            box.className = "fixed top-6 left-1/2 -translate-x-1/2 z-50";
            document.body.appendChild(box);
          }
          const el = document.createElement("div");
          el.className = "px-4 py-2 rounded shadow-lg text-white text-sm " +
                         (variant==="success" ? "bg-green-600" :
                          variant==="info" ? "bg-blue-600" :
                          "bg-red-600");
          el.textContent = message;
          box.appendChild(el);
          setTimeout(()=> el.remove(), 2200);
        }

        // ===== Available-for-sale (QtyAvailable) =====
        let STOCK_MAP = {}; // { productId: available }

        function getAvail(pid){
          if (STOCK_MAP && (pid in STOCK_MAP)) return STOCK_MAP[pid];
          const span = document.querySelector(`[data-avail-for="${pid}"]`);
          if (span){
            const n = parseInt(String(span.textContent).replace(/[^\d-]/g,''),10);
            if (!isNaN(n)) return n;
          }
          return 0;
        }

        function updateButtonsByAvail(){
          // ปุ่มเพิ่มสินค้าทั้งหมดในพื้นที่แสดงสินค้า
          document.querySelectorAll('#productScroll form').forEach(f=>{
            const pidInput = f.querySelector('input[name="ProductId"]');
            const btn = f.querySelector('button[type="submit"]');
            if (!pidInput || !btn) return;
            const pid = parseInt(pidInput.value || '0',10) || 0;
            const avail = getAvail(pid);
            btn.disabled = (avail <= 0);
            btn.classList.toggle('opacity-50', avail <= 0);
            btn.classList.toggle('cursor-not-allowed', avail <= 0);
          });
        }

        async function loadAvail() {
          if (!LOCATION_ID || !USERID) return;
          try {
            const url = `${APIBASEURL}api/ProductStock/location/${LOCATION_ID}?userId=${USERID}`;
            const res = await fetch(url, { headers: { 'Authorization': `Bearer ${AUTHTOKEN}` } });
            if (!res.ok) return;

            const rows = await res.json();
            for (const r of (rows || [])) {
              const pid = r.productId ?? r.ProductId;
              const oh  = Number(r.qtyOnHand    ?? r.QtyOnHand    ?? 0);
              const rs  = Number(r.qtyReserved  ?? r.QtyReserved  ?? 0);
              const dm  = Number(r.qtyDamaged   ?? r.QtyDamaged   ?? 0);
              let avail = Number(r.qtyAvailable ?? r.QtyAvailable);
              if (!Number.isFinite(avail)) avail = oh - rs - dm;
              avail = Math.max(0, Math.trunc(avail));

              STOCK_MAP[pid] = avail;

              const span = document.querySelector(`[data-avail-for="${pid}"]`);
              if (span) span.textContent = avail.toLocaleString();
            }
            updateButtonsByAvail();
          } catch (e) {
            console.error('loadAvail failed', e);
          }
        }

        // ดัก submit ปุ่ม "เพิ่มลงตะกร้า" ทั้งของที่เรนเดอร์จาก Razor และที่เติมจาก JS
        document.getElementById('productScroll')?.addEventListener('submit', (ev)=>{
          const form = ev.target.closest('form');
          if (!form) return;
          const pidInput = form.querySelector('input[name="ProductId"]');
          if (!pidInput) return;

          const pid = parseInt(pidInput.value || '0',10) || 0;
          const avail = getAvail(pid);

          if (avail <= 0) {
            ev.preventDefault();
            showToast('จำนวนสินค้าไม่พอขาย');
          }
        });

        // โหลดเมื่อเปิดหน้า
        document.addEventListener('DOMContentLoaded', loadAvail);

        // ===== ค้นหา =====
        async function doSearch(e){
            e.preventDefault();
            const keyword = document.getElementById("searchInput").value.trim();
            const container = document.getElementById("productScroll");
            container.innerHTML = "";
            if(!keyword){ container.innerHTML = `<p class="text-sm text-gray-400">Please enter keyword.</p>`; return; }

            const url = `${APIBASEURL}api/product/ProductSearch?query=${encodeURIComponent(keyword)}`;
            try{
                const res = await fetch(url, { headers: { 'Authorization': `Bearer ${AUTHTOKEN}` }});
                if(!res.ok){ container.innerHTML = `<p class="text-sm text-red-500">Search failed (${res.status})</p>`; return; }

                const vis = new Set(VISIBLE_IDS || []);
                let products = await res.json();
                products = Array.isArray(products) ? products.filter(p => vis.has(p.id)) : [];

                if(!products.length){ container.innerHTML = `<p class="text-sm text-gray-400">No products found.</p>`; return; }

                products.forEach(p=>{
                    const el = document.createElement("div");
                    el.className = "border rounded-xl p-2 text-center shadow-sm min-w-[40%]";
                    const imgSrc = resolveImg(p.imageUrl);
                    const pid = p.id;
                    const availNow = (pid in STOCK_MAP) ? STOCK_MAP[pid] : null;
                    const availText = (availNow == null) ? '-' : Number(availNow).toLocaleString();

                    el.innerHTML = `
                        <img src="${imgSrc}" class="w-75 h-75 aspect-square rounded mb-2 object-cover" />
                        <div class="text-xs text-gray-500">${p.brandName || ''}</div>
                        <div class="font-semibold text-sm">${p.name}</div>
                        <div class="text-sm text-black font-bold">${p.price ? Number(p.price).toLocaleString() + ' Baht' : ''}</div>

                        <div class="text-xs text-gray-600 mt-0.5">
                          พร้อมขาย: <span class="font-semibold" data-avail-for="${pid}">${availText}</span>
                        </div>

                        <form method="post" action="?handler=AddToCart">
                            <input type="hidden" name="${AF_NAME}" value="${AF_TOKEN}" />
                            <input type="hidden" name="LocationId"  value="${LOCATION_ID}" />
                            <input type="hidden" name="ProductId"   value="${pid}" />
                            <input type="hidden" name="ProductName" value="${p.name}" />
                            <input type="hidden" name="Price"       value="${p.price}" />
                            <input type="hidden" name="ImageUrl"    value="${p.imageUrl || ''}" />
                            <button type="submit" class="mt-2 w-full bg-yellow-500 text-white text-sm rounded-lg py-1 hover:bg-yellow-600">
                              ➕ เพิ่มลงตะกร้า
                            </button>
                        </form>`;

                    container.appendChild(el);
                });

                //อัปเดตสถานะปุ่มตามสต็อกล่าสุด
                updateButtonsByAvail();

            }catch(err){
                console.error(err);
                container.innerHTML = `<p class="text-sm text-red-500">Something went wrong.</p>`;
            }
        }
    </script>
}

