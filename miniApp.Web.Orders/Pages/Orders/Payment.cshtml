@page
@model miniApp.WebOrders.Pages.Orders.PaymentModel
@{
    ViewData["Title"] = "Add Order - Payment";
    var toastMsg = TempData["ShowToast"] as string;
    var nextUrl = TempData["NextUrl"] as string;
    var delayMs = (TempData["DelayMs"] as int?) ?? 2000;
}

@if (!string.IsNullOrEmpty(toastMsg))
{
    <div id="toast" class="fixed top-6 left-1/2 -translate-x-1/2 bg-green-600 text-white px-4 py-2 rounded shadow-lg z-50">
        @toastMsg
    </div>
}

<style>
    .r05 {
        border-radius: 4px !important
    }

    .ctl {
        padding: .5rem .75rem;
        line-height: 1.25rem
    }
</style>

<div class="max-w-md mx-auto bg-white p-4 min-h-screen space-y-4">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <a asp-page="/Orders/Customer" class="text-xl">←</a>
        <h1 class="text-lg font-semibold text-center flex-1">Add Order</h1>
    </div>

    <!-- Step Indicator -->
    <div class="flex justify-between items-center text-center text-sm font-medium my-4">
        <div class="flex flex-col items-center flex-1">
            <div class="w-3 h-3 bg-gray-300 rounded-full mb-1"></div>
            <div class="text-black font-semibold">Order Summary</div>
        </div>
        <div class="flex-1 border-t border-dashed border-gray-400 mx-2 mt-2"></div>
        <div class="flex flex-col items-center flex-1">
            <div class="w-3 h-3 bg-gray-300 rounded-full mb-1"></div>
            <div class="text-gray-400">Customer</div>
        </div>
        <div class="flex-1 border-t border-dashed border-gray-400 mx-2 mt-2"></div>
        <div class="flex flex-col items-center flex-1">
            <div class="w-3 h-3 bg-yellow-400 rounded-full mb-1"></div>
            <div class="text-gray-400">Payment</div>
        </div>
    </div>

    <!-- Order Summary -->
    <div class="bg-white border rounded-2xl shadow p-4">
        <div class="font-semibold text-lg mb-2">Order Summary</div>
        <div class="text-sm">
            <div class="flex justify-between py-1"><span>Items</span><span>@Model.TotalItems</span></div>
            <div class="flex justify-between py-1"><span>Subtotal</span><span>@Model.Subtotal.ToString("N0") Baht</span></div>
            <div class="flex justify-between py-1"><span>Discount</span><span>@Model.DiscountTotal.ToString("N0") Baht</span></div>
            <div class="border-t my-2"></div>
            <div class="flex justify-between font-bold"><span>Total</span><span>@Model.Total.ToString("N0") Baht</span></div>
        </div>
    </div>

    <!-- Payment form -->
    <form method="post" asp-antiforgery="true" enctype="multipart/form-data" class="space-y-4" id="paymentForm">
        <div asp-validation-summary="All" class="text-red-600 text-sm"></div>

        <!-- Choose payment method -->
        <div class="bg-white border rounded-2xl shadow p-4 space-y-2">
            <div class="font-semibold text-base">Choose payment method</div>

            <label class="flex items-center cursor-pointer">
                <input id="payTransfer" asp-for="PaymentMethod" type="radio" value="transfer" class="accent-yellow-400 mr-2" />
                <span class="flex items-center"><span class="mr-1">💳</span> Transfer money <span class="text-red-600 ml-1" id="slipReqStar" style="display:none">*</span></span>
            </label>

            <label class="flex items-center cursor-pointer opacity-80">
                <input id="payCash" asp-for="PaymentMethod" type="radio" value="cash"  class="accent-yellow-400 mr-2" />
                <span class="flex items-center"><span class="mr-1">🪙</span> Cash</span>
            </label>
        </div>

        <!-- Add payment slip -->
        <div id="slipBlock" class="bg-white border rounded-2xl shadow p-4">
            <div class="flex items-center gap-2 mb-1">
                <div class="font-medium text-base">Add Payment slip</div>
                <div id="slipHint" class="text-xs text-gray-500"></div>
            </div>

            <label class="flex items-center cursor-pointer space-x-2 py-2">
                <input id="slipInput" asp-for="Slip" type="file" accept="image/*" class="hidden" onchange="previewSlip(this)" />
                <span class="flex items-center justify-center w-8 h-8 r05 border border-gray-400 text-2xl bg-gray-50 cursor-pointer">+</span>
                <span class="text-gray-500 text-sm" id="slipFilename"></span>
            </label>

            <div class="mt-2">
                <img id="slipPreview" src="#" alt="Slip Preview"
                     style="display:none; max-width:220px; max-height:220px; border-radius:.5px; border:1px solid #ddd;" />
            </div>

            <!-- client-side error -->
            <div id="slipError" class="text-red-600 text-xs mt-2 hidden">กรุณาอัปโหลดสลิปเมื่อเลือกชำระแบบโอนเงิน</div>
            <!-- server-side error -->
            <span asp-validation-for="Slip" class="text-red-600 text-xs"></span>
        </div>

        <!-- SAVE Button -->
        <button type="submit" id="saveBtn"
                class="w-full inline-flex items-center justify-center py-3 rounded-2xl bg-emerald-700 hover:bg-emerald-800 text-white text-base font-bold mt-2 shadow-md">
            SAVE
        </button>
    </form>
</div>

@section Scripts {
    <script>
        function previewSlip(input){
          if(input.files && input.files[0]){
            const reader=new FileReader();
            reader.onload=function(e){
              const img=document.getElementById('slipPreview');
              img.src=e.target.result; img.style.display='block';
              document.getElementById('slipFilename').textContent=input.files[0].name;
            };
            reader.readAsDataURL(input.files[0]);
          }
        }

        const form = document.getElementById('paymentForm');
        const saveBtn = document.getElementById('saveBtn');
        const payTransfer = document.getElementById('payTransfer');
        const payCash = document.getElementById('payCash');
        const slipInput = document.getElementById('slipInput');
        const slipError = document.getElementById('slipError');
        const slipHint = document.getElementById('slipHint');
        const slipReqStar = document.getElementById('slipReqStar');

        function refreshSlipRequirement(){
          const requireSlip = payTransfer.checked;
          slipInput.required = requireSlip;
          slipReqStar.style.display = requireSlip ? '' : 'none';
          slipHint.textContent = requireSlip ? '(จำเป็นต้องแนบสลิป)' : '(ไม่จำเป็นเมื่อชำระเงินสด)';
          if(!requireSlip){ slipError.classList.add('hidden'); }
        }
        payTransfer.addEventListener('change', refreshSlipRequirement);
        payCash.addEventListener('change', refreshSlipRequirement);
        refreshSlipRequirement(); // initial

        // กันกดซ้ำ + ตรวจสลิปก่อนส่ง
        form.addEventListener('submit', (e)=>{
          if (payTransfer.checked && (!slipInput.files || slipInput.files.length === 0)) {
            e.preventDefault();
            slipError.classList.remove('hidden');
            slipInput.focus();
            return;
          }
          saveBtn.disabled = true;
          saveBtn.textContent = 'Saving...';
        });

        // ===== Toast auto-hide + optional redirect =====
        const TOAST_MSG = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(toastMsg ?? ""));
        const NEXT_URL  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(nextUrl ?? ""));
        const DELAY_MS  = @delayMs;

        if (TOAST_MSG) {
          setTimeout(function () {
            document.getElementById("toast")?.remove();
            if (NEXT_URL) { window.location.href = NEXT_URL; }
          }, DELAY_MS);
        }
    </script>
}
