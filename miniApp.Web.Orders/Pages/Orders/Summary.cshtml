@page
@model miniApp.WebOrders.Pages.Orders.SummaryModel
@{
    ViewData["Title"] = "Add Order - Summary";
    var cart = Model.Cart;

    // สำหรับเรียก API สต็อก
    var apiBase = ViewData["APIBASEURL"];
    var token = ViewData["AUTHTOKEN"];
    var userId = ViewData["USERID"];

    var toastMsg = TempData["ShowToast"] as string;
}

@functions {
    string Img(string? url, string folder = "products")
    {
        if (string.IsNullOrWhiteSpace(url)) return $"/images/{folder}/default.png";
        var u = url.Replace("\\", "/").Trim();
        if (u.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            u.StartsWith("https://", StringComparison.OrdinalIgnoreCase)) return u;
        while (u.StartsWith("/")) u = u[1..];
        if (u.StartsWith("images/", StringComparison.OrdinalIgnoreCase)) return "/" + u;
        if (u.StartsWith($"{folder}/", StringComparison.OrdinalIgnoreCase)) return "/images/" + u;
        return $"/images/{folder}/{u}";
    }
}

@if (!string.IsNullOrWhiteSpace(toastMsg))
{
    <div id="toast" class="fixed top-6 left-1/2 -translate-x-1/2 bg-red-600 text-white px-4 py-2 rounded shadow-lg z-50">
        @toastMsg
    </div>
    <script> setTimeout(()=>document.getElementById("toast")?.remove(),2200); </script>
}

<div class="max-w-md mx-auto bg-white p-4 min-h-screen space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <a asp-page="/Orders/Customer" class="text-xl">←</a>
        <h1 class="text-lg font-semibold text-center flex-1">Add Order</h1>
    </div>

    <!-- Search -->
    @* <form method="get" class="relative">
        <input type="text" name="query" placeholder="Search by name or SKU"
               class="w-full bg-gray-100 rounded-xl px-4 py-2 text-sm border border-gray-300" />
        <button type="submit"
                class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500 text-sm">
            🔍
        </button>
    </form> *@

    <!-- Favorite / History -->
    @* <div class="flex justify-start space-x-2">
        <button type="button" class="flex items-center space-x-1 px-3 py-1 border border-gray-300 rounded-full text-sm">
            <span>♥</span><span>Favorites</span>
        </button>
        <button type="button" class="flex items-center space-x-1 px-3 py-1 border border-gray-300 rounded-full text-sm">
            <span>⏲</span><span>History</span>
        </button>
    </div> *@

    <!-- Step Indicator -->
    <div class="flex justify-between items-center text-center text-sm font-medium my-4">
        <div class="flex flex-col items-center flex-1">
            <div class="w-3 h-3 bg-yellow-400 rounded-full mb-1"></div>
            <div class="text-black font-semibold">Order Summary</div>
        </div>
        <div class="flex-1 border-t border-dashed border-gray-400 mx-2 mt-2"></div>
        <div class="flex flex-col items-center flex-1">
            <div class="w-3 h-3 bg-gray-300 rounded-full mb-1"></div>
            <div class="text-gray-400">Customer</div>
        </div>
        <div class="flex-1 border-t border-dashed border-gray-400 mx-2 mt-2"></div>
        <div class="flex flex-col items-center flex-1">
            <div class="w-3 h-3 bg-gray-300 rounded-full mb-1"></div>
            <div class="text-gray-400">Payment</div>
        </div>
    </div>

    @if (!cart.Any())
    {
        <div class="text-center text-gray-400">No items in cart.</div>
    }
    else
    {
        @for (int i = 0; i < cart.Count; i++)
        {
            <div class="bg-gray-50 border rounded-2xl shadow p-4">
                <form method="post" class="flex flex-1 items-center bg-gray-50 cart-row border-b p-2"
                  data-pid="@cart[i].ProductId"
                  data-loc="@cart[i].LocationId">
                <img src="@Img(cart[i].ImageUrl)" class="w-16 h-16 rounded mr-2 object-cover" />
                <div class="flex-1">
                    <div class="font-bold">@cart[i].ProductName</div>
                    <div class="text-sm text-gray-500">@cart[i].Price.ToString("N0") Baht</div>

                    <!-- พร้อมขาย -->
                    <div class="text-xs text-gray-600 mt-1">
                        พร้อมขาย: <b class="avail"
                                     data-pid="@cart[i].ProductId"
                                     data-loc="@cart[i].LocationId">-</b>
                    </div>

                    <div class="flex items-center mt-2 space-x-2">
                        <button formaction="?handler=Decrease" name="productId" value="@cart[i].ProductId"
                                class="px-2 py-1 rounded bg-gray-200">
                            -
                        </button>
                        <span class="qty"
                              data-pid="@cart[i].ProductId"
                              data-loc="@cart[i].LocationId">@cart[i].Quantity</span>
                        <button formaction="?handler=Increase" name="productId" value="@cart[i].ProductId"
                                class="px-2 py-1 rounded bg-green-300 btn-plus"
                                data-pid="@cart[i].ProductId"
                                data-loc="@cart[i].LocationId">
                            +
                        </button>


                    </div>
                        <input type="hidden" name="productId" value="@cart[i].ProductId" />
                        <input type="number" name="discount" value="@cart[i].Discount"
                               class="form-input h-8 w-16 text-right border rounded mt-2 px-2 py-1"
                               min="0" step="1" />
                        <button formaction="?handler=Discount" class="h-8 px-2 py-1 rounded bg-yellow-300">
                            Set Discount
                        </button>
                </div>

                <button formaction="?handler=Remove" name="productId" value="@cart[i].ProductId"
                        class="text-red-400">
                    🗑
                </button>
            </form>
            </div>
        }

        <div class="bg-white border rounded-2xl shadow p-4">
        <div class="text-sm p-2">
            <div class="flex justify-between py-1">
                <span>Items</span><span>@Model.TotalItems</span>
            </div>
            <div class="flex justify-between py-1">
                <span>Subtotal</span><span>@Model.Subtotal.ToString("N0") Baht</span>
            </div>
            <div class="flex justify-between py-1">
                <span>Discount</span><span>@Model.DiscountTotal.ToString("N0") Baht</span>
            </div>
            <div class="border-t my-2"></div>
            <div class="flex justify-between font-bold">
                <span>Total</span><span>@Model.Total.ToString("N0") Baht</span>
            </div>
        </div>
        </div>

        <div class="flex justify-between mt-6">
            <a asp-page="/ProductSearch" class="px-6 py-2 rounded-xl bg-gray-300">Back</a>
            <a asp-page="/Orders/Customer" class="px-6 py-2 rounded-xl bg-black text-white">Next</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        // ===== Config เรียกสต็อก =====
        const APIBASEURL  = '@apiBase';
        const AUTHTOKEN   = '@token';
        const USERID      = @((userId ?? "0"));
        // มีหลาย location ในตะกร้าได้ → จะจัดกลุ่มเองใน JS

        // Toast ง่ายๆ
        function showToast(message, variant="error"){
          let box = document.getElementById("__toast");
          if(!box){ box = document.createElement("div"); box.id="__toast"; box.className="fixed top-6 left-1/2 -translate-x-1/2 z-50"; document.body.appendChild(box); }
          const el = document.createElement("div");
          el.className = "px-4 py-2 rounded shadow-lg text-white text-sm " + (variant==="success"?"bg-green-600":"bg-red-600");
          el.textContent = message;
          box.appendChild(el);
          setTimeout(()=>el.remove(), 2200);
        }

        // เก็บ available ต่อ {loc,pid}
        const STOCK_MAP = {}; // key: `${loc}:${pid}`

        const parseIntSafe = (t) => {
          const n = parseInt(String(t||'').replace(/[^\d-]/g,''), 10);
          return Number.isFinite(n) ? n : 0;
        };

        function key(loc,pid){ return `${loc}:${pid}`; }

        function getQty(pid, loc){
          const el = document.querySelector(`.qty[data-pid="${pid}"][data-loc="${loc}"]`);
          return el ? parseIntSafe(el.textContent) : 0;
        }

        // ถ้ายังไม่มีตัวเลข → ไม่บล็อก (Infinity)
        function getAvail(pid, loc){
          const k = key(loc,pid);
          if (k in STOCK_MAP) return STOCK_MAP[k];
          const el = document.querySelector(`.avail[data-pid="${pid}"][data-loc="${loc}"]`);
          if (!el) return Number.POSITIVE_INFINITY;
          const s = (el.textContent||'').trim();
          if (s === '-' || s === '') return Number.POSITIVE_INFINITY;
          const n = parseIntSafe(s);
          return Number.isFinite(n) ? n : Number.POSITIVE_INFINITY;
        }

        function updateAvailBadge(pid, loc, avail){
          const badge = document.querySelector(`.avail[data-pid="${pid}"][data-loc="${loc}"]`);
          if (badge) badge.textContent = Number.isFinite(avail) ? Number(avail).toLocaleString() : '-';
        }

        function updatePlusState(pid, loc){
          const btn   = document.querySelector(`.btn-plus[data-pid="${pid}"][data-loc="${loc}"]`);
          if(!btn) return;
          const qty   = getQty(pid, loc);
          const avail = getAvail(pid, loc);
          const dis   = Number.isFinite(avail) && avail > 0 && qty >= avail;
          btn.disabled = dis;
          btn.classList.toggle('opacity-50', dis);
          btn.classList.toggle('cursor-not-allowed', dis);
        }

        async function loadAvail(){
          try{
            if(!APIBASEURL || !AUTHTOKEN || !USERID) return;

            // group by location
            const rows = Array.from(document.querySelectorAll('.cart-row'));
            const group = new Map(); // loc -> Set<pid>
            rows.forEach(r=>{
              const pid = parseInt(r.dataset.pid||'0',10);
              const loc = parseInt(r.dataset.loc||'0',10);
              if(!pid || !loc) return;
              if(!group.has(loc)) group.set(loc, new Set());
              group.get(loc).add(pid);
            });

            for (const [loc, pidSet] of group.entries()){
              const url = `${APIBASEURL}api/ProductStock/location/${loc}?userId=${USERID}`;
              const res = await fetch(url, { headers: { 'Authorization': `Bearer ${AUTHTOKEN}` }});
              if(!res.ok) continue;
              const stockRows = await res.json();

              for(const r of (stockRows||[])){
                const pid = r.productId ?? r.ProductId;
                if(!pidSet.has(pid)) continue;

                const oh  = Number(r.qtyOnHand   ?? r.QtyOnHand   ?? 0);
                const rs  = Number(r.qtyReserved ?? r.QtyReserved ?? 0);
                const dm  = Number(r.qtyDamaged  ?? r.QtyDamaged  ?? 0);
                let avail = Number(r.qtyAvailable ?? r.QtyAvailable);
                if(!Number.isFinite(avail)) avail = oh - rs - dm;
                avail = Math.max(0, Math.trunc(avail));

                STOCK_MAP[key(loc,pid)] = avail;
                updateAvailBadge(pid, loc, avail);
                updatePlusState(pid, loc);
              }
            }
          }catch(e){ console.error('loadAvail failed', e); }
        }

        // ดัก Enter ที่ช่อง discount แล้วส่งไป handler=Discount แทน
        document.addEventListener('keydown', function (ev) {
          const t = ev.target;
          if (ev.key === 'Enter' && t && t.matches('input[name="discount"]')) {
            ev.preventDefault();
            const form = t.closest('form');
            const btn = form?.querySelector('button[formaction*="handler=Discount"]');
            if (btn) btn.click();
          }
        });

        // กันกดบวกเกิน “พร้อมขาย”
        document.addEventListener('submit', (ev)=>{
          const form = ev.target.closest('form.cart-row');
          if(!form) return;

          const submitter = ev.submitter;
          if(!submitter) return;

          const isIncrease = (submitter.getAttribute('formaction')||'').toLowerCase().includes('increase');
          if(!isIncrease) return;

          const pid = parseInt(submitter.dataset.pid || form.dataset.pid || '0', 10) || 0;
          const loc = parseInt(submitter.dataset.loc || form.dataset.loc || '0', 10) || 0;

          const qty   = getQty(pid, loc);
          const avail = getAvail(pid, loc);

          if (Number.isFinite(avail) && avail > 0 && qty >= avail){
            ev.preventDefault();
            showToast('จำนวนสินค้าไม่พอขาย');
            updatePlusState(pid, loc);
          }
        });

        document.addEventListener('DOMContentLoaded', loadAvail);
    </script>
}
