@page
@model miniApp.WebOrders.Pages.Orders.CustomerModel
@{
    ViewData["Title"] = "Add Order - Step 1";
    var apiBase = ViewData["APIBASEURL"];
    var token = ViewData["AUTHTOKEN"];
    var userId = ViewData["USERID"];
}

<style>
    .r05 {
        border-radius: 4px !important
    }

    .ctl {
        padding: .5rem .75rem;
        line-height: 1rem
    }

    .btn-del {
        border: 1px solid #ef4444;
        color: #b91c1c
    }

        .btn-del:hover {
            background: #fee2e2
        }
</style>

<div class="max-w-md mx-auto bg-white p-4 min-h-screen space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <button onclick="history.back()" class="text-xl">&#8592;</button>
        <h1 class="text-lg font-semibold text-center flex-1">Add Order</h1>
    </div>

    <!-- Steps -->
    <div class="flex justify-between items-center text-center text-sm font-medium my-4">
        <div class="flex flex-col items-center flex-1">
            <div class="w-3 h-3 bg-gray-300 rounded-full mb-1"></div>
            <div class="text-black font-semibold">Order Summary</div>
        </div>
        <div class="flex-1 border-t border-dashed border-gray-400 mx-2 mt-2"></div>
        <div class="flex flex-col items-center flex-1">
            <div class="w-3 h-3 bg-yellow-400 rounded-full mb-1"></div>
            <div class="text-gray-400">Customer</div>
        </div>
        <div class="flex-1 border-t border-dashed border-gray-400 mx-2 mt-2"></div>
        <div class="flex flex-col items-center flex-1">
            <div class="w-3 h-3 bg-gray-300 rounded-full mb-1"></div>
            <div class="text-gray-400">Payment</div>
        </div>
    </div>

    <!-- TagHelper + ปิด HTML5 validation -->
    <form method="post" id="Customer" asp-antiforgery="true" novalidate class="space-y-4" autocomplete="off">

        <div asp-validation-summary="All" class="text-red-600 text-sm"></div>

        <!-- Basic (required) -->
        <div class="bg-white border rounded-2xl shadow p-4 space-y-3">
            <div class="text-base font-semibold">*Name & Contract</div>

            <input asp-for="Customer.CustomerName"
                   class="form-input w-full border border-gray-300 r05 ctl"
                   placeholder="ชื่อลูกค้า" />

            <select asp-for="Customer.Gender"
                    class="form-select w-full border border-gray-300 r05 ctl">
                <option value="">เพศ (เลือก)</option>
                <option value="Male">ชาย</option>
                <option value="Female">หญิง</option>
                <option value="Other">อื่นๆ</option>
            </select>

            <input asp-for="Customer.CustomerEmail" type="email"
                   class="form-input w-full border border-gray-300 r05 ctl"
                   placeholder="อีเมล (เช่น name@example.com)" />

            <input asp-for="Customer.CustomerPhone" class="form-input w-full border border-gray-300 r05 ctl"
                   placeholder="0899999999" />
        </div>

        <!-- Social -->
        <div class="bg-white border rounded-2xl shadow p-4 space-y-3">
            <div class="flex items-center justify-between">
                <div class="text-base font-semibold">Social</div>
                <button type="button" id="addSocialBtn" class="text-sm px-3 py-1 rounded-full bg-emerald-600 text-white">
                  Add
                </button>
            </div>

            <div id="socialList" class="space-y-2"><!-- rows by JS --></div>
            <input type="hidden" asp-for="Customer.Social" id="SocialJson" />
        </div>

        <!-- Contact & Address -->
        <div class="bg-white border rounded-2xl shadow p-4 space-y-3">
            <div class="text-base font-semibold">Address</div>

            <input asp-for="Customer.AddressLine" class="form-input w-full border border-gray-300 r05 ctl"
                   placeholder="ที่อยู่ (บ้านเลขที่/ซอย/ถนน)" />

            <div class="grid grid-cols-2 gap-3">
                <input asp-for="Customer.SubDistrict" class="form-input border border-gray-300 r05 ctl" placeholder="แขวง/ตำบล" />
                <input asp-for="Customer.District" class="form-input border border-gray-300 r05 ctl" placeholder="เขต/อำเภอ" />
            </div>

            <div class="grid grid-cols-2 gap-3">
                <input asp-for="Customer.Province" class="form-input border border-gray-300 r05 ctl" placeholder="จังหวัด" />
                <input asp-for="Customer.ZipCode" class="form-input border border-gray-300 r05 ctl" placeholder="รหัสไปรษณีย์" />
            </div>
        </div>

        <!-- Personal -->
        <div class="bg-white border rounded-2xl shadow p-4 space-y-3">
            <div class="text-base font-semibold">Personal</div>

            <label for="Note" class="block text-sm font-medium text-gray-700">Birth Date</label>
            <input asp-for="Customer.BirthDate" type="date"
                   class="form-input w-full border border-gray-300 r05 ctl" placeholder="วันเกิด" />

            <div class="grid grid-cols-2 gap-3">
                <input asp-for="Customer.Occupation" class="form-input border border-gray-300 r05 ctl" placeholder="อาชีพ" />
                <input asp-for="Customer.Nationality" class="form-input border border-gray-300 r05 ctl" placeholder="สัญชาติ" />
            </div>

            <div class="flex items-center gap-2 pt-1">
                <input asp-for="Customer.MayIAsk" type="checkbox" class="form-checkbox" />
                <span class="text-sm text-gray-700">ยินยอมให้ติดต่อภายหลัง</span>
            </div>
        </div>

        <div class="text-center">
            <button type="submit" class="w-full bg-black text-white px-6 py-2 r05">Next</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const socialList   = document.getElementById('socialList');
        const addBtn       = document.getElementById('addSocialBtn');
        const socialHidden = document.getElementById('SocialJson');
        const kinds = [
          {v:'line',t:'Line'},{v:'tiktok',t:'TikTok'},{v:'facebook',t:'Facebook'},
          {v:'instagram',t:'Instagram'},{v:'website',t:'Website'},{v:'other',t:'Other'}
        ];

        function createSocialRow(kind='line', val=''){
          const row = document.createElement('div');
          row.className = 'social-row flex flex-wrap items-center gap-2';
          row.innerHTML = `
            <select class="soc-kind shrink-0 w-36 border border-gray-300 r05 ctl">
              ${kinds.map(o=>`<option value="${o.v}" ${o.v===kind?'selected':''}>${o.t}</option>`).join('')}
            </select>
            <button type="button" class="soc-remove btn-del r05 ctl shrink-0">ลบ</button>
            <input class="soc-value flex-1 min-w-[220px] border border-gray-300 r05 ctl"
                   placeholder="กรอกข้อมูล (เช่น @@account หรือ URL)" value="${(val||'').replaceAll('"','&quot;')}" />
          `;
          return row;
        }

        // ---preload: 1.AttemptedValue, 2.Model --
        (function initSocialFromServer(){
          const attempted = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                                          ViewData.ModelState?["Customer.Social"]?.AttemptedValue ?? ""
                                                      ));
      const fromModel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Customer?.Social ?? ""));
      const raw = (attempted && attempted.trim()!=="") ? attempted : fromModel;

          try {
            if (raw && raw.trim()!=="") {
              const obj = JSON.parse(raw);
              const ent = Object.entries(obj);
              if (ent.length){
                ent.forEach(([k,v])=>{
                  String(v).split(/\s*,\s*/).filter(Boolean).forEach(p=> socialList.appendChild(createSocialRow(k,p)));
                });
                return;
              }
            }
          } catch { /* ignore */ }

          // default social 1 null
          socialList.appendChild(createSocialRow());
        })();

        addBtn.addEventListener('click', ()=>{
          if (socialList.children.length>=10) return;
          socialList.appendChild(createSocialRow());
        });

        socialList.addEventListener('click', e=>{
          if (e.target.classList.contains('soc-remove')){
            e.target.closest('.social-row')?.remove();
          }
        });

        // -- Custom validation + build JSON --
        function showToast(msg, color = "red") {
            document.querySelectorAll(".toast-msg").forEach(el => el.remove());

            const toast = document.createElement("div");
            toast.textContent = msg;
            toast.className = `toast-msg fixed top-6 left-1/2 -translate-x-1/2 bg-${color}-600 text-white px-4 py-2 rounded shadow-lg z-50`;
            document.body.appendChild(toast);

            setTimeout(() => toast.remove(), 2500);
        }

        const form = document.getElementById('Customer');
        form.addEventListener('submit', (e) => {
        const name   = document.getElementById('Customer_CustomerName');
        const gender = document.getElementById('Customer_Gender');
        const email  = document.getElementById('Customer_CustomerEmail');
        const phoneno  = document.getElementById('Customer_CustomerPhone');

        if (!name.value.trim()) {
            e.preventDefault();
            name.focus();
            showToast("กรุณากรอกชื่อลูกค้า");
            return;
        }

        if (!gender.value.trim()) {
            e.preventDefault();
            gender.focus();
            showToast("กรุณาเลือกเพศ");
            return;
        }

        if (!email.value.trim()) {
            e.preventDefault();
            email.focus();
            showToast("กรุณากรอกอีเมล");
            return;
        }

        const emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        if (!emailPattern.test(email.value.trim())) {
            e.preventDefault();
            email.focus();
            showToast("กรุณากรอกอีเมลให้ถูกต้อง เช่น example@mail.com");
            return;
        }
        if (!phoneno.value.trim()) {
           e.preventDefault();
           phoneno.focus();
           showToast("กรุณากรอกเบอร์โทรศัพท์");
           return;
        }
                 
          // รวม Social เก็บใน socialHidden
          const obj = {};
          Array.from(socialList.children).forEach(row=>{
            const kind = row.querySelector('.soc-kind')?.value?.trim();
            const val  = row.querySelector('.soc-value')?.value?.trim();
            if (kind && val){
              if (obj[kind]) obj[kind] = obj[kind] + ', ' + val;
              else obj[kind] = val;
            }
          });
          socialHidden.value = Object.keys(obj).length ? JSON.stringify(obj) : '';
        });
    </script>
}
