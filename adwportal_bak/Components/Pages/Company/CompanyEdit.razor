@page "/CompanyEdit"
@page "/CompanyEdit/{Id:int}"
@using adwportal.Dtos
@using adwportal.Services
@inject CompanyService Svc
@inject IdwImportService Idw
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Company @title</h3>

@if (loading)
{
    <div class="alert alert-info">Loading...</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="model.Name" />
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="Save" disabled="@saving">Save</button>
                <button class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }

    string? token;
    bool loading, saving;
    string? error;
    string title = "Add";

    // ใช้ Dto เดิม แต่ให้ IsActive ถูกโหลด/เซ็ตจาก backend เฉย ๆ (ไม่มี UI ให้แก้)
    CompanyUpsertBasicDtos model = new() { IsActive = true };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;

            // login เพื่อเอา token ไปยิง CompanyService
            var loginIdw = await Idw.LoginAsync("admin", "123456yjm");
            token = loginIdw?.Token;
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Login IDW failed";
                return;
            }

            if (Id.HasValue)
            {
                title = "Edit";

                var c = await Svc.GetCompanyAsync(token!, Id.Value);
                if (c == null)
                {
                    error = "Not found";
                    return;
                }

                // โหลดค่าปัจจุบันมาใส่ model (Name แก้ได้, IsActive เก็บไว้ไม่ให้แก้)
                model = new CompanyUpsertBasicDtos
                {
                    Name = c.Name,
                    IsActive = c.IsActive
                };
            }
            else
            {
                title = "Add";
                // model.IsActive = true (ค่า default อยู่แล้ว)
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    async Task Save()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(model.Name))
            {
                await JS.InvokeVoidAsync("showToast", "Name is required", "error");
                return;
            }

            if (string.IsNullOrWhiteSpace(token))
            {
                await JS.InvokeVoidAsync("showToast", "Token is empty", "error");
                return;
            }

            saving = true;

            if (Id.HasValue)
            {
                _ = await Svc.UpdateCompanyBasicAsync(token!, Id.Value, model);
            }
            else
            {
                _ = await Svc.CreateCompanyBasicAsync(token!, model);
            }

            await JS.InvokeVoidAsync("showToast", "Saved", "success");
            Nav.NavigateTo("/CompanyList");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
        finally
        {
            saving = false;
        }
    }

    void Cancel() => Nav.NavigateTo("/CompanyList");
}
