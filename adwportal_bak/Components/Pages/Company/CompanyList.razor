@page "/CompanyList"
@using adwportal.Dtos
@using adwportal.Services

@inject CompanyService Svc
@inject IdwImportService Idw
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Companies</h3>

@if (loading)
{
    <div class="alert alert-info">Loading...</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <!-- Filter + Add -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-8">
                    <label class="form-label">Name</label>
                    <input class="form-control"
                           @bind="NameFilter"
                           @bind:event="oninput" />
                </div>
                <div class="col-md-4 text-end align-self-end">
                    <button class="btn btn-primary" @onclick="Add">+ Add</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Table: # + Name + Action -->
    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:80px">#</th>
                    <th>Name</th>
                    <th style="width:160px">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (paged.Count == 0)
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">No data</td>
                    </tr>
                }
                else
                {
                    var rowNo = (pageIndex - 1) * pageSize;

                    foreach (var c in paged)
                    {
                        rowNo++;
                        <tr>
                            <td>@rowNo</td>
                            <td>@c.Name</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        @onclick="() => Edit(c.Id)">
                                    Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => Delete(c.Id)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <nav>
        <ul class="pagination">
            <li class="page-item @(pageIndex == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="Prev">Prev</button>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(pageIndex == i ? "active" : "")">
                    <button class="page-link" @onclick="@(() => Go(i))">@i</button>
                </li>
            }

            <li class="page-item @(pageIndex == totalPages ? "disabled" : "")">
                <button class="page-link" @onclick="Next">Next</button>
            </li>
        </ul>
    </nav>
}

@code {
    string? token;
    bool loading;
    string? error;

    List<CompanyListItemDtos> all = new();
    List<CompanyListItemDtos> filtered = new();
    List<CompanyListItemDtos> paged = new();

    string? nameFilter;
    string? NameFilter
    {
        get => nameFilter;
        set
        {
            nameFilter = value;
            pageIndex = 1;
            Apply();
        }
    }

    const int pageSize = 10;
    int pageIndex = 1;
    int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;

            // login เอา token จาก Idw
            var login = await Idw.LoginAsync("admin", "123456yjm");
            token = login?.Token;
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Login failed";
                return;
            }

            // ดึงบริษัททั้งหมด
            all = await Svc.GetCompaniesAsync(token!);
            Apply();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    void Apply()
    {
        IEnumerable<CompanyListItemDtos> q = all;

        // filter ชื่อ
        if (!string.IsNullOrWhiteSpace(nameFilter))
        {
            var kw = nameFilter.Trim();
            q = q.Where(x =>
                (x.Name ?? string.Empty)
                    .Contains(kw, StringComparison.OrdinalIgnoreCase));
        }

        // group by ชื่อบริษัท ซ้ำให้เหลือแค่ row เดียว
        q = q
            .GroupBy(
                x => (x.Name ?? string.Empty).Trim(),
                StringComparer.OrdinalIgnoreCase
            )
            .Select(g => g.First());

        // เรียง + ทำ paging
        filtered = q.OrderBy(x => x.Name).ToList();

        totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)pageSize));
        pageIndex = Math.Clamp(pageIndex, 1, totalPages);

        paged = filtered
            .Skip((pageIndex - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    void Prev()
    {
        if (pageIndex > 1)
        {
            pageIndex--;
            Apply();
        }
    }

    void Next()
    {
        if (pageIndex < totalPages)
        {
            pageIndex++;
            Apply();
        }
    }

    void Go(int i)
    {
        pageIndex = i;
        Apply();
    }

    void Add() => Nav.NavigateTo("/CompanyEdit");

    void Edit(int id) => Nav.NavigateTo($"/CompanyEdit/{id}");

    async Task Delete(int id)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Delete company id={id} ?");
        if (!ok) return;

        try
        {
            await Svc.DeleteCompanyAsync(token!, id);

            // เอา record ตัวนี้ออกจาก list แล้วคำนวณใหม่
            var idx = all.FindIndex(x => x.Id == id);
            if (idx >= 0) all.RemoveAt(idx);

            await JS.InvokeVoidAsync("showToast", "Deleted", "success");
            Apply();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
    }
}
