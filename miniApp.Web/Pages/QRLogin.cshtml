@page
@model miniApp.Web.Pages.QRLoginModel
@{
    ViewData["Title"] = "QR Login";
}

<div class="flex flex-col items-center justify-center min-h-screen bg-gray-100 p-6">
    <div class="bg-white shadow-md rounded-lg p-8 max-w-md w-full">
        <h2 class="text-2xl font-bold text-center text-green-700 mb-6">Scan QR to Login</h2>

        <div class="flex justify-center mb-6">
            <img id="qrImage" class="w-48 h-48" alt="QR Code" />
        </div>
        <div class="text-center text-sm text-gray-600 mb-4">Waiting for scan...</div>
        <div class="flex justify-center">
            <a href="/Login" class="text-blue-500 text-sm hover:underline">Cancel</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const apiBase = '@(Model.ApiBaseUrl ?? "http://localhost:5252")';
         let qrToken = null;

        async function generateQR() {
            try {
                const res = await fetch(`${apiBase}/api/qrlogin/generate`);
                const data = await res.json();
                qrToken = data.qrToken;

                document.getElementById('qrImage').src =
                    `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${qrToken}`;

                pollQR();
            } catch (err) {
                console.error("QR Generation Failed", err);
            }
        }

        async function pollQR() {
            const interval = setInterval(async () => {
                try {
                    const res = await fetch(`${apiBase}/api/qrlogin/scan?token=${qrToken}`, {
                        method: 'POST'
                    });

                    if (res.ok) {
                        clearInterval(interval);
                        const result = await res.json();

                        await fetch('/Session/SetJwt', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ token: result.token })
                        });

                        window.location.href = "/";
                    }
                } catch (err) {
                    console.error("Polling failed", err);
                }
            }, 2000);
        }

        generateQR();
    </script>
}
