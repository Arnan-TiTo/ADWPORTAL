@page
@model miniApp.Web.Pages.ProductModel
@{
    ViewData["Title"] = "Product";
    var apiBaseUrl = @Model?.HttpContext?.RequestServices?.GetService(typeof(IConfiguration)) is IConfiguration cfg
        ? cfg["ApiBaseUrl"] ?? ""
        : "";
    var authToken = @Model?.HttpContext?.RequestServices?.GetService(typeof(IConfiguration)) is IConfiguration config
        ? config["AUTHTOKEN"] ?? ""
        : "";
}

<div class="max-w-md w-full mx-auto px-4 py-4 space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <button onclick="history.back()" class="text-xl">&#8592;</button>
        <h1 class="text-lg font-semibold text-center flex-1">Product</h1>
    </div>

    <!-- Search -->
    <form onsubmit="return loadProducts(event)" class="relative">
        <input id="queryInput" type="text" placeholder="Search by name or SKU"
               class="w-full bg-gray-100 rounded-xl px-4 py-2 text-sm" />
        <button type="submit"
                class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500 text-sm">
            🔍
        </button>
    </form>

    <!-- Sort -->
    <div class="flex gap-2 mb-4">
        <button onclick="loadProducts(null,'asc')"
                class="bg-white border rounded-xl px-4 py-2 text-sm shadow-sm">
            🔼
        </button>
        <button onclick="loadProducts(null,'desc')"
                class="bg-white border rounded-xl px-4 py-2 text-sm shadow-sm">
            🔽
        </button>
    </div>

    <!-- Results -->
    <div id="productList" class="space-y-6"></div>
</div>

<!--Toast Notification Container -->
<div id="toast" class="fixed top-5 right-5 z-50 hidden">
    <div id="toastContent" class="px-4 py-2 rounded-xl shadow-lg text-white text-sm font-medium"></div>
</div>

@section Scripts {
    <script>
        const apiBaseUrl = '@apiBaseUrl';
        const authToken = '@authToken';

        async function loadProducts(e, sort = null) {
            if (e) e.preventDefault();

            const query = document.getElementById('queryInput').value.trim();
            let url = `${apiBaseUrl}api/product`;
            if (query) url = `${apiBaseUrl}api/product/productsearch?query=${encodeURIComponent(query)}`;

            try {
                const res = await fetch(url, {
                    headers: { "Authorization": "Bearer " + authToken }
                });

                if (!res.ok) throw new Error("Failed to fetch products");

                let products = await res.json();

                if (sort === "asc")
                    products.sort((a,b) => a.name.localeCompare(b.name));
                else if (sort === "desc")
                    products.sort((a,b) => b.name.localeCompare(a.name));

                renderProducts(products);

            } catch (err) {
                console.error(err);
                showToast("Error loading products", "red");
            }

            return false;
        }

        function renderProducts(products) {
            const container = document.getElementById("productList");
            container.innerHTML = "";

            if (!products || products.length === 0) {
                container.innerHTML = `<p class="text-center text-sm text-gray-500">No products found</p>`;
                return;
            }

            for (const p of products) {
                container.innerHTML += `
                    <div class="bg-white border rounded-xl p-4 shadow-sm">
                        <div class="text-center mb-2">
                            <img src="${p.imageUrl || '/images/no-image.png'}" class="w-20 h-20 mx-auto mb-2" />
                            <p class="text-sm text-gray-500">${p.name}</p>
                        </div>
                        <form onsubmit="return updateQuantity(this,event)">
                            <input type="hidden" name="Id" value="${p.id}" />
                            <input type="number" name="Quantity" value="${p.quantity}"
                                   class="w-full border rounded-xl px-4 py-2 text-sm" required />
                            <button type="submit"
                                    class="w-full bg-black text-white py-3 rounded-xl font-semibold mt-2">
                                Update
                            </button>
                        </form>
                    </div>
                `;
            }
        }

        async function updateQuantity(form, e) {
            e.preventDefault();
            const formData = new FormData(form);
            const dto = [{
                id: parseInt(formData.get("Id")),
                quantity: parseInt(formData.get("Quantity"))
            }];

            try {
                const res = await fetch(`${apiBaseUrl}api/Product/updatequantities`, {
                    method: "PUT",
                    headers: {
                        "Content-Type": "application/json",
                        "Authorization": "Bearer " + authToken
                    },
                    body: JSON.stringify(dto)
                });

                if (res.ok) showToast("Product updated successfully", "green");
                else showToast("Failed to update product", "red");

            } catch (err) {
                console.error(err);
                showToast("Error updating product", "red");
            }
            return false;
        }

        function showToast(message, color) {
            const toast = document.getElementById("toast");
            const content = document.getElementById("toastContent");
            content.textContent = message;
            content.className = `px-4 py-2 rounded-xl shadow-lg text-white text-sm font-medium bg-${color}-500`;
            toast.classList.remove("hidden");
            setTimeout(() => toast.classList.add("hidden"), 3000);
        }

        // auto load when page ready
        document.addEventListener("DOMContentLoaded", () => loadProducts());
    </script>
}
