@page
@model miniApp.Web.Pages.StockAdjustModel
@{
    ViewData["Title"] = "Stock adjust";
}

<div class="max-w-md w-full mx-auto px-4 py-4 space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <button onclick="history.back()" class="text-xl">&#8592;</button>
        <h1 class="text-lg font-semibold text-center flex-1">Stock adjust</h1>
    </div>

    <!-- Search -->
    <input type="text" placeholder="Search" class="w-full bg-gray-100 rounded-xl px-4 py-2 text-sm" />

    <!-- Form -->
    <form class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
            <input type="text" placeholder="Date : Auto" class="w-full border rounded-xl px-4 py-2 text-sm" disabled />
            <input type="text" placeholder="SKU no :" class="w-full border rounded-xl px-4 py-2 text-sm" />
        </div>

        <select class="w-full border rounded-xl px-4 py-2 text-sm">
            <option selected hidden>Hotel/Location name</option>
            <option>Bangkok Hotel</option>
            <option>Aonang Hotel</option>
        </select>

        <input type="text" placeholder="Product name" class="w-full border rounded-xl px-4 py-2 text-sm" />
        <input type="number" placeholder="Qty" class="w-full border rounded-xl px-4 py-2 text-sm" />
        <input type="text" placeholder="Field agent name" class="w-full border rounded-xl px-4 py-2 text-sm" />
        <input type="text" placeholder="Note" class="w-full border rounded-xl px-4 py-2 text-sm" />

        <button type="submit" class="w-full bg-black text-white py-3 rounded-xl font-semibold">Save</button>
    </form>
</div>
