@page
@model miniApp.Web.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="h-screen flex items-center justify-center bg-white overflow-hidden">
  <div class="bg-white p-6 rounded-xl w-full max-w-md shadow-md">
    <div class="text-center mb-6">
      <img src="/images/logo.png" alt="Logo" class="mx-auto w-24 h-24 mb-4" />
      <h2 class="text-xl font-semibold text-black">Welcome to Front Line</h2>
      <p class="text-sm text-gray-600">Sign in to your account</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-2 mb-4 rounded">
        @Model.ErrorMessage
      </div>
    }

    <form onsubmit="return loginDirect(event)" class="space-y-4">
      <input id="username" placeholder="Username"
             class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-black" />
      <input id="password" type="password" placeholder="Password"
             class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-black" />

      <input id="role" type="hidden" value="FrontLine"/>  

      <button type="submit" class="w-full bg-black text-white py-3 rounded-xl font-semibold transition hover:bg-gray-900">
        Continue
      </button>

      <div class="flex items-center justify-center my-2">
        <div class="border-t border-gray-300 w-full"></div>
        <span class="px-2 text-gray-400 text-sm">or</span>
        <div class="border-t border-gray-300 w-full"></div>
      </div>

      <button type="button" onclick="openQrScanner()"
              class="w-full bg-gray-100 border border-gray-300 py-3 rounded-xl font-medium flex justify-center items-center gap-2 text-sm text-gray-700 hover:bg-gray-200 transition">
        <!-- icon -->
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 3h4v4H3V3zm0 8h4v4H3v-4zm8-8h4v4h-4V3zm8 0h4v4h-4V3zM3 19h4v2H3v-2zm8 0h2v2h-2v-2zm4 0h4v2h-4v-2z" />
        </svg>
        Continue with QR Code
      </button>

      <a asp-page="/Register"
         class="w-full block bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl text-center font-semibold text-sm transition">
        Register
      </a>
    </form>
  </div>
</div>

<!-- Modal สแกน QR -->
<div id="qrScanModal" class="fixed inset-0 bg-black/60 hidden z-50">
  <div class="bg-white rounded-xl max-w-md w-[95%] mx-auto mt-16 p-4 shadow-lg">
    <div class="flex items-center justify-between mb-2">
      <h3 class="font-semibold">Scan QR Code</h3>
      <button type="button" class="text-gray-500 hover:text-black" onclick="closeQrScanner()">✕</button>
    </div>

    <div class="rounded overflow-hidden border">
      <video id="qrVideo" class="w-full h-64 object-cover bg-black" playsinline></video>
    </div>

    <div class="flex items-center gap-2 mt-3">
      <button id="qrSwitchBtn" type="button" class="px-3 py-2 rounded border text-sm hover:bg-gray-100">Switch Camera</button>
      <button type="button" onclick="chooseQrImage()" class="px-3 py-2 rounded border text-sm hover:bg-gray-100">Choose from Photos</button>
      <input id="qrFileInput" type="file" accept="image/*" class="hidden" />
    </div>

    <div id="qrStatus" class="text-xs text-gray-500 mt-2"></div>
  </div>
</div>

<!--Toast Notification Container -->
<div id="toast" class="fixed top-5 right-5 z-50 hidden">
    <div id="toastContent" class="px-4 py-2 rounded-xl shadow-lg text-white text-sm font-medium"></div>
</div>

@section Scripts {
  <script src="https://cdn.jsdelivr.net/npm/qr-scanner@@1.4.2/qr-scanner.umd.min.js"></script>
  <script>QrScanner.WORKER_PATH='https://cdn.jsdelivr.net/npm/qr-scanner@@1.4.2/qr-scanner-worker.min.js';</script>
  <script src="https://cdn.jsdelivr.net/npm/jsqr@@1.4.0/dist/jsQR.js"></script>

  <script>
    const apiBase='@Model.ApiBaseUrl';

    async function loginDirect(e){
      e.preventDefault();
      const username=document.getElementById('username').value.trim();
      const password=document.getElementById('password').value.trim();
      const role=document.getElementById('role').value.trim();

      if(!username||!password){ showToast('Please enter username and password.', "red"); return false; }
      const r=await fetch(`${apiBase}api/Auth/login`,{
        method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({username,password,role})
      });
      if(!r.ok){ showToast(await r.text()||'Invalid username or password.', "red"); return false; }
      const data=await r.json();
      const s=await fetch('/Login?handler=SetSession',{
        method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({token:data.token,userId:data.userId,fullname:data.fullname,username}),
        credentials:'include'
      });
      if(s.ok) location.href='/'; else showToast('Failed to set session.', "red");
      return false;
    }

    const modal=document.getElementById('qrScanModal');
    const videoEl=document.getElementById('qrVideo');
    const fileInput=document.getElementById('qrFileInput');
    const statusEl=document.getElementById('qrStatus');
    const switchBtn=document.getElementById('qrSwitchBtn');
    let scanner=null,cameras=[],camIdx=0, noResultTimer=null;

    function setStatus(m){ statusEl.textContent=m||''; }

    async function openQrScanner(){
      modal.classList.remove('hidden');
      setStatus('Initializing camera...');
      try{
        if(!scanner){
          scanner=new QrScanner(videoEl, res=>handleDecoded(res), {
            returnDetailedScanResult:true,
            highlightScanRegion:true,
            highlightCodeOutline:true
          });
          scanner.setInversionMode('both');
        }
        cameras=await QrScanner.listCameras(true);
        if(cameras.length){
          const back=cameras.findIndex(c=>/back|rear|environment/i.test(c.label));
          camIdx=back>=0?back:0;
          await scanner.setCamera(cameras[camIdx].id);
        }
        await scanner.start();
        setStatus(cameras.length?`Using: ${cameras[camIdx].label||'Camera'}`:'Camera ready');
        clearTimeout(noResultTimer);
        noResultTimer=setTimeout(()=>setStatus('Tip: ขยับให้ QR อยู่กลางเฟรม/สว่างขึ้น/เข้าใกล้'),8000);
      }catch(e){
        console.error(e); setStatus('Cannot access camera. You can choose a photo instead.');
      }
    }
    async function closeQrScanner(){ clearTimeout(noResultTimer); try{await scanner?.stop();}catch{} modal.classList.add('hidden'); setStatus(''); }
    switchBtn.addEventListener('click', async ()=>{ if(!cameras.length) return; camIdx=(camIdx+1)%cameras.length; await scanner.setCamera(cameras[camIdx].id); setStatus(`Using: ${cameras[camIdx].label||'Camera'}`); });

    function chooseQrImage(){ fileInput.click(); }

    async function decodeFromFile(file){
      const opts={ returnDetailedScanResult:true, inversionAttempts:'attemptBoth', alsoTryWithoutScanRegion:true };
      try { return await QrScanner.scanImage(file, opts); }
      catch(e1){
        const url=URL.createObjectURL(file);
        try{
          const img=await new Promise((resolve,reject)=>{ const im=new Image(); im.onload=()=>resolve(im); im.onerror=reject; im.src=url; });
          const max=1000, ratio=Math.min(1, max/Math.max(img.width,img.height));
          const w=Math.max(1,Math.round(img.width*ratio)), h=Math.max(1,Math.round(img.height*ratio));
          const canvas=document.createElement('canvas'); canvas.width=w; canvas.height=h;
          const ctx=canvas.getContext('2d'); ctx.drawImage(img,0,0,w,h);
          try { return await QrScanner.scanImage(canvas, opts); }
          catch(e2){
            try{
              const id=ctx.getImageData(0,0,w,h);
              if (window.jsQR){
                const res=jsQR(id.data, w, h, { inversionAttempts:'attemptBoth' });
                if(res && res.data) return { data: res.data };
              }
              throw e2;
            }catch(e3){ throw e2; }
          }
        } finally { URL.revokeObjectURL(url); }
      }
    }

    fileInput.addEventListener('change', async (e)=>{
      const f=e.target.files?.[0]; if(!f) return;
      setStatus('Scanning image...');
      try{
        const res=await decodeFromFile(f);
        await handleDecoded(res);
      }catch(err){
        console.error(err);
        setStatus('No QR code found. ลองภาพคมชัด/ไม่มีเงา/มีขอบขาวรอบโค้ด หรือเปิดรูปให้ใหญ่ขึ้นแล้วลองใหม่ครับ');
      }finally{ fileInput.value=''; }
    });

    function qrText(decoded){ return typeof decoded==='string'?decoded:(decoded?.data||''); }

    async function handleDecoded(decoded){
      const role=document.getElementById('role').value.trim();
      const text=qrText(decoded); if(!text){ setStatus('Invalid QR.'); return; }
      setStatus('QR detected. Logging in...');
      try{
        const r=await fetch(`${apiBase}api/qrlogin/loginByQr`,{
          method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({ qr:text,role })
        });
        if(!r.ok){ setStatus(await r.text()||'QR not recognized.'); return; }
        const result=await r.json();
        await closeQrScanner();
        const s=await fetch('/Login?handler=SetSession',{
          method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({ token:result.token, userId:result.userId, fullname:result.fullname, username:result.username }),
          credentials:'include'
        });
        if(s.ok) location.href='/'; else showToast('Failed to set session.', "red");
      }catch(err){ console.error(err); setStatus('Login failed.'); }
    }

    function showToast(message, color) {
        const toast = document.getElementById("toast");
        const content = document.getElementById("toastContent");
        content.textContent = message;
        content.className =
            "px-4 py-2 rounded-xl shadow-lg text-white text-sm font-medium bg-" + color + "-500";
        toast.classList.remove("hidden");
        setTimeout(() => toast.classList.add("hidden"), 4000);
    }
  </script>
}
