@page
@model miniApp.Web.Pages.LocationModel
@{
    ViewData["Title"] = "Location";
}

<!-- Container ที่คุมทุกอย่าง -->
<div class="max-w-md w-full mx-auto px-4 py-4 space-y-6">

    <!-- Header -->
    <div class="bg-yellow-200 text-center py-6 px-4 rounded-2xl relative w-full">
        <img src="/images/logo.png" alt="Logo" class="w-16 h-16 mx-auto rounded-full -mt-10 border-4 border-white" />
        <h2 class="text-lg font-bold text-black mt-2">@Model.Username</h2>
        <p class="text-sm text-gray-700">@Model.RoleDescription</p>
    </div>

    <!-- Location Panel -->
    <div class="bg-white shadow-lg rounded-2xl p-4 text-center border">
        <h3 class="font-semibold text-lg mb-2">Location</h3>
        <button id="getLocationBtn" class="bg-blue-800 text-white py-2 px-6 rounded-full font-medium">Get</button>
        <div class="text-sm mt-4 text-gray-600">Date : @Model.CurrentDate</div>
        <div class="text-sm font-semibold text-blue-700">Time : @Model.CurrentTime</div>

        <!-- Upload Images -->
        <div class="mt-6 text-left">
            <label class="block text-sm font-medium text-gray-700">Images</label>
            <div id="imageInputs" class="space-y-4">
                <div class="flex flex-col sm:flex-row sm:items-center sm:space-x-4">
                    <input type="file" name="Image" class="image-upload-input" accept="image/*" capture="environment" onchange="previewImage(this)" />
                    <button type="button" class="remove-btn text-red-500 font-bold text-xl sm:mt-0 mt-2">−</button>
                </div>
            </div>
            <button type="button" id="addImageBtn" class="mt-4 px-4 py-1 text-sm bg-green-500 text-white rounded-full">+ Add Image</button>
        </div>
    </div>

    <!-- Form -->
    <form id="locationForm" class="space-y-4">
        <input id="Name" placeholder="Location name" class="w-full px-4 py-2 border rounded-md shadow-sm" />
        <span class="text-red-600 text-sm" id="nameError"></span>

        <input id="Note" placeholder="Note" class="w-full px-4 py-2 border rounded-md shadow-sm" />
        <span class="text-red-600 text-sm" id="noteError"></span>

        <div>
            <label for="Latitude" class="block text-sm font-medium text-gray-700">Latitude</label>
            <input id="Latitude" type="text" class="w-full px-4 py-2 border rounded-md shadow-sm bg-gray-100" readonly />
        </div>

        <div>
            <label for="Longitude" class="block text-sm font-medium text-gray-700">Longitude</label>
            <input id="Longitude" type="text" class="w-full px-4 py-2 border rounded-md shadow-sm bg-gray-100" readonly />
        </div>

        <input type="hidden" id="LatitudeHidden" />
        <input type="hidden" id="LongitudeHidden" />
        <input type="hidden" id="Usernames" value="@Model.Usernames" />

        <button type="submit" class="w-full bg-black text-white py-3 rounded-md font-semibold">Save</button>
    </form>
</div>

@section Scripts {
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            sidebar.classList.toggle("hidden");
        }

        document.getElementById("getLocationBtn")?.addEventListener("click", function (e) {
            e.preventDefault();
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(function (position) {
                    document.getElementById("Latitude").value = position.coords.latitude;
                    document.getElementById("Longitude").value = position.coords.longitude;
                    document.getElementById("LatitudeHidden").value = position.coords.latitude;
                    document.getElementById("LongitudeHidden").value = position.coords.longitude;
                    showToast("Lat: " + position.coords.latitude + "\nLng: " + position.coords.longitude,"green");
                }, function (error) {
                    showToast("Error getting location: " + error.message,"red");
                });
            } else {
                showToast("Geolocation is not supported by this browser.","red");
            }
        });

        function previewImage(inputElement) {
            const file = inputElement.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    let preview = inputElement.parentElement.querySelector('img');
                    if (!preview) {
                        preview = document.createElement('img');
                        preview.className = "w-24 h-24 object-cover rounded border mt-2";
                        inputElement.parentElement.appendChild(preview);
                    }
                    preview.src = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        }

        document.getElementById('addImageBtn').addEventListener('click', () => {
            const container = document.getElementById('imageInputs');
            if (container.children.length >= 5) {
                showToast("You can only upload up to 5 images.","red");
                return;
            }

            const newInputDiv = document.createElement('div');
            newInputDiv.classList = 'flex flex-col sm:flex-row sm:items-center sm:space-x-4';
            newInputDiv.innerHTML = `
                <input type="file" name="Image" class="image-upload-input" accept="image/*" capture="environment" onchange="previewImage(this)" />
                <button type="button" class="remove-btn text-red-500 font-bold text-xl sm:mt-0 mt-2">−</button>
            `;
            container.appendChild(newInputDiv);
        });

        document.getElementById('imageInputs').addEventListener('click', (e) => {
            if (e.target && e.target.classList.contains('remove-btn')) {
                e.target.parentElement.remove();
            }
        });

        document.getElementById('locationForm').addEventListener('submit', async function (event) {
            event.preventDefault();

            const formData = new FormData();
            formData.append('Name', document.getElementById('Name').value);
            formData.append('Note', document.getElementById('Note').value);
            formData.append('Latitude', document.getElementById('LatitudeHidden').value);
            formData.append('Longitude', document.getElementById('LongitudeHidden').value);
            formData.append('Usernames', document.getElementById('Usernames').value);

            const imageInputs = document.querySelectorAll('.image-upload-input');
            imageInputs.forEach(input => {
                const files = input.files;
                for (let i = 0; i < files.length; i++) {
                    formData.append('Image', files[i]);
                }
            });

            const apiBaseUrl = '@ViewData["ApiBaseUrl"]';
            const apiUrl = apiBaseUrl + 'api/locations';

            try {
                const response = await fetch(apiUrl, {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error("Failed:", errorText);
                    throw new Error('Submit failed');
                }

                const result = await response.json();
                showToast("Location saved successfully","green");
                console.log(result);
            } catch (error) {
                showToast("Error submitting location!","red");
                console.error(error);
            }
        });

        function showToast(message, color) {
            const toast = document.getElementById("toast");
            const content = document.getElementById("toastContent");
            content.textContent = message;
            content.className =
                "px-4 py-2 rounded-xl shadow-lg text-white text-sm font-medium bg-" + color + "-500";
            toast.classList.remove("hidden");
            setTimeout(() => toast.classList.add("hidden"), 5000);
        }
    </script>
}
