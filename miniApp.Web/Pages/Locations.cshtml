@page
@model miniApp.Web.Pages.LocationModel
@{
    ViewData["Title"] = "Location";
}

<div class="bg-yellow-200 text-center py-4 rounded-b-3xl relative">
    <img src="/images/logo.png" alt="Logo" class="w-16 h-16 mx-auto rounded-full -mt-10 border-4 border-white" />
    <h2 class="text-lg font-bold text-black mt-2">@Model.Username</h2>
    <p class="text-sm text-gray-700">@Model.RoleDescription</p>
    <div class="absolute top-4 right-4">
        <button class="text-black text-2xl" onclick="toggleSidebar()">&#9776;</button>
    </div>
</div>

<div class="bg-white shadow-lg rounded-2xl p-4 mx-4 mt-6 text-center border">
    <h3 class="font-semibold text-lg mb-2">Location</h3>
    <button id="getLocationBtn" class="bg-blue-800 text-white py-2 px-6 rounded-full font-medium">Get</button>
    <div class="text-sm mt-4 text-gray-600">Date : @Model.CurrentDate</div>
    <div class="text-sm font-semibold text-blue-700">Time : @Model.CurrentTime</div>

    <div class="mt-4">
        <label for="upload" class="cursor-pointer">
            <div class="bg-green-500 w-20 h-20 rounded-full flex items-center justify-center mx-auto">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm5 3a1 1 0 112 0v3h2a1 1 0 110 2h-2v3a1 1 0 11-2 0v-3H7a1 1 0 110-2h2V6z" />
                </svg>
            </div>
            <p class="text-xs mt-2 text-gray-500">Click to upload your pictures</p>
        </label>
        <input id="upload" type="file" name="Upload" multiple class="hidden" accept="image/*" />
        <div id="previewContainer" class="flex flex-wrap justify-center gap-2 mt-2"></div>
    </div>
</div>

<form id="locationForm" class="px-4 mt-6 space-y-4">
    <input id="Name" placeholder="Location name" class="w-full px-4 py-2 border rounded-md shadow-sm" />
    <span class="text-red-600 text-sm" id="nameError"></span>

    <input id="Note" placeholder="Note" class="w-full px-4 py-2 border rounded-md shadow-sm" />
    <span class="text-red-600 text-sm" id="noteError"></span>

    <!-- Read-only Latitude and Longitude fields -->
    <div class="mt-4">
        <label for="Latitude" class="block text-sm font-medium text-gray-700">Latitude</label>
        <input id="Latitude" type="text" class="w-full px-4 py-2 border rounded-md shadow-sm bg-gray-100" readonly />
    </div>

    <div class="mt-4">
        <label for="Longitude" class="block text-sm font-medium text-gray-700">Longitude</label>
        <input id="Longitude" type="text" class="w-full px-4 py-2 border rounded-md shadow-sm bg-gray-100" readonly />
    </div>

    <input type="hidden" id="LatitudeHidden" />
    <input type="hidden" id="LongitudeHidden" />

    <button type="submit" class="w-full bg-black text-white py-3 rounded-md font-semibold">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            sidebar.classList.toggle("hidden");
        }

        document.getElementById("getLocationBtn")?.addEventListener("click", function (e) {
            e.preventDefault();
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(function (position) {
                    console.log('Location Data:', position);

                    document.getElementById("Latitude").value = position.coords.latitude;
                    document.getElementById("Longitude").value = position.coords.longitude;
                    document.getElementById("LatitudeHidden").value = position.coords.latitude;
                    document.getElementById("LongitudeHidden").value = position.coords.longitude;
                    alert("Lat: " + position.coords.latitude + "\nLng: " + position.coords.longitude);
                }, function (error) {
                    alert("Error getting location: " + error.message);
                });
            } else {
                alert("Geolocation is not supported by this browser.");
            }
        });

        document.getElementById('locationForm').addEventListener('submit', async function (event) {
            event.preventDefault();  // Prevent the form from refreshing the page

            const formData = new FormData();
            formData.append('Name', document.getElementById('Name').value);
            formData.append('Note', document.getElementById('Note').value);
            formData.append('Latitude', document.getElementById('LatitudeHidden').value);
            formData.append('Longitude', document.getElementById('LongitudeHidden').value);

            const fileInput = document.getElementById('upload');
            if (fileInput.files.length > 0) {
                Array.from(fileInput.files).forEach(file => {
                    formData.append('Image', file);
                });
            }

            try {
                // Call API to save location, targeting `api/locations` directly
                const response = await fetch('/locations', {  // Change URL to api/locations
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Failed to submit location');
                }

                const result = await response.json();
                console.log('API Response:', result);
                alert('Location saved successfully!');
            } catch (error) {
                console.error('Error:', error);
                alert('Failed to submit location');
            }
        });
    </script>
}
