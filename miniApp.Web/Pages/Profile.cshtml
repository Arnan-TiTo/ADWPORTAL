@page
@model miniApp.Web.Pages.ProfileModel
@{
    ViewData["Title"] = "Profile";
}

<!-- Header -->
<div class="bg-white py-4 px-4 border-b shadow-sm flex items-center justify-between">
    <h1 class="text-lg font-semibold text-gray-900">👤 Profile</h1>
</div>

<!-- Profile Content -->
<div class="px-4 py-6 space-y-6 bg-white min-h-screen">

    <!-- User Info -->
    <div class="flex flex-col items-center space-y-2">
        <img src="/images/logo.png" alt="Profile" class="w-20 h-20 rounded-full border-4 border-white shadow-md" />
        <h2 class="text-xl font-bold text-gray-800">@Model.Username</h2>
        <p class="text-sm text-gray-500">@Model.RoleDescription</p>
    </div>

    <!-- Profile Fields -->
    <div class="space-y-4">
        <div>
            <label class="text-sm text-gray-600">Email</label>
            <input type="text" value="@Model.Email" readonly class="w-full px-4 py-2 border rounded-md bg-gray-100 text-gray-700" />
        </div>
        <div>
            <label class="text-sm text-gray-600">Phone</label>
            <input type="text" value="@Model.Phone" readonly class="w-full px-4 py-2 border rounded-md bg-gray-100 text-gray-700" />
        </div>
        <div>
            <label class="text-sm text-gray-600">Role</label>
            <input type="text" value="@Model.RoleDescription" readonly class="w-full px-4 py-2 border rounded-md bg-gray-100 text-gray-700" />
        </div>
    </div>

    <!-- Button -->
    <button class="w-full bg-black text-white py-3 rounded-md font-semibold">Edit Profile</button>
</div>
