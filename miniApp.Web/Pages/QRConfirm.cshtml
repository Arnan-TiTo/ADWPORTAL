@page
@model miniApp.Web.Pages.QRConfirmModel
@{
    ViewData["Title"] = "QR Confirm";
}

<div class="flex flex-col items-center justify-center min-h-screen bg-gray-100 px-6">
    <div class="bg-white p-6 rounded shadow-md w-full max-w-md">
        <h2 class="text-xl font-bold mb-4 text-green-600 text-center">Confirm QR Login</h2>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="bg-yellow-100 border border-yellow-400 text-yellow-700 px-4 py-2 mb-4 rounded">
                @Model.Message
            </div>
        }

        <form method="post" class="space-y-4">
            <input type="hidden" asp-for="QrToken" />

            <div>
                <label class="block text-sm font-medium text-gray-700">Username</label>
                <input asp-for="Login.Username" class="w-full px-3 py-2 border rounded shadow-sm" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">Password</label>
                <input asp-for="Login.Password" type="password" class="w-full px-3 py-2 border rounded shadow-sm" />
            </div>

            <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded">
                Confirm Login
            </button>
        </form>
    </div>
</div>
