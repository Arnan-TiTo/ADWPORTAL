@page
@model miniApp.Web.Pages.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="min-h-screen flex items-center justify-center bg-white">
    <div class="bg-white p-6 rounded-xl w-full max-w-md">
        <div class="text-center mb-6">
            <img src="/images/logo.png" alt="Logo" class="mx-auto w-28 h-28 mb-4">
            <h2 class="text-xl font-semibold text-black">Create your account</h2>
            <p class="text-sm text-gray-600">Fill in your details to register</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-2 mb-4 rounded">
                @Model.ErrorMessage
            </div>
        }

        <form method="post" class="space-y-4" autocomplete="off">
            <input asp-for="Register.Fullname" placeholder="Full Name"
                   class="w-full px-3 py-3 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-black" />
            <span asp-validation-for="Register.Fullname" class="text-red-600 text-sm"></span>

            <input asp-for="Register.Username" placeholder="Username" autocomplete="new-password"
                   class="w-full px-3 py-3 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-black" />
            <span asp-validation-for="Register.Username" class="text-red-600 text-sm"></span>

            <input asp-for="Register.Email" placeholder="Email" type="email"
                   class="w-full px-3 py-3 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-black" />
            <span asp-validation-for="Register.Email" class="text-red-600 text-sm"></span>

            <input asp-for="Register.Phone" placeholder="Phone" type="tel" pattern="^0[689]\d{8}" title="Enter a valid Thai phone number"
                   class="w-full px-3 py-3 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-black" />
            <span asp-validation-for="Register.Phone" class="text-red-600 text-sm"></span>

            <input asp-for="Register.Password" type="password" placeholder="Password" autocomplete="new-password"
                   class="w-full px-3 py-3 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-black" />
            <span asp-validation-for="Register.Password" class="text-red-600 text-sm"></span>


            <button type="submit" class="w-full bg-black text-white py-3 rounded-md font-semibold">Register</button>

            <a href="/Login" class="w-full block text-sm text-blue-600 text-center underline mt-4">Back to Login</a>

            <p class="text-xs text-center text-gray-400 mt-2">
                By clicking register, you agree to our <a href="/terms" class="underline">Terms of Service</a>
                and <a href="/privacy" class="underline">Privacy Policy</a>
            </p>
        </form>
    </div>
</div>
