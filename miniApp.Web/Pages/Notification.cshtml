@page
@model miniApp.Web.Pages.NotificationModel
@{
    ViewData["Title"] = "Notifications";
    var userId = ViewData["UserId"];
}
<div class="max-w-md mx-auto bg-white p-4 min-h-screen space-y-4">
<!-- Header -->
<div class="bg-white py-4 px-4 border-b shadow-sm flex items-center justify-between">
    <h1 class="text-lg font-semibold text-gray-900">🔔 Notifications</h1>
</div>

<!-- Notification List -->
<div id="notifyList" class="px-4 py-4 space-y-4 bg-white min-h-screen">
    <p class="text-gray-500 text-sm">Loading...</p>
</div>
</div>

@section Scripts {
    <script>
        const APIBASEURL = '@ViewData["APIBASEURL"]';
        const AUTHTOKEN = '@ViewData["AUTHTOKEN"]';
        const USERID = '@ViewData["USERID"]';

        async function loadNotifications() {
            try {
                const res = await fetch(`${APIBASEURL}api/notification/user/${USERID}`, {
                    headers: {
                        'Authorization': `Bearer ${AUTHTOKEN}`
                    }
                });

                const listContainer = document.getElementById("notifyList");
                listContainer.innerHTML = "";

                if (!res.ok) {
                    listContainer.innerHTML = `<p class="text-red-500 text-sm">Failed to load notifications (${res.status})</p>`;
                    return;
                }

                const notifications = await res.json();
                if (!notifications.length) {
                    listContainer.innerHTML = `<p class="text-gray-500 text-sm">No notifications yet.</p>`;
                    return;
                }

                notifications.forEach(n => {
                    const el = document.createElement("div");
                    el.className = "border rounded-xl p-4 shadow-sm hover:bg-gray-50 transition";
                    el.innerHTML = `
                        <div class="flex justify-between items-center">
                            <h2 class="text-base font-medium text-gray-800">${n.title}</h2>
                            <span class="text-xs text-gray-400">${timeAgo(n.createdAt)}</span>
                        </div>
                        <p class="text-sm text-gray-600 mt-1">${n.message}</p>
                    `;
                    listContainer.appendChild(el);
                });
            } catch (err) {
                console.error("Error loading notifications", err);
            }
        }

        function timeAgo(date) {
            const d = new Date(date);
            const diff = Math.floor((new Date() - d) / 1000);
            if (diff < 60) return `${diff}s ago`;
            if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
            if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
            return d.toLocaleDateString();
        }

        document.addEventListener("DOMContentLoaded", loadNotifications);
    </script>
}
