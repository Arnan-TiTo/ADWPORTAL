@using miniApp.AdminPortal.Shared
@if (State is not null && State.TotalPages > 1)
{
    <nav class="@ContainerClass">
        <ul class="pagination pagination-sm mb-0">

            <!-- First -->
            <li class="page-item @(State.Page == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="(() => Change(1))">««</button>
            </li>

            <!-- Prev -->
            <li class="page-item @(State.Page == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="(() => Change(State.Page - 1))">‹</button>
            </li>

            <!-- Page 1 -->
            <li class="page-item @(State.Page == 1 ? "active" : "")">
                <button class="page-link" @onclick="(() => Change(1))">1</button>
            </li>

            <!-- Left ellipsis -->
            @if (State.WindowStart > 2)
            {
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }

            <!-- Window pages -->
            @for (int p = State.WindowStart; p <= State.WindowEnd; p++)
            {
                var pageNum = p;  // << สำคัญ: กันบั๊ก capture ตัวแปรลูป
                                  <li class="page-item @(State.Page == pageNum ? "active" : "")">
                                      <button class="page-link" @onclick="(() => Change(pageNum))">@pageNum</button>
                                  </li>
            }

            <!-- Right ellipsis -->
            @if (State.WindowEnd < State.TotalPages - 1)
            {
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }

            <!-- Last page -->
            @if (State.TotalPages > 1)
            {
                <li class="page-item @(State.Page == State.TotalPages ? "active" : "")">
                    <button class="page-link" @onclick="(() => Change(State.TotalPages))">@State.TotalPages</button>
                </li>
            }

            <!-- Next -->
            <li class="page-item @(State.Page == State.TotalPages ? "disabled" : "")">
                <button class="page-link" @onclick="(() => Change(State.Page + 1))">›</button>
            </li>

            <!-- Last -->
            <li class="page-item @(State.Page == State.TotalPages ? "disabled" : "")">
                <button class="page-link" @onclick="(() => Change(State.TotalPages))">»»</button>
            </li>
        </ul>
    </nav>
}

@code {
    [Parameter, EditorRequired] public PaginationState State { get; set; } = default!;
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public string ContainerClass { get; set; } = "d-flex justify-content-end mt-2";

    private async Task Change(int p)
    {
        var clamped = Math.Clamp(p, 1, State.TotalPages);
        if (clamped == State.Page) return;
        await OnPageChanged.InvokeAsync(clamped);
    }
}
