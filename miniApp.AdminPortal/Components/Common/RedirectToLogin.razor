@rendermode InteractiveServer
@inject NavigationManager Nav

<p>Redirecting to login… <a href="/login">Go to login</a></p>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // forceLoad:true กันเคสที่ Router ยังไม่ attach
            Nav.NavigateTo("/login", replace: true, forceLoad: true);
        }
    }
}
