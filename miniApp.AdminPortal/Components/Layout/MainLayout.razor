@rendermode InteractiveServer
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject NavigationManager Nav
@inject IJSRuntime JS

<AuthorizeView>
    <Authorized Context="auth">
        <div class="page">
            <!-- Sidebar -->
            <div class="sidebar @(isSidebarOpen ? "open" : "closed")">
                <nav>
                    <ul>
                        <li><NavLink href="/" Match="NavLinkMatch.All" ActiveClass="is-active">Home</NavLink></li>
                        <li><NavLink href="/UserList" Match="NavLinkMatch.Prefix" ActiveClass="is-active">User</NavLink></li>
                        <li><NavLink href="/ProductList" Match="NavLinkMatch.Prefix" ActiveClass="is-active">Product</NavLink></li>
                        <li><NavLink href="/ProductStockList" Match="NavLinkMatch.Prefix" ActiveClass="is-active">Product Stock Manage</NavLink></li>
                        <li><NavLink href="/ProductStockQtyList" Match="NavLinkMatch.Prefix" ActiveClass="is-active">Product Stock Quantity</NavLink></li>
                        <li><NavLink href="/ProductCategoryList" Match="NavLinkMatch.Prefix" ActiveClass="is-active">Product Category</NavLink></li>
                        <li><NavLink href="/ProductBrandList" Match="NavLinkMatch.Prefix" ActiveClass="is-active">Product Brand</NavLink></li>
                        <li><NavLink href="/OrderList" Match="NavLinkMatch.Prefix" ActiveClass="is-active">Order</NavLink></li>
                        <li><NavLink href="/LocationList" Match="NavLinkMatch.Prefix" ActiveClass="is-active">Location</NavLink></li>
                        <li><NavLink href="/NotificationList" Match="NavLinkMatch.Prefix" ActiveClass="is-active">Notification</NavLink></li>
                        <li><NavLink href="/IdwImport" Match="NavLinkMatch.Prefix" ActiveClass="is-active">IDW Import</NavLink></li>
                        <li><NavLink href="/IdwManageList" Match="NavLinkMatch.Prefix" ActiveClass="is-active">IDW Manage</NavLink></li>
                    </ul>
                </nav>
            </div>

            <!-- Main -->
            <div class="main-content @(isSidebarOpen ? "shrink" : "")">
                <div class="top-row d-flex align-items-center">
                    <div class="logo-area d-flex align-items-center gap-2">
                        <img src="/images/logo.png" class="logo" />
                        <strong>VAC Admin Portal</strong>
                        <button class="menu-toggle" @onclick="ToggleSidebar">☰</button>
                    </div>

                    <!-- ดันขวา -->
                    <span class="ms-auto"></span>

                    <!-- ชื่อผู้ใช้จาก Claims -->
                    <span class="topbar-name me-2">
                        Welcome @GetDisplayName(auth.User)
                    </span>

                    <button class="btn btn-sm btn-outline-secondary" @onclick="Logout">Logout</button>
                </div>

                <main>@Body</main>
            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool isSidebarOpen = true;
    void ToggleSidebar() => isSidebarOpen = !isSidebarOpen;

    // อ่านชื่อจาก Claims
    private static string GetDisplayName(ClaimsPrincipal? user)
    {
        if (user is null) return "";
        var full = user.FindFirst("FULLNAME")?.Value;
        if (!string.IsNullOrWhiteSpace(full)) return full!;
        return user.Identity?.Name ?? "";
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("miniapp.logout");
    }
}
