@page "/ProductList"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using miniApp.AdminPortal.Models
@using miniApp.AdminPortal.Shared
@using miniApp.AdminPortal.Components
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject IJSRuntime JS
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<h3 class="d-flex align-items-center justify-content-between">
    <span>Product List</span>
    <button class="btn btn-sm btn-primary" @onclick="AddProduct">+ Add</button>
</h3>

<!-- Search bar -->
<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Name / SKU</label>
                <input class="form-control"
                       placeholder="Search by name or SKU"
                       value="@queryText"
                       @oninput="OnQueryChanged" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Category</label>
                <select class="form-select" value="@GetSelectValue(selectedCategoryId)" @onchange="OnCategoryChanged">
                    <option value="">-- All Categories --</option>
                    @if (categories != null)
                    {
                        @foreach (var c in categories)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Brand</label>
                <select class="form-select" value="@GetSelectValue(selectedBrandId)" @onchange="OnBrandChanged">
                    <option value="">-- All Brands --</option>
                    @if (brands != null)
                    {
                        @foreach (var b in brands)
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-1 d-grid">
                <button class="btn btn-outline-secondary" @onclick="ClearSearch">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (!filtered.Any())
{
    <p>No products found.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th style="width:80px;">Image</th>
                    <th @onclick='() => SortBy("Name")' style="cursor:pointer">
                        Name @SortIcon("Name")
                    </th>
                    <th @onclick='() => SortBy("Sku")' style="cursor:pointer">
                        SKU @SortIcon("Sku")
                    </th>
                    <th @onclick='() => SortBy("Category")' style="cursor:pointer">
                        Category @SortIcon("Category")
                    </th>
                    <th @onclick='() => SortBy("Brand")' style="cursor:pointer">
                        Brand @SortIcon("Brand")
                    </th>
                    <th class="text-end" style="width:120px; cursor:pointer" @onclick='() => SortBy("Price")'>
                        Price @SortIcon("Price")
                    </th>
                    <th class="text-end" style="width:90px; cursor:pointer" @onclick='() => SortBy("Quantity")'>
                        Qty @SortIcon("Quantity")
                    </th>

                    <th class="text-end" style="width:160px;">Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var p in paged)
                {
                    var fullImageUrl = string.IsNullOrEmpty(p.ImageUrl) ? null : $"{ApiBaseUrl.TrimEnd('/')}{p.ImageUrl}";
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(fullImageUrl))
                            {
                                <img src="@fullImageUrl"
                                     width="56" height="56"
                                     class="rounded border object-fit-cover"
                                     style="cursor: zoom-in"
                                     @onclick="() => OpenImage(fullImageUrl)" />
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>@p.Name</td>
                        <td>@p.Sku</td>
                        <td>@p.CategoryName</td>
                        <td>@p.BrandName</td>
                        <td class="text-end">@p.Price.ToString("C")</td>
                        <td class="text-end">@p.Quantity</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-primary me-2" @onclick="() => EditProduct(p.Id)">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(p.Id, p.Name)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pager State="_pager" OnPageChanged="OnPageChanged" ContainerClass="d-flex justify-content-end mt-2" />
}

@code {
    // ---------- Paging ----------
    private PaginationState _pager = new() { WindowSize = 5 }; // PageSize set in OnInitializedAsync

    // ---------- Data ----------
    private List<ProductDto> all = new();
    private List<ProductDto> filtered = new();
    private List<ProductDto> paged = new();

    private List<CategoryDto>? categories;
    private List<BrandDto>? brands;

    // ---------- Filters ----------
    private string? queryText;
    private int? selectedCategoryId;
    private int? selectedBrandId;

    // ---------- Sorting ----------
    private string sortColumn = "Name";
    private bool sortAscending = true;

    // ---------- UI ----------
    private CancellationTokenSource? _cts;
    private bool loading = true;

    private string ApiBaseUrl => Options.Value.ApiBaseUrl ?? "";

    private async Task OpenImage(string? src)
    {
        if (string.IsNullOrWhiteSpace(src)) return;
        await JS.InvokeVoidAsync("showImage", src);
    }

    protected override async Task OnInitializedAsync()
    {
        _pager.SetPageSize(10); // หน้าละ 10 รายการ

        var token = TokenProvider.Token;
        if (string.IsNullOrEmpty(token))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Auth token not found in server.");
            loading = false;
            return;
        }

        var client = ClientFactory.CreateClient();
        client.BaseAddress = new Uri(ApiBaseUrl.TrimEnd('/') + "/");
        client.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", token);

        try
        {
            categories = await client.GetFromJsonAsync<List<CategoryDto>>("api/ProductCategory");
            brands = await client.GetFromJsonAsync<List<BrandDto>>("api/ProductBrand");

            // โหลดทั้งหมดรอบแรก
            all = await client.GetFromJsonAsync<List<ProductDto>>("api/Product") ?? new();

            ApplyFilterSortAndPage(resetPage: true);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Failed to load products: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    // ---------- Server-side search (คงโลจิกเดิม) ----------
    private async Task Search()
    {
        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(ApiBaseUrl.TrimEnd('/') + "/");
            client.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", TokenProvider.Token);

            var hasQuery = !string.IsNullOrWhiteSpace(queryText);
            var hasCategory = selectedCategoryId is not null;
            var hasBrand = selectedBrandId is not null;

            List<ProductDto> result;

            if (hasQuery)
            {
                var q = Uri.EscapeDataString(queryText!.Trim());
                var url = $"api/Product/ProductSearch?query={q}";
                if (hasCategory) url += $"&categoryId={selectedCategoryId}";
                result = await client.GetFromJsonAsync<List<ProductDto>>(url) ?? new();
            }
            else if (hasCategory && !hasBrand)
            {
                result = await client.GetFromJsonAsync<List<ProductDto>>(
                    $"api/Product/ByCategory?categoryId={selectedCategoryId}") ?? new();
            }
            else
            {
                result = await client.GetFromJsonAsync<List<ProductDto>>("api/Product") ?? new();
            }

            if (hasBrand)
                result = result.Where(x => x.BrandId == selectedBrandId).ToList();

            all = result;
            ApplyFilterSortAndPage(resetPage: true);
        }
        catch (HttpRequestException ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Search failed: {ex.Message}", "error");
        }
    }

    // ---------- Filtering + Sorting + Paging ----------
    private void ApplyFilterSortAndPage(bool resetPage)
    {
        // ตอนนี้ filter ทั้งหมดทำที่ server แล้ว -> ใช้ all ตรง ๆ
        filtered = all;

        // sort
        var sorted = ApplySort(filtered);

        // page
        _pager.SetTotal(sorted.Count());
        if (resetPage) _pager.GoTo(1);
        else if (_pager.Page > _pager.TotalPages) _pager.GoTo(_pager.TotalPages);

        paged = sorted.Page(_pager);

        StateHasChanged();
    }

    private IEnumerable<ProductDto> ApplySort(IEnumerable<ProductDto> src)
    {
        Func<ProductDto, object?> key = sortColumn switch
        {
            "Name" => p => p.Name,
            "Sku" => p => p.Sku,
            "Category" => p => p.CategoryName,
            "Brand" => p => p.BrandName,
            "Price" => p => p.Price,
            "Quantity" => p => p.Quantity,
            _ => p => p.Name
        };

        return sortAscending ? src.OrderBy(key) : src.OrderByDescending(key);
    }

    private void SortBy(string column)
    {
        if (sortColumn == column) sortAscending = !sortAscending;
        else { sortColumn = column; sortAscending = true; }

        ApplyFilterSortAndPage(resetPage: false);
    }

    private MarkupString SortIcon(string column)
    {
        if (sortColumn != column) return (MarkupString)string.Empty;
        var icon = sortAscending ? "↑" : "↓";
        return (MarkupString)$"<span class='ms-1'>{icon}</span>";
    }

    // ---------- Search inputs ----------
    private void OnQueryChanged(ChangeEventArgs e)
    {
        queryText = e.Value?.ToString();
        DebounceSearch();
    }
    private void OnCategoryChanged(ChangeEventArgs e)
    {
        selectedCategoryId = int.TryParse(e.Value?.ToString(), out var v) ? v : (int?)null;
        _ = Search();
    }
    private void OnBrandChanged(ChangeEventArgs e)
    {
        selectedBrandId = int.TryParse(e.Value?.ToString(), out var v) ? v : (int?)null;
        _ = Search();
    }

    private void DebounceSearch(int delayMs = 350)
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(delayMs, token);
                if (!token.IsCancellationRequested)
                    await InvokeAsync(Search);
            }
            catch (TaskCanceledException) { }
        });
    }

    private async Task ClearSearch()
    {
        queryText = null;
        selectedCategoryId = null;
        selectedBrandId = null;
        await Search();
    }

    private string GetSelectValue(int? val) => val?.ToString() ?? "";

    // ---------- Pager callback ----------
    private Task OnPageChanged(int p)
    {
        _pager.GoTo(p);
        var sorted = ApplySort(filtered);
        paged = sorted.Page(_pager);
        StateHasChanged();
        return Task.CompletedTask;
    }

    // ---------- Actions ----------
    private void EditProduct(int id) => Navigation.NavigateTo($"/ProductEdit/{id}");
    private void AddProduct() => Navigation.NavigateTo("/ProductEdit/0");

    private async Task ConfirmDelete(int id, string? name)
    {
        var safeName = string.IsNullOrWhiteSpace(name) ? "this product" : name;
        var ok = await JS.InvokeAsync<bool>("confirmToast", $"Delete product ID : {id}\n{safeName} ?", "Delete", "Cancel", "error");
        if (!ok)
        {
            await JS.InvokeVoidAsync("showToast", "Cancelled.", "info");
            return;
        }

        var client = ClientFactory.CreateClient();
        client.BaseAddress = new Uri(ApiBaseUrl.TrimEnd('/') + "/");
        client.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", TokenProvider.Token);

        var resp = await client.DeleteAsync($"api/Product/{id}");
        if (resp.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("showToast", "Deleted.", "success");
            all.RemoveAll(x => x.Id == id);
            ApplyFilterSortAndPage(resetPage: false);
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", $"Delete failed: {await resp.Content.ReadAsStringAsync()}", "error");
        }
    }

    // ---------- DTO ----------
    public class ProductDto
    {
        public int Id { get; set; }
        public string? Name { get; set; }
        public string? Sku { get; set; }
        public string? CategoryName { get; set; }
        public string? BrandName { get; set; }
        public int? BrandId { get; set; }
        public string? ImageUrl { get; set; }
        public decimal Price { get; set; }
        public int Quantity { get; set; }
    }
    public class CategoryDto { public int Id { get; set; } public string Name { get; set; } = ""; }
    public class BrandDto { public int Id { get; set; } public string Name { get; set; } = ""; }
}
