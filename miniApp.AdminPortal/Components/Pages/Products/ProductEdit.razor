@page "/product-edit/{Id:int}"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.Extensions.Options
@using miniApp.AdminPortal.Models
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<h3>Edit Product</h3>

@if (product == null || brands == null || categories == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="product" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Name</label>
            <InputText class="form-control" @bind-Value="product.Name" />
        </div>

        <div class="mb-3">
            <label>Brand</label>
            <InputSelect class="form-control" @bind-Value="product.BrandId">
                <option value="">-- Select Brand --</option>
                @foreach (var b in brands)
                {
                    <option value="@b.Id">@b.Name</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label>Category</label>
            <InputSelect class="form-control" @bind-Value="product.CategoryId">
                <option value="">-- Select Category --</option>
                @foreach (var c in categories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label>SKU</label>
            <InputText class="form-control" @bind-Value="product.Sku" />
        </div>

        <div class="mb-3">
            <label>Quantity</label>
            <InputNumber class="form-control" @bind-Value="product.Quantity" />
        </div>

        <div class="mb-3">
            <label>Price</label>
            <InputNumber class="form-control" @bind-Value="product.Price" />
        </div>

        <div class="mb-3">
            <label>Note</label>
            <InputTextArea class="form-control" @bind-Value="product.Note" />
        </div>

        <div class="mb-3">
            <label>Image</label>
            <InputFile OnChange="HandleFileSelected" />
            @if (!string.IsNullOrEmpty(previewUrl))
            {
                <img src="@previewUrl" width="120" class="mt-2 border rounded" />
            }
            else if (!string.IsNullOrEmpty(product.ImageUrl))
            {
                <img src="@($"{ApiBaseUrl}{product.ImageUrl}")" width="120" class="mt-2 border rounded" />
            }
        </div>


        <button class="btn btn-primary" type="submit">Save</button>
        <button class="btn btn-secondary ms-2" @onclick="GoBack">Cancel</button>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }
    private ProductUpdateDto? product;
    private IBrowserFile? uploadedFile;
    private string? previewUrl;
    private List<BrandDto>? brands;
    private List<CategoryDto>? categories;
    private string ApiBaseUrl => Options.Value.ApiBaseUrl;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(ApiBaseUrl);
            client.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", TokenProvider.Token);

            // โหลด Product
            var products = await client.GetFromJsonAsync<List<ProductResponseDto>>("api/Product");
            var prod = products?.FirstOrDefault(p => p.Id == Id);

            if (prod != null)
            {
                product = new ProductUpdateDto
                {
                    Id = prod.Id,
                    Name = prod.Name,
                    Description = prod.Description,
                    Sku = prod.Sku,
                    Quantity = prod.Quantity,
                    Note = prod.Note,
                    LocationId = prod.LocationId,
                    UserId = prod.UserId,
                    Price = prod.Price,
                    BrandId = prod.BrandId,
                    CategoryId = prod.CategoryId,
                    ImageUrl = prod.ImageUrl
                };
            }

            // โหลด Brand & Category
            brands = await client.GetFromJsonAsync<List<BrandDto>>("api/ProductBrand");
            categories = await client.GetFromJsonAsync<List<CategoryDto>>("api/ProductCategory");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Failed to load product: {ex.Message}");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (product == null) return;

        // 1. Update product JSON
        var client = ClientFactory.CreateClient();
        client.BaseAddress = new Uri(ApiBaseUrl);
        client.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", TokenProvider.Token);

        var response = await client.PutAsJsonAsync("api/Product", product);

        if (response.IsSuccessStatusCode)
        {
            // 2. Upload image ถ้าเลือกใหม่
            if (uploadedFile != null)
            {
                using var content = new MultipartFormDataContent();
                var stream = uploadedFile.OpenReadStream(5_000_000);
                content.Add(new StreamContent(stream), "file", uploadedFile.Name);

                var uploadResponse = await client.PostAsync($"api/Product/UploadImage/{product.Id}", content);
                if (!uploadResponse.IsSuccessStatusCode)
                {
                    var err = await uploadResponse.Content.ReadAsStringAsync();
                    await JSRuntime.InvokeVoidAsync("alert", $"Product updated but image upload failed: {err}");
                }
            }

            await JSRuntime.InvokeVoidAsync("alert", "Product updated successfully.");
            Navigation.NavigateTo("/ProductList");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            await JSRuntime.InvokeVoidAsync("alert", $"Failed to update product: {error}");
        }
    }


    private async void HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;

        // แปลงไฟล์เป็น base64 เพื่อแสดง preview
        using var stream = uploadedFile.OpenReadStream(5_000_000);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var bytes = ms.ToArray();
        previewUrl = $"data:{uploadedFile.ContentType};base64,{Convert.ToBase64String(bytes)}";

        StateHasChanged(); // refresh UI
    }

    private void GoBack() => Navigation.NavigateTo("/ProductList");

    public class ProductResponseDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string? Sku { get; set; }
        public int Quantity { get; set; }
        public string? Note { get; set; }
        public string? ImageUrl { get; set; }
        public int UserId { get; set; }
        public int LocationId { get; set; }
        public int? CategoryId { get; set; }
        public decimal Price { get; set; }
        public int? BrandId { get; set; }
    }

    public class ProductUpdateDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string? Sku { get; set; }
        public int Quantity { get; set; }
        public string? Note { get; set; }
        public int UserId { get; set; }
        public int LocationId { get; set; }
        public decimal Price { get; set; }
        public int? BrandId { get; set; }
        public int? CategoryId { get; set; }
        public string? ImageUrl { get; set; }
    }

    public class BrandDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
    }

    public class CategoryDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? ImageUrl { get; set; }
    }
}
