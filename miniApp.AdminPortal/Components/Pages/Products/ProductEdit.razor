@page "/ProductEdit/{Id:int}"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using miniApp.AdminPortal.Components.Pages
@using miniApp.AdminPortal.Models
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<h3>@(IsCreate ? "Add Product" : "Edit Product")</h3>

@if (product is null || brands is null || categories is null || users is null || locations is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="product" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="product.Name" />
            </div>
            <div class="col-md-3">
                <label class="form-label">SKU</label>
                <InputText class="form-control" @bind-Value="product.Sku" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Price</label>
                <InputNumber class="form-control" @bind-Value="product.Price" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Brand</label>
                <InputSelect class="form-select" @bind-Value="product.BrandId">
                    <option value="">-- Select Brand --</option>
                    @foreach (var b in brands)
                    {
                        <option value="@b.Id">@b.Name</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-6">
                <label class="form-label">Category</label>
                <InputSelect class="form-select" @bind-Value="product.CategoryId">
                    <option value="">-- Select Category --</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-4">
                <label class="form-label">Quantity</label>
                <InputNumber class="form-control" @bind-Value="product.Quantity" />
            </div>

            <!-- ✅ Location: dropdown -->
            <div class="col-md-4">
                <label class="form-label">Location</label>
                <InputSelect class="form-select" @bind-Value="product.LocationId">
                    <option value="0">-- Select Location --</option>
                    @foreach (var l in locations)
                    {
                        <option value="@l.Id">@l.Name</option>
                    }
                </InputSelect>
            </div>

            <!-- ✅ User: dropdown -->
            <div class="col-md-4">
                <label class="form-label">User</label>
                <InputSelect class="form-select" @bind-Value="product.UserId">
                    <option value="0">-- Select User --</option>
                    @foreach (var u in users)
                    {
                        <option value="@u.Id">@u.Fullname (@u.Username)</option>
                    }
                </InputSelect>
            </div>

            <div class="col-12">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" @bind-Value="product.Description" />
            </div>
            <div class="col-12">
                <label class="form-label">Note</label>
                <InputTextArea class="form-control" @bind-Value="product.Note" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Image</label>
                <InputFile OnChange="HandleFileSelected" accept="image/*" />
                @if (GetPreviewSrc() is string src)
                {
                    <div class="mt-2">
                        <img src="@src"
                             width="160"
                             class="border rounded"
                             style="cursor:zoom-in; object-fit:cover"
                             @onclick="@(() => OpenImage(src))"
                             onerror="this.style.display='none';" />
                    </div>
                }
            </div>
        </div>

        <div class="mt-3">
            <button class="btn btn-primary" type="submit">Save</button>
            <button class="btn btn-secondary ms-2" type="button" @onclick="GoBack">Cancel</button>
        </div>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }
    private bool IsCreate => Id == 0;

    private ProductEditDto? product;
    private List<BrandDto>? brands;
    private List<CategoryDto>? categories;
    private List<UserItem>? users;
    private List<LocationItem>? locations;

    private IBrowserFile? uploadedFile;
    private string? previewUrl;
    private string ApiBaseUrl => Options.Value.ApiBaseUrl;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(ApiBaseUrl);
            client.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", TokenProvider.Token);

            brands = await client.GetFromJsonAsync<List<BrandDto>>("api/ProductBrand");
            categories = await client.GetFromJsonAsync<List<CategoryDto>>("api/ProductCategory");
            users = await client.GetFromJsonAsync<List<UserItem>>("api/Users/all");
            locations = await client.GetFromJsonAsync<List<LocationItem>>("api/Locations/dropdown");

            if (IsCreate)
            {
                product = new ProductEditDto
                {
                    Id = 0,
                    Name = "",
                    Description = "",
                    Sku = "",
                    Quantity = 0,
                    Note = "",
                    LocationId = 0,
                    UserId = 0,
                    Price = 0,
                    BrandId = null,
                    CategoryId = null,
                    ImageUrl = null
                };
                previewUrl = null;
            }
            else
            {
                var p = await client.GetFromJsonAsync<ProductResponseDto>($"api/Product/{Id}");
                if (p is null)
                {
                    await JS.InvokeVoidAsync("showToast", "Product not found.", "error");
                    Navigation.NavigateTo("/ProductList");
                    return;
                }

                product = new ProductEditDto
                {
                    Id = p.Id,
                    Name = p.Name,
                    Description = p.Description,
                    Sku = p.Sku,
                    Quantity = p.Quantity,
                    Note = p.Note,
                    LocationId = p.LocationId,
                    UserId = p.UserId,
                    Price = p.Price,
                    BrandId = p.BrandId,
                    CategoryId = p.CategoryId,
                    ImageUrl = p.ImageUrl
                };

                previewUrl = BuildProductImageUrl(product.ImageUrl);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Failed to load product: {ex.Message}", "error");
        }
    }

    private string? BuildProductImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl)) return null;

        string full;
        if (imageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            full = imageUrl;
        else if (imageUrl.StartsWith("/"))
            full = $"{ApiBaseUrl.TrimEnd('/')}{imageUrl}";
        else
            full = $"{ApiBaseUrl.TrimEnd('/')}/images/products/{imageUrl}";

        return $"{full}?t={DateTimeOffset.UtcNow.ToUnixTimeSeconds()}";
    }

    private string? GetPreviewSrc()
        => !string.IsNullOrWhiteSpace(previewUrl)
            ? previewUrl
            : BuildProductImageUrl(product?.ImageUrl);

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
        using var stream = uploadedFile.OpenReadStream(5_000_000);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        previewUrl = $"data:{uploadedFile.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        if (product is null) return;

        if (product.UserId == 0 || product.LocationId == 0)
        {
            await JS.InvokeVoidAsync("showToast", "Please select User and Location.", "warning");
            return;
        }

        var client = ClientFactory.CreateClient();
        client.BaseAddress = new Uri(ApiBaseUrl);
        client.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", TokenProvider.Token);

        if (IsCreate)
        {
            var createPayload = new ProductCreateDto
            {
                Name = product.Name,
                Description = product.Description,
                Sku = product.Sku,
                Quantity = product.Quantity,
                Note = product.Note,
                UserId = product.UserId,
                LocationId = product.LocationId,
                Price = product.Price,
                BrandId = product.BrandId,
                CategoryId = product.CategoryId,
                CreatedAt = DateTime.UtcNow
            };

            var createResp = await client.PostAsJsonAsync("api/Product", createPayload);
            if (!createResp.IsSuccessStatusCode)
            {
                var err = await createResp.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("showToast", $"Create failed: {err}", "error");
                return;
            }

            var created = await createResp.Content.ReadFromJsonAsync<IdOnly>();
            var newId = created?.Id ?? 0;

            if (uploadedFile != null && newId > 0)
            {
                using var form = new MultipartFormDataContent();
                using var s = uploadedFile.OpenReadStream(5_000_000);
                var fileContent = new StreamContent(s);
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(uploadedFile.ContentType);
                form.Add(fileContent, "file", uploadedFile.Name);

                var up = await client.PostAsync($"api/Product/UploadImage/{newId}", form);
                if (!up.IsSuccessStatusCode)
                {
                    var err = await up.Content.ReadAsStringAsync();
                    await JS.InvokeVoidAsync("showToast", $"Image upload failed: {err}", "warning");
                }
            }

            await JS.InvokeVoidAsync("showToast", "Product created.", "success");
            Navigation.NavigateTo("/ProductList");
        }
        else
        {
            var updatePayload = new ProductUpdateDto
            {
                Id = product.Id,
                Name = product.Name,
                Description = product.Description,
                Sku = product.Sku,
                Quantity = product.Quantity,
                Note = product.Note,
                UserId = product.UserId,
                LocationId = product.LocationId,
                Price = product.Price,
                BrandId = product.BrandId,
                CategoryId = product.CategoryId,
                ImageUrl = product.ImageUrl
            };

            var resp = await client.PutAsJsonAsync("api/Product", updatePayload);
            if (!resp.IsSuccessStatusCode)
            {
                var err = await resp.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("showToast", $"Update failed: {err}", "error");
                return;
            }

            if (uploadedFile != null)
            {
                using var form = new MultipartFormDataContent();
                using var s = uploadedFile.OpenReadStream(5_000_000);
                var fileContent = new StreamContent(s);
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(uploadedFile.ContentType);
                form.Add(fileContent, "file", uploadedFile.Name);

                var up = await client.PostAsync($"api/Product/UploadImage/{product.Id}", form);
                if (!up.IsSuccessStatusCode)
                {
                    var err = await up.Content.ReadAsStringAsync();
                    await JS.InvokeVoidAsync("showToast", $"Image upload failed: {err}", "warning");
                }
            }

            await JS.InvokeVoidAsync("showToast", "Product updated.", "success");
            Navigation.NavigateTo("/ProductList");
        }
    }

    private void GoBack() => Navigation.NavigateTo("/ProductList");

    private async Task OpenImage(string src) => await JS.InvokeVoidAsync("showImage", src);

    public class ProductResponseDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string? Sku { get; set; }
        public int Quantity { get; set; }
        public string? Note { get; set; }
        public string? ImageUrl { get; set; }
        public int UserId { get; set; }
        public int LocationId { get; set; }
        public int? CategoryId { get; set; }
        public decimal Price { get; set; }
        public int? BrandId { get; set; }
    }

    public class ProductEditDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string? Sku { get; set; }
        public int Quantity { get; set; }
        public string? Note { get; set; }
        public int UserId { get; set; }
        public int LocationId { get; set; }
        public decimal Price { get; set; }
        public int? BrandId { get; set; }
        public int? CategoryId { get; set; }
        public string? ImageUrl { get; set; }
    }

    public class ProductCreateDto
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string? Sku { get; set; }
        public int Quantity { get; set; }
        public string? Note { get; set; }
        public int UserId { get; set; }
        public int LocationId { get; set; }
        public decimal Price { get; set; }
        public int? BrandId { get; set; }
        public int? CategoryId { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    public class ProductUpdateDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string? Sku { get; set; }
        public int Quantity { get; set; }
        public string? Note { get; set; }
        public int UserId { get; set; }
        public int LocationId { get; set; }
        public decimal Price { get; set; }
        public int? BrandId { get; set; }
        public int? CategoryId { get; set; }
        public string? ImageUrl { get; set; }
    }

    public class BrandDto { public int Id { get; set; } public string Name { get; set; } = ""; }
    public class CategoryDto { public int Id { get; set; } public string Name { get; set; } = ""; }

    public class UserItem { public int Id { get; set; } public string Username { get; set; } = ""; public string Fullname { get; set; } = ""; }
    public class LocationItem { public int Id { get; set; } public string Name { get; set; } = ""; }

    public class IdOnly { public int Id { get; set; } }
}
