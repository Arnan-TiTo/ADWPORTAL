@page "/ProductBrandList"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using miniApp.AdminPortal.Components.Pages
@using miniApp.AdminPortal.Models
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject IJSRuntime JS

<h3 class="d-flex align-items-center justify-content-between">
    <span>Product Brands</span>
    <button class="btn btn-sm btn-primary" @onclick="OpenAdd">+ Add</button>
</h3>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label">Search (Name / description)</label>
                <input class="form-control"
                       placeholder="Type to search name / description"
                       @bind="keyword"
                       @bind:event="oninput" />
            </div>
            <div class="col-md-12 mt-2">
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearSearch">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else
{
    var view = GetSorted(Filter(brands));
    if (!view.Any())
    {
        <p>No brands found.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-sm align-middle">
                <thead>
                    <tr>
                        <th style="width:90px;" role="button" @onclick="() => SortBy(nameof(BrandDto.Id))">
                            ID @SortIcon(nameof(BrandDto.Id))
                        </th>
                        <th role="button" @onclick="() => SortBy(nameof(BrandDto.Name))">
                            Name @SortIcon(nameof(BrandDto.Name))
                        </th>
                        <th role="button" @onclick="() => SortBy(nameof(BrandDto.Description))">
                            Description @SortIcon(nameof(BrandDto.Description))
                        </th>
                        <th style="width:140px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in view)
                    {
                        <tr>
                            <td>@b.Id</td>
                            <td>@b.Name</td>
                            <td class="text-truncate" style="max-width:520px">@b.Description</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => OpenEdit(b)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(b)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.3);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@((isEdit ? "Edit" : "Add") + " Brand")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="form.Name" />
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="3" @bind="form.Description"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                        @(saving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private bool showModal = false;
    private bool isEdit = false;
    private bool saving = false;

    private string keyword = "";
    private List<BrandDto> brands = new();

    private BrandForm form = new();
    private string ApiBaseUrl => Options.Value.ApiBaseUrl;

    private string sortBy = nameof(BrandDto.Name);
    private bool sortAsc = true;

    protected override async Task OnInitializedAsync()
    {
        await Load();
        loading = false;
    }

    private async Task<HttpClient> CreateClient()
    {
        var c = ClientFactory.CreateClient();
        c.BaseAddress = new Uri(ApiBaseUrl);
        var token = TokenProvider.Token;
        if (!string.IsNullOrWhiteSpace(token))
            c.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return c;
    }

    private async Task Load()
    {
        try
        {
            var c = await CreateClient();
            brands = await c.GetFromJsonAsync<List<BrandDto>>("api/ProductBrand") ?? new();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load brands failed: {ex.Message}", "error");
            brands = new();
        }
    }

    private void OpenAdd()
    {
        isEdit = false;
        form = new BrandForm();
        showModal = true;
    }

    private void OpenEdit(BrandDto src)
    {
        isEdit = true;
        form = new BrandForm { Id = src.Id, Name = src.Name ?? "", Description = src.Description ?? "" };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.Name))
        {
            await JS.InvokeVoidAsync("showToast", "Please fill brand name.", "warning");
            return;
        }

        try
        {
            saving = true;
            var c = await CreateClient();

            if (!isEdit)
            {
                var payload = new CreateBrand { Name = form.Name, Description = form.Description };
                var resp = await c.PostAsJsonAsync("api/ProductBrand", payload);
                if (resp.IsSuccessStatusCode)
                {
                    var created = await resp.Content.ReadFromJsonAsync<BrandDto>();
                    if (created != null) brands.Insert(0, created);
                    await JS.InvokeVoidAsync("showToast", "Brand created.", "success");
                    showModal = false;
                }
                else
                {
                    await JS.InvokeVoidAsync("showToast", $"Create failed: {await resp.Content.ReadAsStringAsync()}", "error");
                }
            }
            else
            {
                var payload = new UpdateBrand { Id = form.Id, Name = form.Name, Description = form.Description };
                var resp = await c.PutAsJsonAsync("api/ProductBrand", payload);
                if (resp.IsSuccessStatusCode)
                {
                    var updated = await resp.Content.ReadFromJsonAsync<BrandDto>();
                    if (updated != null)
                    {
                        var idx = brands.FindIndex(x => x.Id == updated.Id);
                        if (idx >= 0) brands[idx] = updated;
                    }
                    await JS.InvokeVoidAsync("showToast", "Brand updated.", "success");
                    showModal = false;
                }
                else
                {
                    await JS.InvokeVoidAsync("showToast", $"Update failed: {await resp.Content.ReadAsStringAsync()}", "error");
                }
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Save failed: {ex.Message}", "error");
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ConfirmDelete(BrandDto b)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast", $"Delete brand: {b.Name} (ID: {b.Id}) ?", "Delete", "Cancel", "error");
        if (!ok) return;

        try
        {
            var c = await CreateClient();
            var resp = await c.DeleteAsync($"api/ProductBrand/{b.Id}");
            if (resp.IsSuccessStatusCode || resp.StatusCode == System.Net.HttpStatusCode.NoContent)
            {
                brands.RemoveAll(x => x.Id == b.Id);
                await JS.InvokeVoidAsync("showToast", "Deleted.", "success");
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", $"Delete failed: {await resp.Content.ReadAsStringAsync()}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Delete failed: {ex.Message}", "error");
        }
    }

    private IEnumerable<BrandDto> Filter(IEnumerable<BrandDto> src)
    {
        if (string.IsNullOrWhiteSpace(keyword)) return src;
        var k = keyword.Trim().ToLowerInvariant();
        return src.Where(b =>
            (b.Name ?? "").ToLowerInvariant().Contains(k) ||
            (b.Description ?? "").ToLowerInvariant().Contains(k));
    }

    private void SortBy(string field)
    {
        if (sortBy == field) sortAsc = !sortAsc;
        else { sortBy = field; sortAsc = true; }
    }

    private void ClearSearch()
    {
        keyword = null;
        sortBy = nameof(form.Name);
        sortAsc = true;
    }

    private RenderFragment SortIcon(string field) => builder =>
    {
        if (sortBy != field) return;
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "ms-1");
        builder.AddContent(2, sortAsc ? "▲" : "▼");
        builder.CloseElement();
    };

    private IEnumerable<BrandDto> GetSorted(IEnumerable<BrandDto> src)
    {
        Func<BrandDto, object?> key = sortBy switch
        {
            nameof(BrandDto.Id) => b => b.Id,
            nameof(BrandDto.Name) => b => b.Name,
            nameof(BrandDto.Description) => b => b.Description,
            _ => b => b.Name
        };
        return sortAsc ? src.OrderBy(key) : src.OrderByDescending(key);
    }

    // ===== DTOs =====
    public class BrandDto
    {
        public int Id { get; set; }
        public string? Name { get; set; } = "";
        public string? Description { get; set; } = "";
    }

    public class BrandForm
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; } = "";
    }

    public class CreateBrand
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; } = "";
    }

    public class UpdateBrand
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; } = "";
    }
}
