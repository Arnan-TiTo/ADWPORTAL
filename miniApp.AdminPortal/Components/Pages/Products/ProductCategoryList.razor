@page "/ProductCategoryList"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using miniApp.AdminPortal.Components.Pages
@using miniApp.AdminPortal.Models
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject IJSRuntime JS

<h3 class="d-flex align-items-center justify-content-between">
    <span>Product Categories</span>
    <button class="btn btn-sm btn-primary" @onclick="OpenAdd">+ Add</button>
</h3>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label">Search (Name)</label>
                <input class="form-control"
                       placeholder="Type to search name"
                       @bind="keyword"
                       @bind:event="oninput" />
            </div>
            <div class="col-md-12 mt-2">
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearSearch">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else
{
    var view = GetSorted(Filter(categories));
    if (!view.Any())
    {
        <p>No categories found.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-sm align-middle">
                <thead>
                    <tr>
                        <th style="width:90px;" role="button" @onclick="() => SortBy(nameof(CategoryDto.Id))">
                            ID @SortIcon(nameof(CategoryDto.Id))
                        </th>
                        <th style="width:90px;">Image</th>
                        <th role="button" @onclick="() => SortBy(nameof(CategoryDto.Name))">
                            Name @SortIcon(nameof(CategoryDto.Name))
                        </th>
                        <th>ImageUrl</th>
                        <th style="width:200px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in view)
                    {
                        var img = BuildImageUrl(c.ImageUrl);
                        <tr>
                            <td>@c.Id</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(img))
                                {
                                    <img src="@img"
                                         width="50" height="50"
                                         class="rounded border"
                                         style="cursor:zoom-in; object-fit:cover"
                                         @onclick="() => OpenImage(img!)" />
                                }
                                else
                                {

                                    <span>-</span>
                                }
                            </td>
                            <td>@c.Name</td>
                            <td class="text-truncate" style="max-width:420px">@c.ImageUrl</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => OpenEdit(c)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(c)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.3);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@((isEdit ? "Edit" : "Add") + " Category")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="form-label">Name <span class="text-danger">*</span></label>
                                <input class="form-control" @bind="form.Name" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">ImageUrl (optional)</label>
                                <input class="form-control" @bind="form.ImageUrl" placeholder="/images/categories/xxx.jpg หรือ https://..." />
                                <small class="text-muted">เลือกไฟล์จากเครื่องได้ทางขวา ระบบจะอัปโหลดตอนกด Save แล้วใส่ลิงก์ให้อัตโนมัติ</small>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Choose Image (optional)</label>
                            <InputFile OnChange="OnFileSelected" accept="image/*" />
                            <div class="mt-2 text-center">
                                @{
                                    var preview = !string.IsNullOrWhiteSpace(previewBase64)
                                    ? previewBase64
                                    : BuildImageUrl(form.ImageUrl);
                                }
                                @if (!string.IsNullOrWhiteSpace(preview))
                                {
                                    <img src="@preview" class="border rounded" width="140"
                                         style="cursor:zoom-in; object-fit:cover"
                                         @onclick="() => OpenImage(preview!)" />
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <small class="me-auto text-muted">สูงสุด ~5 MB, jpeg/png/webp</small>
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                        @(saving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private bool showModal = false;
    private bool isEdit = false;
    private bool saving = false;

    private IBrowserFile? newFile;
    private string? previewBase64;

    private string keyword = "";
    private List<CategoryDto> categories = new();

    private CategoryForm form = new();
    private string ApiBaseUrl => Options.Value.ApiBaseUrl;

    private string sortBy = nameof(CategoryDto.Name);
    private bool sortAsc = true;

    protected override async Task OnInitializedAsync()
    {
        await Load();
        loading = false;
    }

    private Task<HttpClient> CreateClient()
    {
        var c = ClientFactory.CreateClient();
        c.BaseAddress = new Uri(ApiBaseUrl);
        var token = TokenProvider.Token;
        if (!string.IsNullOrWhiteSpace(token))
            c.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return Task.FromResult(c);
    }

    private async Task Load()
    {
        try
        {
            var c = await CreateClient();
            categories = await c.GetFromJsonAsync<List<CategoryDto>>("api/ProductCategory") ?? new();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load categories failed: {ex.Message}", "error");
            categories = new();
        }
    }

    private void OpenAdd()
    {
        isEdit = false;
        form = new CategoryForm();
        newFile = null;
        previewBase64 = null;
        showModal = true;
    }

    private void OpenEdit(CategoryDto src)
    {
        isEdit = true;
        form = new CategoryForm { Id = src.Id, Name = src.Name ?? "", ImageUrl = src.ImageUrl ?? "" };
        newFile = null;
        previewBase64 = null;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        newFile = null;
        previewBase64 = null;
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        newFile = e.File;
        previewBase64 = null;
        try
        {
            using var stream = newFile.OpenReadStream(5_000_000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            previewBase64 = $"data:{newFile.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Preview failed: {ex.Message}", "error");
            newFile = null;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.Name))
        {
            await JS.InvokeVoidAsync("showToast", "Please fill category name.", "warning");
            return;
        }

        saving = true;
        try
        {
            var client = await CreateClient();

            string? finalImageUrl = form.ImageUrl;

            if (newFile is not null)
            {
                using var formData = new MultipartFormDataContent();
                using var s = newFile.OpenReadStream(5_000_000);
                var fileContent = new StreamContent(s);
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(newFile.ContentType);
                formData.Add(fileContent, "file", newFile.Name);

                HttpResponseMessage upResp;
                if (isEdit && form.Id > 0)
                    upResp = await client.PostAsync($"api/ProductCategory/UploadImage/{form.Id}", formData);
                else
                    upResp = await client.PostAsync("api/ProductCategory/UploadImage", formData);

                if (!upResp.IsSuccessStatusCode)
                {
                    var err = await upResp.Content.ReadAsStringAsync();
                    await JS.InvokeVoidAsync("showToast", $"Upload failed: {err}", "error");
                    saving = false; return;
                }

                var text = await upResp.Content.ReadAsStringAsync();
                finalImageUrl = TryExtractImageUrl(text) ?? finalImageUrl;
                newFile = null;
                previewBase64 = null;
            }

            if (!isEdit)
            {
                var payload = new CreateCategory { Name = form.Name, ImageUrl = ToStoredPath(finalImageUrl) };
                var resp = await client.PostAsJsonAsync("api/ProductCategory", payload);

                if (resp.IsSuccessStatusCode)
                {
                    var created = await resp.Content.ReadFromJsonAsync<CategoryDto>();
                    if (created != null) categories.Insert(0, created);
                    await JS.InvokeVoidAsync("showToast", "Category created.", "success");
                    showModal = false;
                }
                else
                {
                    await JS.InvokeVoidAsync("showToast", $"Create failed: {await resp.Content.ReadAsStringAsync()}", "error");
                }
            }
            else
            {
                var payload = new UpdateCategory { Id = form.Id, Name = form.Name, ImageUrl = ToStoredPath(finalImageUrl) };
                var resp = await client.PutAsJsonAsync("api/ProductCategory", payload);

                if (resp.IsSuccessStatusCode)
                {
                    var updated = await resp.Content.ReadFromJsonAsync<CategoryDto>();
                    if (updated != null)
                    {
                        var idx = categories.FindIndex(x => x.Id == updated.Id);
                        if (idx >= 0) categories[idx] = updated;
                    }
                    await JS.InvokeVoidAsync("showToast", "Category updated.", "success");
                    showModal = false;
                }
                else
                {
                    await JS.InvokeVoidAsync("showToast", $"Update failed: {await resp.Content.ReadAsStringAsync()}", "error");
                }
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Save failed: {ex.Message}", "error");
        }
        finally
        {
            saving = false;
        }
    }

    private string? TryExtractImageUrl(string jsonText)
    {
        try
        {
            var root = System.Text.Json.JsonDocument.Parse(jsonText).RootElement;

            if (root.TryGetProperty("imageUrl", out var p)) return p.GetString();
            if (root.TryGetProperty("ImageUrl", out var p2)) return p2.GetString();

            if (root.TryGetProperty("id", out _)
                && (root.TryGetProperty("imageUrl", out var p3) || root.TryGetProperty("ImageUrl", out p3)))
                return p3.GetString();

            var dto = System.Text.Json.JsonSerializer.Deserialize<CategoryDto>(jsonText,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            return dto?.ImageUrl;
        }
        catch { return null; }
    }

    private async Task ConfirmDelete(CategoryDto cItem)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast", $"Delete category: {cItem.Name} (ID: {cItem.Id}) ?", "Delete", "Cancel", "error");
        if (!ok) return;

        try
        {
            var c = await CreateClient();
            var resp = await c.DeleteAsync($"api/ProductCategory/{cItem.Id}");
            if (resp.IsSuccessStatusCode || resp.StatusCode == System.Net.HttpStatusCode.NoContent)
            {
                categories.RemoveAll(x => x.Id == cItem.Id);
                await JS.InvokeVoidAsync("showToast", "Deleted.", "success");
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", $"Delete failed: {await resp.Content.ReadAsStringAsync()}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Delete failed: {ex.Message}", "error");
        }
    }

    private async Task OpenImage(string src)
        => await JS.InvokeVoidAsync("showImage", src);

    private IEnumerable<CategoryDto> Filter(IEnumerable<CategoryDto> src)
    {
        if (string.IsNullOrWhiteSpace(keyword)) return src;
        var k = keyword.Trim().ToLowerInvariant();
        return src.Where(c =>
            (c.Name ?? "").ToLowerInvariant().Contains(k));
    }

    private void ClearSearch()
    {
        keyword = "";
        sortBy = nameof(form.Name);
        sortAsc = true;
    }

    private void SortBy(string field)
    {
        if (sortBy == field) sortAsc = !sortAsc;
        else { sortBy = field; sortAsc = true; }
    }

    private RenderFragment SortIcon(string field) => builder =>
    {
        if (sortBy != field) return;
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "ms-1");
        builder.AddContent(2, sortAsc ? "▲" : "▼");
        builder.CloseElement();
    };

    private IEnumerable<CategoryDto> GetSorted(IEnumerable<CategoryDto> src)
    {
        Func<CategoryDto, object?> key = sortBy switch
        {
            nameof(CategoryDto.Id) => c => c.Id,
            nameof(CategoryDto.Name) => c => c.Name,
            _ => c => c.Name
        };
        return sortAsc ? src.OrderBy(key) : src.OrderByDescending(key);
    }

    private string? BuildImageUrl(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return null;
        if (raw.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return raw;
        if (!raw.StartsWith("/")) raw = "/images/categories/" + raw.Trim();
        return $"{ApiBaseUrl.TrimEnd('/')}{raw}";
    }

    private string? ToStoredPath(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return null;
        if (raw.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return raw;
        if (!raw.StartsWith("/")) return "/images/categories/" + raw.Trim();
        return raw;
    }

    public class CategoryDto
    {
        public int Id { get; set; }
        public string? Name { get; set; } = "";
        public string? ImageUrl { get; set; } = "";
    }

    public class CategoryForm
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? ImageUrl { get; set; } = "";
    }

    public class CreateCategory
    {
        public string Name { get; set; } = "";
        public string? ImageUrl { get; set; } = "";
    }

    public class UpdateCategory
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? ImageUrl { get; set; } = "";
    }
}
