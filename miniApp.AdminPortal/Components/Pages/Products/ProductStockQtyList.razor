    private void OpenTransfer(StockRow r)
    {
        selectedRow = r;
        transferToLocationId = null;
        transferQty = 1;
        transferNote = null;
        showTransfer = true;
    }
    private void CloseTransfer() => showTransfer = false;

    private async Task ConfirmTransfer()
    {
        if (selectedRow is null) return;
        if (transferToLocationId is null || transferToLocationId <= 0)
        {
            await JS.InvokeVoidAsync("showToast", "Please select destination location.", "warning");
            return;
        }
        if (transferQty <= 0) { await JS.InvokeVoidAsync("showToast", "Quantity must be > 0", "warning"); return; }
        if (transferQty > selectedRow.QtyAvailable)
        {
            await JS.InvokeVoidAsync("showToast", $"Max {selectedRow.QtyAvailable}.", "warning");
            return;
        }

        try
        {
            saving = true;
            var http = await CreateClient();
            var payload = new
            {
                FromLocationId = selectedLocationId,
                ToLocationId = transferToLocationId.Value,
                ProductId = selectedRow.ProductId,
                QtyOnHand = transferQty,
                PerformedByUserId = _userId,
                ReasonCode = "TRANSFER",
                referenceType = "TRANSFER",
                ReferenceId = "",
                Note = transferNote ?? ""
            };
            var resp = await http.PostAsJsonAsync("api/ProductStock/transfer", payload);
            if (resp.IsSuccessStatusCode)
            {
                selectedRow.QtyOnHand -= transferQty;
                selectedRow.QtyAvailable -= transferQty;

                await JS.InvokeVoidAsync("showToast", "Transferred.", "success");
                showTransfer = false;
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", $"Transfer failed: {await resp.Content.ReadAsStringAsync()}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Transfer failed: {ex.Message}", "error");
        }
        finally { saving = false; }
    }

