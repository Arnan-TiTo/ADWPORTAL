    // ===== utils =====
    private string BuildImageUrl(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        if (raw.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return raw;
        if (!raw.StartsWith("/")) raw = "/images/products/" + raw.Trim();
        return $"{ApiBase.TrimEnd('/')}{raw}";
    }

    private async Task OpenImage(string src) => await JS.InvokeVoidAsync("showImage", src);

    private string CurrentLocationName()
        => locations.FirstOrDefault(x => x.Id == selectedLocationId)?.Name ?? $"#{selectedLocationId}";

