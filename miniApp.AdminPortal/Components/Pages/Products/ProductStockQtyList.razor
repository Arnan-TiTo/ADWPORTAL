@page "/ProductStockQtyList"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Options
@using miniApp.AdminPortal.Components.Pages
@using miniApp.AdminPortal.Models
@using miniApp.AdminPortal.Shared
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider Auth

<h3 class="d-flex align-items-center justify-content-between">
    <span>Product Stock (by Location)</span>
</h3>

<!-- Filter bar -->
<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Location</label>
                <select class="form-select" @onchange="OnLocationChanged">
                    @if (locations is null || locations.Count == 0)
                    {
                        <option value="">(no location)</option>
                    }
                    else
                    {
                        @foreach (var l in locations)
                        {
                            <option value="@l.Id" selected="@(l.Id == selectedLocationId)">@l.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label">Search (Name / SKU)</label>
                <input class="form-control"
                       placeholder="Type to search…"
                       value="@queryText"
                       @oninput="OnSearchChanged" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-dark w-50" @onclick="@(() => ApplyFilter())">Search</button>
                <button class="btn btn-outline-secondary w-50" @onclick="@(() => ClearFilter())">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (view is null || view.Count == 0)
{
    <p>No data.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
            <thead>
                <tr>
                    <th style="width:64px;">Image</th>

                    <th style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.Name))">
                        Product @SortIcon(nameof(StockRow.Name))
                    </th>

                    <th style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.Sku))">
                        SKU @SortIcon(nameof(StockRow.Sku))
                    </th>

                    <th>Category</th>
                    <th>Brand</th>

                    <th class="text-end" style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.Price))">
                        Price @SortIcon(nameof(StockRow.Price))
                    </th>

                    <th class="text-end" style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.QtyOnHand))">
                        OnHand @SortIcon(nameof(StockRow.QtyOnHand))
                    </th>
                    <th class="text-end" style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.QtyReserved))">
                        Reserved @SortIcon(nameof(StockRow.QtyReserved))
                    </th>
                    <th class="text-end" style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.QtyDamaged))">
                        Damaged @SortIcon(nameof(StockRow.QtyDamaged))
                    </th>
                    <th class="text-end" style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.QtyAvailable))">
                        Available @SortIcon(nameof(StockRow.QtyAvailable))
                    </th>

                    <th class="text-end" style="width:520px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in paged)
                {
                    var img = BuildImageUrl(r.ImageUrl);
                    <tr>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(img))
                            {
                                <img src="@img" width="48" height="48" class="rounded border object-fit-cover"
                                     style="cursor:zoom-in" @onclick="() => OpenImage(img)" />
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>@r.Name</td>
                        <td>@r.Sku</td>
                        <td>@r.CategoryName</td>
                        <td>@r.BrandName</td>
                        <td class="text-end">@r.Price.ToString("N2")</td>
                        <td class="text-end">@r.QtyOnHand</td>
                        <td class="text-end">@r.QtyReserved</td>
                        <td class="text-end">@r.QtyDamaged</td>
                        <td class="text-end fw-bold">@r.QtyAvailable</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">

                                <button class="btn btn-outline-success" title="รับเข้า (+)" @onclick="() => OpenAdjust(r, +1)">+ In</button>
                                <button class="btn btn-outline-dark" title="โอนย้าย" @onclick="() => OpenTransfer(r)">Transfer</button>

                                @if (locationIsWarehouse)
                                {
                                    <button class="btn btn-outline-danger" title="รับคืนของเสียเข้าคลังใหญ่ (ทยอยรับได้)"
                                            @onclick="() => OpenReceiveDamage(r)">
                                        Receive Damage
                                    </button>

                                    <button class="btn btn-outline-warning" title="โอนของเสียไป Damagehouse"
                                            @onclick="() => OpenTransferDamage(r)">
                                        Transfer Damage
                                    </button>
                                }

                                <button class="btn btn-outline-info" title="ประวัติ" @onclick="() => OpenHistory(r)">History</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_pager.TotalPages > 1)
    {
        <nav class="d-flex justify-content-end">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @( _pager.Page == 1 ? "disabled" : "" )">
                    <button class="page-link" @onclick="() => GoTo(1)">&laquo;</button>
                </li>
                <li class="page-item @( _pager.Page == 1 ? "disabled" : "" )">
                    <button class="page-link" @onclick="() => GoTo(_pager.Page - 1)">&lsaquo;</button>
                </li>

                @foreach (var p in PageWindow())
                {
                    <li class="page-item @(p == _pager.Page ? "active" : "")">
                        <button class="page-link" @onclick="() => GoTo(p)">@p</button>
                    </li>
                }

                <li class="page-item @( _pager.Page == _pager.TotalPages ? "disabled" : "" )">
                    <button class="page-link" @onclick="() => GoTo(_pager.Page + 1)">&rsaquo;</button>
                </li>
                <li class="page-item @( _pager.Page == _pager.TotalPages ? "disabled" : "" )">
                    <button class="page-link" @onclick="() => GoTo(_pager.TotalPages)">&raquo;</button>
                </li>
            </ul>
        </nav>
    }
}

@* ========== Modal: Adjust In (Storehouse only) ========== *@
@if (showAdjust)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.3);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        รับเข้า (+) — @selectedRow?.Name (@selectedRow?.Sku)
                    </h5>
                    <button type="button" class="btn-close" @onclick="@(() => CloseAdjust())"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Quantity</label>
                        <input type="number" class="form-control" min="1" step="1"
                               @bind="adjustQty" @bind:event="oninput" />
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Note (optional)</label>
                        <textarea class="form-control" rows="2" @bind="adjustNote"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="@(() => CloseAdjust())">Cancel</button>
                    <button class="btn btn-primary" @onclick="ConfirmAdjust" disabled="@saving">
                        @(saving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ========== Modal: Transfer (ทั่วไป) ========== *@
@if (showTransfer)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.3);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Transfer — @selectedRow?.Name (@selectedRow?.Sku)</h5>
                    <button type="button" class="btn-close" @onclick="@(() => CloseTransfer())"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">From</label>
                        <input class="form-control" value="@CurrentLocationName()" disabled />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">To Location</label>
                        <select class="form-select" @bind="transferToLocationId">
                            <option value="">-- Select --</option>
                            @foreach (var l in locations.Where(x => x.Id != selectedLocationId))
                            {
                                <option value="@l.Id">@l.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Quantity</label>
                        <input type="number" class="form-control" min="1" step="1"
                               @bind="transferQty" @bind:event="oninput" />
                        <small class="text-muted">Max: @selectedRow?.QtyAvailable</small>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Note (optional)</label>
                        <textarea class="form-control" rows="2" @bind="transferNote"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="@(() => CloseTransfer())">Cancel</button>
                    <button class="btn btn-primary" @onclick="ConfirmTransfer" disabled="@saving">
                        @(saving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ========== Modal: Receive Damage (Warehouse only, ทยอยรับได้) ========== *@
@if (showReceiveDamage)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.3);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Receive Damage — @selectedRow?.Name (@selectedRow?.Sku)</h5>
                    <button type="button" class="btn-close" @onclick="@(() => showReceiveDamage = false)"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <div class="d-flex justify-content-between">
                            <label class="form-label mb-0">Damage Return Document (Status ≠ CONFIRMED)</label>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ReloadPendingDamageDocs" disabled="@pendingDamageLoading">
                                @(pendingDamageLoading ? "Loading..." : "Reload")
                            </button>
                        </div>
                        <select class="form-select mt-1" @bind="SelectedPendingDamageId">
                            <option value="">-- เลือกเอกสาร --</option>
                            @foreach (var o in pendingDamageOptions)
                            {
                                <option value="@o.Id">@o.Label</option>
                            }
                        </select>
                        <small class="text-muted">จะแสดงเอกสารที่ยังไม่ Confirm เท่านั้น</small>
                    </div>

                    @if (receiveDamageDoc != null)
                    {
                        var outstanding = Math.Max(0, receiveDamageDoc.Qty - receiveDamageDoc.QtyReceive);
                        <div class="border rounded p-2 mb-2">
                            <div><strong>DocNo:</strong> @receiveDamageDoc.DocNo</div>
                            <div><strong>Create date:</strong> @receiveDamageDoc.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                            <div><strong>Create by:</strong> @(receiveDamageDoc.CreatedByUserId?.ToString() ?? "-")</div>
                            <div><strong>Return Damage From:</strong> @FromLocationName(receiveDamageDoc.FromLocationId)</div>
                            <div><strong>Product:</strong> @receiveDamageDoc.ProductName (@receiveDamageDoc.Sku)</div>
                            <div><strong>Qty (ในเอกสาร):</strong> @receiveDamageDoc.Qty</div>
                            <div><strong>QtyReceive (รวมแล้ว):</strong> @receiveDamageDoc.QtyReceive</div>
                            <div><strong>ค้างรับ:</strong> @outstanding</div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label">จำนวนที่รับจริง (ครั้งนี้)</label>
                            <input type="number" class="form-control" min="1" step="1"
                                   @bind="receiveQtyThisTime" @bind:event="oninput" />
                            <small class="text-muted">
                                ต้องไม่เกินค้างรับ @(receiveDamageDoc is null ? 0 : (receiveDamageDoc.Qty - receiveDamageDoc.QtyReceive))
                            </small>
                        </div>
                    }

                    <div class="mb-0">
                        <label class="form-label">Note (optional)</label>
                        <textarea class="form-control" rows="2" @bind="receiveDamageNote"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="@(() => showReceiveDamage = false)">Cancel</button>
                    <button type="button"
                            class="btn btn-primary"
                            @onclick="ConfirmReceiveDamage"
                            disabled="@(saving || !CanConfirmReceive)">
                        @(saving ? "Saving..." : "Confirm")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ========== Modal: Transfer Damage (Warehouse -> Damagehouse) ========== *@
@if (showTransferDamage)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.3);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Transfer Damage — @selectedRow?.Name (@selectedRow?.Sku)</h5>
                    <button type="button" class="btn-close" @onclick="@(() => showTransferDamage = false)"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">From (Warehouse)</label>
                        <input class="form-control" value="@CurrentLocationName()" disabled />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">To Damagehouse</label>
                        <select class="form-select" @bind="transferDamageToId">
                            <option value="">-- Select --</option>
                            @foreach (var l in locations.Where(x => x.Id != selectedLocationId))
                            {
                                <option value="@l.Id">@l.Name</option>
                            }
                        </select>
                        <small class="text-muted">ปลายทางต้องเป็นคลัง Damagehouse (ระบบจะตรวจสอบที่ API)</small>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Quantity</label>
                        <input type="number" class="form-control" min="1" step="1"
                               @bind="transferDamageQty" @bind:event="oninput" />
                        <small class="text-muted">Max (Damaged ที่คลังนี้): @selectedRow?.QtyDamaged</small>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Note (optional)</label>
                        <textarea class="form-control" rows="2" @bind="transferDamageNote"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="@(() => showTransferDamage = false)">Cancel</button>
                    <button class="btn btn-primary" @onclick="ConfirmTransferDamage" disabled="@saving">
                        @(saving ? "Saving..." : "Transfer")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ========== Modal: History ========== *@
@if (showHistory)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.3);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        History — @selectedRow?.Name (@selectedRow?.Sku)
                    </h5>
                    <button type="button" class="btn-close" @onclick="@(() => CloseHistory())"></button>
                </div>
                <div class="modal-body">
                    @if (auditLoading)
                    {
                        <p><em>Loading...</em></p>
                    }
                    else if (audit is null || audit.Count == 0)
                    {
                        <p>No history.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th style="width:160px;">When</th>
                                        <th style="width:140px;">Action</th>
                                        <th class="text-end" style="width:90px;">Qty</th>
                                        <th>Note</th>
                                        <th style="width:160px;">By</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var a in audit)
                                    {
                                        <tr>
                                            <td>@a.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>@a.Action</td>
                                            <td class="text-end">@a.Qty</td>
                                            <td class="text-truncate" style="max-width:420px">@a.Note</td>
                                            <td>@a.ByUser</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="@(() => CloseHistory())">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ===== state =====
    private bool loading = true;
    private List<LocationOption> locations = new();
    private int selectedLocationId;

    private List<StockRow> all = new();
    private List<StockRow> filtered = new();
    private List<StockRow> view = new();
    private List<StockRow> paged = new();

    private string? queryText;
    private string sortBy = nameof(StockRow.Name);
    private bool sortAsc = true;

    private PaginationState _pager = new();

    // location flags
    private bool locationIsWarehouse = false;
    private bool locationIsStorehouse = false;
    private bool locationIsDamagehouse = false;

    // auth
    private int _userId = 0;

    // modals
    private StockRow? selectedRow;
    private bool saving;

    // Adjust In
    private bool showAdjust;
    private int adjustQty = 1;
    private string? adjustNote;

    // Transfer
    private bool showTransfer;
    private int? transferToLocationId;
    private int transferQty = 1;
    private string? transferNote;

    // Receive Damage (dropdown)
    private bool showReceiveDamage;
    private bool pendingDamageLoading;
    private List<DamageReturnOption> pendingDamageOptions = new();
    private int? selectedPendingDamageId;
    private DamageReturnDocView? receiveDamageDoc;
    private string? receiveDamageNote;

    // Transfer Damage (Warehouse -> Damagehouse)
    private bool showTransferDamage;
    private int? transferDamageToId;
    private int transferDamageQty = 1;
    private string? transferDamageNote;

    // History
    private bool showHistory;
    private bool auditLoading;
    private List<AuditEntry>? audit;

    // ===== Receive Damage helper =====
    private bool CanConfirmReceive =>
        receiveDamageDoc != null
        && receiveQtyThisTime > 0
        && (receiveDamageDoc.QtyReceive + receiveQtyThisTime) <= receiveDamageDoc.Qty;

    private int _receiveQtyThisTime = 1;
    private int receiveQtyThisTime
    {
        get => _receiveQtyThisTime;
        set
        {
            var max = receiveDamageDoc is null ? int.MaxValue
                                               : Math.Max(0, receiveDamageDoc.Qty - receiveDamageDoc.QtyReceive);
            _receiveQtyThisTime = Math.Clamp(value, 0, max);
        }
    }

    private string ApiBase => Options.Value.ApiBaseUrl;

    protected override async Task OnInitializedAsync()
    {
        _pager.SetPageSize(20);
        _pager.WindowSize = 5;

        // อ่าน USERID จาก Claims และเก็บไว้ใช้เรียก API
        try
        {
            var auth = await Auth.GetAuthenticationStateAsync();
            var claim = auth.User?.FindFirst("USERID")?.Value;
            int.TryParse(claim, out _userId);
        }
        catch { _userId = 0; }

        await LoadLocationsForUser(_userId);
        await LoadStocks();
        loading = false;
    }

    private async Task<HttpClient> CreateClient()
    {
        var c = ClientFactory.CreateClient();
        c.BaseAddress = new Uri(ApiBase);
        var token = TokenProvider.Token;
        if (!string.IsNullOrWhiteSpace(token))
            c.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return c;
    }

    private async Task LoadLocationsForUser(int userId)
    {
        try
        {
            var http = await CreateClient();

            // สิทธิ์ location ของ user
            var allows = await http.GetFromJsonAsync<List<UserLocationDto>>($"api/userlocations/user/{userId}") ?? new();
            var allowIds = allows.Select(x => x.LocationId).ToHashSet();

            // ชื่อ Location (dropdown)
            var drops = await http.GetFromJsonAsync<List<LocationOption>>("api/locations/dropdown") ?? new();

            locations = drops.Where(d => allowIds.Count == 0 || allowIds.Contains(d.Id))
                             .OrderBy(d => d.Name)
                             .ToList();

            if (locations.Count > 0)
                selectedLocationId = locations.First().Id;
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load locations failed: {ex.Message}", "error");
            locations = new();
            selectedLocationId = 0;
        }
    }

    private async Task LoadStocks()
    {
        if (selectedLocationId <= 0) { all = new(); filtered = new(); view = new(); paged = new(); return; }

        try
        {
            var http = await CreateClient();
            var url = $"api/ProductStock/location/{selectedLocationId}?userId={_userId}";
            all = await http.GetFromJsonAsync<List<StockRow>>(url) ?? new();

            // set flags by first row
            if (all.Count > 0)
            {
                locationIsWarehouse = all[0].isWarehouse == 1;
                locationIsStorehouse = all[0].isStorehouse == 1;
                locationIsDamagehouse = all[0].isDamagehouse == 1;
            }
            else
            {
                locationIsWarehouse = locationIsStorehouse = locationIsDamagehouse = false;
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load stock failed: {ex.Message}", "error");
            all = new();
        }

        ApplyFilter();
    }

    // ===== filter/sort/paging =====
    private void ApplyFilter()
    {
        IEnumerable<StockRow> q = all;

        if (!string.IsNullOrWhiteSpace(queryText))
        {
            var k = queryText.Trim();
            q = q.Where(x =>
                (x.Name ?? "").Contains(k, StringComparison.OrdinalIgnoreCase) ||
                (x.Sku ?? "").Contains(k, StringComparison.OrdinalIgnoreCase));
        }

        // sort
        Func<StockRow, object?> key = sortBy switch
        {
            nameof(StockRow.Sku) => x => x.Sku,
            nameof(StockRow.Price) => x => x.Price,
            nameof(StockRow.QtyOnHand) => x => x.QtyOnHand,
            nameof(StockRow.QtyReserved) => x => x.QtyReserved,
            nameof(StockRow.QtyDamaged) => x => x.QtyDamaged,
            nameof(StockRow.QtyAvailable) => x => x.QtyAvailable,
            _ => x => x.Name
        };
        q = sortAsc ? q.OrderBy(key) : q.OrderByDescending(key);

        filtered = q.ToList();
        view = filtered;
        _pager.SetTotal(view.Count);
        if (_pager.Page <= 0 || _pager.Page > _pager.TotalPages) _pager.GoTo(1);

        paged = view.Page(_pager);
    }

    private void SortBy(string field)
    {
        if (sortBy == field) sortAsc = !sortAsc;
        else { sortBy = field; sortAsc = true; }
        ApplyFilter();
    }

    private RenderFragment SortIcon(string field) => builder =>
    {
        if (sortBy != field) return;
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "ms-1");
        builder.AddContent(2, sortAsc ? "▲" : "▼");
        builder.CloseElement();
    };

    private void ApplyFilter(object? _ = null) => ApplyFilter();

    private void ClearFilter()
    {
        queryText = null;
        sortBy = nameof(StockRow.Name);
        sortAsc = true;
        ApplyFilter();
    }

    private async Task OnLocationChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            selectedLocationId = v;
        await LoadStocks();
    }

    private IEnumerable<int> PageWindow()
    {
        if (_pager.TotalPages <= 0) yield break;

        var half = Math.Max(1, _pager.WindowSize / 2);
        var start = Math.Max(1, _pager.Page - half);
        var end = Math.Min(_pager.TotalPages, start + _pager.WindowSize - 1);
        start = Math.Max(1, end - _pager.WindowSize + 1);

        for (int p = start; p <= end; p++) yield return p;
    }

    private void GoTo(int p)
    {
        if (p < 1) p = 1;
        if (p > _pager.TotalPages) p = _pager.TotalPages;
        _pager.GoTo(p);
        paged = view.Page(_pager);
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        queryText = e.Value?.ToString();
        ApplyFilter();
    }

    // ===== actions =====
    private void OpenAdjust(StockRow r, int sign)
    {
        selectedRow = r;
        adjustQty = 1;
        adjustNote = null;
        showAdjust = true;
    }
    private void CloseAdjust() => showAdjust = false;

    private async Task ConfirmAdjust()
    {
        if (saving) return;
        if (selectedRow is null) return;
        if (adjustQty <= 0)
        {
            await JS.InvokeVoidAsync("showToast", "Quantity must be > 0", "warning"); return;
        }

        try
        {
            saving = true;
            var http = await CreateClient();

            var payload = new
            {
                ProductId = selectedRow.ProductId,
                LocationId = selectedLocationId,
                QtyOnHand = Math.Abs(adjustQty),
                ReasonCode = "ADJUST_IN",
                ReferenceType = "MANUAL",
                ReferenceId = "",
                PerformedByUserId = _userId,
                Note = adjustNote?.Trim() ?? ""
            };

            var resp = await http.PostAsJsonAsync("api/ProductStock/adjust", payload);
            if (resp.IsSuccessStatusCode)
            {
                selectedRow.QtyOnHand += adjustQty;
                selectedRow.QtyAvailable += adjustQty;
                await JS.InvokeVoidAsync("showToast", "Saved.", "success");
                showAdjust = false;
            }
            else
            {
                var msg = await resp.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("showToast", $"Adjust failed: {msg}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Adjust failed: {ex.Message}", "error");
        }
        finally { saving = false; }
    }

