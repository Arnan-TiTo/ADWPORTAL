    private void OpenReserve(StockRow r) { selectedRow = r; reserveQty = 1; reserveNote = null; showReserve = true; }
    private void CloseReserve() => showReserve = false;

    private async Task ConfirmReserve()
    {
        if (selectedRow is null) return;
        if (reserveQty <= 0) { await JS.InvokeVoidAsync("showToast", "Quantity must be > 0", "warning"); return; }
        if (reserveQty > selectedRow.QtyAvailable)
        {
            await JS.InvokeVoidAsync("showToast", $"Max {selectedRow.QtyAvailable}.", "warning");
            return;
        }

        try
        {
            saving = true;
            var http = await CreateClient();
            var payload = new
            {
                LocationId = selectedLocationId,
                ProductId = selectedRow.ProductId,
                QtyOnHand = reserveQty,
                ReasonCode = "RESERVE",
                ReferenceType = "RESERVE",
                ReferenceId = (string)"",
                PerformedByUserId = _userId,
                Note = reserveNote ?? ""
            };
            var resp = await http.PostAsJsonAsync("api/ProductStock/reserve", payload);
            if (resp.IsSuccessStatusCode)
            {
                selectedRow.QtyReserved += reserveQty;
                selectedRow.QtyAvailable -= reserveQty;
                await JS.InvokeVoidAsync("showToast", "Reserved.", "success");
                showReserve = false;
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", $"Reserve failed: {await resp.Content.ReadAsStringAsync()}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Reserve failed: {ex.Message}", "error");
        }
        finally { saving = false; }
    }

