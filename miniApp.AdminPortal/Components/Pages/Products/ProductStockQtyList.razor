@page "/ProductStockQtyList"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Options
@using miniApp.AdminPortal.Components.Pages
@using miniApp.AdminPortal.Models
@using miniApp.AdminPortal.Shared
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider Auth

<h3 class="d-flex align-items-center justify-content-between">
    <span>Product Stock (by Location)</span>
</h3>

<!-- Filter bar -->
<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Location</label>
                <select class="form-select" @onchange="OnLocationChanged">
                    @if (locations is null || locations.Count == 0)
                    {
                        <option value="">(no location)</option>
                    }
                    else
                    {
                        @foreach (var l in locations)
                        {
                            <option value="@l.Id" selected="@(l.Id == selectedLocationId)">@l.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label">Search (Name / SKU)</label>
                <input class="form-control"
                       placeholder="Type to search…"
                       value="@queryText"
                       @oninput="OnSearchChanged" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-dark w-50" @onclick="@(() => ApplyFilter())">Search</button>
                <button class="btn btn-outline-secondary w-50" @onclick="@(() => ClearFilter())">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (view is null || view.Count == 0)
{
    <p>No data.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
            <thead>
                <tr>
                    <th style="width:64px;">Image</th>

                    <th style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.Name))">
                        Product @SortIcon(nameof(StockRow.Name))
                    </th>

                    <th style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.Sku))">
                        SKU @SortIcon(nameof(StockRow.Sku))
                    </th>

                    <th>Category</th>
                    <th>Brand</th>

                    <th class="text-end" style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.Price))">
                        Price @SortIcon(nameof(StockRow.Price))
                    </th>

                    <th class="text-end" style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.QtyOnHand))">
                        OnHand @SortIcon(nameof(StockRow.QtyOnHand))
                    </th>
                    <th class="text-end" style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.QtyReserved))">
                        Reserved @SortIcon(nameof(StockRow.QtyReserved))
                    </th>
                    <th class="text-end" style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.QtyDamaged))">
                        Damaged @SortIcon(nameof(StockRow.QtyDamaged))
                    </th>
                    <th class="text-end" style="cursor:pointer" @onclick="() => SortBy(nameof(StockRow.QtyAvailable))">
                        Available @SortIcon(nameof(StockRow.QtyAvailable))
                    </th>

                    <th class="text-end" style="width:380px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in paged)
                {
                    var img = BuildImageUrl(r.ImageUrl);
                    <tr>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(img))
                            {
                                <img src="@img" width="48" height="48" class="rounded border object-fit-cover"
                                     style="cursor:zoom-in" @onclick="() => OpenImage(img)" />
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>@r.Name</td>
                        <td>@r.Sku</td>
                        <td>@r.CategoryName</td>
                        <td>@r.BrandName</td>
                        <td class="text-end">@r.Price.ToString("N2")</td>
                        <td class="text-end">@r.QtyOnHand</td>
                        <td class="text-end">@r.QtyReserved</td>
                        <td class="text-end">@r.QtyDamaged</td>
                        <td class="text-end fw-bold">@r.QtyAvailable</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-success" title="รับเข้า (+)" @onclick="() => OpenAdjust(r, +1)">+ In</button>
                                <button class="btn btn-outline-warning" title="ตัดออก (−)" @onclick="() => OpenAdjust(r, -1)">− Out</button>
                                <button class="btn btn-outline-primary" title="จองสินค้า" @onclick="() => OpenReserve(r)">Reserve</button>
                                <button class="btn btn-outline-secondary" title="คืนจอง" @onclick="() => OpenRelease(r)">Release</button>
                                <button class="btn btn-outline-danger" title="ชำรุด" @onclick="() => OpenDamage(r)">Damage</button>
                                <button class="btn btn-outline-dark" title="โอนย้าย" @onclick="() => OpenTransfer(r)">Move</button>
                                <button class="btn btn-outline-info" title="ประวัติ" @onclick="() => OpenHistory(r)">History</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_pager.TotalPages > 1)
    {
        <nav class="d-flex justify-content-end">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @( _pager.Page == 1 ? "disabled" : "" )">
                    <button class="page-link" @onclick="() => GoTo(1)">&laquo;</button>
                </li>
                <li class="page-item @( _pager.Page == 1 ? "disabled" : "" )">
                    <button class="page-link" @onclick="() => GoTo(_pager.Page - 1)">&lsaquo;</button>
                </li>

                @foreach (var p in PageWindow())
                {
                    <li class="page-item @(p == _pager.Page ? "active" : "")">
                        <button class="page-link" @onclick="() => GoTo(p)">@p</button>
                    </li>
                }

                <li class="page-item @( _pager.Page == _pager.TotalPages ? "disabled" : "" )">
                    <button class="page-link" @onclick="() => GoTo(_pager.Page + 1)">&rsaquo;</button>
                </li>
                <li class="page-item @( _pager.Page == _pager.TotalPages ? "disabled" : "" )">
                    <button class="page-link" @onclick="() => GoTo(_pager.TotalPages)">&raquo;</button>
                </li>
            </ul>
        </nav>
    }
}

@if (showAdjust)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.3);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(adjustSign > 0 ? "รับเข้า (+)" : "ตัดออก (−)") — @selectedRow?.Name (@selectedRow?.Sku)
                    </h5>
                    <button type="button" class="btn-close" @onclick="@(() => CloseAdjust())"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Quantity</label>
                        <input type="number" class="form-control" min="1" step="1"
                               @bind="adjustQty" @bind:event="oninput" />
                        @if (adjustSign < 0)
                        {
                            <small class="text-muted">
                                Max: @selectedRow?.QtyAvailable (จะไม่ให้ติดลบ)
                            </small>
                        }
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Note (optional)</label>
                        <textarea class="form-control" rows="2" @bind="adjustNote"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="@(() => CloseAdjust())">Cancel</button>
                    <button class="btn btn-primary" @onclick="ConfirmAdjust" disabled="@saving">
                        @(saving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

