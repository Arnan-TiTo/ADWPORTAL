    // ===== Receive Damage =====
    private async Task OpenReceiveDamage(StockRow r)
    {
        if (!locationIsWarehouse)
        {
            await JS.InvokeVoidAsync("showToast", "Receive Damage ใช้ได้เฉพาะที่ Warehouse", "warning");
            return;
        }
        selectedRow = r;
        receiveDamageDoc = null;
        selectedPendingDamageId = null;
        receiveDamageNote = null;
        receiveQtyThisTime = 1;
        showReceiveDamage = true;

        await ReloadPendingDamageDocs();
    }

    private async Task ReloadPendingDamageDocs()
    {
        if (selectedRow is null) return;

        pendingDamageLoading = true;
        pendingDamageOptions = new();
        try
        {
            var http = await CreateClient();

            // ค้นทุก location ที่ไม่ใช่คลังนี้
            foreach (var l in locations.Where(x => x.Id != selectedLocationId))
            {
                var list = await http.GetFromJsonAsync<List<DamageReturnListItem>>(
                    $"api/ProductStock/damage-return/list?fromLocationId={l.Id}&top=200") ?? new();

                var candidates = list.Where(x =>
                    !string.Equals(x.Status, "CONFIRMED", StringComparison.OrdinalIgnoreCase) &&
                    x.ProductId == selectedRow!.ProductId);

                foreach (var c in candidates)
                {
                    var doc = await http.GetFromJsonAsync<DamageReturnDocView>($"api/ProductStock/damage-return/{c.Id}");
                    if (doc is null) continue;
                    if (doc.ToLocationId != selectedLocationId) continue;

                    var fromName = FromLocationName(doc.FromLocationId);
                    pendingDamageOptions.Add(new DamageReturnOption
                    {
                        Id = doc.Id,
                        Label = $"{doc.DocNo} — {fromName}",
                        FromLocationId = doc.FromLocationId,
                        FromLocationName = fromName,
                        Qty = doc.Qty
                    });
                }
            }

            pendingDamageOptions = pendingDamageOptions.OrderByDescending(o => o.Id).ToList();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"โหลดรายการเอกสารล้มเหลว: {ex.Message}", "error");
        }
        finally { pendingDamageLoading = false; }
    }

    private int? _selectedPendingDamageId;
    private int? SelectedPendingDamageId
    {
        get => _selectedPendingDamageId;
        set
        {
            if (_selectedPendingDamageId == value) return;
            _selectedPendingDamageId = value;
            _ = OnPendingDamageSelected(value);
        }
    }

    private async Task OnPendingDamageSelected(int? id)
    {
        receiveDamageDoc = null;
        if (id is int v)
        {
            await FetchAndBindDamageDoc(v);
        }
        StateHasChanged();
    }

    private async Task FetchAndBindDamageDoc(int id)
    {
        try
        {
            var http = await CreateClient();
            var doc = await http.GetFromJsonAsync<DamageReturnDocView>($"api/ProductStock/damage-return/{id}");
            if (doc == null) { receiveDamageDoc = null; await JS.InvokeVoidAsync("showToast", "ไม่พบเอกสาร", "warning"); return; }

            if (string.Equals(doc.Status, "CONFIRMED", StringComparison.OrdinalIgnoreCase))
            { receiveDamageDoc = null; await JS.InvokeVoidAsync("showToast", "เอกสารถูกยืนยันแล้ว", "warning"); return; }

            if (selectedRow is null || doc.ProductId != selectedRow.ProductId)
            { receiveDamageDoc = null; await JS.InvokeVoidAsync("showToast", "เอกสารนี้เป็นคนละสินค้า", "warning"); return; }

            if (doc.ToLocationId != selectedLocationId)
            { receiveDamageDoc = null; await JS.InvokeVoidAsync("showToast", "เอกสารนี้ปลายทางไม่ตรงคลังปัจจุบัน", "warning"); return; }

            receiveDamageDoc = doc;
            var outstanding = Math.Max(0, doc.Qty - doc.QtyReceive);
            receiveQtyThisTime = Math.Clamp(receiveQtyThisTime <= 0 ? 1 : receiveQtyThisTime,
                                            1, Math.Max(1, outstanding));
        }
        catch (Exception ex)
        {
            receiveDamageDoc = null;
            await JS.InvokeVoidAsync("showToast", $"โหลดเอกสารล้มเหลว: {ex.Message}", "error");
        }
    }

    private async Task ConfirmReceiveDamage()
    {
        if (selectedRow is null) return;
        if (!locationIsWarehouse) { await JS.InvokeVoidAsync("showToast", "ใช้ได้เฉพาะที่ Warehouse", "warning"); return; }
        if (receiveDamageDoc is null) { await JS.InvokeVoidAsync("showToast", "กรุณาเลือกเอกสาร", "warning"); return; }

        var outstanding = Math.Max(0, receiveDamageDoc.Qty - receiveDamageDoc.QtyReceive);
        var qty = receiveQtyThisTime;

        if (qty <= 0 || qty > outstanding)
        {
            await JS.InvokeVoidAsync("showToast", $"จำนวนที่รับจริงต้องอยู่ระหว่าง 1 ถึง {outstanding}", "warning");
            return;
        }

        try
        {
            saving = true;
            var http = await CreateClient();

            // ส่งชื่อฟิลด์ให้ตรงกับ DTO: QtyReceive
            var payload = new
            {
                Id = receiveDamageDoc.Id,
                QtyReceive = qty,
                PerformedByUserId = _userId,
                Note = receiveDamageNote
            };

            var resp = await http.PostAsJsonAsync("api/ProductStock/damage-return/confirm", payload);
            if (resp.IsSuccessStatusCode)
            {
                // ที่คลังใหญ่: OnHand สุทธิเท่าเดิม, Damaged + qty
                selectedRow.QtyDamaged += qty;
                selectedRow.QtyAvailable = selectedRow.QtyOnHand - selectedRow.QtyReserved - selectedRow.QtyDamaged;

                await JS.InvokeVoidAsync("showToast", "Receive Damage recorded.", "success");
                showReceiveDamage = false;
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                var msg = string.IsNullOrWhiteSpace(body) ? resp.StatusCode.ToString() : body;
                await JS.InvokeVoidAsync("showToast", $"Receive Damage failed: {msg}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Receive Damage failed: {ex.Message}", "error");
        }
        finally { saving = false; }
    }

    // ===== Transfer Damage (Warehouse -> Damagehouse) =====
    private async Task OpenTransferDamage(StockRow r)
    {
        if (!locationIsWarehouse)
        {
            await JS.InvokeVoidAsync("showToast", "Transfer Damage ใช้ได้เฉพาะที่ Warehouse", "warning");
            return;
        }

        selectedRow = r;
        transferDamageToId = null;
        transferDamageQty = 1;
        transferDamageNote = null;
        showTransferDamage = true;
    }

    private async Task ConfirmTransferDamage()
    {
        if (selectedRow is null) return;
        if (transferDamageToId is null || transferDamageToId <= 0)
        {
            await JS.InvokeVoidAsync("showToast", "Please select destination Damagehouse.", "warning");
            return;
        }
        if (transferDamageQty <= 0) { await JS.InvokeVoidAsync("showToast", "Quantity must be > 0", "warning"); return; }
        if (transferDamageQty > selectedRow.QtyDamaged)
        {
            await JS.InvokeVoidAsync("showToast", $"Max damaged at this warehouse: {selectedRow.QtyDamaged}.", "warning");
            return;
        }

        try
        {
            saving = true;
            var http = await CreateClient();
            var payload = new
            {
                ProductId = selectedRow.ProductId,
                FromWarehouseId = selectedLocationId,
                ToDamagehouseId = transferDamageToId.Value,
                Qty = transferDamageQty,
                PerformedByUserId = _userId,
                Note = transferDamageNote ?? ""
            };
            var resp = await http.PostAsJsonAsync("api/ProductStock/warehouse-to-damagehouse", payload);
            if (resp.IsSuccessStatusCode)
            {
                // ที่คลังใหญ่: Damaged -qty, OnHand -qty
                selectedRow.QtyDamaged -= transferDamageQty;
                selectedRow.QtyOnHand -= transferDamageQty;
                selectedRow.QtyAvailable = selectedRow.QtyOnHand - selectedRow.QtyReserved - selectedRow.QtyDamaged;

                await JS.InvokeVoidAsync("showToast", "Transferred to Damagehouse.", "success");
                showTransferDamage = false;
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", $"Transfer failed: {await resp.Content.ReadAsStringAsync()}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Transfer failed: {ex.Message}", "error");
        }
        finally { saving = false; }
    }

