@page "/OrderList"
@using System.Globalization
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Text
@using System.Linq
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using miniApp.AdminPortal.Models
@using miniApp.AdminPortal.Shared
@using miniApp.AdminPortal.Components
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject IJSRuntime JS
@inject NavigationManager Navigation

<h3 class="d-flex align-items-center justify-content-between">
    <span>Order List</span>
    <div class="d-flex gap-2">
        <button class="btn btn-dark btn-sm" @onclick="ExportCsv">Export CSV</button>
    </div>
</h3>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Order No</label>
                <input class="form-control"
                       placeholder="e.g. OD123456"
                       @bind="queryOrderNo"
                       @bind:event="oninput" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Start date</label>
                <InputDate @bind-Value="dateFrom" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">End date</label>
                <InputDate @bind-Value="dateTo" class="form-control" />
            </div>
            <div class="col-md-1 d-grid">
                <button class="btn btn-dark" @onclick="ApplyFilterClick">Search</button>
            </div>
            <div class="col-md-1 d-grid">
                <button class="btn btn-outline-secondary" @onclick="ClearFilter">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (!filtered.Any())
{
    <p>No orders found.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
            <thead>
                <tr>
                    <th style="width:48px">#</th>

                    <th style="cursor:pointer" @onclick="SortByOrderNo">
                        Order No @SortIcon(nameof(OrderViewDto.OrderNo))
                    </th>

                    <th style="cursor:pointer" @onclick="SortByOrderDate">
                        Date @SortIcon(nameof(OrderViewDto.OrderDate))
                    </th>

                    <th style="cursor:pointer" @onclick="SortByLocation">
                        Location @SortIcon(nameof(OrderViewDto.LocationName))
                    </th>

                    <th style="cursor:pointer" @onclick="SortByUser">
                        User @SortIcon(nameof(OrderViewDto.UserFullname))
                    </th>

                    <th style="cursor:pointer" @onclick="SortByCustomer">
                        Customer @SortIcon(nameof(OrderViewDto.CustomerName))
                    </th>

                    <th>Phone</th>
                    <th>Address</th>
                    <th>Slip</th>

                    <th class="text-end" style="cursor:pointer" @onclick="SortByItems">
                        Quantity @SortIcon("Items")
                    </th>

                    <th class="text-end" style="cursor:pointer" @onclick="SortByAmount">
                        Amount @SortIcon("Amount")
                    </th>

                    <th style="width:160px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in paged)
                {
                    var amount = CalcOrderAmount(o);
                    <tr>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => ToggleExpand(o.Id)">
                                @(expanded.Contains(o.Id) ? "−" : "+")
                            </button>
                        </td>
                        <td>@o.OrderNo</td>
                        <td>@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(string.IsNullOrWhiteSpace(o.LocationName) ? "-" : o.LocationName)</td>
                        <td>@(string.IsNullOrWhiteSpace(o.UserFullname) ? "-" : o.UserFullname)</td>
                        <td>@o.CustomerName</td>
                        <td>@o.CustomerPhone</td>
                        <td class="text-truncate" style="max-width:320px">
                            @o.AddressLine, @o.SubDistrict, @o.District, @o.Province, @o.ZipCode
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(o.SlipImage))
                            {
                                var slip = BuildImageUrl(o.SlipImage);
                                <img src="@slip" width="42" height="42" class="rounded border"
                                     style="cursor:zoom-in"
                                     @onclick="() => OpenImage(slip)" />
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td class="text-end">@((o.Items?.Count ?? 0).ToString())</td>
                        <td class="text-end">@FormatCurrency(amount)</td>
                        <td>
                            <button class="btn btn-sm btn-primary me-2" @onclick="@(() => ViewOrder(o.Id))">View</button>
                            <button class="btn btn-sm btn-danger" @onclick="@(() => ConfirmDelete(o.Id, o.OrderNo))">Delete</button>
                        </td>
                    </tr>

                    @if (expanded.Contains(o.Id) && (o.Items?.Any() ?? false))
                    {
                        <tr class="bg-light">
                            <td></td>
                            <td colspan="11">
                                <div class="table-responsive">
                                    <table class="table table-sm mb-0">
                                        <thead>
                                            <tr>
                                                <th style="width:64px;">Image</th>
                                                <th>Product</th>
                                                <th>Location</th>
                                                <th class="text-end">Qty</th>
                                                <th class="text-end">Unit</th>
                                                <th class="text-end">Discount</th>
                                                <th class="text-end">Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var it in o.Items)
                                            {
                                                var lineTotal = (it.UnitPrice - it.Discount) * it.Quantity;
                                                var img = BuildImageUrl(it.ImageUrl);
                                                <tr>
                                                    <td>
                                                        @if (!string.IsNullOrWhiteSpace(img))
                                                        {
                                                            <img src="@img" width="48" height="48" class="rounded border"
                                                                 style="cursor:zoom-in"
                                                                 @onclick="() => OpenImage(img)" />
                                                        }
                                                    </td>
                                                    <td>@it.ProductName</td>
                                                    <td>@(string.IsNullOrWhiteSpace(it.LocationName) ? "-" : it.LocationName)</td>
                                                    <td class="text-end">@it.Quantity</td>
                                                    <td class="text-end">@FormatCurrency(it.UnitPrice)</td>
                                                    <td class="text-end">@FormatCurrency(it.Discount)</td>
                                                    <td class="text-end">@FormatCurrency(lineTotal)</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <td colspan="6" class="text-end"><strong>Grand Total</strong></td>
                                                <td class="text-end"><strong>@FormatCurrency(CalcOrderAmount(o))</strong></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <Pager State="_pager" OnPageChanged="OnPageChanged" ContainerClass="d-flex justify-content-end mt-2" />
}

@code {
    // ---------- Paging ----------
    private PaginationState _pager = new() { WindowSize = 5 };

    // ---------- Data ----------
    private List<OrderViewDto> all = new();
    private List<OrderViewDto> filtered = new();
    private List<OrderViewDto> paged = new();

    // lookups
    private Dictionary<int, string> _userNameMap = new();
    private Dictionary<int, string> _locationNameMap = new();

    private HashSet<int> expanded = new();

    // ---------- Filter ----------
    private string? queryOrderNo;
    private DateTime? dateFrom;
    private DateTime? dateTo;

    // ---------- Sorting ----------
    private string? sortField;
    private bool sortAsc = true;

    // ---------- UI state ----------
    private bool loading = true;

    private string ApiBaseUrl => Options.Value.ApiBaseUrl?.TrimEnd('/') ?? "";

    protected override async Task OnInitializedAsync()
    {
        _pager.SetPageSize(5);
        await Load();
        loading = false;
    }

    private async Task Load()
    {
        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(ApiBaseUrl + "/");

            var token = TokenProvider.Token;
            if (!string.IsNullOrWhiteSpace(token))
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            // 1) โหลด orders
            all = await client.GetFromJsonAsync<List<OrderViewDto>>("api/Order") ?? new();
            foreach (var o in all) o.Items ??= new();

            // 2) โหลด users & locations
            var usersTask = client.GetFromJsonAsync<List<UserLite>>("api/Users");
            var locsTask = client.GetFromJsonAsync<List<LocationLite>>("api/Locations/all");
            await Task.WhenAll(usersTask!, locsTask!);

            var users = usersTask?.Result ?? new List<UserLite>();
            var locs = locsTask?.Result ?? new List<LocationLite>();

            // 3) สร้างแผนที่ lookup (กัน key ซ้ำด้วย GroupBy → First)
            _userNameMap = users
                .GroupBy(u => u.Id)
                .ToDictionary(g => g.Key, g => g.First().Fullname ?? string.Empty);

            _locationNameMap = locs
                .GroupBy(l => l.Id)
                .ToDictionary(g => g.Key, g => g.First().Name ?? string.Empty);

            // 4) เติม UserFullname (จาก CreatedByUserId) และ LocationName (จาก Item.LocationId)
            foreach (var o in all)
            {
                o.UserFullname = _userNameMap.TryGetValue(o.CreatedByUserId, out var uf) ? uf : string.Empty;

                foreach (var it in o.Items!)
                {
                    it.LocationName = _locationNameMap.TryGetValue(it.LocationId, out var ln) ? ln : string.Empty;
                }

                // รวมชื่อ location ของออเดอร์ (กันซ้ำ)
                o.LocationName = string.Join(", ",
                    o.Items.Select(i => i.LocationName)
                           .Where(n => !string.IsNullOrWhiteSpace(n))
                           .Distinct());
            }

            // default sort: วันที่ล่าสุดก่อน
            sortField = nameof(OrderViewDto.OrderDate);
            sortAsc = false;

            ApplyFilterSortAndPage(resetPage: true);
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Failed to load orders: {ex.Message}", "error");
            all = new();
            ApplyFilterSortAndPage(resetPage: true);
        }
    }


    // --- Filtering + Sorting + Paging ---
    private void ApplyFilterClick() => ApplyFilterSortAndPage(resetPage: true);

    private void ApplyFilterSortAndPage(bool resetPage)
    {
        // 1) filter
        IEnumerable<OrderViewDto> q = all;

        if (!string.IsNullOrWhiteSpace(queryOrderNo))
        {
            var key = queryOrderNo.Trim();
            q = q.Where(o => (o.OrderNo ?? "").Contains(key, StringComparison.OrdinalIgnoreCase));
        }

        if (dateFrom is not null)
        {
            var fromDate = dateFrom.Value.Date;
            q = q.Where(o => o.OrderDate.ToLocalTime().Date >= fromDate);
        }
        if (dateTo is not null)
        {
            var toDate = dateTo.Value.Date;
            q = q.Where(o => o.OrderDate.ToLocalTime().Date <= toDate);
        }

        filtered = q.ToList();

        // 2) sort
        var sorted = ApplySort(filtered);

        // 3) page
        _pager.SetTotal(sorted.Count());
        if (resetPage) _pager.GoTo(1);
        paged = sorted.Page(_pager);

        StateHasChanged();
    }

    private IEnumerable<OrderViewDto> ApplySort(IEnumerable<OrderViewDto> src)
    {
        Func<OrderViewDto, object> key = sortField switch
        {
            nameof(OrderViewDto.OrderNo) => o => o.OrderNo ?? "",
            nameof(OrderViewDto.OrderDate) => o => o.OrderDate,
            nameof(OrderViewDto.CustomerName) => o => o.CustomerName ?? "",
            "Items" => o => o.Items?.Count ?? 0,
            "Amount" => o => CalcOrderAmount(o),
            _ => o => o.Id
        };

        return sortAsc ? src.OrderBy(key) : src.OrderByDescending(key);
    }

    private void ToggleSort(string field)
    {
        if (sortField == field) sortAsc = !sortAsc;
        else { sortField = field; sortAsc = true; }
        ApplyFilterSortAndPage(resetPage: false);
    }

    private void SortByOrderNo() => ToggleSort(nameof(OrderViewDto.OrderNo));
    private void SortByOrderDate() => ToggleSort(nameof(OrderViewDto.OrderDate));
    private void SortByLocation() => ToggleSort(nameof(OrderViewDto.LocationName));
    private void SortByUser() => ToggleSort(nameof(OrderViewDto.UserFullname));
        private void SortByCustomer() => ToggleSort(nameof(OrderViewDto.CustomerName));
    private void SortByItems() => ToggleSort("Items");
    private void SortByAmount() => ToggleSort("Amount");

    private MarkupString SortIcon(string field)
        => sortField == field
            ? (MarkupString)$"&nbsp;<small>{(sortAsc ? "▲" : "▼")}</small>"
            : (MarkupString)string.Empty;

    private void ClearFilter()
    {
        queryOrderNo = null;
        dateFrom = null;
        dateTo = null;

        sortField = nameof(OrderViewDto.OrderDate);
        sortAsc = false;

        ApplyFilterSortAndPage(resetPage: true);
    }

    // --- Row expand / actions ---
    private void ToggleExpand(int id)
    {
        if (!expanded.Add(id)) expanded.Remove(id);
    }

    private decimal CalcOrderAmount(OrderViewDto o)
        => (o.Items ?? new()).Sum(i => (i.UnitPrice - i.Discount) * i.Quantity);

    private string FormatCurrency(decimal v)
        => v.ToString("N2", CultureInfo.InvariantCulture);

    private string BuildImageUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return string.Empty;
        if (url.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return url;

        if (url.StartsWith("/"))
            return $"{ApiBaseUrl}{url}?t={DateTimeOffset.UtcNow.ToUnixTimeSeconds()}";

        var guess = $"/images/slips/{url}";
        return $"{ApiBaseUrl}{guess}?t={DateTimeOffset.UtcNow.ToUnixTimeSeconds()}";
    }

    private async Task OpenImage(string? src)
    {
        if (string.IsNullOrWhiteSpace(src)) return;
        await JS.InvokeVoidAsync("showImage", src);
    }

    private void ViewOrder(int id) => Navigation.NavigateTo($"/OrderView/{id}");

    private async Task ConfirmDelete(int id, string orderNo)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast",
            $"Delete order: {orderNo} (ID: {id}) ?", "Delete", "Cancel", "error");
        if (!ok) return;

        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(ApiBaseUrl + "/");

            var token = TokenProvider.Token;
            if (!string.IsNullOrWhiteSpace(token))
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var resp = await client.DeleteAsync($"api/Order/{id}");
            if (resp.IsSuccessStatusCode)
            {
                all.RemoveAll(x => x.Id == id);
                expanded.Remove(id);
                ApplyFilterSortAndPage(resetPage: true);
                await JS.InvokeVoidAsync("showToast", "Deleted.", "success");
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", $"Delete failed: {await resp.Content.ReadAsStringAsync()}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Delete failed: {ex.Message}", "error");
        }
    }

    private async Task ExportCsv()
    {
        if (filtered is null || filtered.Count == 0)
        {
            await JS.InvokeVoidAsync("showToast", "No data to export.", "warning");
            return;
        }

        var header = new[]
        {
            "OrderNo","OrderDate","Location","User","Customer","Phone","Address",
            "Product","Quantity","UnitPrice","Discount","LineTotal","OrderAmount"
        };
        var lines = new List<string> { string.Join(",", header) };

        string Esc(string s)
        {
            if (string.IsNullOrEmpty(s)) return "";
            var needs = s.Contains(',') || s.Contains('"') || s.Contains('\n') || s.Contains('\r');
            s = s.Replace("\"", "\"\"");
            return needs ? $"\"{s}\"" : s;
        }

        foreach (var o in filtered)
        {
            var orderAmount = CalcOrderAmount(o).ToString("0.00", CultureInfo.InvariantCulture);
            var address = $"{o.AddressLine}, {o.SubDistrict}, {o.District}, {o.Province}, {o.ZipCode}";
            var items = o.Items ?? new List<OrderItemDto>();

            if (items.Count == 0)
            {
                lines.Add(string.Join(",", new[]
                {
                    Esc(o.OrderNo ?? ""),
                    Esc(o.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")),
                    Esc(o.LocationName ?? ""),
                    Esc(o.UserFullname ?? ""),
                    Esc(o.CustomerName ?? ""),
                    Esc(o.CustomerPhone ?? ""),
                    Esc(address),
                    "", "", "", "", "",
                    orderAmount
                }));
                continue;
            }

            foreach (var it in items)
            {
                var lineTotal = ((it.UnitPrice - it.Discount) * it.Quantity)
                    .ToString("0.00", CultureInfo.InvariantCulture);

                lines.Add(string.Join(",", new[]
                {
                    Esc(o.OrderNo ?? ""),
                    Esc(o.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")),
                    Esc(o.LocationName ?? ""),
                    Esc(o.UserFullname ?? ""),
                    Esc(o.CustomerName ?? ""),
                    Esc(o.CustomerPhone ?? ""),
                    Esc(address),
                    Esc(it.ProductName ?? ""),
                    it.Quantity.ToString(CultureInfo.InvariantCulture),
                    it.UnitPrice.ToString("0.00", CultureInfo.InvariantCulture),
                    it.Discount.ToString("0.00", CultureInfo.InvariantCulture),
                    lineTotal,
                    orderAmount
                }));
            }
        }

        var csvContent = string.Join("\r\n", lines);
        var bom = Encoding.UTF8.GetPreamble();
        var csvBytes = bom.Concat(Encoding.UTF8.GetBytes(csvContent)).ToArray();

        var base64 = Convert.ToBase64String(csvBytes);
        var fileName = $"orders_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv;charset=utf-8", base64);
    }

    // ---------- Pager callback ----------
    private Task OnPageChanged(int p)
    {
        _pager.GoTo(p);
        // คำนวณหน้าใหม่จากรายการที่ sort แล้ว
        var sorted = ApplySort(filtered);
        paged = sorted.Page(_pager);
        StateHasChanged();
        return Task.CompletedTask;
    }

    // ---------- DTO ----------
    public class OrderViewDto
    {
        public int Id { get; set; }
        public string OrderNo { get; set; } = "";
        public DateTime OrderDate { get; set; }

        public string CustomerName { get; set; } = "";
        public string CustomerPhone { get; set; } = "";
        public string CustomerEmail { get; set; } = "";

        public string AddressLine { get; set; } = "";
        public string SubDistrict { get; set; } = "";
        public string District { get; set; } = "";
        public string Province { get; set; } = "";
        public string ZipCode { get; set; } = "";

        public string Gender { get; set; } = "";
        public DateTime? BirthDate { get; set; }
        public string Occupation { get; set; } = "";
        public string Nationality { get; set; } = "";
        public bool MayIAsk { get; set; }

        public int CreatedByUserId { get; set; }
        public string PaymentMethod { get; set; } = "";
        public string SlipImage { get; set; } = "";

        public List<OrderItemDto>? Items { get; set; }

        // เติมจาก lookup/API
        public string UserFullname { get; set; } = "";
        public string LocationName { get; set; } = "";
    }

    public class OrderItemDto
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = "";
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal Discount { get; set; }
        public string? ImageUrl { get; set; }

        public int LocationId { get; set; }
        public string LocationName { get; set; } = "";
    }

    // --- Lite DTOs for lookup ---
    public class UserLite
    {
        public int Id { get; set; }
        public string? Fullname { get; set; }
    }

    public class LocationLite
    {
        public int Id { get; set; }
        public string? Name { get; set; }
    }
}
