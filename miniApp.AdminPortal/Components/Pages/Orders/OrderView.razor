@page "/OrderView/{Id:int}"
@using System.Globalization
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.Extensions.Options
@using miniApp.AdminPortal.Components.Pages
@using miniApp.AdminPortal.Models
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject IJSRuntime JS
@inject NavigationManager Navigation

<h3>Order Detail</h3>

@if (order is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">Order</div>
                <div class="card-body">
                    <div><strong>No:</strong> @order.OrderNo</div>
                    <div><strong>Date:</strong> @order.OrderDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    <div><strong>Payment:</strong> @order.PaymentMethod</div>
                    <div><strong>Ask to contact:</strong> @(order.MayIAsk ? "Yes" : "No")</div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">Items</div>
                <div class="card-body table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Unit</th>
                                <th class="text-end">Discount</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var it in order.Items ?? new())
                            {
                                var total = (it.UnitPrice - it.Discount) * it.Quantity;
                                <tr>
                                    <td>@it.ProductName</td>
                                    <td class="text-end">@it.Quantity</td>
                                    <td class="text-end">@FormatCurrency(it.UnitPrice)</td>
                                    <td class="text-end">@FormatCurrency(it.Discount)</td>
                                    <td class="text-end">@FormatCurrency(total)</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="text-end"><strong>Grand Total</strong></td>
                                <td class="text-end"><strong>@FormatCurrency(CalcGrand(order))</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">Customer</div>
                <div class="card-body">
                    <div><strong>Name:</strong> @order.CustomerName</div>
                    <div><strong>Phone:</strong> @order.CustomerPhone</div>
                    <div><strong>Email:</strong> @order.CustomerEmail</div>
                    <hr />
                    <div class="small text-muted">Address</div>
                    <div>@order.AddressLine</div>
                    <div>@order.SubDistrict, @order.District</div>
                    <div>@order.Province @order.ZipCode</div>
                    <hr />
                    <div class="small text-muted">Profile</div>
                    <div>Gender: @order.Gender</div>
                    <div>Birth: @(order.BirthDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div>Occupation: @order.Occupation</div>
                    <div>Nationality: @order.Nationality</div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">Slip</div>
                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(order.SlipImage))
                    {
                        var slip = BuildImageUrl(order.SlipImage);
                        <img src="@slip" class="img-fluid rounded border"
                             style="cursor:zoom-in; max-height:320px;"
                             @onclick="() => OpenImage(slip)" />
                    }
                    else
                    {

                        <span>-</span>
                    }
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-secondary" @onclick="GoBack">Back</button>
                <button class="btn btn-danger ms-auto" @onclick="() => ConfirmDelete(order.Id, order.OrderNo)">Delete</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private OrderViewDto? order;
    private string ApiBaseUrl => Options.Value.ApiBaseUrl;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(ApiBaseUrl);

            var token = TokenProvider.Token;
            if (!string.IsNullOrWhiteSpace(token))
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            order = await client.GetFromJsonAsync<OrderViewDto>($"api/Order/{Id}");
            order ??= new();
            order.Items ??= new();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Failed to load: {ex.Message}", "error");
        }
    }

    private decimal CalcGrand(OrderViewDto o)
        => (o.Items ?? new()).Sum(i => (i.UnitPrice - i.Discount) * i.Quantity);

    private string FormatCurrency(decimal v)
        => v.ToString("N2", CultureInfo.InvariantCulture);

    private string BuildImageUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return string.Empty;
        if (url.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return url;
        if (url.StartsWith("/")) return $"{ApiBaseUrl.TrimEnd('/')}{url}?t={DateTimeOffset.UtcNow.ToUnixTimeSeconds()}";
        var guess = $"/images/slips/{url}";
        return $"{ApiBaseUrl.TrimEnd('/')}{guess}?t={DateTimeOffset.UtcNow.ToUnixTimeSeconds()}";
    }

    private async Task OpenImage(string? src)
    {
        if (string.IsNullOrWhiteSpace(src)) return;
        await JS.InvokeVoidAsync("showImage", src);
    }

    private void GoBack() => Navigation.NavigateTo("/OrderList");

    private async Task ConfirmDelete(int id, string orderNo)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast",
            $"Delete order: {orderNo} (ID: {id}) ?", "Delete", "Cancel", "error");
        if (!ok) return;

        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(ApiBaseUrl);
            var token = TokenProvider.Token;
            if (!string.IsNullOrWhiteSpace(token))
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var resp = await client.DeleteAsync($"api/Order/{id}");
            if (resp.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("showToast", "Deleted.", "success");
                Navigation.NavigateTo("/OrderList");
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", $"Delete failed: {await resp.Content.ReadAsStringAsync()}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Delete failed: {ex.Message}", "error");
        }
    }

    public class OrderViewDto
    {
        public int Id { get; set; }
        public string OrderNo { get; set; } = "";
        public DateTime OrderDate { get; set; }

        public string CustomerName { get; set; } = "";
        public string CustomerPhone { get; set; } = "";
        public string CustomerEmail { get; set; } = "";

        public string AddressLine { get; set; } = "";
        public string SubDistrict { get; set; } = "";
        public string District { get; set; } = "";
        public string Province { get; set; } = "";
        public string ZipCode { get; set; } = "";

        public string Gender { get; set; } = "";
        public DateTime? BirthDate { get; set; }
        public string Occupation { get; set; } = "";
        public string Nationality { get; set; } = "";
        public bool MayIAsk { get; set; }

        public string PaymentMethod { get; set; } = "";
        public string SlipImage { get; set; } = "";

        public List<OrderItemDto>? Items { get; set; }
    }

    public class OrderItemDto
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = "";
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal Discount { get; set; }
        public string? ImageUrl { get; set; }
    }
}
