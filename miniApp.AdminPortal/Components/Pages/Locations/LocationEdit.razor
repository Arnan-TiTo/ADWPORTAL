@page "/LocationEdit/{Id:int}"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using miniApp.AdminPortal.Components.Pages
@using miniApp.AdminPortal.Models
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject IJSRuntime JS
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<h3>Edit Location</h3>

@if (model is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="model" OnValidSubmit="HandleSave">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row g-3">
            <!-- Basic -->
            <div class="col-md-6">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="model.Name" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Note</label>
                <InputText class="form-control" @bind-Value="model.Note" />
            </div>

            <!-- New address fields -->
            <div class="col-md-6">
                <label class="form-label">Place Name</label>
                <InputText class="form-control" @bind-Value="model.PlaceName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Building</label>
                <InputText class="form-control" @bind-Value="model.Building" />
            </div>

            <div class="col-12">
                <label class="form-label">Address</label>
                <InputText class="form-control" @bind-Value="model.Address" />
            </div>

            <div class="col-md-4">
                <label class="form-label">District</label>
                <InputText class="form-control" @bind-Value="model.District" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Province</label>
                <InputText class="form-control" @bind-Value="model.Province" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Postcode</label>
                <InputText class="form-control" @bind-Value="model.Postcode" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Contact Person</label>
                <InputText class="form-control" @bind-Value="model.ContractPerson" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Contact Phone</label>
                <InputText class="form-control" @bind-Value="model.ContractPhone" />
            </div>

            <!-- Geo + User -->
            <div class="col-md-4">
                <label class="form-label">Latitude</label>
                <InputNumber class="form-control" @bind-Value="model.Latitude" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Longitude</label>
                <InputNumber class="form-control" @bind-Value="model.Longitude" />
            </div>
            <div class="col-md-4">
                <label class="form-label">User</label>
                <InputSelect class="form-select" @bind-Value="model.UserId">
                    @if (users != null)
                    {
                        @foreach (var u in users)
                        {
                            <option value="@u.Id">@u.Fullname (@u.Username)</option>
                        }
                    }
                </InputSelect>
            </div>

            <!-- Type flags -->
            <div class="col-12">
                <label class="form-label d-block mb-1">Location type</label>
                <div class="form-check form-check-inline">
                    <InputCheckbox class="form-check-input" id="chkWarehouse" @bind-Value="model.IsWarehouse" />
                    <label class="form-check-label" for="chkWarehouse">Warehouse</label>
                </div>
                <div class="form-check form-check-inline">
                    <InputCheckbox class="form-check-input" id="chkStorehouse" @bind-Value="model.IsStorehouse" />
                    <label class="form-check-label" for="chkStorehouse">Storehouse</label>
                </div>
                <div class="form-check form-check-inline">
                    <InputCheckbox class="form-check-input" id="chkDamagehouse" @bind-Value="model.IsDamagehouse" />
                    <label class="form-check-label" for="chkDamagehouse">Damagehouse</label>
                </div>
                <div class="form-text">ไม่เลือก = 0</div>
            </div>

            <!-- Images -->
            <div class="col-12">
                <label class="form-label">Current Images</label>
                <div class="d-flex flex-wrap gap-2">
                    @if (existingThumbs?.Any() == true)
                    {
                        @foreach (var src in existingThumbs)
                        {
                            @if (!string.IsNullOrWhiteSpace(src))
                            {
                                <img src="@src"
                                     width="50" height="50"
                                     class="rounded border"
                                     style="cursor: zoom-in; object-fit: cover"
                                     @onclick="() => OpenImage(src)" />
                            }
                        }
                    }
                    else
                    {
                        <span>-</span>
                    }
                </div>
            </div>

            <div class="col-12">
                <label class="form-label">Add new images</label>
                <InputFile OnChange="HandleFiles" multiple accept="image/*" />
                <div class="d-flex flex-wrap gap-2 mt-2">
                    @foreach (var p in newPreviews)
                    {
                        <img src="@p" width="96" height="96" class="rounded border" style="object-fit:cover" />
                    }
                </div>
            </div>

            <div class="col-12 mt-3">
                <button class="btn btn-primary" type="submit">Save</button>
                <button class="btn btn-secondary ms-2" type="button" @onclick="GoBack">Cancel</button>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private LocationEditVm? model;
    private List<UserItem>? users;
    private List<IBrowserFile> newFiles = new();
    private List<string> newPreviews = new();
    private List<string>? existingThumbs;

    private string ApiBaseUrl => Options.Value.ApiBaseUrl;

    private (string msg, string type)? _pendingToast;
    private bool _navigateToList;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(ApiBaseUrl);

            var token = TokenProvider.Token;
            if (!string.IsNullOrWhiteSpace(token))
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            users = await client.GetFromJsonAsync<List<UserItem>>("api/Users");

            var loc = await client.GetFromJsonAsync<LocationDto>($"api/Locations/{Id}");
            if (loc == null)
            {
                _pendingToast = ("Location not found.", "error");
                _navigateToList = true;
                return;
            }

            model = new LocationEditVm
            {
                Id = loc.Id,
                Name = loc.Name,
                Note = loc.Note ?? "",
                Latitude = loc.Latitude,
                Longitude = loc.Longitude,
                UserId = loc.UserId,

                // address
                PlaceName = loc.PlaceName,
                Building = loc.Building,
                Address = loc.Address,
                District = loc.District,
                Province = loc.Province,
                Postcode = loc.Postcode,
                ContractPerson = loc.ContractPerson,
                ContractPhone = loc.ContractPhone,

                // flags -> bool
                IsWarehouse = (loc.isWarehouse ?? 0) == 1,
                IsStorehouse = (loc.isStorehouse ?? 0) == 1,
                IsDamagehouse = (loc.isDamagehouse ?? 0) == 1
            };

            existingThumbs = loc.Images?.Select(i => BuildImageUrl(i.ImageUrl)).ToList();
        }
        catch (Exception ex)
        {
            _pendingToast = ($"Failed to load location: {ex.Message}", "error");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingToast is { } t)
        {
            await JS.InvokeVoidAsync("showToast", t.msg, t.type);
            _pendingToast = null;

            if (_navigateToList)
            {
                _navigateToList = false;
                await Task.Delay(400);
                Navigation.NavigateTo("/LocationList");
            }
        }
    }

    private async Task HandleFiles(InputFileChangeEventArgs e)
    {
        newFiles = e.GetMultipleFiles().ToList();
        newPreviews.Clear();

        foreach (var f in newFiles)
        {
            using var s = f.OpenReadStream(5_000_000);
            using var ms = new MemoryStream();
            await s.CopyToAsync(ms);
            newPreviews.Add($"data:{f.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}");
        }
        StateHasChanged();
    }

    private async Task HandleSave()
    {
        if (model is null) return;

        // client-side guard
        if (string.IsNullOrWhiteSpace(model.Name))
        {
            await JS.InvokeVoidAsync("showToast", "กรุณากรอก Name", "warning");
            return;
        }
        var selected = users?.FirstOrDefault(u => u.Id == model.UserId);
        if (selected is null)
        {
            await JS.InvokeVoidAsync("showToast", "กรุณาเลือก User", "warning");
            return;
        }

        try
        {
            var client = ClientFactory.CreateClient();
            client.BaseAddress = new Uri(ApiBaseUrl);

            var token = TokenProvider.Token;
            if (!string.IsNullOrWhiteSpace(token))
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            using var form = new MultipartFormDataContent();

            // ==== ฟิลด์ที่ API รับ ====
            form.Add(new StringContent(model.Name), "Name");
            form.Add(new StringContent(model.Note ?? ""), "Note");
            form.Add(new StringContent(model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture)), "Latitude");
            form.Add(new StringContent(model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture)), "Longitude");

            // ใช้ usernames แบบเดิม (ถ้าจะเปลี่ยนเป็น UserId ให้ส่งคีย์ "UserId")
            form.Add(new StringContent(selected.Username), "Usernames");

            // address
            form.Add(new StringContent(model.PlaceName ?? ""), "PlaceName");
            form.Add(new StringContent(model.Building ?? ""), "Building");
            form.Add(new StringContent(model.Address ?? ""), "Address");
            form.Add(new StringContent(model.District ?? ""), "District");
            form.Add(new StringContent(model.Province ?? ""), "Province");
            form.Add(new StringContent(model.Postcode ?? ""), "Postcode");
            form.Add(new StringContent(model.ContractPerson ?? ""), "ContractPerson");
            form.Add(new StringContent(model.ContractPhone ?? ""), "ContractPhone");

            // flags: ส่งเป็น 1/0 เสมอ (ไม่ติ๊ก = 0)
            form.Add(new StringContent(model.IsWarehouse ? "1" : "0"), "isWarehouse");
            form.Add(new StringContent(model.IsStorehouse ? "1" : "0"), "isStorehouse");
            form.Add(new StringContent(model.IsDamagehouse ? "1" : "0"), "isDamagehouse");

            // images
            foreach (var f in newFiles)
            {
                var sc = new StreamContent(f.OpenReadStream(5_000_000));
                sc.Headers.ContentType = new MediaTypeHeaderValue(f.ContentType);
                form.Add(sc, "Image", f.Name);
            }

            var resp = await client.PutAsync($"api/Locations/{model.Id}", form);
            if (resp.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("showToast", "Location updated.", "success");
                Navigation.NavigateTo("/LocationList");
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("showToast", $"Update failed ({(int)resp.StatusCode}): {body}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Update failed: {ex.Message}", "error");
        }
    }

    private async Task OpenImage(string? src)
    {
        if (string.IsNullOrWhiteSpace(src)) return;
        await JS.InvokeVoidAsync("showImage", src);
    }

    private void GoBack() => Navigation.NavigateTo("/LocationList");

    private string BuildImageUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return string.Empty;

        if (url.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return url;

        if (!url.StartsWith("/"))
            url = "/images/uploads/" + url;

        var full = $"{ApiBaseUrl.TrimEnd('/')}{url}";
        return $"{full}?t={DateTimeOffset.UtcNow.ToUnixTimeSeconds()}";
    }

    // ===== DTOs =====
    public class UserItem
    {
        public int Id { get; set; }
        public string Username { get; set; } = "";
        public string Fullname { get; set; } = "";
    }

    public class LocationImageDto
    {
        public int? Id { get; set; }
        public string? ImageUrl { get; set; } = "";
    }

    public class LocationDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Note { get; set; }
        public float Latitude { get; set; }
        public float Longitude { get; set; }
        public int UserId { get; set; }
        public string Username { get; set; } = "";
        public string Fullname { get; set; } = "";
        public List<LocationImageDto>? Images { get; set; }

        // new fields from API
        public string? PlaceName { get; set; }
        public string? Building { get; set; }
        public string? Address { get; set; }
        public string? District { get; set; }
        public string? Province { get; set; }
        public string? Postcode { get; set; }
        public string? ContractPerson { get; set; }
        public string? ContractPhone { get; set; }

        // flags (รับจาก API เป็น int? 0/1)
        public int? isWarehouse { get; set; }
        public int? isStorehouse { get; set; }
        public int? isDamagehouse { get; set; }
    }

    public class LocationEditVm
    {
        public int Id { get; set; }
        public string? Name { get; set; }
        public string? Note { get; set; }
        public float Latitude { get; set; }
        public float Longitude { get; set; }
        public int UserId { get; set; }

        // address
        public string? PlaceName { get; set; }
        public string? Building { get; set; }
        public string? Address { get; set; }
        public string? District { get; set; }
        public string? Province { get; set; }
        public string? Postcode { get; set; }
        public string? ContractPerson { get; set; }
        public string? ContractPhone { get; set; }

        // flags
        public bool IsWarehouse { get; set; } = false;
        public bool IsStorehouse { get; set; } = false;
        public bool IsDamagehouse { get; set; } = false;
    }
}
