@page "/IdwMangeEdit/edit/{Id:long}"
@using miniApp.AdminPortal.Models
@using miniApp.AdminPortal.Services
@using miniApp.AdminPortal.States
@inject IdwImportService Idw
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IdwListState State

<h3>IDW Manage</h3>

@if (loading)
{
    <div class="alert alert-info">กำลังโหลด...</div>
}
else if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Order No.</label>
                    <input class="form-control" @bind="model.OrderNo" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Pickup Date</label>
                    <input type="text" class="form-control" @bind="pickupDateStr" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Ship By Date</label>
                    <input type="text" class="form-control" @bind="shipByDateStr" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Sender Name</label>
                    <input class="form-control" @bind="model.SenderName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Sender Address</label>
                    <textarea class="form-control" rows="2" @bind="model.SenderAddress"></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Receiver Name</label>
                    <input class="form-control" @bind="model.ReceiverName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Receiver Address</label>
                    <textarea class="form-control" rows="2" @bind="model.ReceiverAddress"></textarea>
                </div>
                <div class="col-md-3">
                    <label class="form-label">SKU</label>
                    <input class="form-control" @bind="model.ItemSdk" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Product Name</label>
                    <input class="form-control" @bind="model.ItemName" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Variant</label>
                    <input class="form-control" @bind="model.ItemVariant" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Quantity</label>
                    <input type="number" class="form-control" @bind="model.Qty" />
                </div>
                <div class="col-md-3 d-flex align-items-center">
                    <div class="form-check mt-4">
                        <input id="chkCod" class="form-check-input" type="checkbox" @bind="model.IsCod" />
                        <label class="form-check-label" for="chkCod">COD</label>
                    </div>
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="Save" disabled="@saving">Save</button>
                <button class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public long Id { get; set; }
    bool loading, saving;
    string? error;
    string? token;
    IdwImportRowDto model = new();
    string? pickupDateStr, shipByDateStr;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var resp = await Idw.LoginAsync("admin", "123456yjm");
            token = resp?.Token;
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Login failed";
                return;
            }
            await Load();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    async Task Load()
    {
        try
        {
            loading = true;
            error = null;
            var row = await Idw.GetImportRowAsync(token!, Id);
            if (row == null)
            {
                error = "ไม่พบข้อมูล";
                return;
            }
            model.Id = row.Id;
            model.ImportId = row.ImportId;
            model.PageNo = row.PageNo;
            model.OrderNo = row.OrderNo;
            model.PickupDate = row.PickupDate;
            model.ShipByDate = row.ShipByDate;
            model.SenderName = row.SenderName;
            model.SenderAddress = row.SenderAddress;
            model.ReceiverName = row.ReceiverName;
            model.ReceiverAddress = row.ReceiverAddress;
            model.ItemSdk = row.ItemSdk;
            model.ItemName = row.ItemName;
            model.ItemVariant = row.ItemVariant;
            model.IsCod = row.IsCod;
            model.Qty = row.Qty;
            pickupDateStr = row.PickupDate?.ToString("yyyy-MM-dd");
            shipByDateStr = row.ShipByDate?.ToString("yyyy-MM-dd");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    async Task Save()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "กรุณาเข้าสู่ระบบใหม่";
                return;
            }
            saving = true;
            error = null;
            model.PickupDate = string.IsNullOrWhiteSpace(pickupDateStr) ? null : DateTime.Parse(pickupDateStr);
            model.ShipByDate = string.IsNullOrWhiteSpace(shipByDateStr) ? null : DateTime.Parse(shipByDateStr);
            await Idw.UpdateImportRowAsync(token!, model);
            State.RefreshRowId = model.Id;
            State.Dirty = false;
            await JS.InvokeVoidAsync("showToast", $"บันทึกเรียบร้อย: {Id}", "info");
            Nav.NavigateTo("/IdwManageList");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    void Cancel() => Nav.NavigateTo("/IdwManageList");
}
