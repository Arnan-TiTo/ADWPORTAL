@page "/IdwMangeEdit/edit/{Id:long}"
@using adwportal.Dtos
@using adwportal.Models
@using adwportal.Services
@using adwportal.States

@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider Auth
@inject AuthTokenProvider TokenProvider

@inject IdwImportService Idw
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IdwListState State

<h3>IDW Manage</h3>

@if (loading)
{
    <div class="alert alert-info">กำลังโหลด...</div>
}
else if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card">
        <div class="card-body">

            <!-- READONLY: Company / Platform / Logistic -->
            <div class="row g-3 mb-2">
                <div class="col-md-4">
                    <label class="form-label">Company</label>
                    <input class="form-control" value="@companyName" disabled />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Platform</label>
                    <input class="form-control" value="@platformName" disabled />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Logistic</label>
                    <input class="form-control" value="@logisticName" disabled />
                </div>
            </div>

            <hr />

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Order No.</label>
                    <input class="form-control" @bind="model.OrderNo" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Pickup Date</label>
                    <input type="text" class="form-control" @bind="pickupDateStr" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Ship By Date</label>
                    <input type="text" class="form-control" @bind="shipByDateStr" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Sender Name</label>
                    <input class="form-control" @bind="model.SenderName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Sender Address</label>
                    <textarea class="form-control" rows="2" @bind="model.SenderAddress"></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Receiver Name</label>
                    <input class="form-control" @bind="model.ReceiverName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Receiver Address</label>
                    <textarea class="form-control" rows="2" @bind="model.ReceiverAddress"></textarea>
                </div>
                <div class="col-md-3">
                    <label class="form-label">SKU</label>
                    <input class="form-control" @bind="model.ItemSdk" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Product Name</label>
                    <input class="form-control" @bind="model.ItemName" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Variant</label>
                    <input class="form-control" @bind="model.ItemVariant" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Quantity</label>
                    <input type="number" class="form-control" @bind="model.Qty" />
                </div>
                <div class="col-md-3 d-flex align-items-center">
                    <div class="form-check mt-4">
                        <input id="chkCod" class="form-check-input" type="checkbox" @bind="model.IsCod" />
                        <label class="form-check-label" for="chkCod">COD</label>
                    </div>
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="Save" disabled="@saving">Save</button>
                <button class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public long Id { get; set; }

    bool loading, saving;
    string? error;
    string? token;

    IdwImportRowDtos model = new();
    string? pickupDateStr, shipByDateStr;

    // readonly names
    string companyName = "-";
    string platformName = "-";
    string logisticName = "-";

    // lookups (ใช้ map id -> name/value1)
    List<CompanyItemDtos>? companies;
    List<MiscItemDtos>? platforms;
    List<MiscItemDtos>? logistics;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1) ลองอ่านจาก AuthTokenProvider ก่อน (กรณีมาจาก Dashboard ใน circuit เดียวกัน)
            token = TokenProvider.IdwToken;

            // 2) ถ้ายังว่าง ให้ใช้ username/password จาก Claims ไป login ใหม่
            if (string.IsNullOrWhiteSpace(token))
            {
                var authState = await Auth.GetAuthenticationStateAsync();
                var user = authState.User;

                var username =
                    user.Identity?.Name
                    ?? user.FindFirst("USERNAME")?.Value;

                var password = TokenProvider.Password;

                if (!string.IsNullOrWhiteSpace(username) &&
                    !string.IsNullOrWhiteSpace(password))
                {
                    await Idw.LoginAsync(username, password);
                }
            }

            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Token is empty. กรุณาเข้า Dashboard (หน้าแรก) หรือ login ใหม่อีกครั้ง";
                return;
            }

            loading = true;
            await LoadLookups();   // โหลดชื่อไว้ก่อน
            await Load();          // โหลดแถวที่แก้ + map company/platform/logistic
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    async Task LoadLookups()
    {
        // ดึงลิสต์ทั้งหมดครั้งเดียวพอ
        companies = await Idw.GetCompaniesAsync(token!);
        platforms = await Idw.GetPlatformsAsync(token!);
        logistics = await Idw.GetLogisticsAsync(token!);
    }

    async Task Load()
    {
        try
        {
            error = null;

            // 1) โหลดแถว
            var row = await Idw.GetImportRowAsync(token!, Id);
            if (row == null)
            {
                error = "ไม่พบข้อมูล";
                return;
            }

            model.Id = row.Id;
            model.ImportId = row.ImportId;
            model.PageNo = row.PageNo;
            model.OrderNo = row.OrderNo;
            model.PickupDate = row.PickupDate;
            model.ShipByDate = row.ShipByDate;
            model.SenderName = row.SenderName;
            model.SenderAddress = row.SenderAddress;
            model.ReceiverName = row.ReceiverName;
            model.ReceiverAddress = row.ReceiverAddress;
            model.ItemSdk = row.ItemSdk;
            model.ItemName = row.ItemName;
            model.ItemVariant = row.ItemVariant;
            model.IsCod = row.IsCod;
            model.Qty = row.Qty;

            pickupDateStr = row.PickupDate?.ToString("yyyy-MM-dd");
            shipByDateStr = row.ShipByDate?.ToString("yyyy-MM-dd");

            // 2) โหลด Import (เพื่อได้ CompanyId / MiscIdPlatform / MiscIdLogistic)
            var imp = await Idw.GetImportAsync(token!, row.ImportId);
            if (imp != null)
            {
                // map เป็นชื่อจาก lookup list
                var comp = companies?.FirstOrDefault(x => x.Id == imp.CompanyId);
                companyName = comp?.Name ?? "-";

                var plat = platforms?.FirstOrDefault(x => x.Id == imp.MiscIdPlatform);
                platformName = plat?.Value1 ?? "-";

                var logi = logistics?.FirstOrDefault(x => x.Id == imp.MiscIdLogistic);
                logisticName = logi?.Value1 ?? "-";
            }
            else
            {
                companyName = platformName = logisticName = "-";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    async Task Save()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "กรุณาเข้าสู่ระบบใหม่";
                return;
            }
            saving = true;
            error = null;

            model.PickupDate = string.IsNullOrWhiteSpace(pickupDateStr) ? null : DateTime.Parse(pickupDateStr);
            model.ShipByDate = string.IsNullOrWhiteSpace(shipByDateStr) ? null : DateTime.Parse(shipByDateStr);

            await Idw.UpdateImportRowAsync(token!, model);

            State.RefreshRowId = model.Id;
            State.Dirty = false;
            await JS.InvokeVoidAsync("showToast", $"บันทึกเรียบร้อย: {Id}", "info");
            Nav.NavigateTo("/IdwManageList");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    void Cancel() => Nav.NavigateTo("/IdwManageList");
}
