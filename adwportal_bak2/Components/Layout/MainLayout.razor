@rendermode InteractiveServer
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject NavigationManager Nav
@inject IJSRuntime JS

<script>
    window.forceNavigate = function (url) { window.location.href = url; };
</script>


<AuthorizeView>
    <Authorized Context="auth">
        <div class="page">
            <!-- Sidebar -->
            <div class="sidebar @(isSidebarOpen ? "open" : "closed")">
                <nav>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <NavLink href="/" Match="NavLinkMatch.All" class="nav-link" ActiveClass="is-active">
                                Home
                            </NavLink>
                        </li>

                        <!-- Config (parent) -->
                        <li class="nav-item">
                            <button type="button"
                                    class="nav-link btn btn-toggle w-100 d-flex align-items-center justify-content-between"
                                    @onclick="ToggleConfig">
                                <span>Config</span>
                                <span class="caret @(configOpen ? "rotate-90" : "")">▶</span>
                            </button>

                            @if (configOpen)
                            {
                                <ul class="nav flex-column ms-3 submenu">
                                    <li class="nav-item">
                                        <NavLink href="/UserList" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                            User
                                        </NavLink>
                                    </li>
                                    <li class="nav-item">
                                        <NavLink href="/CompanyList" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                            Company
                                        </NavLink>
                                    </li>
                                    <li class="nav-item">
                                        <NavLink href="/PartnerList" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                            Partner
                                        </NavLink>
                                    </li>
                                    <li class="nav-item">
                                        <NavLink href="/ShopList" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                            Shop
                                        </NavLink>
                                    </li>
                                    <li class="nav-item">
                                        <NavLink href="/MiscList" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                            Misc
                                        </NavLink>
                                    </li>
                                </ul>
                            }
                        </li>

                        <li class="nav-item">
                            <NavLink href="/IdwImport" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                IDW Import
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/IdwManageList" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                IDW Manage
                            </NavLink>
                        </li> 
                        <li class="nav-item">
                            <NavLink href="/shopsOAuth" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                MDW Shops OAuth
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/normalize" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                MDW Normalize
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/ViewOrderData" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                MDW Raw Data Import
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/AdwFlowAccountExport" Match="NavLinkMatch.Prefix" class="nav-link" ActiveClass="is-active">
                                FlowAccount Export
                            </NavLink>
                        </li>
                    </ul>
                </nav>
            </div>

            <!-- Main -->
            <div class="main-content @(isSidebarOpen ? "shrink" : "")">
                <div class="top-row d-flex align-items-center">
                    <div class="logo-area d-flex align-items-center gap-2">
                        <img src="/images/logo.png" class="logo" alt="logo" />
                        <strong>VAC Admin Portal</strong>
                        <button class="menu-toggle btn btn-outline-secondary btn-sm ms-2" type="button" @onclick="ToggleSidebar">☰</button>
                    </div>

                    <span class="ms-auto"></span>

                    <span class="topbar-name me-2">
                        Welcome @GetDisplayName(auth.User)
                    </span>

                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="Logout">Logout</button>
                </div>

                <main>@Body</main>
            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool isSidebarOpen = true;
    private bool configOpen = true;

    private void ToggleSidebar() => isSidebarOpen = !isSidebarOpen;
    private void ToggleConfig() => configOpen = !configOpen;

    private static string GetDisplayName(ClaimsPrincipal? user)
    {
        if (user is null) return "";
        var full = user.FindFirst("FULLNAME")?.Value;
        if (!string.IsNullOrWhiteSpace(full)) return full!;
        return user.Identity?.Name ?? "";
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("miniapp.logout");
    }
}
