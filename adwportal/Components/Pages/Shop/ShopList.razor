@page "/ShopList"
@using adwportal.Dtos
@using adwportal.Services
@inject ShopService Svc
@inject ShopGroupService ShopGroupSvc
@inject PartnerService PartnerSvc
@inject IdwImportService Idw
@inject AuthTokenProvider TokenProvider
@inject AuthenticationStateProvider Auth
@inject IJSRuntime JS
@inject NavigationManager Nav

<h3>Shops</h3>

@if (loading)
{
    <div class="alert alert-info">Loading...</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Partner</label>
                    <select class="form-select" @bind="SelectedPartnerId">
                        <option value="">-- All --</option>
                        @foreach (var p in partners)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="NameFilter" @bind:event="oninput" />
                </div>
                <div class="col-md-3 text-end">
                    <button class="btn btn-primary" @onclick="Add">+ Add</button>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:80px">Id</th>
                    <th style="width:180px">ShopId</th>
                    <th>Name</th>
                    <th style="width:200px">Partner</th>
                    <th style="width:120px">Country</th>
                    <th style="width:180px">Created</th>
                    <th style="width:160px">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (paged.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted">No data</td></tr>
                }
                else
                {
                    @foreach (var s in paged)
                    {
                        <tr>
                            <td>@s.Id</td>
                            <td>@s.ShopId</td>
                            <td>@(s.Name ?? "-")</td>
                            <td>@(PartnerName(Convert.ToInt64(s.PartnerId)))</td>
                            <td>@(s.Country ?? "-")</td>
                            <td>@s.CreatedAt.ToString("dd-MM-yyyy HH:mm")</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Edit(s.Id)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(s.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <nav>
        <ul class="pagination">
            <li class="page-item @(pageIndex == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="Prev">Prev</button>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(pageIndex == i ? "active" : "")">
                    <button class="page-link" @onclick="(() => Go(i))">@i</button>
                </li>
            }
            <li class="page-item @(pageIndex == totalPages ? "disabled" : "")">
                <button class="page-link" @onclick="Next">Next</button>
            </li>
        </ul>
    </nav>
}

@code {
    string? token;
    bool loading;
    string? error;

    List<PartnerDtos> partners = new();
    List<ShopDtos> all = new();
    List<ShopDtos> filtered = new();
    List<ShopDtos> paged = new();

    string? nameFilter;
    int? selectedPartnerId;

    string? NameFilter
    {
        get => nameFilter;
        set { nameFilter = value; pageIndex = 1; Apply(); }
    }

    int? SelectedPartnerId
    {
        get => selectedPartnerId;
        set { selectedPartnerId = value; pageIndex = 1; Apply(); }
    }

    const int pageSize = 10;
    int pageIndex = 1;
    int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;
            
            // Get token from AuthTokenProvider (which delegates to TokenCacheService)
            token = TokenProvider.IdwToken;
            if (string.IsNullOrWhiteSpace(token)) { error = "Token is empty. Please login."; return; }

            // โหลดข้อมูลครั้งเดียว แล้วกรองฝั่ง FE
            partners = await PartnerSvc.GetPartnersAsync(token!);

            // Shops — Admin เห็นทุก shop, non-admin กรองตาม ShopGroup
            var authState = await Auth.GetAuthenticationStateAsync();
            var userClaims = authState.User;
            var userRole = userClaims.FindFirst("ROLE")?.Value ?? userClaims.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
            var username = userClaims.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";

            if (userRole.Equals("Admin", StringComparison.OrdinalIgnoreCase))
            {
                all = (await Svc.GetShopsAsync(token!))
                    .GroupBy(s => s.ShopId).Select(g => g.First()).ToList();
            }
            else if (!string.IsNullOrWhiteSpace(username))
            {
                var effectiveShops = await ShopGroupSvc.GetUserEffectiveShopsByUsernameAsync(token!, username);
                all = effectiveShops
                    .GroupBy(es => es.ShopId).Select(g => g.First())
                    .Select(es => new ShopDtos(
                        Id: 0,
                        ShopId: es.ShopId,
                        PartnerId: es.PartnerId,
                        Name: es.ShopName,
                        Country: null,
                        CreatedAt: DateTime.MinValue,
                        Platform: es.Platform
                    )).ToList();

                // Filter partner dropdown ให้เหลือเฉพาะ partner ที่มี shop ที่มีสิทธิ์
                var allowedPartnerIds = all.Select(s => s.PartnerId).Distinct().ToHashSet();
                partners = partners?.Where(p => allowedPartnerIds.Contains(p.Id)).ToList();
            }

            Apply();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    void Apply()
    {
        IEnumerable<ShopDtos> q = all;

        if (selectedPartnerId.HasValue)
            q = q.Where(x => x.PartnerId == selectedPartnerId.Value);

        if (!string.IsNullOrWhiteSpace(nameFilter))
        {
            var kw = nameFilter.Trim();
            q = q.Where(x => (x.Name ?? "").Contains(kw, StringComparison.OrdinalIgnoreCase));
        }

        filtered = q.OrderBy(x => x.Name).ThenBy(x => x.Id).ToList();

        totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)pageSize));
        pageIndex = Math.Clamp(pageIndex, 1, totalPages);
        paged = filtered.Skip((pageIndex - 1) * pageSize).Take(pageSize).ToList();
        StateHasChanged();
    }

    string PartnerName(long partnerId) =>
        partners.FirstOrDefault(p => p.Id == partnerId)?.Name ?? $"- ({partnerId})";

    void Prev() { if (pageIndex > 1) { pageIndex--; Apply(); } }
    void Next() { if (pageIndex < totalPages) { pageIndex++; Apply(); } }
    void Go(int i) { pageIndex = i; Apply(); }

    void Add() => Nav.NavigateTo("/ShopEdit");
    void Edit(int id) => Nav.NavigateTo($"/ShopEdit/{id}");

    async Task Delete(int id)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Delete shop id={id} ?");
        if (!ok) return;

        try
        {
            await Svc.DeleteShopAsync(token!, id);
            var idx = all.FindIndex(x => x.Id == id);
            if (idx >= 0) all.RemoveAt(idx);

            await JS.InvokeVoidAsync("showToast", "Deleted", "success");
            Apply();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
    }
}
