@page "/ShopEdit"
@page "/ShopEdit/{Id:int}"
@using adwportal.Dtos
@using adwportal.Services
@inject ShopService Svc
@inject PartnerService PartnerSvc
@inject AuthTokenProvider TokenProvider
@inject MiscService MiscSvc
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Shop @title</h3>

@if (loading)
{
    <div class="alert alert-info">Loading...</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Partner</label>
                    <select class="form-select" @bind="model.PartnerId">
                        <option value="0">-- Select partner --</option>
                        @foreach (var p in partners)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">ShopId (platform)</label>
                    <input type="number" class="form-control" @bind="shopIdStr" />
                    <div class="form-text">ตัวเลขจากแพลตฟอร์ม (Shopee, ฯลฯ)</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="model.Name" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Platform</label>
                    <select class="form-select" @bind="model.Platform">
                        <option value="">-- Select platform --</option>
                        @foreach (var p in platformOptions)
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                    <div class="form-text">แพลตฟอร์มของร้าน (ใช้กรอง/ยิงงาน Normalize/Export)</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Country</label>
                    <input class="form-control" @bind="model.Country" placeholder="e.g. TH" />
                </div>

                @if (Id.HasValue && loaded != null)
                {
                    <div class="col-md-4">
                        <label class="form-label">Created</label>
                        <input class="form-control" value="@loaded.CreatedAt.ToString("dd-MM-yyyy HH:mm")" disabled />
                    </div>
                }
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="Save" disabled="@saving">Save</button>
                <button class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }

    string? token;
    bool loading, saving;
    string? error;
    string title = "Add";

    List<PartnerDtos> partners = new();
    ShopUpsertDtos model = new();
    ShopDtos? loaded;

    // Platform dropdown options (from Misc where Type='Platform')
    List<string> platformOptions = new();

    string? shopIdStr;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;
            token = await TokenProvider.GetIdwTokenAsync();
            if (string.IsNullOrWhiteSpace(token)) { error = "Login failed"; return; }

            partners = await PartnerSvc.GetPartnersAsync(token!);

            // Platform dropdown
            var plats = await MiscSvc.GetMiscAsync(token!, type: "Platform");
            platformOptions = (plats ?? new List<MiscDtos>())
                .Where(x => x.IsActive)
                .Select(x => CanonicalPlatform(!string.IsNullOrWhiteSpace(x.Name) ? x.Name : x.Value1))
                .OfType<string>()
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(x => x)
                .ToList();

            if (Id.HasValue)
            {
                title = "Edit";
                loaded = await Svc.GetShopAsync(token!, Id.Value);
                if (loaded == null) { error = "Not found"; return; }

                model = new ShopUpsertDtos
                {
                    PartnerId = loaded.PartnerId,
                    Name = loaded.Name,
                    Country = loaded.Country,
                    Platform = CanonicalPlatform(loaded.Platform)
                };
                shopIdStr = loaded.ShopId.ToString();
            }
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    async Task Save()
    {
        try
        {
            if (model.PartnerId <= 0)
            {
                await JS.InvokeVoidAsync("showToast", "Partner is required", "error");
                return;
            }

            if (!long.TryParse(shopIdStr, out var shopId) || shopId <= 0)
            {
                await JS.InvokeVoidAsync("showToast", "ShopId must be a positive number", "error");
                return;
            }

            if (string.IsNullOrWhiteSpace(model.Name))
            {
                await JS.InvokeVoidAsync("showToast", "Name is required", "error");
                return;
            }

            if (string.IsNullOrWhiteSpace(model.Platform))
            {
                await JS.InvokeVoidAsync("showToast", "Platform is required", "error");
                return;
            }

            saving = true;

            var dto = model with
            {
                ShopId = shopId,
                Platform = CanonicalPlatform(model.Platform)
            };

            if (Id.HasValue)
                _ = await Svc.UpdateShopAsync(token!, Id.Value, dto);
            else
                _ = await Svc.CreateShopAsync(token!, dto);

            await JS.InvokeVoidAsync("showToast", "Saved", "success");
            Nav.NavigateTo("/ShopList");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
        finally { saving = false; }
    }

    void Cancel() => Nav.NavigateTo("/ShopList");

    private static string? CanonicalPlatform(string? p)
    {
        var x = (p ?? "").Trim().ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(x)) return null;
        if (x.Contains("tiktok")) return "TikTok";
        if (x.Contains("shopee")) return "Shopee";
        if (x.Contains("lazada")) return "Lazada";
        return p?.Trim();
    }
}
