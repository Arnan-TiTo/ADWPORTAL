@page "/ShopEdit"
@page "/ShopEdit/{Id:int}"
@using adwportal.Dtos
@using adwportal.Services
@inject ShopService Svc
@inject PartnerService PartnerSvc
@inject IdwImportService Idw
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Shop @title</h3>

@if (loading)
{
    <div class="alert alert-info">Loading...</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Partner</label>
                    <select class="form-select" @bind="model.PartnerId">
                        <option value="0">-- Select partner --</option>
                        @foreach (var p in partners)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">ShopId (platform)</label>
                    <input type="number" class="form-control" @bind="shopIdStr" />
                    <div class="form-text">ตัวเลขจากแพลตฟอร์ม (Shopee, ฯลฯ)</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="model.Name" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Country</label>
                    <input class="form-control" @bind="model.Country" placeholder="e.g. TH" />
                </div>

                @if (Id.HasValue && loaded != null)
                {
                    <div class="col-md-4">
                        <label class="form-label">Created</label>
                        <input class="form-control" value="@loaded.CreatedAt.ToString("dd-MM-yyyy HH:mm")" disabled />
                    </div>
                }
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="Save" disabled="@saving">Save</button>
                <button class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }

    string? token;
    bool loading, saving;
    string? error;
    string title = "Add";

    List<PartnerDtos> partners = new();
    ShopUpsertDtos model = new();
    ShopDtos? loaded;

    string? shopIdStr;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;
            var login = await Idw.LoginAsync("admin", "123456yjm");
            token = login?.Token;
            if (string.IsNullOrWhiteSpace(token)) { error = "Login failed"; return; }

            partners = await PartnerSvc.GetPartnersAsync(token!);

            if (Id.HasValue)
            {
                title = "Edit";
                loaded = await Svc.GetShopAsync(token!, Id.Value);
                if (loaded == null) { error = "Not found"; return; }

                model = new ShopUpsertDtos
                {
                    PartnerId = loaded.PartnerId,
                    Name = loaded.Name,
                    Country = loaded.Country
                };
                shopIdStr = loaded.ShopId.ToString();
            }
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    async Task Save()
    {
        try
        {
            if (model.PartnerId <= 0)
            {
                await JS.InvokeVoidAsync("showToast", "Partner is required", "error");
                return;
            }

            if (!long.TryParse(shopIdStr, out var shopId) || shopId <= 0)
            {
                await JS.InvokeVoidAsync("showToast", "ShopId must be a positive number", "error");
                return;
            }

            if (string.IsNullOrWhiteSpace(model.Name))
            {
                await JS.InvokeVoidAsync("showToast", "Name is required", "error");
                return;
            }

            saving = true;

            if (Id.HasValue)
                _ = await Svc.UpdateShopAsync(token!, Id.Value, model with { ShopId = shopId });
            else
                _ = await Svc.CreateShopAsync(token!, model with { ShopId = shopId });

            await JS.InvokeVoidAsync("showToast", "Saved", "success");
            Nav.NavigateTo("/ShopList");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
        finally { saving = false; }
    }

    void Cancel() => Nav.NavigateTo("/ShopList");
}
