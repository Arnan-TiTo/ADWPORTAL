@page "/ShopGroupList"
@using adwportal.Dtos
@using adwportal.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject ShopGroupService GroupSvc
@inject TokenCacheService TokenCache
@inject AuthenticationStateProvider Auth
@inject IJSRuntime JS
@inject NavigationManager Nav

<h3 class="d-flex align-items-center justify-content-between">
    <span>Shop Groups</span>
    <button class="btn btn-sm btn-primary" @onclick="Add">+ Add Group</button>
</h3>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

@if (loading)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th style="width:100px;">Code</th>
                    <th>Name</th>
                    <th style="width:120px;">Permission</th>
                    <th style="width:100px;">Users</th>
                    <th style="width:100px;">Shops</th>
                    <th style="width:80px;">Active</th>
                    <th style="width:160px;" class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!groups.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted">No groups found.</td></tr>
                }
                else
                {
                    @foreach (var g in groups)
                    {
                        <tr>
                            <td><code>@g.GroupCode</code></td>
                            <td>@g.Name</td>
                            <td>
                                <span class="badge @PermissionBadge(g.Permission)">@g.Permission</span>
                            </td>
                            <td>@g.UserCount</td>
                            <td>@g.ShopCount</td>
                            <td>
                                @if (g.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Edit(g.Id)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(g)">Delete</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool loading;
    private string? error;
    private string? idwToken;
    private List<ShopGroupDtos> groups = new();

    private bool _isClientReady;
    private readonly Queue<(string msg, string type)> _toastQueue = new();
    private async Task SafeToast(string message, string type = "info")
    {
        if (_isClientReady) await JS.InvokeVoidAsync("showToast", message, type);
        else _toastQueue.Enqueue((message, type));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _isClientReady = true;
        while (_toastQueue.Count > 0)
        {
            var (m, t) = _toastQueue.Dequeue();
            await JS.InvokeVoidAsync("showToast", m, t);
        }

        try
        {
            loading = true;

            // Check user role — only Admin can manage groups
            var authState = await Auth.GetAuthenticationStateAsync();
            var userRole = authState.User.FindFirst("ROLE")?.Value ?? "";
            if (!userRole.Equals("Admin", StringComparison.OrdinalIgnoreCase))
            {
                error = "เฉพาะ Admin เท่านั้นที่สามารถจัดการ Shop Groups ได้";
                return;
            }

            idwToken = await TokenCache.GetIdwTokenAsync();
            if (string.IsNullOrWhiteSpace(idwToken))
            {
                error = "IDW token is empty. Please login.";
                return;
            }
            await LoadGroups();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            await SafeToast(ex.Message, "error");
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadGroups()
    {
        groups = await GroupSvc.GetGroupsAsync(idwToken!);
    }

    private void Add() => Nav.NavigateTo("/ShopGroupEdit/0");
    private void Edit(int id) => Nav.NavigateTo($"/ShopGroupEdit/{id}");

    private async Task Delete(ShopGroupDtos g)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast",
            $"Delete group '{g.GroupCode} - {g.Name}'? This will remove all user/shop mappings.",
            "Delete", "Cancel", "error");
        if (!ok) return;

        try
        {
            await GroupSvc.DeleteGroupAsync(idwToken!, g.Id);
            groups.RemoveAll(x => x.Id == g.Id);
            await SafeToast("Group deleted.", "success");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await SafeToast($"Delete failed: {ex.Message}", "error");
        }
    }

    private static string PermissionBadge(string p) => p switch
    {
        "admin" => "bg-danger",
        "write" => "bg-warning text-dark",
        "read"  => "bg-info text-dark",
        _       => "bg-secondary"
    };
}
