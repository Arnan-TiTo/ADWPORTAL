    <strong>Token Debug Logs:</strong>
    @foreach(var log in TokenCache.DebugLog)
    {
        <div>@log</div>
    }
</div> -->

<!-- Token cards -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div class="fw-semibold">Platform Token Status</div>
        <div class="muted-small">Green = active • Red = expired • Grey = inactive</div>
    </div>

    <div class="card-body">
        @if (isLoading)
        {
            <div class="text-center py-4">Loading tokens...</div>
        }
        else if (tokenList.Count == 0)
        {
            <div class="text-muted text-center py-4">No token records found.</div>
        }
        else
        {
            <div class="token-grid">
                @foreach (var t in tokenList)
                {
                    <div class="token-card">
                        <div class="head d-flex align-items-center gap-2">
                            <div class="token-icon d-flex align-items-center justify-content-center rounded-circle"
                                 style="width:32px;height:32px;background:@GetIconBg(t.Channel); color:white;">
                                @((MarkupString)GetPlatformSvg(t.Channel))
                            </div>

                            <div style="flex:1">
                                <div class="token-title fw-semibold">@(t.ChannelDisplay)</div>
                                <div class="token-sub text-muted small">@(t.EnvironmentDisplay)</div>
                            </div>

                            <div style="text-align:right">
                                @if (!t.IsActive)
                                {
                                    <span class="badge badge-small" style="background:#6c6f75; color:white">INACTIVE</span>
                                }
                                else if (t.IsExpired)
                                {
                                    <span class="badge badge-small" style="background:#e11d48; color:white">EXPIRED</span>
                                }
                                else
                                {
                                    <span class="badge badge-small" style="background:#10b981; color:white">ACTIVE</span>
                                }
                            </div>
                        </div>

                        <div class="token-sub small mt-2">
                            <div><strong>Account:</strong> @(t.AccountLabel)</div>
                            <div><strong>Expires (TH):</strong> @(TimeZoneInfo.ConvertTimeFromUtc(t.AccessTokenExpAt, TimeZoneInfo.FindSystemTimeZoneById("Asia/Bangkok")).ToString("dd-MM-yyyy HH:mm:ss"))</div>
                        </div>

                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Jobs section with filter -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <div class="fw-semibold">Recent Job Logs</div>
        <div class="d-flex align-items-center gap-2">
            <label class="muted-small mb-0">Platform</label>
            <select class="form-select form-select-sm" style="width:160px" @bind="jobPlatformFilter">
                <option value="">(All)</option>
                @foreach (var p in platformOptions)
                {
                    <option value="@p">@p</option>
                }
            </select>
        </div>
    </div>

    <div class="card-body">
        <div class="jobs-toolbar d-flex align-items-center mb-2">
            <div class="muted-small">Showing @filteredJobs.Count of @jobList.Count</div>
            <div class="ms-auto muted-small">Last refresh: @lastRefreshedDisplay</div>
        </div>

        @if (isLoading)
        {
            <div class="text-center py-4">Loading job logs...</div>
        }
        else if (jobList.Count == 0)
        {
            <div class="text-muted text-center py-4">No job logs available.</div>
        }
        else
        {
            <div class="table-responsive" style="max-height:50vh; overflow:auto;">
                <table class="table table-sm table-striped">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>#</th>
                            <th>Platform</th>
                            <th>ShopId</th>
                            <th>Mode</th>
                            <th>Requested (UTC)</th>
                            <th>Completed (UTC)</th>
                            <th>Total</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th class="text-danger">Failed</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var j in filteredJobs)
                        {
                            <tr>
                                <td>@j.TransId</td>
                                <td>@(j.Platform ?? "-")</td>
                                <td>@(j.ShopId?.ToString() ?? "-")</td>
                                <td>@(j.Mode ?? "-")</td>
                                <td>@j.RequestAtUtc.ToString("dd-MM-yyyy HH:mm:ss")</td>
                                <td>@(j.CompletedAtUtc?.ToString("dd-MM-yyyy HH:mm:ss") ?? "-")</td>
                                <td>@j.TotalRefs</td>
                                <td>@j.CreatedCount</td>
                                <td>@j.UpdatedCount</td>
                                <td class="text-danger">@j.FailedCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    // ===== Dashboard แสดงทุก platform =====
    private const string DashboardPlatform = "All"; // แสดงทุก platform

    private string? error;

    // ===== STATE =====
    private List<TokenUi> tokenList = new();
    private List<JobLogDto> jobList = new();
    private List<JobLogDto> filteredJobs = new();
    private string jobPlatformFilter = "";

    // Platform dropdown options (from Misc where Type='Platform')
    private List<string> platformOptions = new();

    private bool isLoading = true; // Start as true to show spinner immediately
    private DateTime lastRefreshedUtc = DateTime.MinValue;
    private string lastRefreshedDisplay => lastRefreshedUtc == DateTime.MinValue ? "-" : $"{lastRefreshedUtc:yyyy-MM-dd HH:mm:ss} UTC";

    // ===== TOKEN STATE =====
    private string mdwToken = "";
    private string idwToken = "";

    // ===== AUTO REFRESH =====
    private System.Threading.Timer? _timer;
    private bool autoRefreshEnabled = true;
    private readonly TimeSpan RefreshInterval = TimeSpan.FromSeconds(1800);
    private readonly SemaphoreSlim _refreshSemaphore = new(1, 1);


    // ===== DTOs for UI =====
    private class TokenUi
    {
        public int Id { get; set; }
        public string Channel { get; set; } = "";
        public string Environment { get; set; } = "";
        public string AccountIdStr { get; set; } = "";
        public long? AccountIdBig { get; set; }
        public DateTime AccessTokenExpAt { get; set; }
        public DateTime? RefreshTokenExpAt { get; set; }
        public bool IsActive { get; set; }
        public string TokenStatus { get; set; } = "";

        public bool IsExpired => TokenStatus?.ToLowerInvariant() == "expired";
        public string ChannelDisplay => string.IsNullOrWhiteSpace(Channel) ? "(unknown)" : char.ToUpper(Channel[0]) + Channel.Substring(1);
        public string EnvironmentDisplay => string.IsNullOrWhiteSpace(Environment) ? "-" : Environment;
        public string AccountLabel => !string.IsNullOrWhiteSpace(AccountIdStr) ? AccountIdStr : (AccountIdBig?.ToString() ?? "-");
    }

    public class JobLogDto
    {
        public long TransId { get; set; }
        public string? Platform { get; set; }
        public long? ShopId { get; set; }
        public string? Mode { get; set; }
        public DateTime RequestAtUtc { get; set; }
        public DateTime? CompletedAtUtc { get; set; }
        public int TotalRefs { get; set; }
        public int Attempted { get; set; }
        public int CreatedCount { get; set; }
        public int UpdatedCount { get; set; }
        public int UnchangedCount { get; set; }
        public int FailedCount { get; set; }
        public string? Notes { get; set; }
    }

    // ===== LIFECYCLE =====
    protected override async Task OnInitializedAsync()
    {
        // 3) ตั้ง Timer auto-refresh (แต่ยังไม่โหลดข้อมูล)
        _timer = new System.Threading.Timer(async _ => await TimerTick(), null, RefreshInterval, RefreshInterval);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isLoading = true;
            StateHasChanged();

            // 1) Login MDW + IDW ด้วย username/password จาก session (Async & Non-blocking)
            await RefreshToken();

            // 2) โหลด Dashboard ครั้งแรก
            await LoadDashboard();

            // Done
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task TimerTick()
    {
        if (!autoRefreshEnabled) return;
        if (!await _refreshSemaphore.WaitAsync(0)) return;

        try
        {
            await InvokeAsync(async () =>
            {
                await RefreshToken();
                await LoadDashboard(inBackground: true);
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"TimerTick error: {ex.Message}");
        }
        finally
        {
            _refreshSemaphore.Release();
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _refreshSemaphore?.Dispose();
    }

    // ===== ACTIONS =====
    private async Task ManualRefresh()
    {
        await RefreshToken();
        await LoadDashboard();
    }

    private void ToggleAutoRefresh()
    {
        autoRefreshEnabled = !autoRefreshEnabled;
    }

    private static string? NormalizeToken(string? t)
    {
        if (string.IsNullOrWhiteSpace(t)) return null;
        t = t.Trim().Trim('"');
        if (t.StartsWith("Bearer ", StringComparison.OrdinalIgnoreCase)) t = t[7..].Trim();
        return t;
    }

    private static string CanonicalPlatform(string? platform)
    {
        if (string.IsNullOrWhiteSpace(platform)) return "";
        var p = platform.Trim();
        if (p.Equals("tiktok", StringComparison.OrdinalIgnoreCase) || p.Equals("tik tok", StringComparison.OrdinalIgnoreCase)) return "TikTok";
        if (p.Equals("shopee", StringComparison.OrdinalIgnoreCase)) return "Shopee";
        if (p.Equals("lazada", StringComparison.OrdinalIgnoreCase)) return "Lazada";
        return p;
    }

    private async Task EnsurePlatformOptions()
    {
        if (platformOptions.Count > 0) return;
        if (string.IsNullOrWhiteSpace(idwToken)) return;
        try
        {
            var plats = await MiscSvc.GetMiscAsync(idwToken, type: "Platform");
            platformOptions = (plats ?? new List<MiscDtos>())
                .Where(x => x.IsActive)
                .Select(x => CanonicalPlatform(!string.IsNullOrWhiteSpace(x.Name) ? x.Name : x.Value1))
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(x => x)
                .ToList();
        }
        catch
        {
            // ignore
        }
    }

    private async Task RefreshToken()
    {
        try
        {

            // Get tokens asynchronously from TokenCacheService directly!
            // (Avoids TokenProvider.MdwToken which uses .Result and causes Deadlock)
            mdwToken = await TokenCache.GetMdwTokenAsync() ?? "";
            idwToken = await TokenCache.GetIdwTokenAsync() ?? "";

            if (string.IsNullOrEmpty(mdwToken) || string.IsNullOrEmpty(idwToken))
            {
                throw new Exception("ไม่สามารถดึง token ได้ (กรุณา Login ใหม่)");
            }

            await EnsurePlatformOptions();
            error = null;
        }
        catch (Exception ex)
        {
            error = ex.Message;
            Console.Error.WriteLine($"RefreshToken error: {ex.Message}");
        }
        finally
        {
        }
    }

    private async Task LoadDashboard(bool inBackground = false)
    {
        try
        {
            if (!inBackground)
            {
                isLoading = true;
                StateHasChanged();
            }

            if (string.IsNullOrWhiteSpace(mdwToken))
            {
                error = "MDW token is empty, cannot load dashboard.";
                return;
            }

            var client = ClientFactory.CreateClient("MdwApiBaseUrl");
            client.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", mdwToken);

            var requestMessage = new HttpRequestMessage(HttpMethod.Get, "/api/dashboard");
            var response = await client.SendAsync(requestMessage);

            if (!response.IsSuccessStatusCode)
            {
                Console.Error.WriteLine($"LoadDashboard: API responded with {(int)response.StatusCode} {response.ReasonPhrase}");
                error = $"API Error: {(int)response.StatusCode} {response.ReasonPhrase}";
                return;
            }

            var jsonResponse = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(jsonResponse))
            {
                Console.Error.WriteLine("LoadDashboard: Received empty response body from API.");
                error = "API returned empty response.";
                return;
            }

            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var dashResp = JsonSerializer.Deserialize<DashboardResponse>(jsonResponse, options);

            if (dashResp == null)
            {
                Console.Error.WriteLine("LoadDashboard: Failed to deserialize API response.");
                error = "Failed to parse API response.";
                return;
            }

            tokenList = dashResp.tokens?.Select(t => new TokenUi
            {
                Id = t.Id,
                Channel = t.Channel ?? "",
                Environment = t.Environment ?? "",
                AccountIdStr = t.AccountIdStr ?? "",
                AccountIdBig = t.AccountIdBig,
                AccessTokenExpAt = t.AccessTokenExpAt,
                RefreshTokenExpAt = t.RefreshTokenExpAt,
                IsActive = t.IsActive,
                TokenStatus = t.TokenStatus ?? ""
            }).ToList() ?? new();

            // แสดงทุก token (ไม่ filter ตาม platform)
            // tokenList = tokenList
            //     .Where(x => string.Equals(x.Channel, DashboardPlatform, StringComparison.OrdinalIgnoreCase))
            //     .ToList();

            jobList = dashResp.jobs ?? new();

            ApplyFilter();
            lastRefreshedUtc = DateTime.UtcNow;
            error = null;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"LoadDashboard error: {ex.Message}");
            error = $"An error occurred while loading dashboard: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplyFilter()
    {
        // เริ่มจากแสดงทุก job (ไม่ filter ตาม DashboardPlatform)
        IEnumerable<JobLogDto> query = jobList;

        // ถ้า user เลือก filter เพิ่มจาก dropdown
        if (!string.IsNullOrWhiteSpace(jobPlatformFilter))
        {
            query = query.Where(j =>
                string.Equals(j.Platform, jobPlatformFilter, StringComparison.OrdinalIgnoreCase));
        }

        filteredJobs = query.ToList();
    }

    private void ShowDetails(TokenUi t)
    {
        var msg =
            $"Platform: {t.Channel}\n" +
            $"Env: {t.Environment}\n" +
            $"Account: {t.AccountLabel}\n" +
            $"Expires(UTC): {t.AccessTokenExpAt:dd-MM-yyyy HH:mm:ss}\n" +
            $"Status: {t.TokenStatus}";
        _ = InvokeAsync(() => JSRuntimeInvoke("alert", msg));
    }

    private async Task JSRuntimeInvoke(string name, object arg)
    {
        try { await JS.InvokeVoidAsync(name, arg); }
        catch { /* ignore */ }
    }

    // ===== UTILS =====
    private string GetPlatformSvg(string platform)
    {
        if (string.IsNullOrWhiteSpace(platform)) return "❓";
        var p = platform.Trim().ToLowerInvariant();
        return p switch
        {
            "shopee" => @"<svg width='22' height='22' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'><rect width='24' height='24' rx='6' fill='white' /><path d='M12 2C8.1 2 5 5.1 5 9c0 5.3 7 13 7 13s7-7.7 7-13c0-3.9-3.1-7-7-7z' fill='white' /><text x='50%' y='54%' text-anchor='middle' dominant-baseline='middle' font-size='10' fill='white'>S</text></svg>",
            "lazada" => @"<svg width='22' height='22' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'><rect width='24' height='24' rx='6' fill='white' /><text x='50%' y='54%' text-anchor='middle' dominant-baseline='middle' font-size='10' fill='white'>L</text></svg>",
            "tiktok" => @"<svg width='22' height='22' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'><rect width='24' height='24' rx='6' fill='white' /><text x='50%' y='54%' text-anchor='middle' dominant-baseline='middle' font-size='10' fill='white'>T</text></svg>",
            _ => $"<div style='font-size:14px'>{platform[0].ToString().ToUpperInvariant()}</div>"
        };
    }

    private string GetIconBg(string platform)
    {
        if (string.IsNullOrWhiteSpace(platform)) return "#9CA3AF";
        var p = platform.Trim().ToLowerInvariant();
        return p switch
        {
            "shopee" => "#ff6f61",
            "lazada" => "#0066ff",
            "tiktok" => "#111827",
            _ => "#6b7280"
        };
    }

    // ===== DTOs matching backend =====
    private class DashboardResponse
    {
        public List<TokenStatusDto>? tokens { get; set; }
        public List<JobLogDto>? jobs { get; set; }
    }

    private class TokenStatusDto
    {
        public int Id { get; set; }
        public string? Channel { get; set; }
        public string? Environment { get; set; }
        public string? AccountIdStr { get; set; }
        public long? AccountIdBig { get; set; }
        public DateTime AccessTokenExpAt { get; set; }
        public DateTime? RefreshTokenExpAt { get; set; }
        public bool IsActive { get; set; }
        public string? TokenStatus { get; set; }
    }
}
