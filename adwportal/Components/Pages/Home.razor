@page "/"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Text.Json
@using System.Threading
@using Microsoft.AspNetCore.Components.Authorization
@using adwportal.Dtos
@using adwportal.Services

@inject IHttpClientFactory ClientFactory
@inject IJSRuntime JS
@inject AuthenticationStateProvider Auth
@inject IdwImportService IdwSvc
@inject MdwMarketplaceService MdwSvc
@inject AuthTokenProvider TokenProvider
@inject MiscService MiscSvc

@implements IDisposable

<style>
    .token-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 12px;
    }

    .token-card {
        background: linear-gradient(180deg, #ffffff 0%, #fbfbfb 100%);
        border-radius: 12px;
        padding: 12px;
        box-shadow: 0 6px 18px rgba(25, 30, 40, 0.06);
        border: 1px solid rgba(0,0,0,0.04);
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-height: 120px;
    }

    @@media (max-width: 576px) {
        .token-grid {
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        }
    }
</style>

@inject TokenCacheService TokenCache

<h3 class="mb-3 d-flex align-items-center justify-content-between">
    <span>Dashboard (@DashboardPlatform)</span>
    <!-- <span class="text-muted">(@(mdwToken ?? "mdwToken is null"))</span> -->
    <!-- <span class="text-muted">(@(idwToken ?? "idwToken is null"))</span>  -->
    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-sm btn-outline-primary" @onclick="ManualRefresh" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            }
            Refresh
        </button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleAutoRefresh">
            @if (autoRefreshEnabled)
            {
                <span>Auto: On</span>
            }
            else
            {
                <span>Auto: Off</span>
            }
        </button>
    </div>
</h3>

