@page "/IdwImport"
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components
@using System.Text
@using adwportal.Models
@using adwportal.Dtos
@using adwportal.Services

@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider Auth
@inject AuthTokenProvider TokenProvider

@inject IHttpClientFactory ClientFactory
@inject IJSRuntime JS
@inject IOptions<ApiSettings> Options
@inject IdwImportService IdwImportService
@inject MiscService MiscSvc
@inject ShopService ShopSvc
@inject ShopGroupService ShopGroupSvc
@inject NavigationManager Navigation

<h3>Import Data</h3>

<div class="card mb-3">
    <div class="card-body">

        <!-- ===== Dropdowns: Company(จาก partners) / Shop / Platform / Logistic ===== -->
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <label class="form-label">Company</label>
                <!-- ค่า value คือ Partner.Id แต่โชว์ชื่อบริษัท -->
                <InputSelect class="form-select"
                             @bind-Value="SelectedPartnerDbId"
                             TValue="int?"
                             disabled="@isLookupLoading">
                    <option value="">-- Select company --</option>
                    @if (partners is not null)
                    {
                        @foreach (var p in partners)
                        {
                            <option value="@p.Id">@FormatCompanyPlatform(p)</option>
                        }
                    }
                </InputSelect>
                @if (SelectedPartnerDbId is not null)
                {
                    <div class="form-text">
                        Partner (ext): @CurrentPartnerExternalIdText
                    </div>
                }
            </div>

            <div class="col-md-3">
                <label class="form-label">Shop</label>
                <InputSelect class="form-select"
                             @bind-Value="selectedShopDbId"
                             TValue="int?"
                             disabled="@(isLookupLoading || shops.Count == 0)">
                    <option value="">-- @(shops.Count > 0 ? "Select shop" : "No shop available") --</option>
                    @foreach (var s in shops)
                    {
                        <option value="@s.Id">@((s.Name ?? "(no name)")) [@s.ShopId]</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-3">
                <label class="form-label">Platform</label>
                <InputSelect class="form-select" @bind-Value="selectedPlatformId" TValue="int?" disabled="@isLookupLoading">
                    <option value="">-- Select platform --</option>
                    @if (platforms is not null)
                    {
                        @foreach (var p in platforms)
                        {
                            <option value="@p.Id">@(!string.IsNullOrWhiteSpace(p.Name) ? p.Name : p.Value1)</option>
                        }
                    }
                </InputSelect>
            </div>

            <div class="col-md-3">
                <label class="form-label">Logistic</label>
                <InputSelect class="form-select" @bind-Value="selectedLogisticId" TValue="int?" disabled="@isLookupLoading">
                    <option value="">-- Select logistic --</option>
                    @if (logistics is not null)
                    {
                        @foreach (var l in logistics)
                        {
                            <option value="@l.Id">@l.Value1</option>
                        }
                    }
                </InputSelect>
            </div>
        </div>

        <!-- ===== OCR Engine ===== -->
        <div class="row g-3 mb-3">
            <div class="col-md-2">
                <label class="form-label">OCR Engine</label>
                <InputSelect class="form-select" @bind-Value="selectedOcrEngine" TValue="string">
                    <option value="typhoon">Typhoon Local (Default)</option>
                    <option value="typhoon-cloud">Typhoon Cloud</option>
                    <option value="pdfpig">PdfPig OCR</option>
                </InputSelect>
            </div>
            @if (selectedOcrEngine.StartsWith("typhoon"))
            {
                @if (selectedOcrEngine == "typhoon")
                {
                    <div class="col-md-2">
                        <label class="form-label">Task Type</label>
                        <InputSelect class="form-select" @bind-Value="selectedTaskType" TValue="string">
                            <option value="structure">structure</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Figure Language</label>
                        <InputSelect class="form-select" @bind-Value="selectedFigureLanguage" TValue="string">
                            <option value="Thai">Thai</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Image Dim</label>
                        <InputSelect class="form-select" @bind-Value="selectedImageDim" TValue="int">
                            <option value="1200">1200 (Default)</option>
                            <option value="1000">1000</option>
                            <option value="800">800</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Max Tokens</label>
                        <InputSelect class="form-select" @bind-Value="selectedMaxTokens" TValue="int">
                            <option value="4096">4096 (Default)</option>
                            <option value="2048">2048</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Repetition Penalty</label>
                        <InputSelect class="form-select" @bind-Value="selectedRepetitionPenalty" TValue="string">
                            <option value="1.5">1.5 (Default)</option>
                            <option value="1.8">1.8</option>
                            <option value="2.0">2.0</option>
                        </InputSelect>
                    </div>
                }
                else
                {
                    <div class="col-md-4 d-flex align-items-end">
                        <span class="text-muted small">☁️ Cloud API uses optimized defaults (max_tokens=16384, rep_penalty=1.2)</span>
                    </div>
                }
            }
        </div>
        <!-- ===== /OCR Engine ===== -->

        <InputFile OnChange="OnFileSelected" />

        @if (!string.IsNullOrWhiteSpace(selectedFileName))
        {
            <p class="mt-2"><strong>Selected:</strong> @selectedFileName</p>
            <div class="border p-2 bg-light" style="max-height:200px; overflow:auto">
                <pre>@previewText</pre>
            </div>
            <div class="mt-3">
                <button class="btn btn-success me-2" @onclick="Save" disabled="@DisableSave">Save</button>
                <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </div>
        }
    </div>
</div>

@if (lastUpload != null)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5>Import Summary</h5>
            <div class="row">
                <div class="col-md-3"><strong>ImportId:</strong> @lastUpload.importId</div>
                <div class="col-md-3"><strong>Inserted Order:</strong> @lastUpload.rows</div>
                <div class="col-md-3"><strong>Skipped Order:</strong> @lastUpload.skippedDb</div>
                <div class="col-md-3"><strong>Skipped File:</strong> @lastUpload.skippedFile</div>
            </div>

            @if (lastUpload.skippedOrders != null && lastUpload.skippedOrders.Any())
            {
                <div class="mt-3">
                    <h6>Skipped Orders</h6>
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>OrderNo</th>
                                <th>Reason</th>
                                <th>Detail</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in lastUpload.skippedOrders)
                            {
                                <tr>
                                    <td>@s.OrderNo</td>
                                    <td>@s.Reason</td>
                                    <td>@s.Detail</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@if (lastImported != null)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5>Batch Detail</h5>
            <p><strong>BatchNo:</strong> @lastImported.BatchNo</p>
            <p><strong>File:</strong> @lastImported.FileName</p>
            <p><strong>ImportedBy:</strong> @lastImported.ImportedBy</p>
            <p><strong>ImportedAt:</strong> @lastImported.ImportedAt</p>
            <p><strong>Status:</strong> @lastImported.Status</p>
            <p><strong>RowCount:</strong> @(importedRows?.Count ?? lastImported.RowCount)</p>

            <div class="mt-3">
                <button class="btn btn-danger" @onclick="Delete" disabled="@isDelete">Delete</button>
            </div>

            <table class="table table-sm table-bordered mt-3">
                <thead>
                    <tr>
                        <th>Page</th>
                        <th>OrderNo</th>
                        <th>PickupDate</th>
                        <th>ShipByDate</th>
                        <th>SenderName</th>
                        <th>SenderAddress</th>
                        <th>ReceiverName</th>
                        <th>ReceiverAddress</th>
                        <th>ItemName</th>
                        <th>IsCOD</th>
                        <th>ItemVariant</th>
                        <th>Qty</th>
                    </tr>
                </thead>
                <tbody>
                    @if (importedRows != null && importedRows.Any())
                    {
                        @foreach (var r in importedRows)
                        {
                            <tr>
                                <td><!-- ไม่มี page ใน IdwOrderDto --></td>
                                <td>@r.OrderNo</td>
                                <td>@r.PickupDate?.ToString("dd-MM-yyyy")</td>
                                <td>@r.ShipByDate?.ToString("dd-MM-yyyy")</td>
                                <td>@r.SenderName</td>
                                <td>@r.SenderAddress</td>
                                <td>@r.ReceiverName</td>
                                <td>@r.ReceiveAddress</td>
                                <td>@r.ProductName</td>
                                <td>@r.Cod</td>
                                <td>@r.Variant</td>
                                <td>@r.Qty</td>
                            </tr>
                        }
                    }
                    else if (lastImported?.Rows != null && lastImported.Rows.Any())
                    {
                        @* เผื่อ API คืน Rows ใน IdwImportDtos *@
                        @foreach (var r in lastImported.Rows)
                        {
                            <tr>
                                <td>@r.PageNo</td>
                                <td>@r.OrderNo</td>
                                <td>@r.PickupDate?.ToString("dd-MM-yyyy")</td>
                                <td>@r.ShipByDate?.ToString("")</td>
                                <td>@r.SenderName</td>
                                <td>@r.SenderAddress</td>
                                <td>@r.ReceiverName</td>
                                <td>@r.ReceiverAddress</td>
                                <td>@r.ItemName</td>
                                <td>@(r.IsCod == true ? "Y" : r.IsCod == false ? "N" : null)</td>
                                <td>@r.ItemVariant</td>
                                <td>@r.Qty</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="12" class="text-muted text-center">No rows found</td>
                        </tr>
                    }
                </tbody>
            </table>

            <button class="btn btn-outline-secondary" @onclick="ClearImported">Clear</button>
        </div>
    </div>
}

@code {
    private string? tokenRaw;
    private string? token;
    private string? error;
    private IBrowserFile? selectedFile;
    private string? selectedFileName;
    private string? previewText;
    private bool? isSaving;
    private bool? isDelete;

    private UploadResponseDtos? lastUpload;
    private IdwImportDtos? lastImported;

    // แถวที่จะแสดง (fallback มาจาก SearchAsync)
    private List<IdwOrderDtos> importedRows = new();

    private MemoryStream? cachedFileStream;
    private string? importId;

    private bool isLookupLoading = false;

    // partners (รวม CompanyName)
    private List<MdwPartnerDtos>? partners;
    private List<MiscDtos>? platforms;
    private List<MiscItemDtos>? logistics;

    // Shop group permission cache
    private bool _isAdmin = true;
    private List<UserEffectiveShopDtos>? _effectiveShops;

    private readonly List<ShopDtos> shops = new();
    private int? selectedShopDbId;

    private int? _selectedPartnerDbId;
    private int? SelectedPartnerDbId
    {
        get => _selectedPartnerDbId;
        set
        {
            if (_selectedPartnerDbId != value)
            {
                _selectedPartnerDbId = value;
                _ = OnPartnerChanged();
            }
        }
    }

    private int? selectedPlatformId;
    private int? selectedLogisticId;
    private string selectedOcrEngine = "typhoon";
    private string selectedTaskType = "structure";
    private string selectedFigureLanguage = "Thai";
    private int selectedImageDim = 1200;
    private int selectedMaxTokens = 4096;
    private string selectedRepetitionPenalty = "1.5";

    private bool DisableSave => isSaving == true
                                || selectedFile == null
                                || isLookupLoading
                                || !selectedPlatformId.HasValue
                                || !selectedLogisticId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1) ลองอ่านจาก AuthTokenProvider ก่อน (async เพื่อไม่ให้ค้าง)
            token = await TokenProvider.GetIdwTokenAsync();

            // 2) ถ้ายังว่าง ให้ใช้ username/password จาก Claims ไป login ใหม่
            if (string.IsNullOrWhiteSpace(token))
            {
                var authState = await Auth.GetAuthenticationStateAsync();
                var user = authState.User;

                var username =
                    user.Identity?.Name
                    ?? user.FindFirst("USERNAME")?.Value;

                var password = TokenProvider.Password;

                if (!string.IsNullOrWhiteSpace(username) &&
                    !string.IsNullOrWhiteSpace(password))
                {
                    await LoginAsync(username, password);
                }
            }

            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Token is empty. กรุณาเข้า Dashboard (หน้าแรก) หรือ login ใหม่อีกครั้ง";
                return;
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }

        await LoadLookupsAsync();
    }

    private async Task LoadLookupsAsync()
    {
        if (string.IsNullOrWhiteSpace(token)) return;
        isLookupLoading = true;
        try
        {
            var ct = CancellationToken.None;

            // Get role/username from claims
            var authState = await Auth.GetAuthenticationStateAsync();
            var userClaims = authState.User;
            var userRole = userClaims.FindFirst("ROLE")?.Value ?? userClaims.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
            var username = userClaims.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";
            _isAdmin = userRole.Equals("Admin", StringComparison.OrdinalIgnoreCase);

            // Load all partners first
            partners = await IdwImportService.GetPartnersAsync(token!, partnerExternalId: null, ct);
            platforms = await MiscSvc.GetMiscAsync(token!, type: "Platform", ct: ct);
            logistics = await IdwImportService.GetLogisticsAsync(token!, ct);

            // Non-admin: cache effective shops + filter partners
            if (!_isAdmin && !string.IsNullOrWhiteSpace(username))
            {
                _effectiveShops = await ShopGroupSvc.GetUserEffectiveShopsByUsernameAsync(token!, username);
                var allowedPartnerIds = _effectiveShops.Select(es => es.PartnerId).ToHashSet();
                partners = partners?.Where(p => allowedPartnerIds.Contains(p.Id)).ToList();
            }

            // ใช้ backing field ตรง ๆ เพื่อไม่ trigger OnPartnerChanged (ซึ่งจะเรียก Load ซ้ำซ้อน)
            _selectedPartnerDbId ??= partners?.FirstOrDefault()?.Id;
            selectedPlatformId ??= platforms?.FirstOrDefault()?.Id;
            selectedLogisticId ??= logistics?.FirstOrDefault()?.Id;

            await LoadShopsForSelectedPartnerAsync();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load lookups failed: {ex.Message}", "error");
        }
        finally
        {
            isLookupLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnPartnerChanged()
    {
        selectedShopDbId = null;
        await LoadShopsForSelectedPartnerAsync();
        StateHasChanged();
    }

    private async Task LoadShopsForSelectedPartnerAsync()
    {
        shops.Clear();

        if (SelectedPartnerDbId is null || string.IsNullOrWhiteSpace(token))
            return;

        try
        {
            var list = await ShopSvc.GetShopsAsync(token!, SelectedPartnerDbId.Value);

            if (_isAdmin)
            {
                shops.AddRange((list ?? new())
                    .GroupBy(s => s.ShopId).Select(g => g.First())
                    .OrderBy(s => s.Name));
            }
            else
            {
                // Non-admin: intersect with cached effective shops
                var allowedShopIds = (_effectiveShops ?? new()).Select(es => es.ShopId).ToHashSet();
                shops.AddRange((list ?? new())
                    .Where(s => allowedShopIds.Contains(s.ShopId))
                    .GroupBy(s => s.ShopId).Select(g => g.First())
                    .OrderBy(s => s.Name));
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load shops failed: {ex.Message}", "error");
        }
    }

    private string CurrentPartnerExternalIdText
        => partners?.FirstOrDefault(p => p.Id == SelectedPartnerDbId)?.PartnerId.ToString() ?? "-";

    // แสดง Company-Platform (concat 2 field) ตามที่ต้องการ
    private static string FormatCompanyPlatform(MdwPartnerDtos p)
    {
        var company = (p.CompanyName ?? "").Trim();
        var plat = (p.Name ?? "").Trim();
        if (string.IsNullOrWhiteSpace(company) && string.IsNullOrWhiteSpace(plat)) return "-";
        if (string.IsNullOrWhiteSpace(plat)) return company;
        if (string.IsNullOrWhiteSpace(company)) return plat;
        return $"{company}-{plat}";
    }

    private static string? NormalizeToken(string? t)
    {
        if (string.IsNullOrWhiteSpace(t)) return null;
        t = t.Trim().Trim('"');
        if (t.StartsWith("Bearer ", StringComparison.OrdinalIgnoreCase))
            t = t.Substring(7).Trim();
        return t;
    }

    private static bool Is401(Exception ex) =>
        ex.Message.Contains("401") || ex.Message.Contains("Unauthorized", StringComparison.OrdinalIgnoreCase);

    private async Task LoginAsync(string user, string pass)
    {
        var resp = await IdwImportService.LoginAsync(user, pass);
        tokenRaw = resp?.Token;
        token = NormalizeToken(tokenRaw);

        if (string.IsNullOrWhiteSpace(token))
            await JS.InvokeVoidAsync("showToast", "Login failed (no token)", "error");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = selectedFile.Name;

        await using var stream = selectedFile.OpenReadStream(maxAllowedSize: 10_000_000);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        previewText = Encoding.UTF8.GetString(ms.ToArray());
        if (previewText.Length > 1000) previewText = previewText[..1000] + "... (truncated)";

        cachedFileStream = new MemoryStream(ms.ToArray());
    }

    private async Task<UploadResponseDtos> DoUploadAsync()
    {
        var bytes = cachedFileStream!.ToArray();
        await using var ms = new MemoryStream(bytes, writable: false);
        return await IdwImportService.UploadImportAsync(
            token!,
            ms,
            selectedFile!.Name,
            shopId: selectedShopDbId,
            miscIdPlatform: selectedPlatformId,
            miscIdLogistic: selectedLogisticId,
            ocrEngine: string.IsNullOrWhiteSpace(selectedOcrEngine) ? null : selectedOcrEngine,
            taskType: selectedTaskType,
            figureLanguage: selectedFigureLanguage,
            imageDim: selectedImageDim,
            maxTokens: selectedMaxTokens,
            repetitionPenalty: double.TryParse(selectedRepetitionPenalty, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var rp) ? rp : 1.5,
            ct: CancellationToken.None
        );
    }

    private async Task LoadRowsByBatchAsync(string? batchNo)
    {
        importedRows.Clear();
        if (string.IsNullOrWhiteSpace(batchNo) || string.IsNullOrWhiteSpace(token)) return;

        try
        {
            // ดึงรายการออเดอร์ทั้งหมดใน batch (ปรับ size ถ้าไฟล์ใหญ่)
            var page = await IdwImportService.SearchAsync(
                token!, batchNo, orderNo: null, sku: null,
                page: 1, size: 1000, CancellationToken.None);

            importedRows = page.Items ?? new List<IdwOrderDtos>();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load rows failed: {ex.Message}", "error");
        }
    }

    private async Task Save()
    {
        if (selectedFile == null || string.IsNullOrWhiteSpace(token) || cachedFileStream == null) return;
        isSaving = true;
        var fileName = selectedFile.Name; // เก็บไว้ก่อน เผื่อ fallback
        try
        {
            // ===== Step 1: POST /api/idw/import =====
            bool uploadTimedOut = false;
            try
            {
                try
                {
                    lastUpload = await DoUploadAsync();
                }
                catch (Exception ex) when (Is401(ex))
                {
                    // Token หมดอายุ → ดึงใหม่แบบ async
                    token = await TokenProvider.GetIdwTokenAsync();
                    if (string.IsNullOrWhiteSpace(token))
                    {
                        var authState = await Auth.GetAuthenticationStateAsync();
                        var u = authState.User.Identity?.Name ?? authState.User.FindFirst("USERNAME")?.Value;
                        var p = TokenProvider.Password;
                        if (!string.IsNullOrWhiteSpace(u) && !string.IsNullOrWhiteSpace(p))
                            await LoginAsync(u, p);
                    }
                    lastUpload = await DoUploadAsync();
                }
            }
            catch (TaskCanceledException)
            {
                uploadTimedOut = true;
                await JS.InvokeVoidAsync("showToast",
                    "Upload timeout — กำลังค้นหา import ที่ backend บันทึกไปแล้ว...", "warning");
            }
            catch (HttpRequestException httpEx)
            {
                uploadTimedOut = true;
                await JS.InvokeVoidAsync("showToast",
                    $"Upload error: {httpEx.Message} — กำลังค้นหา import ที่ backend บันทึกไปแล้ว...", "warning");
            }

            // ===== Step 2: ดึงข้อมูล Import =====
            if (!uploadTimedOut && lastUpload != null && lastUpload.importId > 0)
            {
                // --- Path A: upload สำเร็จ ได้ importId → GET /api/TblImport/{importId} ---
                importId = lastUpload.importId.ToString();

                await JS.InvokeVoidAsync("showToast",
                    $"Import {importId}: +{lastUpload.rows}, skippedDb={lastUpload.skippedDb}, skippedFile={lastUpload.skippedFile}",
                    "success");

                lastImported = await IdwImportService.GetImportAsync(token!, lastUpload.importId);

                if (lastImported == null)
                {
                    lastImported = new IdwImportDtos
                    {
                        BatchNo = lastUpload.batchNo,
                        RowCount = lastUpload.rows
                    };
                }
            }
            else
            {
                // --- Path B: timeout/error → GET /api/idw/latest-import?fileName=xxx ---
                lastImported = await IdwImportService.GetLatestImportByFileNameAsync(
                    token!, fileName, CancellationToken.None);

                if (lastImported != null)
                {
                    importId = lastImported.Id.ToString();
                    await JS.InvokeVoidAsync("showToast",
                        $"พบ import ที่บันทึกแล้ว (Id={importId}, Batch={lastImported.BatchNo})", "success");
                }
                else
                {
                    await JS.InvokeVoidAsync("showToast",
                        "Import failed — ไม่พบข้อมูลใน server", "error");
                    return;
                }
            }

            // ===== Step 3: โหลดแถว (Rows) สำหรับแสดงตาราง =====
            if (lastImported.Rows == null || lastImported.Rows.Count == 0)
            {
                await LoadRowsByBatchAsync(lastImported.BatchNo);
            }
            else
            {
                importedRows.Clear(); // ใช้ Rows ที่มากับ API
            }

            // clear file buffer
            selectedFile = null;
            selectedFileName = null;
            previewText = null;
            cachedFileStream?.Dispose();
            cachedFileStream = null;
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task Delete()
    {
        if (string.IsNullOrWhiteSpace(token) || lastImported?.BatchNo is null) return;

        var ok = await JS.InvokeAsync<bool>("confirm", $"Delete batch '{lastImported.BatchNo}' and all its rows?");
        if (!ok) return;

        isDelete = true;
        try
        {
            await IdwImportService.DeleteImportByBatchAsync(token!, lastImported.BatchNo);
            await JS.InvokeVoidAsync("showToast", $"Deleted batch {lastImported.BatchNo}", "success");
            lastImported = null;
            importId = null;
            selectedFile = null;
            selectedFileName = null;
            previewText = null;
            lastUpload = null;
            importedRows.Clear();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Delete failed: {ex.Message}", "error");
        }
        finally
        {
            isDelete = false;
            StateHasChanged();
        }
    }

    private void IdwImportEditForm(long id) => Navigation.NavigateTo($"/IdwImportEdit/{id}");
    private void Cancel() { selectedFile = null; selectedFileName = null; previewText = null; }
    private void ClearImported() { lastImported = null; lastUpload = null; importedRows.Clear(); }
}
