@page "/IdwImport"
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components
@using System.Text
@using adwportal.Models
@using adwportal.Dtos
@using adwportal.Services
@inject IHttpClientFactory ClientFactory
@inject IJSRuntime JS
@inject IOptions<ApiSettings> Options
@inject IdwImportService IdwImportService
@inject ShopService ShopSvc
@inject NavigationManager Navigation

<h3>Import Data</h3>

<div class="card mb-3">
    <div class="card-body">

        <!-- ===== Dropdowns: Company / Platform / Logistic / Shop ===== -->
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <label class="form-label">Company</label>
                <InputSelect class="form-select" @bind-Value="SelectedCompanyId" TValue="int?" disabled="@isLookupLoading">
                    <option value="">-- Select company --</option>
                    @if (companies != null)
                    {
                        @foreach (var c in companies)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    }
                </InputSelect>
                @if (SelectedCompanyId.HasValue)
                {
                    <div class="form-text">
                        PartnerId: @CurrentPartnerIdText
                    </div>
                }
            </div>

            <div class="col-md-3">
                <label class="form-label">Shop</label>
                <InputSelect class="form-select"
                             @bind-Value="selectedShopDbId"
                             TValue="int?"
                             disabled="@(isLookupLoading || !shops.Any())">
                    <option value="">-- @(shops.Any() ? "Select shop" : "No shop available") --</option>
                    @foreach (var s in shops)
                    {
                        <option value="@s.Id">@((s.Name ?? "(no name)")) [@s.ShopId]</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-3">
                <label class="form-label">Platform</label>
                <InputSelect class="form-select" @bind-Value="selectedPlatformId" TValue="int?" disabled="@isLookupLoading">
                    <option value="">-- Select platform --</option>
                    @if (platforms != null)
                    {
                        @foreach (var p in platforms)
                        {
                            <option value="@p.Id">@p.Value1</option>
                        }
                    }
                </InputSelect>
            </div>

            <div class="col-md-3">
                <label class="form-label">Logistic</label>
                <InputSelect class="form-select" @bind-Value="selectedLogisticId" TValue="int?" disabled="@isLookupLoading">
                    <option value="">-- Select logistic --</option>
                    @if (logistics != null)
                    {
                        @foreach (var l in logistics)
                        {
                            <option value="@l.Id">@l.Value1</option>
                        }
                    }
                </InputSelect>
            </div>
        </div>
        <!-- ===== /Dropdowns ===== -->

        <InputFile OnChange="OnFileSelected" />

        @if (!string.IsNullOrWhiteSpace(selectedFileName))
        {
            <p class="mt-2"><strong>Selected:</strong> @selectedFileName</p>
            <div class="border p-2 bg-light" style="max-height:200px; overflow:auto">
                <pre>@previewText</pre>
            </div>
            <div class="mt-3">
                <button class="btn btn-success me-2" @onclick="Save" disabled="@DisableSave">Save</button>
                <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </div>
        }
    </div>
</div>

@if (lastUpload != null)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5>Import Summary</h5>
            <div class="row">
                <div class="col-md-3"><strong>ImportId:</strong> @lastUpload.importId</div>
                <div class="col-md-3"><strong>Inserted Order:</strong> @lastUpload.rows</div>
                <div class="col-md-3"><strong>Skipped Order:</strong> @lastUpload.skippedDb</div>
                <div class="col-md-3"><strong>Skipped File:</strong> @lastUpload.skippedFile</div>
            </div>

            @if (lastUpload.skippedOrders != null && lastUpload.skippedOrders.Any())
            {
                <div class="mt-3">
                    <h6>Skipped Orders</h6>
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>OrderNo</th>
                                <th>Reason</th>
                                <th>Detail</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in lastUpload.skippedOrders)
                            {
                                <tr>
                                    <td>@s.OrderNo</td>
                                    <td>@s.Reason</td>
                                    <td>@s.Detail</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@if (lastImported != null)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5>Batch Detail</h5>
            <p><strong>BatchNo:</strong> @lastImported.BatchNo</p>
            <p><strong>File:</strong> @lastImported.FileName</p>
            <p><strong>ImportedBy:</strong> @lastImported.ImportedBy</p>
            <p><strong>ImportedAt:</strong> @lastImported.ImportedAt</p>
            <p><strong>Status:</strong> @lastImported.Status</p>
            <p><strong>RowCount:</strong> @lastImported.RowCount</p>
            <div class="mt-3">
                <button class="btn btn-danger" @onclick="Delete" disabled="@isDelete">Delete</button>
            </div>

            <table class="table table-sm table-bordered">
                <thead>
                    <tr>
                        <th>Page</th>
                        <th>OrderNo</th>
                        <th>PickupDate</th>
                        <th>ShipByDate</th>
                        <th>SenderName</th>
                        <th>SenderAddress</th>
                        <th>ReceiverName</th>
                        <th>ReceiverAddress</th>
                        <th>ItemName</th>
                        <th>IsCOD</th>
                        <th>ItemVariant</th>
                        <th>Qty</th>
                    </tr>
                </thead>
                <tbody>
                    @if (lastImported.Rows != null && lastImported.Rows.Any())
                    {
                        @foreach (var r in lastImported.Rows)
                        {
                            <tr>
                                <td>@r.PageNo</td>
                                <td>@r.OrderNo</td>
                                <td>@r.PickupDate?.ToString("dd-MM-yyyy")</td>
                                <td>@r.ShipByDate?.ToString("dd-MM-yyyy")</td>
                                <td>@r.SenderName</td>
                                <td>@r.SenderAddress</td>
                                <td>@r.ReceiverName</td>
                                <td>@r.ReceiverAddress</td>
                                <td>@r.ItemName</td>
                                <td>@r.IsCod</td>
                                <td>@r.ItemVariant</td>
                                <td>@r.Qty</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="12" class="text-muted text-center">No rows found</td>
                        </tr>
                    }
                </tbody>
            </table>

            <button class="btn btn-outline-secondary" @onclick="ClearImported">Clear</button>
        </div>
    </div>
}

@code {
    private string? tokenRaw;
    private string? token;

    private IBrowserFile? selectedFile;
    private string? selectedFileName;
    private string? previewText;
    private bool? isSaving;
    private bool? isDelete;

    private UploadResponseDtos? lastUpload;
    private IdwImportDtos? lastImported;

    private MemoryStream? cachedFileStream;
    private string? importId;

    private string ApiBase => Options.Value.ApiBaseUrl ?? "";

    // ===== Lookup state =====
    private bool isLookupLoading = false;
    private List<CompanyItemDtos>? companies;
    private List<MiscItemDtos>? platforms;
    private List<MiscItemDtos>? logistics;

    // shop dropdown (ขึ้นกับ partner ของ company)
    private List<ShopDtos> shops = new();
    private int? selectedShopDbId;

    // ค่าที่เลือก
    private int? selectedCompanyIdBacking;
    private int? SelectedCompanyId
    {
        get => selectedCompanyIdBacking;
        set
        {
            if (selectedCompanyIdBacking != value)
            {
                selectedCompanyIdBacking = value;
                _ = OnCompanyChanged();
            }
        }
    }
    private int? selectedPlatformId;
    private int? selectedLogisticId;

    private bool DisableSave => isSaving == true
                                || selectedFile == null
                                || isLookupLoading
                                || !SelectedCompanyId.HasValue
                                || !selectedPlatformId.HasValue
                                || !selectedLogisticId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        await LoginAsync("admin", "123456yjm");
        await LoadLookupsAsync();
    }

    private async Task LoadLookupsAsync()
    {
        if (string.IsNullOrWhiteSpace(token)) return;
        isLookupLoading = true;
        try
        {
            var ct = CancellationToken.None;
            companies = await IdwImportService.GetCompaniesAsync(token!, ct);
            platforms = await IdwImportService.GetPlatformsAsync(token!, ct);
            logistics = await IdwImportService.GetLogisticsAsync(token!, ct);

            // default select first
            SelectedCompanyId ??= companies?.FirstOrDefault()?.Id;
            selectedPlatformId ??= platforms?.FirstOrDefault()?.Id;
            selectedLogisticId ??= logistics?.FirstOrDefault()?.Id;

            // โหลด shops ตาม company ที่เลือก (ถ้ามี)
            await LoadShopsForSelectedCompanyAsync();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load lookups failed: {ex.Message}", "error");
        }
        finally
        {
            isLookupLoading = false;
            StateHasChanged();
        }
    }

    // ดึง PartnerId ของบริษัท แล้วโหลด shops ด้วย partnerId
    private async Task OnCompanyChanged()
    {
        // reset shop selection
        selectedShopDbId = null;
        await LoadShopsForSelectedCompanyAsync();
        StateHasChanged();
    }

    private async Task LoadShopsForSelectedCompanyAsync()
    {
        shops.Clear();

        if (!SelectedCompanyId.HasValue || companies is null || string.IsNullOrWhiteSpace(token))
            return;

        var comp = companies.FirstOrDefault(c => c.Id == SelectedCompanyId.Value);
        if (comp == null) return;

        var partnerId = comp.PartnerId;
        if (partnerId <= 0) return;

        try
        {
            var list = await ShopSvc.GetShopsAsync(token!, partnerId);
            shops = list?.OrderBy(s => s.Name).ToList() ?? new List<ShopDtos>();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load shops failed: {ex.Message}", "error");
        }
    }

    private string CurrentPartnerIdText
        => (companies?.FirstOrDefault(c => c.Id == SelectedCompanyId)?.PartnerId)?.ToString() ?? "-";

    // ---- helpers ----
    private static string? NormalizeToken(string? t)
    {
        if (string.IsNullOrWhiteSpace(t)) return null;
        t = t.Trim().Trim('"');
        if (t.StartsWith("Bearer ", StringComparison.OrdinalIgnoreCase))
            t = t.Substring(7).Trim();
        return t;
    }

    private static bool Is401(Exception ex) =>
        ex.Message.Contains("401") || ex.Message.Contains("Unauthorized", StringComparison.OrdinalIgnoreCase);

    private async Task LoginAsync(string user, string pass)
    {
        var resp = await IdwImportService.LoginAsync(user, pass);
        tokenRaw = resp?.Token;
        token = NormalizeToken(tokenRaw);

        if (string.IsNullOrWhiteSpace(token))
            await JS.InvokeVoidAsync("showToast", "Login failed (no token)", "error");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = selectedFile.Name;

        await using var stream = selectedFile.OpenReadStream(maxAllowedSize: 10_000_000);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        previewText = Encoding.UTF8.GetString(ms.ToArray());
        if (previewText.Length > 1000) previewText = previewText[..1000] + "... (truncated)";

        cachedFileStream = new MemoryStream(ms.ToArray());
    }

    private async Task<UploadResponseDtos> DoUploadAsync()
    {
        var bytes = cachedFileStream!.ToArray();
        await using var ms = new MemoryStream(bytes, writable: false);
        return await IdwImportService.UploadImportAsync(
            token!,
            ms,
            selectedFile!.Name,
            companyId: SelectedCompanyId,
            shopId: selectedShopDbId,
            miscIdPlatform: selectedPlatformId,
            miscIdLogistic: selectedLogisticId,
            CancellationToken.None
        );
    }

    private async Task Save()
    {
        if (selectedFile == null || string.IsNullOrWhiteSpace(token) || cachedFileStream == null) return;
        isSaving = true;
        try
        {
            try
            {
                lastUpload = await DoUploadAsync();
            }
            catch (Exception ex) when (Is401(ex))
            {
                await LoginAsync("admin", "123456yjm");
                lastUpload = await DoUploadAsync();
            }

            if (lastUpload != null && lastUpload.importId > 0)
            {
                importId = lastUpload.importId.ToString();
                await JS.InvokeVoidAsync("showToast",
                    $"Import {importId}: +{lastUpload.rows}, skippedDb={lastUpload.skippedDb}, skippedFile={lastUpload.skippedFile}",
                    "success");

                lastImported = await IdwImportService.GetImportAsync(token!, lastUpload.importId);

                selectedFile = null;
                selectedFileName = null;
                previewText = null;
                cachedFileStream?.Dispose();
                cachedFileStream = null;
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", "Import failed", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task Delete()
    {
        if (string.IsNullOrWhiteSpace(token) || lastImported?.BatchNo is null) return;

        var ok = await JS.InvokeAsync<bool>("confirm", $"Delete batch '{lastImported.BatchNo}' and all its rows?");
        if (!ok) return;

        isDelete = true;
        try
        {
            await IdwImportService.DeleteImportByBatchAsync(token!, lastImported.BatchNo);
            await JS.InvokeVoidAsync("showToast", $"Deleted batch {lastImported.BatchNo}", "success");
            lastImported = null;
            importId = null;
            selectedFile = null;
            selectedFileName = null;
            previewText = null;
            lastUpload = null;
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Delete failed: {ex.Message}", "error");
        }
        finally
        {
            isDelete = false;
            StateHasChanged();
        }
    }

    private void IdwImportEditForm(long id) => Navigation.NavigateTo($"/IdwImportEdit/{id}");
    private void Cancel() { selectedFile = null; selectedFileName = null; previewText = null; }
    private void ClearImported() { lastImported = null; lastUpload = null; }
}
