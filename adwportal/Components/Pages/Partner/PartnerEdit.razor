@page "/PartnerEdit"
@page "/PartnerEdit/{Id:int}"
@using adwportal.Dtos
@using adwportal.Services
@inject PartnerService Svc
@inject IdwImportService Idw
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Partner @title</h3>

@if (loading)
{
    <div class="alert alert-info">Loading...</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="model.Name" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">PartnerId (external)</label>
                    <input type="number" class="form-control" @bind="model.PartnerId" />
                </div>
                <div class="col-md-8">
                    <label class="form-label">PartnerKey (secret)</label>
                    <input class="form-control" @bind="model.PartnerKey" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Environment</label>
                    <input class="form-control" @bind="model.Environment" placeholder="e.g. production / test-stable" />
                </div>

                @if (Id.HasValue && loadedPartner != null)
                {
                    <div class="col-md-4">
                        <label class="form-label">Created</label>
                        <input class="form-control" value="@loadedPartner.CreatedAt.ToString("yyyy-MM-dd HH:mm")" disabled />
                    </div>
                }
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="Save" disabled="@saving">Save</button>
                <button class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }

    string? token;
    bool loading, saving;
    string? error;
    string title = "Add";

    PartnerUpsertDtos model = new();
    PartnerDtos? loadedPartner;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;

            var login = await Idw.LoginAsync("admin", "123456yjm");
            token = login?.Token;
            if (string.IsNullOrWhiteSpace(token)) { error = "Login failed"; return; }

            if (Id.HasValue)
            {
                title = "Edit";
                loadedPartner = await Svc.GetPartnerAsync(token!, Id.Value);
                if (loadedPartner == null) { error = "Not found"; return; }

                model = new PartnerUpsertDtos
                {
                    Name = loadedPartner.Name ?? "",
                    PartnerId = loadedPartner.PartnerId,
                    PartnerKey = loadedPartner.PartnerKey,
                    Environment = loadedPartner.Environment
                };
            }
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    async Task Save()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(model.Name))
            {
                await JS.InvokeVoidAsync("showToast", "Name is required", "error");
                return;
            }
            if (model.PartnerId <= 0)
            {
                await JS.InvokeVoidAsync("showToast", "PartnerId must be > 0", "error");
                return;
            }
            if (string.IsNullOrWhiteSpace(model.PartnerKey))
            {
                await JS.InvokeVoidAsync("showToast", "PartnerKey is required", "error");
                return;
            }

            saving = true;

            if (Id.HasValue)
                _ = await Svc.UpdatePartnerAsync(token!, Id.Value, model);
            else
                _ = await Svc.CreatePartnerAsync(token!, model);

            await JS.InvokeVoidAsync("showToast", "Saved", "success");
            Nav.NavigateTo("/PartnerList");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
        finally
        {
            saving = false;
        }
    }

    void Cancel() => Nav.NavigateTo("/PartnerList");
}
