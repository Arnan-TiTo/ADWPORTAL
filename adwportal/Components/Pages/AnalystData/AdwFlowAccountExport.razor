    private async Task SyncPreparedToFlowAccount()
    {
        errorMessage = null;
        erpSyncMessage = null;

        if (preparedPayloads.Count == 0)
        {
            errorMessage = "ยังไม่มี payload ที่เตรียมไว้";
            return;
        }

        isSyncingErp = true;
        erpSyncResults.Clear();

        try
        {
            foreach (var doc in preparedPayloads)
            {
                erpSyncResults[doc.Reference] = await PostPreparedPayloadAsync(doc);
            }

            var ok = erpSyncResults.Count(x => x.Value == "Synced");
            erpSyncMessage = $"Sync ERP เสร็จแล้ว สำเร็จ {ok}/{preparedPayloads.Count} เอกสาร";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSyncingErp = false;
        }
    }

    private async Task SyncPreparedRowToFlowAccount(PreparedFlowPayload doc)
    {
        errorMessage = null;
        erpSyncMessage = null;

        isSyncingErp = true;
        try
        {
            erpSyncResults[doc.Reference] = await PostPreparedPayloadAsync(doc);
            erpSyncMessage = erpSyncResults[doc.Reference] == "Synced"
                ? $"Sync ERP สำเร็จ: {doc.Reference}"
                : $"Sync ERP ไม่สำเร็จ: {doc.Reference}";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSyncingErp = false;
        }
    }

    private async Task<string> PostPreparedPayloadAsync(PreparedFlowPayload doc)
    {
        if (_mdwClient is null)
            throw new InvalidOperationException("Token MDW is not ready.");

        var qs = new Dictionary<string, string?>
        {
            ["channel"] = filter.Channel,
            ["shopId"] = filter.ShopId,
            ["reference"] = doc.Reference
        };

        var endpoint = QueryHelpers.AddQueryString("api/adw/export/flowaccount/cashsale/sync", qs);
        var json = JsonSerializer.Serialize(doc.Payload);
        using var content = new StringContent(json, Encoding.UTF8, "application/json");
        using var resp = await _mdwClient.PostAsync(endpoint, content);
        var body = await resp.Content.ReadAsStringAsync();

        return resp.IsSuccessStatusCode
            ? "Synced"
            : $"Failed {(int)resp.StatusCode}: {TrimForDisplay(body, 180)}";
    }

    private string BuildApiUrl(string path, bool withPaging = false)
    {
        var baseUri = _mdwClient!.BaseAddress!;
        var root = new Uri(baseUri, path);

        var qs = new Dictionary<string, string?>();

        if (!string.IsNullOrWhiteSpace(filter.Channel)) qs["channel"] = filter.Channel;
        if (!string.IsNullOrWhiteSpace(filter.ShopId)) qs["shopId"] = filter.ShopId;
        if (!string.IsNullOrWhiteSpace(filter.ExternalOrderNo)) qs["q"] = filter.ExternalOrderNo.Trim();

        if (filter.CreatedFrom.HasValue) qs["createdFrom"] = filter.CreatedFrom.Value.ToString("yyyy-MM-dd");
        if (filter.CreatedTo.HasValue) qs["createdTo"] = filter.CreatedTo.Value.ToString("yyyy-MM-dd");
        if (filter.UpdatedFrom.HasValue) qs["updatedFrom"] = filter.UpdatedFrom.Value.ToString("yyyy-MM-dd");
        if (filter.UpdatedTo.HasValue) qs["updatedTo"] = filter.UpdatedTo.Value.ToString("yyyy-MM-dd");

        if (withPaging)
        {
            qs["page"] = filter.Page.ToString(CultureInfo.InvariantCulture);
            qs["pageSize"] = filter.PageSize.ToString(CultureInfo.InvariantCulture);
        }

        return QueryHelpers.AddQueryString(root.ToString(), qs!);
    }

    private async Task UpdateAddressesForTargetsAsync(IEnumerable<(string Channel, long ShopId)> targets)
    {
        foreach (var target in targets
            .Where(x => !string.IsNullOrWhiteSpace(x.Channel) && x.ShopId > 0)
            .Select(x => (Channel: CanonicalPlatform(x.Channel), x.ShopId))
            .Distinct())
        {
            var updateQs = new Dictionary<string, string?>
            {
                ["channel"] = target.Channel,
                ["shopId"] = target.ShopId.ToString(CultureInfo.InvariantCulture),
                ["dryRun"] = "false",
                ["overwrite"] = "false"
            };

            var updateUrl = QueryHelpers.AddQueryString("api/adw/maintenance/update-addresses", updateQs);
            using var updResp = await _mdwClient!.PostAsync(updateUrl, content: null);
            updResp.EnsureSuccessStatusCode();
        }
    }

    private static IEnumerable<(string Channel, long ShopId)> ExtractAddressTargets(IEnumerable<Dictionary<string, object?>> rows)
    {
        foreach (var row in rows)
        {
            var channel = FirstNonEmpty(
                Cell(row, "channel"),
                Cell(row, "Channel"),
                Cell(row, "sale_channel"),
                Cell(row, "platform"),
                Cell(row, "Platform"));

            var shopText = FirstNonEmpty(
                Cell(row, "shopId"),
                Cell(row, "ShopId"),
                Cell(row, "shop_id"),
                Cell(row, "shopid"));

            if (!string.IsNullOrWhiteSpace(channel) && long.TryParse(shopText, NumberStyles.Any, CultureInfo.InvariantCulture, out var shopId))
                yield return (channel!, shopId);
        }
    }

