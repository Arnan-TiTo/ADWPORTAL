@page "/AdwFlowAccountExport"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.WebUtilities
@using System.Globalization
@inject IHttpClientFactory ClientFactory
@inject IJSRuntime JS
@inject adwportal.Services.MdwMarketplaceService MdwSvc

<h3 class="mb-3">FlowAccount Export</h3>

<div class="card mb-3">
    <div class="card-body">
        <EditForm Model="@filter" OnValidSubmit="@SearchAsync">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Channel</label>
                    <InputSelect class="form-select" @bind-Value="filter.Channel">
                        <option value="">-- Select --</option>
                        <option>Shopee</option>
                        <option>Lazada</option>
                        <option>TikTok</option>
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Shop ID</label>
                    <InputText class="form-control" @bind-Value="filter.ShopId" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Created From (TH)</label>
                    <InputDate class="form-control" @bind-Value="filter.CreatedFrom" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Created To (TH)</label>
                    <InputDate class="form-control" @bind-Value="filter.CreatedTo" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Updated From (TH)</label>
                    <InputDate class="form-control" @bind-Value="filter.UpdatedFrom" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Updated To (TH)</label>
                    <InputDate class="form-control" @bind-Value="filter.UpdatedTo" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Page</label>
                    <InputNumber class="form-control" @bind-Value="filter.Page" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Page Size</label>
                    <InputNumber class="form-control" @bind-Value="filter.PageSize" />
                </div>

                <div class="col-md-12 d-flex gap-2 mt-2">
                    <button type="submit" class="btn btn-primary">ค้นหา</button>
                    <button type="button" class="btn btn-outline-success" @onclick="ExportCsvLocal">Export CSV</button>
                    <button type="button" class="btn btn-outline-info" @onclick="ExportExcelLocal">Export Excel</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="alert alert-info">กำลังดึงข้อมูล...</div>
}
else
{
    <div class="mb-2 text-muted">
        Total: @totalItems | Page @filter.Page of @((int)Math.Ceiling((double)totalItems / Math.Max(1, filter.PageSize)))
    </div>

    <div class="table-responsive" style="max-height:70vh; overflow:auto;">
        <table class="table table-sm table-striped align-middle">
            <thead class="table-light">
                <tr>
                    @foreach (var col in columns)
                    {
                        <th>@col</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (items is not null)
                {
                    foreach (var row in items)
                    {
                        <tr>
                            @foreach (var col in columns)
                            {
                                row.TryGetValue(col, out var v);
                                <td>@(FmtCell(v))</td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" @onclick="PrevPage" disabled="@IsPrevDisabled">Prev</button>
        <button class="btn btn-outline-secondary" @onclick="NextPage" disabled="@IsNextDisabled">Next</button>
    </div>
}

@code {
    // ===== ลำดับคอลัมน์ (CSV ,) =====
    private static readonly string[] DesiredCsvOrder = new[] {
    "order_no","sale_channel","created_at_th","confirmed_at_th","paid_at_th",
    "buyer_userid","shipto_name","shipto_phone","shipto_email","shipto_address",
    "shipto_district","shipto_city","shipto_state","shipto_postcode",
    "shipment_provider","shipment_service","tracking_no_auto","shipping_fee","payment_method",
    "sale_price","list_price","product_code","sku","barcode","brand","category_main","category_sub",
    "product_name","option1","option2","qty_sold","bill_discount","linepay_coupon","line_points",
    "tracking_no","link_follow_status","payment_status","fulfillment_status","order_status",
    "canceled_at_th","cancel_reason","seller_note","buyer_note",
    "coupon_product_code","coupon_product_amount","coupon_line_code","coupon_line_amount",
    "coupon_shipping_code","coupon_shipping_amount","is_gift","is_preorder","transfer_status",
    "expected_payout_date_th","payout_date_th","amount_processing","amount_pending","amount_received",
    "fee_payment","fee_service","vat_amount","wht_coupon_only","share_and_earn","points_paid"
  };

    // ===== state =====
    private string? _mdwToken;
    private HttpClient? _mdwClient;

    // แถวสำหรับ export (string พร้อมใช้งาน)
    private List<Dictionary<string, string>> exportRows = new();

    private class FilterVm
    {
        public string Channel { get; set; } = "Shopee";
        public string? ShopId { get; set; } = "225987929";
        public DateTime? CreatedFrom { get; set; }
        public DateTime? CreatedTo { get; set; }
        public DateTime? UpdatedFrom { get; set; }
        public DateTime? UpdatedTo { get; set; }
        public int Page { get; set; } = 1;
        public int PageSize { get; set; } = 100;
    }

    private FilterVm filter = new();
    private bool isLoading;
    private string? errorMessage;
    private int totalItems;
    private List<Dictionary<string, object?>>? items;
    private List<string> columns = new();

    private bool IsPrevDisabled => filter.Page <= 1;
    private bool IsNextDisabled => (filter.Page * filter.PageSize) >= totalItems;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var login = await MdwSvc.LoginAsync("admin", "123456yjm");
            _mdwToken = NormalizeToken(login?.Token) ?? throw new Exception("Login MDW failed");

            _mdwClient = ClientFactory.CreateClient("MdwApiBaseUrl");
            _mdwClient.DefaultRequestHeaders.Authorization =
              new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _mdwToken);

            await SearchAsync();
        }
        catch (Exception ex) { errorMessage = ex.Message; StateHasChanged(); }
    }

    private static string? NormalizeToken(string? t)
    {
        if (string.IsNullOrWhiteSpace(t)) return null;
        t = t.Trim().Trim('"');
        if (t.StartsWith("Bearer ", StringComparison.OrdinalIgnoreCase)) t = t[7..].Trim();
        return t;
    }

    // ===== query data =====
    private async Task SearchAsync()
    {
        if (_mdwClient is null) { errorMessage = "MDW client is not ready."; return; }

        isLoading = true; errorMessage = null;
        items = null; totalItems = 0; columns.Clear(); exportRows.Clear();

        try
        {
            var url = BuildApiUrl("/api/adw/export/flowaccount/orders", withPaging: true);
            var resp = await _mdwClient.GetFromJsonAsync<ApiResp>(url);
            totalItems = resp?.total ?? 0;

            items = (resp?.items ?? new()).Select(RowToDict).ToList();

            // ===== บังคับคอลัมน์ = DesiredCsvOrder ทั้งหมด (ถ้าไม่มีค่า จะเว้นว่าง) =====
            columns = DesiredCsvOrder.ToList();

            // build exportRows
            foreach (var r in items)
            {
                var d = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
                foreach (var c in columns)
                {
                    r.TryGetValue(c, out var val);
                    d[c] = FmtCell(val); // แปลงเป็น string พร้อมใช้งาน
                }
                exportRows.Add(d);
            }
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isLoading = false; }
    }

    // === Export (client-side) ===
    private async Task ExportCsvLocal()
    {
        if (columns.Count == 0 || exportRows.Count == 0) { errorMessage = "ไม่มีข้อมูลสำหรับส่งออก"; return; }
        var file = $"order-export_{filter.Channel}_{filter.ShopId}_{DateTime.Now:yyyyMMddHHmmss}.csv";
        await JS.InvokeVoidAsync("adwExportCsvFromRows", columns, exportRows, file);
    }

    private async Task ExportExcelLocal()
    {
        if (columns.Count == 0 || exportRows.Count == 0) { errorMessage = "ไม่มีข้อมูลสำหรับส่งออก"; return; }
        var file = $"order-export_{filter.Channel}_{filter.ShopId}_{DateTime.Now:yyyyMMddHHmmss}.xls";
        await JS.InvokeVoidAsync("adwExportExcelFromRows", columns, exportRows, file);
    }

    private string BuildApiUrl(string path, bool withPaging = false)
    {
        var baseUri = _mdwClient!.BaseAddress!;
        var root = new Uri(baseUri, path);
        var qs = new Dictionary<string, string?>
        {
            ["channel"] = filter.Channel,
            ["shopId"] = filter.ShopId
        };
        if (filter.CreatedFrom.HasValue) qs["createdFrom"] = filter.CreatedFrom.Value.ToString("yyyy-MM-dd");
        if (filter.CreatedTo.HasValue) qs["createdTo"] = filter.CreatedTo.Value.ToString("yyyy-MM-dd");
        if (filter.UpdatedFrom.HasValue) qs["updatedFrom"] = filter.UpdatedFrom.Value.ToString("yyyy-MM-dd");
        if (filter.UpdatedTo.HasValue) qs["updatedTo"] = filter.UpdatedTo.Value.ToString("yyyy-MM-dd");
        if (withPaging)
        {
            qs["page"] = filter.Page.ToString(CultureInfo.InvariantCulture);
            qs["pageSize"] = filter.PageSize.ToString(CultureInfo.InvariantCulture);
        }
        return QueryHelpers.AddQueryString(root.ToString(), qs!);
    }

    private void PrevPage() { if (!IsPrevDisabled) { filter.Page--; _ = SearchAsync(); } }
    private void NextPage() { if (!IsNextDisabled) { filter.Page++; _ = SearchAsync(); } }

    // ===== response models / helpers =====
    private class ApiResp
    {
        public int total { get; set; }
        public int page { get; set; }
        public int pageSize { get; set; }
        public List<object> items { get; set; } = new();
    }

    private static Dictionary<string, object?> RowToDict(object row)
    {
        if (row is System.Text.Json.JsonElement je) return JsonToDict(je);
        if (row is IDictionary<string, object> d2)
            return d2.ToDictionary(kv => kv.Key, kv => kv.Value is DBNull ? null : (object?)kv.Value);
        if (row is IReadOnlyDictionary<string, object> rd2)
            return rd2.ToDictionary(kv => kv.Key, kv => kv.Value is DBNull ? null : (object?)kv.Value);
        if (row is IDictionary<string, object?> d1)
            return d1.ToDictionary(kv => kv.Key, kv => kv.Value is DBNull ? null : kv.Value);

        var dict = new Dictionary<string, object?>();
        foreach (var p in row.GetType().GetProperties())
        {
            if (p.GetIndexParameters().Length > 0) continue;
            var val = p.GetValue(row);
            dict[p.Name] = val is DBNull ? null : val;
        }
        return dict;
    }

    private static Dictionary<string, object?> JsonToDict(System.Text.Json.JsonElement je)
    {
        var d = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
        foreach (var prop in je.EnumerateObject())
            d[prop.Name] = JsonToObj(prop.Value);
        return d;
    }

    private static object? JsonToObj(System.Text.Json.JsonElement v)
    {
        switch (v.ValueKind)
        {
            case System.Text.Json.JsonValueKind.Null: return null;
            case System.Text.Json.JsonValueKind.True: return true;
            case System.Text.Json.JsonValueKind.False: return false;
            case System.Text.Json.JsonValueKind.String:
                var s = v.GetString();
                if (DateTime.TryParse(s, out var dt)) return dt;
                return s;
            case System.Text.Json.JsonValueKind.Number:
                if (v.TryGetInt64(out var i64)) return i64;
                if (v.TryGetDecimal(out var dec)) return dec;
                return v.ToString();
            case System.Text.Json.JsonValueKind.Object:
                return JsonToDict(v);
            case System.Text.Json.JsonValueKind.Array:
                var list = new List<object?>();
                foreach (var e in v.EnumerateArray()) list.Add(JsonToObj(e));
                return list;
            default:
                return v.ToString();
        }
    }

    private static string FmtCell(object? v)
    {
        if (v is null) return "";
        if (v is DateTime dt) return dt.ToString("yyyy-MM-dd HH:mm:ss");
        if (v is DateTimeOffset dto) return dto.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss");
        if (v is bool b) return b ? "true" : "false";
        if (v is IEnumerable<object?> arr && v is not string)
            return string.Join(", ", arr.Select(FmtCell));
        if (v is IFormattable f)
            return f.ToString(null, CultureInfo.InvariantCulture);
        return v.ToString() ?? "";
    }
}

<script>
    function csvEscape(s) {
      if (s == null) return "";
      s = String(s);
      if (s.includes('"')) s = s.replace(/"/g, '""');
      if (s.search(/[",\n\r]/) >= 0) s = `"${s}"`;
      return s;
    }
    window.adwExportCsvFromRows = function (columns, rows, fileName) {
      const bom = new Uint8Array([0xEF, 0xBB, 0xBF]);
      const lines = [];
      lines.push(columns.map(csvEscape).join(',')); // <- comma
      for (const r of rows) {
        const line = columns.map(c => csvEscape(r[c] ?? '')).join(',');
        lines.push(line);
      }
      const blob = new Blob([bom, lines.join('\r\n')], { type: 'text/csv;charset=utf-8' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = fileName || 'export.csv';
      document.body.appendChild(a); a.click(); a.remove();
      setTimeout(() => URL.revokeObjectURL(a.href), 3000);
    };
    window.adwExportExcelFromRows = function (columns, rows, fileName) {
      const esc = s => String(s ?? '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      let html = '<html><head><meta charset="utf-8"></head><body><table border="1"><thead><tr>';
      for (const c of columns) html += `<th>${esc(c)}</th>`;
      html += '</tr></thead><tbody>';
      for (const r of rows) {
        html += '<tr>';
        for (const c of columns) html += `<td>${esc(r[c] ?? '')}</td>`;
        html += '</tr>';
      }
      html += '</tbody></table></body></html>';
      const blob = new Blob([html], { type: 'application/vnd.ms-excel;charset=utf-8' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = fileName || 'export.xls';
      document.body.appendChild(a); a.click(); a.remove();
      setTimeout(() => URL.revokeObjectURL(a.href), 3000);
    };
</script>
