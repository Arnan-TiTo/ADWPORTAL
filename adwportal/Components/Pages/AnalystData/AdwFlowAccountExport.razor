    private void PrepareFlowAccountPayloads()
    {
        errorMessage = null;
        erpSyncMessage = null;
        erpSyncResults.Clear();
        preparedPayloads.Clear();

        if (filter.ExportType != "CashSale")
        {
            errorMessage = "กรุณาเลือก Export Type เป็น FlowAccount Cash Sale Format ก่อนเตรียมข้อมูล";
            return;
        }

        if (items is null || items.Count == 0)
        {
            errorMessage = "ยังไม่มีข้อมูลสำหรับเตรียม payload กรุณาค้นหาข้อมูลก่อน";
            return;
        }

        var groups = items
            .Where(x => !string.IsNullOrWhiteSpace(Cell(x, "หมายเลขคำสั่งซื้อ/อ้างอิงจากเอกสาร")))
            .GroupBy(x => Cell(x, "หมายเลขคำสั่งซื้อ/อ้างอิงจากเอกสาร"), StringComparer.OrdinalIgnoreCase)
            .OrderBy(g => g.Key);

        foreach (var g in groups)
        {
            var rows = g.ToList();
            var first = rows[0];
            var publishedOn = DateOnlyText(Cell(first, "วันที่เอกสาร"));
            var reference = g.Key;
            var contactName = FirstNonEmpty(Cell(first, "ชื่อลูกค้า"), "Cash Sale / ขายเงินสด")!;
            var contactAddress = Cell(first, "ที่อยู่");
            var contactTaxId = Cell(first, "เลขผู้เสียภาษี");
            var contactBranch = Cell(first, "สาขา");
            var salesName = Cell(first, "พนักงานขาย");
            var remarks = Cell(first, "หมายเหตุ");
            var internalNotes = Cell(first, "โน้ตภายในบริษัท");

            var productItems = new List<Dictionary<string, object?>>();
            decimal subTotal = 0;
            decimal totalDiscount = 0;
            decimal grandTotal = 0;

            foreach (var row in rows)
            {
                var qty = DecimalCell(row, "จำนวน", 1);
                var price = DecimalCell(row, "ราคาต่อหน่วย", 0);
                var discount = DecimalCell(row, "ส่วนลด(บาท)", 0);
                var lineTotal = Math.Round((price * qty) - discount, 2);
                subTotal += Math.Round(price * qty, 2);
                totalDiscount += discount;
                grandTotal += lineTotal;

                productItems.Add(new Dictionary<string, object?>
                {
                    ["type"] = 3,
                    ["name"] = FirstNonEmpty(Cell(row, "ชื่อสินค้า/บริการ"), Cell(row, "รหัสสินค้า"), "สินค้า")!,
                    ["description"] = Cell(row, "รหัสสินค้า"),
                    ["quantity"] = qty,
                    ["unitName"] = FirstNonEmpty(Cell(row, "หน่วย"), "ชิ้น")!,
                    ["pricePerUnit"] = price,
                    ["total"] = lineTotal,
                    ["discountAmount"] = discount,
                    ["vatRate"] = -1,
                    ["documentStructureType"] = "InlineProductItem"
                });
            }

            var payload = new Dictionary<string, object?>
            {
                ["recordId"] = 0,
                ["documentStructureType"] = "InlineDocument",
                ["documentPaymentStructureType"] = "InlineDocumentWithPaymentReceivingOtherChannel",
                ["saleAndPurchaseChannel"] = filter.Channel,
                ["contactName"] = contactName,
                ["contactAddress"] = contactAddress,
                ["contactTaxId"] = contactTaxId,
                ["contactBranch"] = contactBranch,
                ["publishedOn"] = publishedOn,
                ["dueDate"] = publishedOn,
                ["creditType"] = 3,
                ["creditDays"] = 0,
                ["salesName"] = salesName,
                ["reference"] = reference,
                ["externalDocumentId"] = $"{filter.Channel}-{filter.ShopId}-{reference}",
                ["isVatInclusive"] = false,
                ["useInlineDiscount"] = true,
                ["discountType"] = 3,
                ["useInlineVat"] = false,
                ["subTotal"] = Math.Round(subTotal, 2),
                ["discountAmount"] = 0,
                ["totalAfterDiscount"] = Math.Round(grandTotal, 2),
                ["isVat"] = false,
                ["isManualVat"] = false,
                ["vatAmount"] = 0,
                ["grandTotal"] = Math.Round(grandTotal, 2),
                ["remarks"] = remarks,
                ["internalNotes"] = internalNotes,
                ["showSignatureOrStamp"] = false,
                ["paymentMethod"] = 13,
                ["paymentDate"] = publishedOn,
                ["collected"] = Math.Round(grandTotal, 2),
                ["paymentDeductionType"] = 0,
                ["paymentDeductionAmount"] = 0,
                ["withheldPercentage"] = 0,
                ["withheldAmount"] = 0,
                ["paymentRemarks"] = FirstNonEmpty(Cell(first, "วิธีการรับชำระ"), "Marketplace")!,
                ["remainingCollectedType"] = 0,
                ["remainingCollected"] = 0,
                ["otherChannelName"] = FirstNonEmpty(Cell(first, "วิธีการรับชำระ"), filter.Channel, "Marketplace")!,
                ["items"] = productItems
            };

            preparedPayloads.Add(new PreparedFlowPayload(
                Reference: reference,
                PublishedOn: publishedOn,
                ContactName: contactName,
                ItemCount: productItems.Count,
                GrandTotal: Math.Round(grandTotal, 2),
                Payload: payload));
        }

        if (preparedPayloads.Count == 0)
        {
            errorMessage = "ไม่พบรายการที่มีหมายเลขคำสั่งซื้อสำหรับเตรียม payload";
            return;
        }

        erpSyncMessage = $"เตรียมข้อมูลสำเร็จ {preparedPayloads.Count} เอกสาร พร้อมยิงไป FlowAccount endpoint /cash-invoices/inline/with-payment";
    }

