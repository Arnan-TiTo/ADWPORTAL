@page "/MiscEdit"
@page "/MiscEdit/{Id:int}"

@using adwportal.Dtos
@using adwportal.Services
@inject IdwImportService IdwSvc
@inject MiscService Svc
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Misc @title</h3>

@if (loading)
{
    <div class="alert alert-info">Loading...</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <!-- Type (distinct จากฐาน) -->
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <InputSelect class="form-select"
                                 @bind-Value="SelectedType"
                                 TValue="string">
                        <option value="">-- Select type --</option>
                        @foreach (var t in types)
                        {
                            <option value="@t">@t</option>
                        }
                    </InputSelect>
                    <div class="form-text">
                        * ค่านี้จะบันทึกลงฟิลด์ <code>Type</code> ของรายการ
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label">ParentId</label>
                    <input type="number" class="form-control" @bind="model.ParentId" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="model.Name" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Value1</label>
                    <input class="form-control" @bind="model.Value1" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Value2</label>
                    <input class="form-control" @bind="model.Value2" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Value3</label>
                    <input class="form-control" @bind="model.Value3" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Value4</label>
                    <input class="form-control" @bind="model.Value4" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Value5</label>
                    <input class="form-control" @bind="model.Value5" />
                </div>

                <div class="col-md-12">
                    <label class="form-label">Note</label>
                    <textarea rows="2" class="form-control" @bind="model.Note"></textarea>
                </div>

                <div class="col-md-3 d-flex align-items-center">
                    <div class="form-check mt-4">
                        <input id="chkActive" type="checkbox" class="form-check-input" @bind="model.IsActive" />
                        <label class="form-check-label" for="chkActive">Active</label>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="Save" disabled="@saving">Save</button>
                <button class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }

    // state
    bool loading, saving;
    string? error, token, title;

    // model ที่จะบันทึก
    MiscUpsertDtos model = new();

    // รายการ type (distinct)
    List<string> types = new();

    // ค่าที่เลือกในดรอปดาวน์
    string? selectedType;
    string? SelectedType
    {
        get => selectedType;
        set
        {
            selectedType = value;
            model.Type = selectedType;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;

            var login = await IdwSvc.LoginAsync("admin", "123456yjm");
            token = login?.Token;
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Login failed";
                return;
            }

            title = Id.HasValue ? "Edit" : "Add";

            // โหลด type แบบ distinct
            await LoadDistinctTypes();

            if (Id.HasValue)
            {
                var m = await Svc.GetMiscByIdAsync(token!, Id.Value);
                if (m == null)
                {
                    error = "Not found.";
                    return;
                }

                model = new MiscUpsertDtos
                {
                    ParentId = m.ParentId,
                    Name = m.Name,
                    Type = m.Type,
                    Value1 = m.Value1,
                    Value2 = m.Value2,
                    Value3 = m.Value3,
                    Value4 = m.Value4,
                    Value5 = m.Value5,
                    Note = m.Note,
                    IsActive = m.IsActive
                };

                // เผื่อ type เดิมไม่มีในลิสต์ (กรณีพิมพ์เอง)
                if (!string.IsNullOrWhiteSpace(model.Type) && !types.Contains(model.Type))
                {
                    types.Add(model.Type);
                    types = types
                        .Where(t => !string.IsNullOrWhiteSpace(t))
                        .Distinct(StringComparer.Ordinal)
                        .OrderBy(t => t)
                        .ToList();
                }

                SelectedType = model.Type; // ทำให้ dropdown ชี้ค่าปัจจุบัน
            }
            else
            {
                SelectedType = null; // หน้า Add ให้ผู้ใช้เลือก
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task LoadDistinctTypes()
    {
        try
        {
            var list = await Svc.GetMiscAsync(token!);
            types = list
                .Select(x => x.Type)
                .Where(t => !string.IsNullOrWhiteSpace(t))
                .Distinct(StringComparer.Ordinal)
                .OrderBy(t => t)
                .ToList();
        }
        catch (Exception ex)
        {
            types = new();
            await JS.InvokeVoidAsync("showToast", $"Load types failed: {ex.Message}", "error");
        }
    }

    async Task Save()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Please login";
                return;
            }

            if (string.IsNullOrWhiteSpace(model.Type))
            {
                await JS.InvokeVoidAsync("showToast", "Type is required", "error");
                return;
            }

            saving = true;

            if (Id.HasValue)
            {
                _ = await Svc.UpdateMiscAsync(token!, Id.Value, model);
            }
            else
            {
                _ = await Svc.CreateMiscAsync(token!, model);
            }

            await JS.InvokeVoidAsync("showToast", "Saved", "success");
            Nav.NavigateTo("/MiscList");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
        finally
        {
            saving = false;
        }
    }

    void Cancel() => Nav.NavigateTo("/MiscList");
}
