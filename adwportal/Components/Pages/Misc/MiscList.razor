@page "/MiscList"
@using adwportal.Dtos
@using adwportal.Services
@inject MiscService Svc
@inject AuthTokenProvider TokenProvider
@inject IJSRuntime JS
@inject NavigationManager Nav

<h3>Misc</h3>

@if (loading)
{
    <div class="alert alert-info">Loading...</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <select class="form-select" @bind="SelectedType">
                        <option value="">-- All --</option>
                        @foreach (var t in types)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="NameFilter" @bind:event="oninput" />
                </div>
                <div class="col-md-5 text-end">
                    <button class="btn btn-primary" @onclick="@Add">+ Add</button>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:80px">Id</th>
                    <th style="width:100px">ParentId</th>
                    <th style="width:160px">Type</th>
                    <th style="width:200px">Name</th>
                    <th>Value1</th>
                    <th>Value2</th>
                    <th>Value3</th>
                    <th>Value4</th>
                    <th>Value5</th>
                    <th style="width:100px">Active</th>
                    <th style="width:160px">Updated</th>
                    <th style="width:140px">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (pagedItems.Count == 0)
                {
                    <tr><td colspan="12" class="text-center text-muted">No data</td></tr>
                }
                else
                {
                    @foreach (var m in pagedItems)
                    {
                        <tr>
                            <td>@m.Id</td>
                            <td>@m.ParentId</td>
                            <td>@m.Type</td>
                            <td>@m.Name</td>
                            <td>@m.Value1</td>
                            <td>@m.Value2</td>
                            <td>@m.Value3</td>
                            <td>@m.Value4</td>
                            <td>@m.Value5</td>
                            <td>@(m.IsActive ? "Y" : "N")</td>
                            <td>@(m.UpdatedAt?.ToString("dd-MM-yyyy HH:mm") ?? m.CreatedAt?.ToString("dd-MM-yyyy HH:mm"))</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Edit(m.Id)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(m.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <nav>
        <ul class="pagination">
            <li class="page-item @(pageIndex == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="Prev">Prev</button>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(pageIndex == i ? "active" : "")">
                    <button class="page-link" @onclick="(() => Go(i))">@i</button>
                </li>
            }
            <li class="page-item @(pageIndex == totalPages ? "disabled" : "")">
                <button class="page-link" @onclick="Next">Next</button>
            </li>
        </ul>
    </nav>
}

@code {
    string? token;
    bool loading;
    string? error;

    List<string> types = new();

    // ---- ฟิลเตอร์ (ใช้ property + setter เรียก ApplyFilters) ----
    string? selectedType;
    string? SelectedType
    {
        get => selectedType;
        set
        {
            if (selectedType != value)
            {
                selectedType = value;
                pageIndex = 1;
                ApplyFilters();
            }
        }
    }

    string? nameFilter;
    string? NameFilter
    {
        get => nameFilter;
        set
        {
            if (nameFilter != value)
            {
                nameFilter = value;
                pageIndex = 1;
                ApplyFilters();
            }
        }
    }

    // ---- ข้อมูล ----
    List<MiscDtos> allRaw = new();
    List<MiscDtos> filtered = new();
    List<MiscDtos> pagedItems = new();

    const int pageSize = 10;
    int pageIndex = 1;
    int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;
            token = await TokenProvider.GetIdwTokenAsync();
            if (string.IsNullOrWhiteSpace(token)) { error = "Login failed"; return; }

            // โหลด types
            types = await Svc.GetMiscTypesAsync(token!);

            // โหลดข้อมูลทั้งหมดครั้งเดียว (ไม่ส่ง filter)
            allRaw = await Svc.GetMiscAsync(token!, type: null, name: null);

            // ตั้งค่าเริ่มต้น
            ApplyFilters();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    // ---- กรองข้อมูลในหน้า ----
    void ApplyFilters()
    {
        IEnumerable<MiscDtos> q = allRaw;

        if (!string.IsNullOrWhiteSpace(selectedType))
            q = q.Where(x => string.Equals(x.Type, selectedType, StringComparison.Ordinal));

        if (!string.IsNullOrWhiteSpace(nameFilter))
        {
            var kw = nameFilter.Trim();
            q = q.Where(x => (x.Name ?? "").Contains(kw, StringComparison.OrdinalIgnoreCase));
        }

        filtered = q
            .OrderBy(x => x.Type)
            .ThenBy(x => x.Name)
            .ThenBy(x => x.Id)
            .ToList();

        RecalcPage();
        StateHasChanged();
    }

    void RecalcPage()
    {
        totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)pageSize));
        pageIndex = Math.Clamp(pageIndex, 1, totalPages);
        pagedItems = filtered.Skip((pageIndex - 1) * pageSize).Take(pageSize).ToList();
    }

    void Prev() { if (pageIndex > 1) { pageIndex--; RecalcPage(); } }
    void Next() { if (pageIndex < totalPages) { pageIndex++; RecalcPage(); } }
    void Go(int i) { pageIndex = i; RecalcPage(); }

    void Add() => Nav.NavigateTo("/MiscEdit");
    void Edit(int id) => Nav.NavigateTo($"/MiscEdit/{id}");

    async Task Delete(int id)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Delete misc id={id} ?");
        if (!ok) return;
        try
        {
            await Svc.DeleteMiscAsync(token!, id);

            // ลบออกจาก allRaw แล้วกรองใหม่ (ไม่ยิง API ซ้ำ)
            var idx = allRaw.FindIndex(x => x.Id == id);
            if (idx >= 0) allRaw.RemoveAt(idx);

            await JS.InvokeVoidAsync("showToast", "Deleted", "success");
            ApplyFilters();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
    }
}
