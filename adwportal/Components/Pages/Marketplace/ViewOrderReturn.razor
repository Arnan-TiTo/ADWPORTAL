@page "/ViewOrderReturn"
@using System.Globalization
@using System.Security.Claims
@using System.Text.Json
@using adwportal.Dtos
@using adwportal.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject AuthenticationStateProvider Auth
@inject AuthTokenProvider TokenProvider
@inject MdwMarketplaceService MdwSvc
@inject ShopService ShopSvc
@inject ShopGroupService ShopGroupSvc
@inject MiscService MiscSvc
@inject IJSRuntime JS

<h3 class="mb-3">MDW — Order Return</h3>
<p class="text-muted">ค้นหาและเรียกดู Unified Return จาก MDW</p>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label">Channel</label>
                <select class="form-select" @bind="FilterChannel">
                    <option value="">(All)</option>
                    @foreach (var p in channelOptions)
                    {
                        <option value="@p">@p</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Shop</label>
                <select class="form-select" @bind="filterShopId">
                    <option value="">(All)</option>
                    @foreach (var s in FilteredShopOptions)
                    {
                        <option value="@s.ShopId">@((s.Name ?? "(no name)") + " · " + s.ShopId)</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Order Ref</label>
                <input class="form-control" @bind="filterOrderRef" @bind:event="oninput" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Return Ref</label>
                <input class="form-control" @bind="filterReturnRef" @bind:event="oninput" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select class="form-select" @bind="filterStatus">
                    <option value="">(All)</option>
                    @foreach (var st in orderStatusOptions)
                    {
                        <option value="@st">@st</option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label d-block">ช่วงวันที่</label>
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <input class="form-control" style="max-width:220px" type="datetime-local"
                           value="@fromLocalText" @onchange="OnFromLocalChanged" />
                    <span>—</span>
                    <input class="form-control" style="max-width:220px" type="datetime-local"
                           value="@toLocalText" @onchange="OnToLocalChanged" />
                </div>
                <div class="form-text">เวลาที่เลือกเป็น local time และจะแปลงเป็น UTC ตอนเรียก API</div>
            </div>

            <div class="col-md-2">
                <label class="form-label">Sort</label>
                <select class="form-select" @bind="filterSort">
                    <option value="updatedDesc">Updated ↓</option>
                    <option value="updatedAsc">Updated ↑</option>
                    <option value="createdDesc">Created ↓</option>
                    <option value="createdAsc">Created ↑</option>
                    <option value="ingestedDesc">Ingested ↓</option>
                    <option value="ingestedAsc">Ingested ↑</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Page Size</label>
                <select class="form-select" @bind="pageSize">
                    <option>20</option>
                    <option>50</option>
                    <option>100</option>
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <div class="form-check">
                    <input id="includeRaw" class="form-check-input" type="checkbox" @bind="includeRaw" />
                    <label class="form-check-label" for="includeRaw">includeRaw</label>
                </div>
            </div>

            <div class="col-12 d-flex gap-2">
                <button class="btn btn-primary" @onclick="Search" disabled="@loading">@(loading ? "Loading..." : "Search")</button>
                <button class="btn btn-outline-secondary" @onclick="ResetFilters" disabled="@loading">Reset</button>
                <button class="btn btn-outline-secondary" @onclick="SetToday" disabled="@loading">วันนี้</button>
                <button class="btn btn-outline-secondary" @onclick="SetLast24h" disabled="@loading">24h</button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<div class="card">
    <div class="card-body">
        @if (loading)
        {
            <div>Loading...</div>
        }
        else if (data?.Items is null || data.Items.Count == 0)
        {
            <div class="text-muted">No returns found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:110px">@SortHeader("id", "ID")</th>
                            <th style="width:110px">@SortHeader("channel", "Channel")</th>
                            <th style="width:130px">@SortHeader("shopId", "ShopId")</th>
                            <th>@SortHeader("orderRef", "Order Ref")</th>
                            <th>@SortHeader("returnRef", "Return Ref")</th>
                            <th style="width:140px">@SortHeader("status", "Status")</th>
                            <th style="width:170px">@SortHeader("created", "Created")</th>
                            <th style="width:170px">@SortHeader("updated", "Updated")</th>
                            <th style="width:170px">@SortHeader("ingested", "Ingested")</th>
                            <th style="width:90px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in SortedItems)
                        {
                            <tr>
                                <td>@DisplayId(r)</td>
                                <td>@Text(r.Channel)</td>
                                <td>@(r.ShopId?.ToString() ?? "-")</td>
                                <td>@Text(DisplayOrderRefWithRaw(r))</td>
                                <td>@Text(DisplayReturnRefWithRaw(r))</td>
                                <td>@Text(DisplayStatusWithRaw(r))</td>
                                <td>@Text(DisplayCreatedWithRaw(r))</td>
                                <td>@Text(DisplayUpdatedWithRaw(r))</td>
                                <td>@ToLocalStringAny(DisplayIngested(r))</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewDetail(DisplayId(r))">
                                        View
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-2">
                <div class="small text-muted">
                    Total: @data.TotalItems
                    &nbsp;•&nbsp; Page @currentPage / @TotalPages
                </div>
                <div class="btn-group">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(!CanPrev)">Prev</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(!CanNext)">Next</button>
                </div>
            </div>
        }
    </div>
</div>

@if (detail is not null)
{
    var returnView = BuildReturnView(detail);

    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <strong>Return @Text(returnView.ReturnRef)</strong>
                <span class="text-muted">(@Text(returnView.Channel))</span>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => detail = null">Close</button>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <h6>ข้อมูลการคืนสินค้า</h6>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Channel</dt>
                        <dd class="col-sm-8">@Text(returnView.Channel)</dd>
                        <dt class="col-sm-4">ShopId</dt>
                        <dd class="col-sm-8">@Text(returnView.ShopId)</dd>
                        <dt class="col-sm-4">เลขออเดอร์</dt>
                        <dd class="col-sm-8">@Text(returnView.OrderRef)</dd>
                        <dt class="col-sm-4">เลขคืนสินค้า</dt>
                        <dd class="col-sm-8">@Text(returnView.ReturnRef)</dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-secondary">@Text(returnView.Status)</span>
                        </dd>
                        <dt class="col-sm-4">เหตุผล</dt>
                        <dd class="col-sm-8">@Text(returnView.Reason)</dd>
                        <dt class="col-sm-4">รายละเอียดเหตุผล</dt>
                        <dd class="col-sm-8">@Text(returnView.TextReason)</dd>
                    </dl>
                </div>

                <div class="col-md-6">
                    <h6>ยอดเงินและลูกค้า</h6>
                    <dl class="row mb-0">
                        <dt class="col-sm-5">ยอด refund</dt>
                        <dd class="col-sm-7 fw-semibold">@Money(returnView.RefundAmount, returnView.Currency)</dd>
                        <dt class="col-sm-5">ยอดก่อนส่วนลด</dt>
                        <dd class="col-sm-7">@Money(returnView.AmountBeforeDiscount, returnView.Currency)</dd>
                        <dt class="col-sm-5">ผู้ซื้อ</dt>
                        <dd class="col-sm-7">@Text(returnView.BuyerUsername)</dd>
                        <dt class="col-sm-5">Email</dt>
                        <dd class="col-sm-7">@Text(returnView.BuyerEmail)</dd>
                        <dt class="col-sm-5">ชนิดคำขอ</dt>
                        <dd class="col-sm-7">@Text(returnView.ReturnRefundType)</dd>
                        <dt class="col-sm-5">Validation</dt>
                        <dd class="col-sm-7">@Text(returnView.ValidationType)</dd>
                    </dl>
                </div>

                <div class="col-md-6">
                    <h6>Timeline</h6>
                    <dl class="row mb-0">
                        <dt class="col-sm-5">สร้างคำขอ</dt>
                        <dd class="col-sm-7">@Text(returnView.CreatedAt)</dd>
                        <dt class="col-sm-5">อัปเดตล่าสุด</dt>
                        <dd class="col-sm-7">@Text(returnView.UpdatedAt)</dd>
                        <dt class="col-sm-5">Due date</dt>
                        <dd class="col-sm-7">@Text(returnView.DueDate)</dd>
                        <dt class="col-sm-5">กำหนดส่งคืน</dt>
                        <dd class="col-sm-7">@Text(returnView.ReturnShipDueDate)</dd>
                        <dt class="col-sm-5">เวลานำเข้าระบบ</dt>
                        <dd class="col-sm-7">@ToLocalStringAny(DisplayIngested(detail))</dd>
                    </dl>
                </div>

                <div class="col-md-6">
                    <h6>Logistics / Proof</h6>
                    <dl class="row mb-0">
                        <dt class="col-sm-5">เลขพัสดุ</dt>
                        <dd class="col-sm-7">@Text(returnView.TrackingNumber)</dd>
                        <dt class="col-sm-5">Logistics</dt>
                        <dd class="col-sm-7">@Text(returnView.LogisticsStatus)</dd>
                        <dt class="col-sm-5">Reverse logistics</dt>
                        <dd class="col-sm-7">@Text(returnView.ReverseLogisticsStatus)</dd>
                        <dt class="col-sm-5">ต้องใช้ logistics</dt>
                        <dd class="col-sm-7">@Text(returnView.NeedsLogistics)</dd>
                        <dt class="col-sm-5">หลักฐานผู้ขาย</dt>
                        <dd class="col-sm-7">@Text(returnView.SellerProofStatus)</dd>
                        <dt class="col-sm-5">หลักฐานจัดส่ง</dt>
                        <dd class="col-sm-7">@Text(returnView.UploadedShippingProof)</dd>
                    </dl>
                </div>

                <div class="col-12">
                    <h6>รายการสินค้า</h6>
                    @if (returnView.Items.Count == 0)
                    {
                        <div class="text-muted small">-</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>สินค้า</th>
                                        <th style="width:160px">SKU</th>
                                        <th style="width:90px" class="text-end">จำนวน</th>
                                        <th style="width:130px" class="text-end">ราคา</th>
                                        <th style="width:130px" class="text-end">Refund</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in returnView.Items)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@Text(item.Name)</div>
                                                <div class="small text-muted">ItemId: @Text(item.ItemId) · ModelId: @Text(item.ModelId)</div>
                                            </td>
                                            <td>
                                                <div>@Text(item.VariationSku)</div>
                                                @if (!string.IsNullOrWhiteSpace(item.ItemSku))
                                                {
                                                    <div class="small text-muted">@item.ItemSku</div>
                                                }
                                            </td>
                                            <td class="text-end">@Text(item.Amount)</td>
                                            <td class="text-end">@Money(item.ItemPrice, returnView.Currency)</td>
                                            <td class="text-end fw-semibold">@Money(item.RefundAmount, returnView.Currency)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="col-12">
                    <details>
                        <summary class="small text-muted">ข้อมูลเทคนิค RawJson</summary>
                        <div class="mt-2">
                            @RenderJsonBlock(detail.RawJson)
                        </div>
                    </details>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string? mdwToken;
    private string? idwToken;
    private readonly List<ShopDtos> allShops = new();
    private List<string> channelOptions = new();
    private List<string> orderStatusOptions = new();

    private bool loading;
    private string? error;
    private PagedResult<FeUnifiedReturnDtos>? data;
    private FeUnifiedReturnDtos? detail;

    private string? filterChannel = "";
    private string? filterShopId = "";
    private string? filterQ = "";
    private string? filterOrderRef = "";
    private string? filterReturnRef = "";
    private string? filterStatus = "";
    private string filterSort = "updatedDesc";
    private bool includeRaw = true;
    private int currentPage = 1;
    private int pageSize = 50;
    private string tableSortColumn = "id";
    private bool tableSortDescending = true;

    private string fromLocalText { get; set; } = DateTime.Now.AddDays(-1).ToString("yyyy-MM-ddTHH:mm");
    private string toLocalText { get; set; } = DateTime.Now.ToString("yyyy-MM-ddTHH:mm");

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)(data?.TotalItems ?? 0) / Math.Max(1, pageSize)));
    private bool CanPrev => !loading && currentPage > 1;
    private bool CanNext => !loading && currentPage < TotalPages;
    private IEnumerable<FeUnifiedReturnDtos> SortedItems => SortItems(data?.Items ?? new List<FeUnifiedReturnDtos>());

    private string FilterChannel
    {
        get => filterChannel ?? "";
        set
        {
            var v = CanonicalPlatform(value);
            if (string.Equals(filterChannel, v, StringComparison.OrdinalIgnoreCase)) return;
            filterChannel = v;
            filterShopId = "";
        }
    }

    private IEnumerable<ShopDtos> FilteredShopOptions =>
        allShops
            .Where(s => string.IsNullOrWhiteSpace(FilterChannel) ||
                        string.Equals(CanonicalPlatform(s.Platform), FilterChannel, StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.Name ?? s.ShopId.ToString());

    protected override async Task OnInitializedAsync()
    {
        try
        {
            mdwToken = NormalizeToken(await TokenProvider.GetMdwTokenAsync());
            idwToken = NormalizeToken(await TokenProvider.GetIdwTokenAsync());

            if (string.IsNullOrWhiteSpace(mdwToken))
            {
                error = "MDW token is empty. กรุณาเข้า Dashboard (หน้าแรก) หรือ login ใหม่อีกครั้ง";
                return;
            }

            await LoadLookupsAsync();
            await Reload();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task LoadLookupsAsync()
    {
        if (string.IsNullOrWhiteSpace(idwToken)) return;

        try
        {
            allShops.Clear();
            var authState = await Auth.GetAuthenticationStateAsync();
            var user = authState.User;
            var role = user.FindFirst("ROLE")?.Value ?? user.FindFirst(ClaimTypes.Role)?.Value ?? "";
            var username = user.FindFirst(ClaimTypes.Name)?.Value ?? "";

            if (role.Equals("Admin", StringComparison.OrdinalIgnoreCase))
            {
                var shops = await ShopSvc.GetShopsAsync(idwToken);
                allShops.AddRange((shops ?? new List<ShopDtos>())
                    .GroupBy(s => s.ShopId).Select(g => g.First())
                    .Select(s => s with { Platform = CanonicalPlatform(s.Platform) })
                    .OrderBy(s => s.Name));
            }
            else if (!string.IsNullOrWhiteSpace(username))
            {
                var effectiveShops = await ShopGroupSvc.GetUserEffectiveShopsByUsernameAsync(idwToken, username);
                allShops.AddRange(effectiveShops
                    .GroupBy(es => es.ShopId).Select(g => g.First())
                    .Select(es => new ShopDtos(
                        Id: 0,
                        ShopId: es.ShopId,
                        PartnerId: es.PartnerId,
                        Name: es.ShopName,
                        Country: null,
                        CreatedAt: DateTime.MinValue,
                        Platform: CanonicalPlatform(es.Platform)
                    )).OrderBy(s => s.Name));
            }

            var platforms = await MiscSvc.GetMiscAsync(idwToken, type: "Platform");
            var miscPlatforms = (platforms ?? new List<MiscDtos>())
                .Where(x => x.IsActive)
                .Select(x => CanonicalPlatform(!string.IsNullOrWhiteSpace(x.Name) ? x.Name : x.Value1))
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(x => x)
                .ToList();

            if (allShops.Any())
            {
                var shopPlatforms = allShops
                    .Select(s => s.Platform)
                    .Where(p => !string.IsNullOrWhiteSpace(p))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
                channelOptions = miscPlatforms.Where(p => shopPlatforms.Contains(p)).ToList();
            }
            else
            {
                channelOptions = miscPlatforms;
            }

            orderStatusOptions = await LoadMiscOptionsAsync(idwToken, "StatusOrder");
        }
        catch
        {
            channelOptions = allShops
                .Select(s => CanonicalPlatform(s.Platform))
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(x => x)
                .ToList();
        }
    }

    private async Task<List<string>> LoadMiscOptionsAsync(string token, string type)
    {
        var list = await MiscSvc.GetMiscAsync(token, type: type);
        return (list ?? new List<MiscDtos>())
            .Where(x => x.IsActive)
            .Select(x => !string.IsNullOrWhiteSpace(x.Name) ? x.Name : x.Value1)
            .Select(x => (x ?? "").Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();
    }

    private async Task Search()
    {
        currentPage = 1;
        await Reload();
    }

    private async Task Reload()
    {
        if (loading) return;
        loading = true;
        error = null;

        try
        {
            long? shopId = null;
            if (!string.IsNullOrWhiteSpace(filterShopId) && long.TryParse(filterShopId, out var sid))
                shopId = sid;

            data = await MdwSvc.FeReturnsListAsync(
                token: mdwToken,
                channel: string.IsNullOrWhiteSpace(filterChannel) ? null : filterChannel,
                shopId: shopId,
                q: string.IsNullOrWhiteSpace(filterQ) ? null : filterQ,
                orderRef: string.IsNullOrWhiteSpace(filterOrderRef) ? null : filterOrderRef,
                returnRef: string.IsNullOrWhiteSpace(filterReturnRef) ? null : filterReturnRef,
                status: string.IsNullOrWhiteSpace(filterStatus) ? null : filterStatus,
                fromUtc: ParseLocalToUtc(fromLocalText),
                toUtc: ParseLocalToUtc(toLocalText),
                page: currentPage,
                pageSize: pageSize,
                sort: filterSort,
                includeRaw: includeRaw);

            detail = null;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ViewDetail(long id)
    {
        if (id <= 0) return;

        try
        {
            detail = await MdwSvc.FeReturnGetByIdAsync(mdwToken, id, includeRaw: true);
            if (detail is null) await JS.InvokeVoidAsync("alert", $"Return {id} not found.");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", ex.Message);
        }
    }

    private async Task NextPage()
    {
        if (!CanNext) return;
        currentPage++;
        await Reload();
    }

    private async Task PrevPage()
    {
        if (!CanPrev) return;
        currentPage--;
        await Reload();
    }

    private void ResetFilters()
    {
        filterChannel = "";
        filterShopId = "";
        filterQ = "";
        filterOrderRef = "";
        filterReturnRef = "";
        filterStatus = "";
        filterSort = "updatedDesc";
        includeRaw = true;
        tableSortColumn = "id";
        tableSortDescending = true;
        currentPage = 1;
        pageSize = 50;
        fromLocalText = DateTime.Now.AddDays(-1).ToString("yyyy-MM-ddTHH:mm");
        toLocalText = DateTime.Now.ToString("yyyy-MM-ddTHH:mm");
        detail = null;
    }

    private async Task SetLast24h()
    {
        var to = DateTime.Now;
        fromLocalText = to.AddDays(-1).ToString("yyyy-MM-ddTHH:mm");
        toLocalText = to.ToString("yyyy-MM-ddTHH:mm");
        currentPage = 1;
        await Reload();
    }

    private async Task SetToday()
    {
        var now = DateTime.Now;
        var from = new DateTime(now.Year, now.Month, now.Day, 0, 0, 0);
        fromLocalText = from.ToString("yyyy-MM-ddTHH:mm");
        toLocalText = now.ToString("yyyy-MM-ddTHH:mm");
        currentPage = 1;
        await Reload();
    }

    private void OnFromLocalChanged(ChangeEventArgs e)
    {
        var s = e?.Value?.ToString() ?? "";
        if (!string.IsNullOrWhiteSpace(s)) fromLocalText = s;
    }

    private void OnToLocalChanged(ChangeEventArgs e)
    {
        var s = e?.Value?.ToString() ?? "";
        if (!string.IsNullOrWhiteSpace(s)) toLocalText = s;
    }

    private static string? NormalizeToken(string? t)
    {
        if (string.IsNullOrWhiteSpace(t)) return null;
        t = t.Trim().Trim('"');
        if (t.StartsWith("Bearer ", StringComparison.OrdinalIgnoreCase)) t = t[7..].Trim();
        return t;
    }

    private static string CanonicalPlatform(string? p)
    {
        var x = (p ?? "").Trim().ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(x)) return "";
        if (x.Contains("tiktok")) return "TikTok";
        if (x.Contains("shopee")) return "Shopee";
        if (x.Contains("lazada")) return "Lazada";
        return p?.Trim() ?? "";
    }

    private static DateTime ParseLocal(string s)
    {
        if (DateTime.TryParseExact(s ?? "", "yyyy-MM-ddTHH:mm:ss", CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var dt))
            return dt;
        if (DateTime.TryParseExact(s ?? "", "yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out dt))
            return dt;
        return DateTime.Now;
    }

    private static DateTime ParseLocalToUtc(string s) =>
        DateTime.SpecifyKind(ParseLocal(s), DateTimeKind.Local).ToUniversalTime();

    private static string ToLocalStringAny(object? utcVal)
    {
        if (utcVal is null) return "-";
        if (utcVal is DateTime dt) return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
        if (utcVal is string s && DateTime.TryParse(s, CultureInfo.InvariantCulture, DateTimeStyles.AdjustToUniversal | DateTimeStyles.AllowWhiteSpaces | DateTimeStyles.AssumeUniversal, out var dts))
            return dts.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
        return utcVal.ToString() ?? "-";
    }

    private static long DisplayId(FeUnifiedReturnDtos r) => r.UnifiedReturnId > 0 ? r.UnifiedReturnId : r.Id;
    private static string? DisplayOrderRef(FeUnifiedReturnDtos r) => FirstText(r.OrderRef, r.OrderSn, r.ExternalOrderNo);
    private static string? DisplayReturnRef(FeUnifiedReturnDtos r) => FirstText(r.ReturnRef, r.ReturnSn, r.ExternalReturnId);
    private static string? DisplayStatus(FeUnifiedReturnDtos r) => FirstText(r.Status, r.ReturnStatus);
    private static DateTime? DisplayIngested(FeUnifiedReturnDtos r) => r.IngestedTimeUtc ?? r.IngestedAtUtc;

    private static string? DisplayOrderRefWithRaw(FeUnifiedReturnDtos r) =>
        FirstText(DisplayOrderRef(r), GetRawResponseString(r, "order_sn"));

    private static string? DisplayReturnRefWithRaw(FeUnifiedReturnDtos r) =>
        FirstText(DisplayReturnRef(r), GetRawResponseString(r, "return_sn"));

    private static string? DisplayStatusWithRaw(FeUnifiedReturnDtos r) =>
        FirstText(DisplayStatus(r), GetRawResponseString(r, "status"));

    private static string? DisplayCreatedWithRaw(FeUnifiedReturnDtos r) =>
        FirstText(ToDisplayDate(r.CreatedTimeUtc), GetRawResponseUnixText(r, "create_time"));

    private static string? DisplayUpdatedWithRaw(FeUnifiedReturnDtos r) =>
        FirstText(ToDisplayDate(r.UpdatedTimeUtc), GetRawResponseUnixText(r, "update_time"));

    private static string? ToDisplayDate(DateTime? value) =>
        value.HasValue ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") : null;

    private void ToggleTableSort(string column)
    {
        if (string.Equals(tableSortColumn, column, StringComparison.OrdinalIgnoreCase))
        {
            tableSortDescending = !tableSortDescending;
        }
        else
        {
            tableSortColumn = column;
            tableSortDescending = DefaultDescending(column);
        }
    }

    private RenderFragment SortHeader(string column, string label) => builder =>
    {
        var active = string.Equals(tableSortColumn, column, StringComparison.OrdinalIgnoreCase);
        var icon = active ? (tableSortDescending ? "↓" : "↑") : "";

        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "type", "button");
        builder.AddAttribute(2, "class", "btn btn-link btn-sm p-0 text-decoration-none text-uppercase fw-semibold text-muted");
        builder.AddAttribute(3, "style", "font-size:inherit");
        builder.AddAttribute(4, "onclick", EventCallback.Factory.Create(this, () => ToggleTableSort(column)));
        builder.AddContent(5, label);
        if (!string.IsNullOrWhiteSpace(icon))
        {
            builder.AddContent(6, " ");
            builder.AddContent(7, icon);
        }
        builder.CloseElement();
    };

    private IEnumerable<FeUnifiedReturnDtos> SortItems(IEnumerable<FeUnifiedReturnDtos> source)
    {
        return tableSortColumn switch
        {
            "id" => SortBy(source, x => DisplayId(x)),
            "shopId" => SortBy(source, x => x.ShopId ?? 0),
            "created" => SortBy(source, x => DisplayCreatedKey(x)),
            "updated" => SortBy(source, x => DisplayUpdatedKey(x)),
            "ingested" => SortBy(source, x => DisplayIngested(x) ?? DateTime.MinValue),
            "channel" => SortBy(source, x => x.Channel ?? ""),
            "orderRef" => SortBy(source, x => DisplayOrderRefWithRaw(x) ?? ""),
            "returnRef" => SortBy(source, x => DisplayReturnRefWithRaw(x) ?? ""),
            "status" => SortBy(source, x => DisplayStatusWithRaw(x) ?? ""),
            _ => SortBy(source, x => DisplayId(x))
        };
    }

    private IEnumerable<FeUnifiedReturnDtos> SortBy<TKey>(IEnumerable<FeUnifiedReturnDtos> source, Func<FeUnifiedReturnDtos, TKey> keySelector) =>
        tableSortDescending ? source.OrderByDescending(keySelector).ToList() : source.OrderBy(keySelector).ToList();

    private static bool DefaultDescending(string column) =>
        column is "id" or "created" or "updated" or "ingested";

    private static DateTime DisplayCreatedKey(FeUnifiedReturnDtos r) =>
        r.CreatedTimeUtc?.ToLocalTime() ?? GetRawResponseUnixDate(r, "create_time") ?? DateTime.MinValue;

    private static DateTime DisplayUpdatedKey(FeUnifiedReturnDtos r) =>
        r.UpdatedTimeUtc?.ToLocalTime() ?? GetRawResponseUnixDate(r, "update_time") ?? DateTime.MinValue;

    private static string? FirstText(params string?[] values) =>
        values.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));

    private static string Text(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string Money(decimal? value, string? currency)
    {
        if (!value.HasValue) return "-";
        var suffix = string.IsNullOrWhiteSpace(currency) ? "" : $" {currency}";
        return value.Value.ToString("#,##0.##", CultureInfo.InvariantCulture) + suffix;
    }

    private static JsonElement FirstJson(params JsonElement[] values) =>
        values.FirstOrDefault(x => x.ValueKind is not JsonValueKind.Undefined and not JsonValueKind.Null);

    private static string? GetRawResponseString(FeUnifiedReturnDtos r, string name)
    {
        var response = GetRawResponse(r);
        return GetString(response, name);
    }

    private static string? GetRawResponseUnixText(FeUnifiedReturnDtos r, string name)
    {
        var response = GetRawResponse(r);
        return UnixText(response, name);
    }

    private static DateTime? GetRawResponseUnixDate(FeUnifiedReturnDtos r, string name)
    {
        var response = GetRawResponse(r);
        return UnixDate(response, name);
    }

    private static JsonElement GetRawResponse(FeUnifiedReturnDtos r)
    {
        var raw = MaterializeJson(r.RawJson);
        return TryGetProperty(raw, "response", out var response) ? response : raw;
    }

    private static ReturnDetailView BuildReturnView(FeUnifiedReturnDtos detail)
    {
        var response = GetRawResponse(detail);
        var user = TryGetProperty(response, "user", out var userEl) ? userEl : default;
        var sellerProof = TryGetProperty(response, "seller_proof", out var proofEl) ? proofEl : default;

        var items = new List<ReturnItemView>();
        if (TryGetProperty(response, "item", out var itemEl) && itemEl.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in itemEl.EnumerateArray())
            {
                items.Add(new ReturnItemView(
                    Name: GetString(item, "name"),
                    ItemId: GetString(item, "item_id"),
                    ModelId: GetString(item, "model_id"),
                    ItemSku: GetString(item, "item_sku"),
                    VariationSku: GetString(item, "variation_sku"),
                    Amount: GetString(item, "amount"),
                    ItemPrice: GetDecimal(item, "item_price"),
                    RefundAmount: GetDecimal(item, "refund_amount")
                ));
            }
        }

        return new ReturnDetailView(
            Channel: detail.Channel,
            ShopId: detail.ShopId?.ToString(CultureInfo.InvariantCulture),
            OrderRef: FirstText(GetString(response, "order_sn"), DisplayOrderRef(detail)),
            ReturnRef: FirstText(GetString(response, "return_sn"), DisplayReturnRef(detail)),
            Status: FirstText(GetString(response, "status"), DisplayStatus(detail)),
            Reason: FirstText(GetString(response, "reason"), detail.Reason),
            TextReason: GetString(response, "text_reason"),
            RefundAmount: GetDecimal(response, "refund_amount"),
            AmountBeforeDiscount: GetDecimal(response, "amount_before_discount"),
            Currency: GetString(response, "currency"),
            BuyerUsername: FirstText(GetString(user, "username"), detail.BuyerUsername),
            BuyerEmail: GetString(user, "email"),
            ReturnRefundType: GetString(response, "return_refund_type"),
            ValidationType: GetString(response, "validation_type"),
            CreatedAt: FirstText(UnixText(response, "create_time"), ToLocalStringAny(detail.CreatedTimeUtc)),
            UpdatedAt: FirstText(UnixText(response, "update_time"), ToLocalStringAny(detail.UpdatedTimeUtc)),
            DueDate: UnixText(response, "due_date"),
            ReturnShipDueDate: UnixText(response, "return_ship_due_date"),
            TrackingNumber: GetString(response, "tracking_number"),
            LogisticsStatus: GetString(response, "logistics_status"),
            ReverseLogisticsStatus: GetString(response, "reverse_logistics_status"),
            NeedsLogistics: BoolText(response, "needs_logistics"),
            SellerProofStatus: GetString(sellerProof, "seller_proof_status"),
            UploadedShippingProof: BoolText(response, "has_uploaded_shipping_proof"),
            Items: items
        );
    }

    private static JsonElement MaterializeJson(JsonElement value)
    {
        if (value.ValueKind == JsonValueKind.String)
        {
            var text = value.GetString();
            if (!string.IsNullOrWhiteSpace(text))
            {
                try
                {
                    using var doc = JsonDocument.Parse(text);
                    return doc.RootElement.Clone();
                }
                catch
                {
                    return value;
                }
            }
        }

        return value;
    }

    private static bool TryGetProperty(JsonElement element, string name, out JsonElement value)
    {
        value = default;
        return element.ValueKind == JsonValueKind.Object && element.TryGetProperty(name, out value);
    }

    private static string? GetString(JsonElement element, string name)
    {
        if (!TryGetProperty(element, name, out var value)) return null;
        return value.ValueKind switch
        {
            JsonValueKind.String => value.GetString(),
            JsonValueKind.Number => value.ToString(),
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            _ => null
        };
    }

    private static decimal? GetDecimal(JsonElement element, string name)
    {
        if (!TryGetProperty(element, name, out var value)) return null;
        if (value.ValueKind == JsonValueKind.Number && value.TryGetDecimal(out var d)) return d;
        if (value.ValueKind == JsonValueKind.String && decimal.TryParse(value.GetString(), NumberStyles.Any, CultureInfo.InvariantCulture, out d)) return d;
        return null;
    }

    private static string? UnixText(JsonElement element, string name)
    {
        var date = UnixDate(element, name);
        return date.HasValue ? date.Value.ToString("yyyy-MM-dd HH:mm:ss") : null;
    }

    private static DateTime? UnixDate(JsonElement element, string name)
    {
        if (!TryGetProperty(element, name, out var value)) return null;
        long unix = 0;
        if (value.ValueKind == JsonValueKind.Number) value.TryGetInt64(out unix);
        if (value.ValueKind == JsonValueKind.String) long.TryParse(value.GetString(), out unix);
        if (unix <= 0) return null;
        return DateTimeOffset.FromUnixTimeSeconds(unix).LocalDateTime;
    }

    private static string? BoolText(JsonElement element, string name)
    {
        if (!TryGetProperty(element, name, out var value)) return null;
        if (value.ValueKind == JsonValueKind.True) return "ใช่";
        if (value.ValueKind == JsonValueKind.False) return "ไม่ใช่";
        return GetString(element, name);
    }

    private static string JsonText(JsonElement value)
    {
        if (value.ValueKind is JsonValueKind.Undefined or JsonValueKind.Null) return "";
        if (value.ValueKind == JsonValueKind.String)
        {
            var text = value.GetString() ?? "";
            if (string.IsNullOrWhiteSpace(text)) return "";
            try
            {
                using var doc = JsonDocument.Parse(text);
                return JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions { WriteIndented = true });
            }
            catch
            {
                return text;
            }
        }

        return JsonSerializer.Serialize(value, new JsonSerializerOptions { WriteIndented = true });
    }

    private RenderFragment RenderJsonBlock(JsonElement value) => builder =>
    {
        var json = JsonText(value);
        if (string.IsNullOrWhiteSpace(json))
        {
            builder.AddMarkupContent(0, "<div class='text-muted small'>-</div>");
            return;
        }

        builder.OpenElement(1, "pre");
        builder.AddAttribute(2, "class", "bg-light border rounded p-3 small");
        builder.AddAttribute(3, "style", "max-height:420px;overflow:auto;white-space:pre-wrap");
        builder.AddContent(4, json);
        builder.CloseElement();
    };

