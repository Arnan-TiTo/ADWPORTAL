@page "/ViewOrderData"
@using System.Text.Json
@using System.Globalization
@using adwportal.Dtos
@using adwportal.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Authorization

@inject AuthenticationStateProvider Auth
@inject AuthTokenProvider TokenProvider
@inject MdwMarketplaceService MdwSvc
@inject IdwImportService IdwSvc
@inject ShopService ShopSvc
@inject MiscService MiscSvc
@inject IJSRuntime JS

<h3 class="mb-3">MDW — View Orders</h3>
<p class="text-muted">ค้นหาจากทุกแพลตฟอร์ม พร้อมดูรายละเอียดออเดอร์ (Items, Payments, Shipments, ShipTo)</p>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3">

            <div class="col-md-2">
                <label class="form-label">Platform</label>
                <select class="form-select" @bind="FilterPlatform">
                    <option value="">(All)</option>
                    @foreach (var p in platformOptions)
                    {
                        <option value="@p">@p</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Shop</label>
                <select class="form-select" @bind="filterShopId">
                    <option value="">(All)</option>
                    @foreach (var s in FilteredShopOptions)
                    {
                        <option value="@s.ShopId">@((s.Name ?? "(no name)") + " · " + s.ShopId)</option>
                    }
                </select>
                <div class="form-text">รายการ Shop จะแสดง/กรองจาก Platform ที่เลือก</div>
            </div>

            <div class="col-md-3">
                <label class="form-label">ค้นหา (OrderId/ExternalOrder)</label>
                <input class="form-control" @bind="filterQ" @bind:event="oninput" />
                <div class="form-text">ใส่เลข Order ภายใน หรือ ExternalOrderNo</div>
            </div>

            <div class="col-md-4">
                <label class="form-label d-block">ช่วงวันที่</label>
                <div class="d-flex gap-2 align-items-center flex-wrap mt-2">
                    <input class="form-control" style="max-width:220px" type="datetime-local"
                           value="@fromLocalText" @onchange="OnFromLocalChanged" />
                    <span>—</span>
                    <input class="form-control" style="max-width:220px" type="datetime-local"
                           value="@toLocalText" @onchange="OnToLocalChanged" />
                    <button class="btn btn-outline-secondary btn-sm" @onclick="SetLast1h">-1h</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="SetToday">วันนี้</button>
                </div>
                <div class="form-text">เวลาที่เลือกเป็น local time — จะถูกแปลงเป็น UTC ตอนส่งไป API</div>

                <InputRadioGroup @bind-Value="dateField" TValue="DateFieldMode">
                    <div class="form-check form-check-inline">
                        <InputRadio class="form-check-input" TValue="DateFieldMode" Value="@DateFieldMode.Updated" id="dateUpd" />
                        <label class="form-check-label" for="dateUpd">Updated</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <InputRadio class="form-check-input" TValue="DateFieldMode" Value="@DateFieldMode.Created" id="dateCre" />
                        <label class="form-check-label" for="dateCre">Created</label>
                    </div>
                </InputRadioGroup>
            </div>

            <!--  Status filters (ดึงจาก Misc) -->
            <div class="col-md-2">
                <label class="form-label">Payment Status</label>
                <select class="form-select" @bind="filterPaymentStatus">
                    <option value="">(All)</option>
                    @foreach (var st in paymentStatusOptions)
                    {
                        <option value="@st">@st</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Fulfillment Status</label>
                <select class="form-select" @bind="filterFulfillmentStatus">
                    <option value="">(All)</option>
                    @foreach (var st in fulfillmentStatusOptions)
                    {
                        <option value="@st">@st</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Order Status</label>
                <select class="form-select" @bind="filterOrderStatus">
                    <option value="">(All)</option>
                    @foreach (var st in orderStatusOptions)
                    {
                        <option value="@st">@st</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Sort</label>
                <select class="form-select" @bind="filterSort">
                    <option value="updatedDesc">Updated ↓</option>
                    <option value="updatedAsc">Updated ↑</option>
                    <option value="createdDesc">Created ↓</option>
                    <option value="createdAsc">Created ↑</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Page Size</label>
                <select class="form-select" @bind="pageSize">
                    <option>20</option>
                    <option>50</option>
                    <option>100</option>
                </select>
            </div>

            <div class="col-12 d-flex gap-2">
                <button class="btn btn-primary" @onclick="Reload" disabled="@loading">@(loading ? "Loading..." : "Search")</button>
                <button class="btn btn-outline-secondary" @onclick="ResetFilters" disabled="@loading">Reset</button>
            </div>

            <div class="col-12">
                <div class="form-text">
                    หมายเหตุ: Status ถูกโหลดจาก Misc (StatusPayment/StatusFullFillment/StatusOrder) และจะกรองผลลัพธ์ฝั่งหน้าให้ตรงตามที่เลือก
                </div>
            </div>

        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
@if (!string.IsNullOrWhiteSpace(info))
{
    <div class="alert alert-info">@info</div>
}

<div class="card">
    <div class="card-body">
        @if (loading)
        {
            <div>Loading...</div>
        }
        else if (data?.Items is null || data.Items.Count == 0)
        {
            <div class="text-muted">No orders found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:120px">OrderId</th>
                            <th>ExternalOrder</th>
                            <th style="width:110px">Channel</th>
                            <th style="width:140px">ShopId</th>
                            <th style="width:120px">Status</th>
                            <th style="width:170px">Created</th>
                            <th style="width:170px">Updated</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in data!.Items)
                        {
                            <tr>
                                <td>@r.UnifiedOrderId</td>
                                <td>@(r.ExternalOrderNo ?? "-")</td>
                                <td>@(r.Channel ?? "-")</td>
                                <td>@r.ShopId</td>
                                <td>@(r.OrderStatus ?? "-")</td>
                                <td>@ToLocalStringAny(r.CreatedTimeUtc)</td>
                                <td>@ToLocalStringAny(r.UpdatedTimeUtc)</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewDetail(r.UnifiedOrderId)">
                                        View
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-2">
                <div class="small text-muted">
                    Total: @data.TotalItems
                    &nbsp;•&nbsp; Page @currentPage / @Math.Max(1, (int)Math.Ceiling((double)data.TotalItems / Math.Max(1, pageSize)))
                </div>
                <div class="btn-group">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(!CanPrev)">Prev</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(!CanNext)">Next</button>
                </div>
            </div>
        }
    </div>
</div>

@if (detail is not null)
{
    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <strong>Order #@detail.UnifiedOrderId</strong>
                <span class="text-muted">(@(detail.Channel ?? "-"))</span>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => detail = null">Close</button>
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <h6>Header</h6>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">ExternalOrder</dt>
                        <dd class="col-sm-8">@detail.ExternalOrderNo</dd>
                        <dt class="col-sm-4">Channel</dt>
                        <dd class="col-sm-8">@detail.Channel</dd>
                        <dt class="col-sm-4">ShopId</dt>
                        <dd class="col-sm-8">@detail.ShopId</dd>
                        <dt class="col-sm-4">SellerId</dt>
                        <dd class="col-sm-8">@detail.SellerId</dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">@detail.OrderStatus</dd>
                        <dt class="col-sm-4">Created (local)</dt>
                        <dd class="col-sm-8">@ToLocalStringAny(detail.CreatedTimeUtc)</dd>
                        <dt class="col-sm-4">Updated (local)</dt>
                        <dd class="col-sm-8">@ToLocalStringAny(detail.UpdatedTimeUtc)</dd>
                    </dl>
                </div>

                <div class="col-md-6">
                    <h6>Ship To</h6>
                    @if (TryObject(detail.ShipToJson, out var shipToObj))
                    {
                        <dl class="row mb-0">
                            @foreach (var kv in shipToObj)
                            {
                                <dt class="col-sm-4">@kv.Key</dt>
                                <dd class="col-sm-8">@kv.Value</dd>
                            }
                        </dl>
                    }
                    else
                    {
                        <div class="text-muted small">-</div>
                    }
                </div>

                <div class="col-12"><hr /></div>

                <div class="col-12">
                    <h6>Items</h6>
                    @RenderArrayTable(detail.ItemsJson)
                </div>

                <div class="col-12">
                    <h6>Payments</h6>
                    @RenderArrayTable(detail.PaymentsJson)
                </div>

                <div class="col-12">
                    <h6>Shipments</h6>
                    @RenderArrayTable(detail.ShipmentsJson)
                </div>
            </div>
        </div>
    </div>
}

@code {
    // --- enum แทน string literal สำหรับ radio ---
    private enum DateFieldMode { Updated, Created }

    private string? mdwToken;
    private string? idwToken;

    // shops (for dropdown)
    private readonly List<ShopDtos> allShops = new();

    // Platform dropdown options (from Misc where Type='Platform')
    private List<string> platformOptions = new();

    // status options (from Misc)
    private List<string> paymentStatusOptions = new();       // type = StatusPayment
    private List<string> fulfillmentStatusOptions = new();   // type = StatusFullFillment
    private List<string> orderStatusOptions = new();         // type = StatusOrder

    // ---------- Filters / paging ----------
    private bool loading;
    private string? error;
    private string? info;

    private string? filterChannel = "";
    private string? filterShopId = "";
    private string? filterQ = "";

    // status filters (ผูกกับ misc types)
    private string? filterPaymentStatus = "";
    private string? filterFulfillmentStatus = "";
    private string? filterOrderStatus = "";

    private DateFieldMode dateField = DateFieldMode.Updated;
    private string filterSort = "updatedDesc";
    private int currentPage = 1;   
    private int pageSize = 50;

    // bind wrapper: เปลี่ยน Platform แล้วล้าง Shop selection (ให้ dropdown กรองตาม)
    private string FilterPlatform
    {
        get => filterChannel ?? "";
        set
        {
            var v = CanonicalPlatform(value);
            if (string.Equals(filterChannel, v, StringComparison.OrdinalIgnoreCase)) return;
            filterChannel = v;
            filterShopId = "";
        }
    }

    private IEnumerable<ShopDtos> FilteredShopOptions =>
        allShops
            .Where(s => string.IsNullOrWhiteSpace(FilterPlatform) ||
                        string.Equals(CanonicalPlatform(s.Platform), FilterPlatform, StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.Name ?? s.ShopId.ToString());

    // datetime-local ใช้ string แบบ "yyyy-MM-ddTHH:mm"
    private string fromLocalText = DateTime.Now.AddHours(-5000).ToString("yyyy-MM-ddTHH:mm");
    private string toLocalText = DateTime.Now.ToString("yyyy-MM-ddTHH:mm");

    private void OnFromLocalChanged(ChangeEventArgs e)
    {
        var s = e?.Value?.ToString() ?? "";
        if (IsLocalText(s)) fromLocalText = s;
    }
    private void OnToLocalChanged(ChangeEventArgs e)
    {
        var s = e?.Value?.ToString() ?? "";
        if (IsLocalText(s)) toLocalText = s;
    }

    // ---------- Data ----------
    private PagedResult<FeUnifiedOrderDtos>? data;
    private FeUnifiedOrderDtos? detail;

    private bool CanPrev => !loading && currentPage > 1;

    private bool CanNext
    {
        get
        {
            if (loading || data is null) return false;
            var totalPages = Math.Max(1, (int)Math.Ceiling((double)data.TotalItems / Math.Max(1, pageSize)));
            return currentPage < totalPages;
        }
    }

    private static string? NormalizeToken(string? t)
    {
        if (string.IsNullOrWhiteSpace(t)) return null;
        t = t.Trim().Trim('"');
        if (t.StartsWith("Bearer ", StringComparison.OrdinalIgnoreCase)) t = t[7..].Trim();
        return t;
    }

    private static string CanonicalPlatform(string? p)
    {
        var x = (p ?? "").Trim().ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(x)) return "";
        if (x.Contains("tiktok")) return "TikTok";
        if (x.Contains("shopee")) return "Shopee";
        if (x.Contains("lazada")) return "Lazada";
        return p?.Trim() ?? "";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            mdwToken = NormalizeToken(TokenProvider.MdwToken);

            if (string.IsNullOrWhiteSpace(mdwToken))
            {
                var authState = await Auth.GetAuthenticationStateAsync();
                var user = authState.User;

                var username = user.Identity?.Name ?? user.FindFirst("USERNAME")?.Value;
                var password = TokenProvider.Password;

                if (!string.IsNullOrWhiteSpace(username) && !string.IsNullOrWhiteSpace(password))
                {
                    var loginMdw = await MdwSvc.LoginAsync(username, password);
                    mdwToken = NormalizeToken(loginMdw?.Token);

                    if (!string.IsNullOrWhiteSpace(mdwToken))
                        TokenProvider.MdwToken = mdwToken;
                }
            }

            if (string.IsNullOrWhiteSpace(mdwToken))
            {
                error = "MDW token is empty. กรุณาเข้า Dashboard (หน้าแรก) หรือ login ใหม่อีกครั้ง";
                return;
            }

            // โหลด IDW token แล้วดึง shops + platform + statuses จาก Misc
            try
            {
                idwToken = NormalizeToken(TokenProvider.IdwToken);

                if (string.IsNullOrWhiteSpace(idwToken))
                {
                    var authState = await Auth.GetAuthenticationStateAsync();
                    var user = authState.User;
                    var username = user.Identity?.Name ?? user.FindFirst("USERNAME")?.Value;
                    var password = TokenProvider.Password;

                    if (!string.IsNullOrWhiteSpace(username) && !string.IsNullOrWhiteSpace(password))
                    {
                        var loginIdw = await IdwSvc.LoginAsync(username, password);
                        idwToken = NormalizeToken(loginIdw?.Token);
                        if (!string.IsNullOrWhiteSpace(idwToken)) TokenProvider.IdwToken = idwToken;
                    }
                }

                if (!string.IsNullOrWhiteSpace(idwToken))
                {
                    // Shops
                    var shops = await ShopSvc.GetShopsAsync(idwToken);
                    allShops.Clear();
                    allShops.AddRange((shops ?? new List<ShopDtos>())
                        .Select(s => s with { Platform = CanonicalPlatform(s.Platform) })
                        .OrderBy(s => s.Name));

                    // Platform (Misc Type='Platform')
                    var plats = await MiscSvc.GetMiscAsync(idwToken, type: "Platform");
                    platformOptions = (plats ?? new List<MiscDtos>())
                        .Where(x => x.IsActive)
                        .Select(x => CanonicalPlatform(!string.IsNullOrWhiteSpace(x.Name) ? x.Name : x.Value1))
                        .Where(x => !string.IsNullOrWhiteSpace(x))
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .OrderBy(x => x)
                        .ToList();

                    //Status options from Misc
                    paymentStatusOptions = await LoadMiscOptionsAsync(idwToken, "StatusPayment");
                    fulfillmentStatusOptions = await LoadMiscOptionsAsync(idwToken, "StatusFullFillment");
                    orderStatusOptions = await LoadMiscOptionsAsync(idwToken, "StatusOrder");
                }
            }
            catch
            {
                // ignore
            }

            await Reload();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task<List<string>> LoadMiscOptionsAsync(string token, string type)
    {
        var list = await MiscSvc.GetMiscAsync(token, type: type);
        return (list ?? new List<MiscDtos>())
            .Where(x => x.IsActive)
            .Select(x => !string.IsNullOrWhiteSpace(x.Name) ? x.Name : x.Value1)
            .Select(x => (x ?? "").Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();
    }

    private async Task Reload()
    {
        if (loading) return;
        loading = true; error = info = null;

        try
        {
            long? shopId = null;
            if (!string.IsNullOrWhiteSpace(filterShopId) && long.TryParse(filterShopId, out var sid))
                shopId = sid;

            var fromUtc = ParseLocalToUtc(fromLocalText);
            var toUtc = ParseLocalToUtc(toLocalText);

            var statusParam = string.IsNullOrWhiteSpace(filterOrderStatus) ? null : filterOrderStatus;

            var result = await MdwSvc.FeOrdersListAsync(
              token: mdwToken,
              channel: string.IsNullOrWhiteSpace(filterChannel) ? null : filterChannel,
              shopId: shopId,
              q: string.IsNullOrWhiteSpace(filterQ) ? null : filterQ,
              status: statusParam,
              fromUtc: fromUtc,
              toUtc: toUtc,
              page: currentPage,
              pageSize: pageSize,
              sort: filterSort
            );

            if (result?.Items is not null)
            {
                var filtered = result.Items.AsEnumerable();

                if (!string.IsNullOrWhiteSpace(filterPaymentStatus))
                    filtered = filtered.Where(x => string.Equals(GetPropString(x, "PaymentStatus"), filterPaymentStatus, StringComparison.OrdinalIgnoreCase));

                if (!string.IsNullOrWhiteSpace(filterFulfillmentStatus))
                    filtered = filtered.Where(x => string.Equals(GetPropString(x, "FulfillmentStatus"), filterFulfillmentStatus, StringComparison.OrdinalIgnoreCase));

                if (!string.IsNullOrWhiteSpace(filterOrderStatus))
                    filtered = filtered.Where(x => string.Equals(x.OrderStatus ?? "", filterOrderStatus, StringComparison.OrdinalIgnoreCase));

                data = new PagedResult<FeUnifiedOrderDtos>
                {
                    Items = filtered.ToList(),
                    TotalItems = result.TotalItems
                };
            }
            else
            {
                data = result;
            }

            detail = null;
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; StateHasChanged(); }
    }

    private static string GetPropString(object? obj, string propName)
    {
        if (obj is null) return "";
        try
        {
            var p = obj.GetType().GetProperty(propName);
            var v = p?.GetValue(obj);
            return (v?.ToString() ?? "").Trim();
        }
        catch { return ""; }
    }

    private void ResetFilters()
    {
        filterChannel = "";
        filterShopId = "";
        filterQ = "";

        filterPaymentStatus = "";
        filterFulfillmentStatus = "";
        filterOrderStatus = "";

        dateField = DateFieldMode.Updated;
        filterSort = "updatedDesc";
        pageSize = 50;
        currentPage = 1;
        fromLocalText = DateTime.Now.AddHours(-1).ToString("yyyy-MM-ddTHH:mm");
        toLocalText = DateTime.Now.ToString("yyyy-MM-ddTHH:mm");
        detail = null;
    }

    private async Task ViewDetail(long id)
    {
        try
        {
            detail = await MdwSvc.FeOrderGetByIdAsync(mdwToken, id);
            if (detail is null) await JS.InvokeVoidAsync("alert", $"Order {id} not found.");
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", ex.Message); }
    }

    private async Task NextPage() { if (!CanNext) return; currentPage++; await Reload(); }
    private async Task PrevPage() { if (!CanPrev) return; currentPage--; await Reload(); }

    private void SetLast1h()
    {
        var to = DateTime.Now;
        var from = to.AddHours(-1);
        fromLocalText = from.ToString("yyyy-MM-ddTHH:mm");
        toLocalText = to.ToString("yyyy-MM-ddTHH:mm");
    }

    private void SetToday()
    {
        var now = DateTime.Now;
        var from = new DateTime(now.Year, now.Month, now.Day, 0, 0, 0);
        var to = from.AddDays(1).AddMinutes(-1);
        fromLocalText = from.ToString("yyyy-MM-ddTHH:mm");
        toLocalText = to.ToString("yyyy-MM-ddTHH:mm");
    }

    // ---------- helpers ----------
    private static bool IsLocalText(string s)
    {
        return DateTime.TryParseExact(
          s ?? "",
          "yyyy-MM-ddTHH:mm",
          CultureInfo.InvariantCulture,
          DateTimeStyles.AssumeLocal,
          out _);
    }

    private static DateTime ParseLocal(string s)
    {
        return DateTime.TryParseExact(
          s ?? "",
          "yyyy-MM-ddTHH:mm",
          CultureInfo.InvariantCulture,
          DateTimeStyles.AssumeLocal,
          out var dt)
          ? dt
          : DateTime.Now;
    }

    private static DateTime ParseLocalToUtc(string s) =>
      DateTime.SpecifyKind(ParseLocal(s), DateTimeKind.Local).ToUniversalTime();

    private static string ToLocalStringAny(object? utcVal)
    {
        if (utcVal is null) return "-";

        if (utcVal is DateTime dt)
            return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

        if (utcVal is string s && DateTime.TryParse(s,
            provider: CultureInfo.InvariantCulture,
            styles: DateTimeStyles.AdjustToUniversal | DateTimeStyles.AllowWhiteSpaces | DateTimeStyles.AssumeUniversal,
            result: out var dts))
            return dts.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

        return utcVal.ToString() ?? "-";
    }

    private RenderFragment RenderArrayTable(JsonElement rawEl) => builder =>
    {
        void RenderCore(JsonElement arrayEl)
        {
            if (arrayEl.ValueKind != JsonValueKind.Array || arrayEl.GetArrayLength() == 0)
            {
                builder.AddContent(0, (MarkupString)"<div class='text-muted small'>-</div>");
                return;
            }

            var rows = arrayEl.EnumerateArray()
                              .Where(x => x.ValueKind == JsonValueKind.Object)
                              .ToList();

            if (rows.Count == 0)
            {
                builder.AddContent(1, (MarkupString)"<div class='text-muted small'>-</div>");
                return;
            }

            var cols = new LinkedList<string>();
            foreach (var r in rows)
            {
                foreach (var p in r.EnumerateObject())
                {
                    if (!cols.Contains(p.Name))
                    {
                        cols.AddLast(p.Name);
                        if (cols.Count >= 12) break;
                    }
                }
                if (cols.Count >= 12) break;
            }
            var colList = cols.ToList();

            builder.AddMarkupContent(2,
                "<div class='table-responsive'><table class='table table-sm table-bordered mb-0'><thead class='table-light'><tr>");
            foreach (var c in colList)
                builder.AddMarkupContent(3, $"<th>{System.Net.WebUtility.HtmlEncode(c)}</th>");
            builder.AddMarkupContent(4, "</tr></thead><tbody>");

            foreach (var r in rows)
            {
                builder.AddMarkupContent(5, "<tr>");
                foreach (var c in colList)
                {
                    string cell = "";
                    if (r.TryGetProperty(c, out var v))
                    {
                        cell = v.ValueKind switch
                        {
                            JsonValueKind.String => v.GetString() ?? "",
                            JsonValueKind.Number => v.ToString(),
                            JsonValueKind.True or JsonValueKind.False => v.GetBoolean().ToString(),
                            JsonValueKind.Object or JsonValueKind.Array => v.ToString(),
                            _ => ""
                        };
                    }
                    builder.AddMarkupContent(6,
                        $"<td class='small'>{System.Net.WebUtility.HtmlEncode(cell)}</td>");
                }
                builder.AddMarkupContent(7, "</tr>");
            }
            builder.AddMarkupContent(8, "</tbody></table></div>");
        }

        try
        {
            if (rawEl.ValueKind == JsonValueKind.String)
            {
                var s = rawEl.GetString();
                if (string.IsNullOrWhiteSpace(s))
                {
                    builder.AddContent(0, (MarkupString)"<div class='text-muted small'>-</div>");
                    return;
                }

                using var doc = JsonDocument.Parse(s);
                RenderCore(doc.RootElement);
            }
            else
            {
                RenderCore(rawEl);
            }
        }
        catch
        {
            builder.AddContent(0, (MarkupString)"<div class='text-muted small'>-</div>");
        }
    };

    private static bool TryObject(JsonElement el, out Dictionary<string, string> dict)
    {
        dict = new();

        if (el.ValueKind == JsonValueKind.String)
        {
            var s = el.GetString();
            if (string.IsNullOrWhiteSpace(s)) return false;

            try
            {
                using var doc = JsonDocument.Parse(s);
                var obj = doc.RootElement;
                if (obj.ValueKind != JsonValueKind.Object) return false;

                foreach (var p in obj.EnumerateObject())
                {
                    var val = p.Value.ValueKind switch
                    {
                        JsonValueKind.String => p.Value.GetString() ?? "",
                        JsonValueKind.Number => p.Value.ToString(),
                        JsonValueKind.True or JsonValueKind.False => p.Value.GetBoolean().ToString(),
                        _ => p.Value.ToString()
                    };
                    dict[p.Name] = val;
                }

                return dict.Count > 0;
            }
            catch
            {
                return false;
            }
        }

        if (el.ValueKind != JsonValueKind.Object) return false;

        foreach (var p in el.EnumerateObject())
        {
            var val = p.Value.ValueKind switch
            {
                JsonValueKind.String => p.Value.GetString() ?? "",
                JsonValueKind.Number => p.Value.ToString(),
                JsonValueKind.True or JsonValueKind.False => p.Value.GetBoolean().ToString(),
                _ => p.Value.ToString()
            };
            dict[p.Name] = val;
        }

        return dict.Count > 0;
    }
}
