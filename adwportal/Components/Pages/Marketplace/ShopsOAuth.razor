@page "/shopsOAuth"
@using System.Text
@using System.Text.Json
@using Microsoft.JSInterop
@using adwportal.Dtos
@using adwportal.Services
@implements IAsyncDisposable
@inject IHttpClientFactory ClientFactory
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject MdwMarketplaceService MdwSvc
@inject IdwImportService Idw
@inject Microsoft.Extensions.Configuration.IConfiguration Cfg

<h1 class="mb-3">MDW — Shops OAuth</h1>
<p class="text-muted">
    List all shops (Shopee, TikTok Shop, Lazada, …). Click <em>Authorize</em> to start OAuth in a popup and auto-exchange the returned code.
</p>
<span class="text-muted">(@(_mdwToken ?? "mdwToken is null"))</span>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Search name</label>
                <input class="form-control" @bind-value="filterName" @bind-value:event="oninput" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Platform</label>
                <select class="form-select" @bind="filterPlatform">
                    <option value="">(All)</option>
                    <option>Shopee</option>
                    <option>TikTok</option>
                    <option>Lazada</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary" @onclick="LoadShops">Reload</button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMsg))
{
    <div class="alert alert-danger">@errorMsg</div>
}
@if (!string.IsNullOrWhiteSpace(infoMsg))
{
    <div class="alert alert-info">@infoMsg</div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th style="width:72px">#</th>
                <th>Shop</th>
                <th>Platform</th>
                <th>Partner (internal)</th>
                <th>Partner (external)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (isLoading)
            {
                <tr><td colspan="6">Loading…</td></tr>
            }
            else if (!ViewRows.Any())
            {
                <tr><td colspan="6" class="text-muted">No shops.</td></tr>
            }
            else
            {
                @foreach (var r in ViewRows)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>
                            <div class="fw-semibold">@r.Name</div>
                            <div class="small text-muted">ShopId: @r.ShopId</div>
                        </td>
                        <td>@r.Platform</td>
                        <td><div>Id: <code>@r.PartnerId</code></div></td>
                        <td><div><code>@r.PartnerExtId</code></div></td>
                        <td>
                            <div class="btn-group">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => StartAuthorizeAsync(r)">Authorize</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyAuthLinkAsync(r)">Copy Link</button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    // ===== tokens & clients (ทุกเส้นติด Bearer) =====
    private string? _idwToken;
    private string? _mdwToken;
    private HttpClient? _idwClient; // Base: IdwApiBaseUrl
    private HttpClient? _mdwClient; // Base: MdwApiBaseUrl

    public record ShopVm(
        int Id,
        long ShopId,
        string? Name,
        int PartnerId,
        long PartnerExtId,
        string? Country,
        string? Platform,
        DateTime CreatedAt
    );

    private List<ShopVm> rows = new();
    private bool isLoading;
    private string? errorMsg;
    private string? infoMsg;
    private string? filterName;
    private string? filterPlatform;

    private IEnumerable<ShopVm> ViewRows =>
        rows.Where(r =>
            (string.IsNullOrWhiteSpace(filterPlatform) || string.Equals(r.Platform, filterPlatform, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(filterName) || (r.Name ?? "").Contains(filterName, StringComparison.OrdinalIgnoreCase))
        );

    private readonly Dictionary<string, PendingAuth> _pending = new();
    private DotNetObjectReference<ShopsOAuth>? _selfRef;

    private class PendingAuth
    {
        public required string Platform { get; init; }       // Shopee | TikTok | Lazada
        public required int PartnerIdInternal { get; init; } // Partners.Id (internal)
        public required long ShopId { get; init; }
        public DateTime CreatedAt { get; init; } = DateTime.UtcNow;
    }

    private static string? NormalizeToken(string? t)
    {
        if (string.IsNullOrWhiteSpace(t)) return null;
        t = t.Trim().Trim('"');
        if (t.StartsWith("Bearer ", StringComparison.OrdinalIgnoreCase)) t = t[7..].Trim();
        return t;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            // 1) login IDW
            var loginIdw = await Idw.LoginAsync("admin", "123456yjm");
            _idwToken = NormalizeToken(loginIdw?.Token) ?? throw new Exception("Login IDW failed");

            // 2) login MDW
            var loginMdw = await MdwSvc.LoginAsync("admin", "123456yjm");
            _mdwToken = NormalizeToken(loginMdw?.Token) ?? throw new Exception("Login MDW failed");

            // 3) bind token ให้ client ทั้งสอง
            _idwClient = ClientFactory.CreateClient("IdwApiBaseUrl");
            _idwClient.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _idwToken);

            _mdwClient = ClientFactory.CreateClient("MdwApiBaseUrl");
            _mdwClient.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _mdwToken);

            // 4) register JS receiver + โหลดรายการ
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("mdwOauth.registerReceiver", _selfRef);
            await LoadShops();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { StateHasChanged(); }
    }

    public async ValueTask DisposeAsync() { _selfRef?.Dispose(); await Task.CompletedTask; }

    private async Task LoadShops()
    {
        if (_idwClient is null) return;
        try
        {
            isLoading = true; errorMsg = infoMsg = null;
            var res = await _idwClient.GetAsync("api/shops");
            res.EnsureSuccessStatusCode();
            var json = await res.Content.ReadAsStringAsync();
            rows = JsonSerializer.Deserialize<List<ShopVm>>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { isLoading = false; StateHasChanged(); }
    }

    private static string? ReadQueryParamFromUrl(string url, string key)
    {
        try
        {
            var u = new Uri(url);
            var qs = System.Web.HttpUtility.ParseQueryString(u.Query);
            return qs.Get(key);
        }
        catch { return null; }
    }

    private string BuildAuthLinkQuery(ShopVm s, string callbackUrl)
    {
        var plat = CanonicalPlatform(s.Platform, s.Name);
        if (string.IsNullOrEmpty(plat))
            throw new InvalidOperationException($"Unsupported platform: '{s.Platform ?? "(blank)"}' for shop {s.ShopId}");

        var encCb = Uri.EscapeDataString(callbackUrl);
        var sb = new StringBuilder("api/market/auth/link?callbackUrl=").Append(encCb);

        switch (plat)
        {
            case "Shopee":
                sb.Append("&platform=Shopee")
                  .Append("&shopId=").Append(s.ShopId);
                break;

            case "TikTok":
                sb.Append("&platform=TikTok")
                  .Append("&partnersId=").Append(s.PartnerId)
                  .Append("&accountIdStr=").Append(Uri.EscapeDataString(s.ShopId.ToString()));
                break;

            case "Lazada":
                sb.Append("&platform=Lazada")
                  .Append("&partnersId=").Append(s.PartnerId);
                break;
        }

        return sb.ToString();
    }

    private static string CanonicalPlatform(string? platform, string? name = null)
    {
        var p = (platform ?? "").Trim().ToLowerInvariant();

        if (p == "shopee") return "Shopee";
        if (p is "tiktok" or "tik tok" or "tiktokshop" or "tiktok shop") return "TikTok";
        if (p == "lazada") return "Lazada";

        // กรณีไม่กรอก platform ใน DB
        var n = (name ?? "").ToLowerInvariant();
        if (n.Contains("tiktok")) return "TikTok";
        if (n.Contains("shopee")) return "Shopee";
        if (n.Contains("lazada")) return "Lazada";

        return ""; // unknown
    }

    // ===== สร้างลิงก์ authorize =====
    private async Task StartAuthorizeAsync(ShopVm s)
    {
        if (_mdwClient is null) return;

        try
        {
            errorMsg = infoMsg = null;
            var callbackUrl = GetCallbackUrl(s.Platform??"");
            var url = BuildAuthLinkQuery(s, callbackUrl);

            var resp = await _mdwClient.GetAsync(url);
            resp.EnsureSuccessStatusCode();
            var body = await resp.Content.ReadAsStringAsync();

            var payload = JsonSerializer.Deserialize<MdwAuthLinkResponse>(body, new JsonSerializerOptions { PropertyNameCaseInsensitive = true })
                          ?? throw new InvalidOperationException("Invalid auth link response");

            if (payload.Success != true || string.IsNullOrWhiteSpace(payload.AuthUrl))
                throw new InvalidOperationException("AuthUrl missing from response");

            // ดึง state ถ้ามี ไม่มีก็ gen
            var state = ReadQueryParamFromUrl(payload.AuthUrl!, "state") ?? Guid.NewGuid().ToString("N");
            _pending[state] = new PendingAuth
            {
                Platform = CanonicalPlatform(s.Platform, s.Name),
                PartnerIdInternal = s.PartnerId,
                ShopId = s.ShopId
            };

            var opened = await JS.InvokeAsync<bool>("mdwOauth.openPopup", payload.AuthUrl, "mdw-oauth", 680, 760);
            if (!opened)
            {
                infoMsg = "Popup blocked — redirecting…";
                Nav.NavigateTo(payload.AuthUrl!, forceLoad: true);
            }
        }
        catch (Exception ex) { errorMsg = ex.Message; }
    }

    private async Task CopyAuthLinkAsync(ShopVm s)
    {
        if (_mdwClient is null) return;
        try
        {
            errorMsg = infoMsg = null;
            var callbackUrl = GetCallbackUrl(s.Platform??"");
            var url = BuildAuthLinkQuery(s, callbackUrl);

            var resp = await _mdwClient.GetAsync(url);
            resp.EnsureSuccessStatusCode();
            var body = await resp.Content.ReadAsStringAsync();

            var payload = JsonSerializer.Deserialize<MdwAuthLinkResponse>(body, new JsonSerializerOptions { PropertyNameCaseInsensitive = true })!;
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", payload.AuthUrl);
            infoMsg = "Authorization link copied to clipboard.";
        }
        catch (Exception ex) { errorMsg = ex.Message; }
    }

    // ===== callback จาก popup แล้วแลก code =====
    [JSInvokable]
    public async Task OnAuthCallback(string json)
    {
        if (_mdwClient is null) return;

        try
        {
            var m = JsonSerializer.Deserialize<AuthCallbackMessage>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true })
                    ?? throw new InvalidOperationException("Invalid callback payload");
            if (!string.Equals(m.Type, "mdw-oauth-callback", StringComparison.Ordinal)) return;

            // จับ context จาก state; ถ้าไม่มีแต่เหลือค้าง 1 รายการ ใช้อันเดียว
            PendingAuth? ctx = null;
            if (!string.IsNullOrWhiteSpace(m.State) && _pending.TryGetValue(m.State!, out var found)) ctx = found;
            else if (_pending.Count == 1) ctx = _pending.Values.First();
            if (ctx is null) throw new InvalidOperationException("Unknown or expired state");

            if (!string.IsNullOrEmpty(m.Error)) throw new InvalidOperationException($"Provider error: {m.Error}");
            if (string.IsNullOrWhiteSpace(m.Code)) throw new InvalidOperationException("Code missing from callback");

            // บางแพลตฟอร์ม (เช่น TikTok) จะส่ง shop_id กลับมา → ใช้ค่านั้นถ้ามี
            long shopForExchange = ctx.ShopId;
            if (!string.IsNullOrWhiteSpace(m.ShopId) && long.TryParse(m.ShopId, out var sidFromCb)) shopForExchange = sidFromCb;

            // POST /api/market/auth/exchange?platform=...&shopId=...&code=...
            var exUrl = $"api/market/auth/exchange?platform={Uri.EscapeDataString(ctx.Platform)}&shopId={shopForExchange}&code={Uri.EscapeDataString(m.Code!)}";
            var resp = await _mdwClient.PostAsync(exUrl, new StringContent(""));

            if (!resp.IsSuccessStatusCode)
            {
                var err = await resp.Content.ReadAsStringAsync();
                throw new InvalidOperationException($"Exchange failed: {(int)resp.StatusCode} {resp.ReasonPhrase} — {err}");
            }

            infoMsg = $"Connected {ctx.Platform} shop {shopForExchange} successfully.";
            if (!string.IsNullOrWhiteSpace(m.State)) _pending.Remove(m.State!);
            await LoadShops();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { StateHasChanged(); }
    }
   
    private string GetCallbackUrl(string platform)
    {
        var portalOrigin = new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority); 
        var cbBase = (Cfg["OAuth:CallbackBaseUrl"] ?? "https://vibeandchic.com").TrimEnd('/');
        var callbackUrl = $"{cbBase}/auth/callback.html?origin={Uri.EscapeDataString(portalOrigin)}&platform={Uri.EscapeDataString(platform)}";

        return callbackUrl;
    }

    private sealed record MdwAuthLinkResponse(bool Success, string AuthUrl);

    private sealed record AuthCallbackMessage(
        string Type,
        string? Code,
        string? State,
        string? Error,
        string? ErrorDescription,
        string? ShopId
    );
}
