@page "/CompanyList"
@using adwportal.Dtos
@using adwportal.Services
@inject CompanyService Svc
@inject IdwImportService Idw
@inject IJSRuntime JS
@inject NavigationManager Nav

<h3>Companies</h3>

@if (loading)
{
    <div class="alert alert-info">Loading...</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Partner</label>
                    <select class="form-select" @bind="SelectedPartnerId">
                        <option value="">-- All --</option>
                        @foreach (var p in partners)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="NameFilter" @bind:event="oninput" />
                </div>
                <div class="col-md-4 text-end align-self-end">
                    <button class="btn btn-primary" @onclick="Add">+ Add</button>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:80px">Id</th>
                    <th>Name</th>
                    <th>Partner</th>
                    <th style="width:120px">Shops</th>
                    <th style="width:100px">Active</th>
                    <th style="width:180px">Updated</th>
                    <th style="width:160px">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (paged.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted">No data</td></tr>
                }
                else
                {
                    @foreach (var c in paged)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td>@c.Name</td>
                            <td>@c.PartnerName</td>
                            <td>@c.ShopCount</td>
                            <td>@(c.IsActive ? "Y" : "N")</td>
                            <td>@(c.UpdatedAt.ToString("dd-MM-yyyy HH:mm") ?? c.CreatedAt.ToString("dd-MM-yyyy HH:mm"))</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        @onclick="() => EditForce(c.Id, Convert.ToInt32(c.PartnerId))">
                                    Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(c.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <nav>
        <ul class="pagination">
            <li class="page-item @(pageIndex == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="Prev">Prev</button>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(pageIndex == i ? "active" : "")">
                    <button class="page-link" @onclick="(() => Go(i))">@i</button>
                </li>
            }
            <li class="page-item @(pageIndex == totalPages ? "disabled" : "")">
                <button class="page-link" @onclick="Next">Next</button>
            </li>
        </ul>
    </nav>
}

@code {
    string? token;
    bool loading;
    string? error;

    List<MdwPartnerDtos> partners = new();
    List<CompanyListItemDtos> all = new();
    List<CompanyListItemDtos> filtered = new();
    List<CompanyListItemDtos> paged = new();

    string? nameFilter;
    int? selectedPartnerId;

    string? NameFilter
    {
        get => nameFilter;
        set { nameFilter = value; pageIndex = 1; Apply(); }
    }

    int? SelectedPartnerId
    {
        get => selectedPartnerId;
        set { selectedPartnerId = value; pageIndex = 1; Apply(); }
    }

    const int pageSize = 10;
    int pageIndex = 1;
    int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;

            var login = await Idw.LoginAsync("admin", "123456yjm");
            token = login?.Token;
            if (string.IsNullOrWhiteSpace(token)) { error = "Login failed"; return; }

            partners = await Svc.GetPartnersAsync(token!);
            all = await Svc.GetCompaniesAsync(token!);
            Apply();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    void Apply()
    {
        IEnumerable<CompanyListItemDtos> q = all;

        if (selectedPartnerId.HasValue)
            q = q.Where(x => x.PartnerId == selectedPartnerId.Value);

        if (!string.IsNullOrWhiteSpace(nameFilter))
        {
            var kw = nameFilter.Trim();
            q = q.Where(x => (x.Name ?? "").Contains(kw, StringComparison.OrdinalIgnoreCase));
        }

        filtered = q.OrderBy(x => x.Name).ToList();

        totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)pageSize));
        pageIndex = Math.Clamp(pageIndex, 1, totalPages);
        paged = filtered.Skip((pageIndex - 1) * pageSize).Take(pageSize).ToList();
        StateHasChanged();
    }

    void Prev() { if (pageIndex > 1) { pageIndex--; Apply(); } }
    void Next() { if (pageIndex < totalPages) { pageIndex++; Apply(); } }
    void Go(int i) { pageIndex = i; Apply(); }

    void Add() => Nav.NavigateTo("/CompanyEdit");

    async Task EditForce(int? companyId, int? partnerPk)
    {
        var url = $"/CompanyEdit/{companyId}?partnerId={partnerPk}";
        await JS.InvokeVoidAsync("forceNavigate", url);

    }

    async Task Delete(int id)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Delete company id={id} ?");
        if (!ok) return;

        try
        {
            await Svc.DeleteCompanyAsync(token!, id);
            var idx = all.FindIndex(x => x.Id == id);
            if (idx >= 0) all.RemoveAt(idx);

            await JS.InvokeVoidAsync("showToast", "Deleted", "success");
            Apply();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
    }
}
