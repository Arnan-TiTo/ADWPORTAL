@page "/CompanyEdit/{Id:int}"
@using adwportal.Dtos
@using adwportal.Services
@inject CompanyService Svc
@inject IdwImportService Idw
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Company @title</h3>

@if (loading)
{
    <div class="alert alert-info">Loading...</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="model.Name" />
                </div>

                <div class="col-md-3 d-flex align-items-center">
                    <div class="form-check mt-4">
                        <input id="chkActive" class="form-check-input" type="checkbox" @bind="model.IsActive" />
                        <label class="form-check-label" for="chkActive">Active</label>
                    </div>
                </div>

                @if (Id.HasValue)
                {
                    <div class="col-12"><hr /></div>

                    <div class="col-md-6">
                        <label class="form-label">Partner</label>
                        <InputSelect class="form-select"
                                     @bind-Value="SelectedPartnerId"
                                     TValue="int?"
                                     disabled="@loadingPartners"
                                     @key="partners">
                            @foreach (var p in partners)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </InputSelect>
                        <div class="form-text">* ใช้สำหรับดูร้านค้าเท่านั้น การบันทึกจะไม่แก้ mapping</div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Shops under selected partner</label>

                        @if (SelectedPartnerId is null)
                        {
                            <div class="form-text text-muted">Select a partner to see shops.</div>
                        }
                        else if (loadingShops)
                        {
                            <div class="form-text">Loading shops...</div>
                        }
                        else if (shops.Count == 0)
                        {
                            <div class="form-text text-muted">No shops for this partner.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width:100px">Id</th>
                                            <th style="width:180px">ShopId</th>
                                            <th>Name</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var s in shops)
                                        {
                                            <tr>
                                                <td>@s.Id</td>
                                                <td>@s.ShopId</td>
                                                <td>@(s.Name ?? "-")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="Save" disabled="@saving">Save</button>
                <button class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }
    [SupplyParameterFromQuery(Name = "partnerId")]
    public int? PartnerId { get; set; }

    string? token;
    bool loading, saving;
    string? error;
    string title = "Add";

    bool loadingPartners, loadingShops;
    List<MdwPartnerDtos> partners = new();
    List<MdwShopDtos> shops = new();

    // ส่งขึ้น API แค่ Name/IsActive
    CompanyUpsertBasicDtos model = new() { IsActive = true };

    // ค่าที่ bind กับ dropdown และ trigger โหลด shops
    int? selectedPartnerId;
    int? SelectedPartnerId
    {
        get => selectedPartnerId;
        set
        {
            if (selectedPartnerId == value) return;
            selectedPartnerId = value;
            _ = LoadShops();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;

            var login = await Idw.LoginAsync("admin", "123456yjm");
            token = login?.Token?.Trim('"');
            if (string.IsNullOrWhiteSpace(token)) { error = "Login failed"; return; }

            if (Id.HasValue)
            {
                title = "Edit";

                // 1) ข้อมูลบริษัท
                var c = await Svc.GetCompanyAsync(token!, Id.Value);
                if (c == null) { error = "Not found"; return; }

                model = new CompanyUpsertBasicDtos
                {
                    Name = c.Name,
                    IsActive = c.IsActive
                };

                // 2) โหลด partner ทั้งหมดที่ map กับบริษัทนี้
                await LoadPartnerForEdit(PartnerId.Value);

                // 3) pre-select
                if (PartnerId is > 0 && partners.Any(p => p.Id == PartnerId))
                    SelectedPartnerId = PartnerId;
                else
                    SelectedPartnerId = partners.FirstOrDefault()?.Id;
            }
            else
            {
                title = "Add";
            }
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    // โหลด partner “ตัวเดียว” ตาม partnerId ที่ส่งมาจากหน้า list (หรือ route)
    // แล้วเซ็ต dropdown ให้เลือกตัวนี้ พร้อมโหลด shops ให้ถูก
    private async Task LoadPartnerForEdit(int partnerId)
    {
        loadingPartners = true;
        try
        {
            partners = new(); // เคลียร์ก่อน

            var p = await Svc.GetPartnerByIdAsync(token!, partnerId);
            if (p != null)
            {
                partners.Add(p);           // dropdown มีแค่ partner ที่แก้ไข
                SelectedPartnerId = p.Id;  // trigger ไปโหลด shops ต่อ
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", $"Partner id={partnerId} not found.", "warning");
                SelectedPartnerId = null;
                shops = new();
            }
        }
        catch (Exception ex)
        {
            partners = new();
            SelectedPartnerId = null;
            shops = new();
            await JS.InvokeVoidAsync("showToast", $"Load partner failed: {ex.Message}", "error");
        }
        finally
        {
            loadingPartners = false;
            StateHasChanged();
        }
    }

    async Task LoadShops()
    {
        shops = new();
        if (!(SelectedPartnerId is > 0) || string.IsNullOrWhiteSpace(token))
        {
            StateHasChanged();
            return;
        }

        loadingShops = true;
        try
        {
            var list = await Svc.GetShopsAsync(token!, SelectedPartnerId.Value) ?? new();
            shops = list
                .GroupBy(s => s.Id)
                .Select(g => g.First())
                .OrderBy(s => s.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load shops failed: {ex.Message}", "error");
        }
        finally
        {
            loadingShops = false;
            StateHasChanged();
        }
    }

    async Task Save()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(model.Name))
            { await JS.InvokeVoidAsync("showToast", "Name is required", "error"); return; }

            saving = true;

            if (Id.HasValue)
                _ = await Svc.UpdateCompanyBasicAsync(token!, Id.Value, model);
            else
                _ = await Svc.CreateCompanyBasicAsync(token!, model);

            await JS.InvokeVoidAsync("showToast", "Saved", "success");
            Nav.NavigateTo("/CompanyList");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", ex.Message, "error");
        }
        finally
        {
            saving = false;
        }
    }

    void Cancel() => Nav.NavigateTo("/CompanyList");
}
