@page "/UserList"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.Extensions.Options
@using Microsoft.AspNetCore.Components
@using adwportal.Shared      @* PaginationState + PagingExtensions *@
@using adwportal.Components  @* Pager.razor *@
@inject IHttpClientFactory ClientFactory
@inject IOptions<ApiSettings> Options
@inject AuthTokenProvider TokenProvider
@inject IJSRuntime JS
@inject NavigationManager Nav

<h3 class="d-flex align-items-center justify-content-between">
    <span>Users</span>
    <button class="btn btn-sm btn-primary" @onclick="AddUser">+ Add</button>
</h3>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label">Search (Username / Fullname / Email)</label>
                <input class="form-control"
                       placeholder="Type to filter"
                       value="@query"
                       @oninput="(e) => { query = e.Value?.ToString(); ApplyFilterSortAndPage(resetPage: true); }" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Role</label>
                <select class="form-select" value="@roleFilter" @onchange="OnRoleChanged">
                    <option value="">All</option>
                    <option value="Admin">Admin</option>
                    <option value="FrontLine">FrontLine</option>
                    <option value="SaleReport">SaleReport</option>
                </select>
            </div>
            <div class="col-md-3 d-grid">
                <button class="btn btn-outline-secondary" @onclick="Clear">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (!filtered.Any())
{
    <p>No users found.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th @onclick='() => SortBy("Username")' style="cursor:pointer">User @SortIcon("Username")</th>
                    <th @onclick='() => SortBy("Fullname")' style="cursor:pointer">Fullname @SortIcon("Fullname")</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th @onclick='() => SortBy("Role")' style="cursor:pointer">Role @SortIcon("Role")</th>
                    <th style="width:110px;">QR</th>
                    <th style="width:110px;">Active</th>
                    <th class="text-end" style="width:480px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in paged)
                {
                    <tr>
                        <td>@u.Username</td>
                        <td>@u.Fullname</td>
                        <td>@u.Email</td>
                        <td>@u.Phone</td>
                        <td><span class="badge bg-secondary">@u.Role</span></td>
                        <td>
                            @if (u.IsApproveQr == 1)
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                        <td>
                            @if (u.IsActive == 1)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => Edit(u.Id)">Edit</button>

                            @if (u.IsApproveQr == 1)
                            {
                                <button class="btn btn-sm btn-outline-secondary me-2" @onclick="() => RevokeQr(u)">Revoke QR</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success me-2" @onclick="() => ApproveQr(u)">Approve QR</button>
                            }

                            <button class="btn btn-sm btn-outline-info me-2"
                                    title="Generate new QR (preview & download)"
                                    @onclick="() => GenerateQr(u)">
                                Gen QR
                            </button>

                            @if (u.IsActive == 1)
                            {
                                <button class="btn btn-sm btn-outline-danger me-2" @onclick="() => Deactivate(u)">Deactivate</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-success me-2" @onclick="() => Activate(u)">Activate</button>
                            }

                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(u)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ===== Modal: Preview QR ===== *@
    @if (showQrModal && !string.IsNullOrWhiteSpace(qrImageUrl))
    {
        <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.35);">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">QR Preview</h5>
                        <button class="btn-close" type="button" @onclick="CloseQrModal"></button>
                    </div>
                    <div class="modal-body text-center">
                        <img src="@qrImageUrl" alt="QR" class="img-fluid border rounded bg-white p-2" />
                        <div class="small text-muted mt-2 text-break">@qrContentForModal</div>
                    </div>
                    <div class="modal-footer d-flex justify-content-between">
                        <button class="btn btn-outline-secondary" @onclick="DownloadPreviewQr">
                            Download PNG
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <Pager State="_pager"
           OnPageChanged="OnPageChanged"
           ContainerClass="d-flex justify-content-end mt-2" />
}

@code {
    // ---------- QR Modal state ----------
    private bool showQrModal;
    private string? qrImageUrl;
    private string? qrContentForModal;
    private string? qrUsernameForModal;
    // private bool sendingMail;

    // ---------- Paging ----------
    private PaginationState _pager = new() { WindowSize = 5 };

    // ---------- Data ----------
    private bool loading = true;
    private List<UserListItem> all = new();
    private List<UserListItem> filtered = new();
    private List<UserListItem> paged = new();

    // ---------- Filter & Sort ----------
    private string? query;
    private string? roleFilter;

    private string sortCol = "Username";
    private bool sortAsc = true;

    private string ApiBase => Options.Value.ApiBaseUrl ?? "";

    protected override async Task OnInitializedAsync()
    {
        _pager.SetPageSize(10);
        await Load();
        loading = false;
    }

    private HttpClient MakeClient()
    {
        var c = ClientFactory.CreateClient();
        c.BaseAddress = new Uri(ApiBase.TrimEnd('/') + "/");
        c.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", TokenProvider.Token);
        return c;
    }

    private async Task Load()
    {
        try
        {
            var client = MakeClient();
            all = await client.GetFromJsonAsync<List<UserListItem>>("api/Users") ?? new();
            ApplyFilterSortAndPage(resetPage: true);
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Load users failed: {ex.Message}", "error");
            all = new();
            ApplyFilterSortAndPage(resetPage: true);
        }
    }

    // ---------- Filter + Sort + Page ----------
    private void ApplyFilterSortAndPage(bool resetPage)
    {
        IEnumerable<UserListItem> q = all;

        // filter
        if (!string.IsNullOrWhiteSpace(query))
        {
            var s = query.Trim().ToLowerInvariant();
            q = q.Where(x => (x.Username ?? "").ToLower().Contains(s)
                          || (x.Fullname ?? "").ToLower().Contains(s)
                          || (x.Email ?? "").ToLower().Contains(s));
        }
        if (!string.IsNullOrWhiteSpace(roleFilter))
        {
            q = q.Where(x => string.Equals(x.Role ?? "", roleFilter, StringComparison.OrdinalIgnoreCase));
        }

        // sort
        Func<UserListItem, object?> key = sortCol switch
        {
            "Fullname" => x => x.Fullname,
            "Role" => x => x.Role,
            _ => x => x.Username
        };
        q = sortAsc ? q.OrderBy(key) : q.OrderByDescending(key);

        // set collections & page
        filtered = q.ToList();
        _pager.SetTotal(filtered.Count);

        if (resetPage) _pager.GoTo(1);
        else if (_pager.Page > _pager.TotalPages) _pager.GoTo(_pager.TotalPages);

        paged = filtered.Page(_pager);
        StateHasChanged();
    }

    private Task OnPageChanged(int page)
    {
        _pager.GoTo(page);
        paged = filtered.Page(_pager);
        StateHasChanged();
        return Task.CompletedTask;
    }

    // ---------- UI handlers ----------
    private void SortBy(string col)
    {
        if (sortCol == col) sortAsc = !sortAsc; else { sortCol = col; sortAsc = true; }
        ApplyFilterSortAndPage(resetPage: false);
    }

    private MarkupString SortIcon(string c)
    {
        if (sortCol != c) return (MarkupString)string.Empty;
        return (MarkupString)$"<span class='ms-1'>{(sortAsc ? "↑" : "↓")}</span>";
    }

    private void OnRoleChanged(ChangeEventArgs e)
    {
        roleFilter = e.Value?.ToString();
        ApplyFilterSortAndPage(resetPage: true);
    }

    private void Clear()
    {
        query = roleFilter = null;
        sortCol = "Username";
        sortAsc = true;
        ApplyFilterSortAndPage(resetPage: true);
    }

    // ---------- Nav ----------
    private void AddUser() => Nav.NavigateTo("/UserEdit/0");
    private void Edit(int id) => Nav.NavigateTo($"/UserEdit/{id}");

    // ---------- Helpers ----------
    private string BuildQrImageUrl(string? text, int size = 280)
        => string.IsNullOrWhiteSpace(text) ? "" :
           $"https://quickchart.io/qr?size={size}&text={Uri.EscapeDataString(text)}";

    private async Task DownloadQr(string url, string? username)
    {
        var file = $"qr-{(username ?? "user")}-{DateTime.UtcNow:yyyyMMddHHmmss}.png";
        await JS.InvokeVoidAsync("downloadFileFromUrl", url, file);
    }

    private async Task DownloadPreviewQr()
    {
        if (!string.IsNullOrWhiteSpace(qrImageUrl))
            await DownloadQr(qrImageUrl!, qrUsernameForModal);
    }

    private void CloseQrModal()
    {
        showQrModal = false;
        qrImageUrl = null;
        qrContentForModal = null;
        qrUsernameForModal = null;
    }

    // ---------- Actions (QR / Active / Delete) ----------
    private async Task ApproveQr(UserListItem u)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast", $"Approve QR for {u.Username}?", "Approve", "Cancel", "info");
        if (!ok) return;
        var resp = await MakeClient().PutAsync($"api/Users/{u.Id}/approve-qr", null);
        if (resp.IsSuccessStatusCode)
        {
            u.IsApproveQr = 1;
            await JS.InvokeVoidAsync("showToast", "Approved.", "success");
            ApplyFilterSortAndPage(resetPage: false);
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", $"Approve failed: {await resp.Content.ReadAsStringAsync()}", "error");
        }
    }

    private async Task RevokeQr(UserListItem u)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast", $"Revoke QR for {u.Username}?", "Revoke", "Cancel", "warning");
        if (!ok) return;
        var resp = await MakeClient().PutAsync($"api/Users/{u.Id}/revoke-qr", null);
        if (resp.IsSuccessStatusCode)
        {
            u.IsApproveQr = 0;
            await JS.InvokeVoidAsync("showToast", "Revoked.", "success");
            ApplyFilterSortAndPage(resetPage: false);
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", $"Revoke failed: {await resp.Content.ReadAsStringAsync()}", "error");
        }
    }

    private async Task GenerateQr(UserListItem u)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast",
            $"Generate new QR for {u.Username}? คุณจะเห็นภาพเพื่อดาวน์โหลดได้ทันที",
            "Generate", "Cancel", "info");
        if (!ok) return;

        try
        {
            var client = MakeClient();
            var resp = await client.PostAsync($"api/Users/{u.Id}/generate-qr?email=false", null);
            if (!resp.IsSuccessStatusCode)
            {
                // fallback ถ้า API ไม่รองรับพารามิเตอร์ email=false
                resp = await client.PostAsync($"api/Users/{u.Id}/generate-qr", null);
            }

            if (resp.IsSuccessStatusCode)
            {
                var x = await resp.Content.ReadFromJsonAsync<GenQrResponse>();
                if (!string.IsNullOrWhiteSpace(x?.Qr))
                {
                    // อัปเดตข้อมูลในตาราง
                    u.QrLogin = x.Qr;
                    u.IsApproveQr = 0;

                    // เตรียม modal
                    qrContentForModal = u.QrLogin;
                    qrUsernameForModal = u.Username;
                    qrImageUrl = BuildQrImageUrl(u.QrLogin, 512);
                    showQrModal = true;

                    await JS.InvokeVoidAsync("showToast", "QR generated. ดาวน์โหลดได้จากหน้าต่างที่แสดง", "success");
                }
                else
                {
                    await JS.InvokeVoidAsync("showToast", "Generate succeeded but QR is empty.", "warning");
                }

                ApplyFilterSortAndPage(resetPage: false);
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", $"Generate failed: {await resp.Content.ReadAsStringAsync()}", "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Generate failed: {ex.Message}", "error");
        }
    }

    private async Task Activate(UserListItem u)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast", $"Activate user {u.Username}?", "Activate", "Cancel", "success");
        if (!ok) return;
        var resp = await MakeClient().PutAsync($"api/Users/{u.Id}/activate", null);
        if (resp.IsSuccessStatusCode)
        {
            u.IsActive = 1;
            await JS.InvokeVoidAsync("showToast", "User activated.", "success");
            ApplyFilterSortAndPage(resetPage: false);
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", $"Activate failed: {await resp.Content.ReadAsStringAsync()}", "error");
        }
    }

    private async Task Deactivate(UserListItem u)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast", $"Deactivate user {u.Username}?", "Deactivate", "Cancel", "warning");
        if (!ok) return;
        var resp = await MakeClient().PutAsync($"api/Users/{u.Id}/deactivate", null);
        if (resp.IsSuccessStatusCode)
        {
            u.IsActive = 0;
            await JS.InvokeVoidAsync("showToast", "User deactivated.", "success");
            ApplyFilterSortAndPage(resetPage: false);
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", $"Deactivate failed: {await resp.Content.ReadAsStringAsync()}", "error");
        }
    }

    private async Task Delete(UserListItem u)
    {
        var ok = await JS.InvokeAsync<bool>("confirmToast", $"Delete user {u.Username}?", "Delete", "Cancel", "error");
        if (!ok) return;
        var resp = await MakeClient().DeleteAsync($"api/Users/{u.Id}");
        if (resp.IsSuccessStatusCode)
        {
            all.RemoveAll(x => x.Id == u.Id);
            await JS.InvokeVoidAsync("showToast", "Deleted.", "success");
            ApplyFilterSortAndPage(resetPage: false);
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", $"Delete failed: {await resp.Content.ReadAsStringAsync()}", "error");
        }
    }

    // ---------- DTO ----------
    public class UserListItem
    {
        public int Id { get; set; }
        public string? Username { get; set; }
        public string? Fullname { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? Role { get; set; }
        public string? QrLogin { get; set; }
        public int IsApproveQr { get; set; }
        public int IsActive { get; set; }
    }

    public class GenQrResponse { public string Qr { get; set; } = string.Empty; }
}
