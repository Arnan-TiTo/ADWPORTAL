
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.JSInterop
@using adwportal.Components.Common
@inject NavigationManager Nav
@inject IJSRuntime JS

<script>
    window.forceNavigate = function (url) { window.location.href = url; };
</script>


<AuthorizeView>
    <Authorized Context="auth">
        <div class="app-shell">
            @* ===== SIDEBAR ===== *@
            <aside class="sidebar @(isSidebarOpen ? "expanded" : "collapsed")">
                @* Logo area at top of sidebar *@
                <div class="sidebar-brand">
                    <img src="/images/logo.png" class="sidebar-logo" alt="logo" />
                    @if (isSidebarOpen)
                    {
                        <span class="brand-text">VAC Portal</span>
                    }
                </div>

                <nav class="sidebar-nav">
                    <ul>
                        <li>
                            <NavLink href="/" Match="NavLinkMatch.All" class="nav-item-link" ActiveClass="active" title="Home">
                                <i class="bi bi-house-door"></i>
                                <span class="nav-label">Home</span>
                            </NavLink>
                        </li>

                        @if (IsUserInRole(auth.User, "Admin"))
                        {
                            @* Config group *@
                            <li class="nav-group">
                                <button type="button" class="nav-item-link group-toggle" @onclick="ToggleConfig" title="Config">
                                    <i class="bi bi-gear"></i>
                                    <span class="nav-label">Config</span>
                                    @if (isSidebarOpen)
                                    {
                                        <i class="bi bi-chevron-right chevron @(configOpen ? "rotated" : "")"></i>
                                    }
                                </button>
                                @if (configOpen)
                                {
                                    <ul class="sub-menu">
                                        <li>
                                            <NavLink href="/UserList" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="User">
                                                <i class="bi bi-people"></i>
                                                <span class="nav-label">User</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/CompanyList" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Company">
                                                <i class="bi bi-building"></i>
                                                <span class="nav-label">Company</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/PartnerList" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Partner">
                                                <i class="bi bi-briefcase"></i>
                                                <span class="nav-label">Partner</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/ShopList" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Shop">
                                                <i class="bi bi-shop"></i>
                                                <span class="nav-label">Shop</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/ShopGroupList" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Shop Groups">
                                                <i class="bi bi-diagram-3"></i>
                                                <span class="nav-label">Shop Groups</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/MiscList" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Misc">
                                                <i class="bi bi-sliders"></i>
                                                <span class="nav-label">Misc</span>
                                            </NavLink>
                                        </li>
                                    </ul>
                                }
                            </li>
                        }

                        @* Member group *@
                        @if (IsUserInRole(auth.User, "Admin"))
                        {
                            <li class="nav-group">
                                <button type="button" class="nav-item-link group-toggle" @onclick="ToggleMember" title="Member">
                                    <i class="bi bi-person-badge"></i>
                                    <span class="nav-label">Member</span>
                                    @if (isSidebarOpen)
                                    {
                                        <i class="bi bi-chevron-right chevron @(memberOpen ? "rotated" : "")"></i>
                                    }
                                </button>
                                @if (memberOpen)
                                {
                                    <ul class="sub-menu">
                                        <li>
                                            <NavLink href="/LineOaConfigs" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="LINE OA Configs">
                                                <i class="bi bi-chat-square-dots"></i>
                                                <span class="nav-label">LINE OA</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/MemberList" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Member List">
                                                <i class="bi bi-people"></i>
                                                <span class="nav-label">Member List</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/BulkMemImport" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Bulk Import">
                                                <i class="bi bi-file-earmark-arrow-up"></i>
                                                <span class="nav-label">Bulk Import</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/MemberMappingRequests" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Mapping Requests">
                                                <i class="bi bi-link-45deg"></i>
                                                <span class="nav-label">Mapping Requests</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/MemberRewards" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Rewards">
                                                <i class="bi bi-gift"></i>
                                                <span class="nav-label">Rewards</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/PointPolicies" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Point Policies">
                                                <i class="bi bi-calculator"></i>
                                                <span class="nav-label">Point Policies</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/EarnFormulas" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Earn Formulas">
                                                <i class="bi bi-code-slash"></i>
                                                <span class="nav-label">Formulas</span>
                                            </NavLink>
                                        </li>
                                        <li>
                                            <NavLink href="/MemberSummary" Match="NavLinkMatch.Prefix" class="nav-item-link sub" ActiveClass="active" title="Member Summary">
                                                <i class="bi bi-graph-up"></i>
                                                <span class="nav-label">Summary</span>
                                            </NavLink>
                                        </li>
                                    </ul>
                                }
                            </li>
                        }

                        @if (isSidebarOpen) { <li class="nav-divider"></li> }

                        @if (IsUserInRole(auth.User, "Admin", "OfficeUser", "SuperUser"))
                        {
                            <li>
                                <NavLink href="/IdwImport" Match="NavLinkMatch.Prefix" class="nav-item-link" ActiveClass="active" title="IDW Import">
                                    <i class="bi bi-cloud-upload"></i>
                                    <span class="nav-label">IDW Import</span>
                                </NavLink>
                            </li>
                            <li>
                                <NavLink href="/IdwManageList" Match="NavLinkMatch.Prefix" class="nav-item-link" ActiveClass="active" title="IDW Manage">
                                    <i class="bi bi-clipboard-data"></i>
                                    <span class="nav-label">IDW Manage</span>
                                </NavLink>
                            </li>
                        }
                        @if (IsUserInRole(auth.User, "Admin"))
                        {
                            <li>
                                <NavLink href="/shopsOAuth" Match="NavLinkMatch.Prefix" class="nav-item-link" ActiveClass="active" title="MDW Shops OAuth">
                                    <i class="bi bi-shield-lock"></i>
                                    <span class="nav-label">Shops OAuth</span>
                                </NavLink>
                            </li>
                        }
                        @if (IsUserInRole(auth.User, "Admin", "SuperUser"))
                        {
                            <li>
                                <NavLink href="/normalize" Match="NavLinkMatch.Prefix" class="nav-item-link" ActiveClass="active" title="MDW Normalize">
                                    <i class="bi bi-arrow-repeat"></i>
                                    <span class="nav-label">Normalize</span>
                                </NavLink>
                            </li>
                        }
                        @if (IsUserInRole(auth.User, "Admin", "OfficeUser", "SuperUser"))
                        {
                            <li>
                                <NavLink href="/ShippingLabels" Match="NavLinkMatch.Prefix" class="nav-item-link" ActiveClass="active" title="Shipping Labels">
                                    <i class="bi bi-tag"></i>
                                    <span class="nav-label">Labels</span>
                                </NavLink>
                            </li>
                        }
                        @if (IsUserInRole(auth.User, "Admin", "OfficeUser", "SuperUser"))
                        {
                            <li>
                                <NavLink href="/ViewOrderData" Match="NavLinkMatch.Prefix" class="nav-item-link" ActiveClass="active" title="Raw Data Import">
                                    <i class="bi bi-database-add"></i>
                                    <span class="nav-label">Raw Data</span>
                                </NavLink>
                            </li>
                            <li>
                                <NavLink href="/AdwFlowAccountExport" Match="NavLinkMatch.Prefix" class="nav-item-link" ActiveClass="active" title="FlowAccount Export">
                                    <i class="bi bi-file-earmark-spreadsheet"></i>
                                    <span class="nav-label">FlowAccount</span>
                                </NavLink>
                            </li>
                            @if (IsUserInRole(auth.User, "Admin"))
                            {
                                <li>
                                    <NavLink href="/AdwOverallDashboard" Match="NavLinkMatch.Prefix" class="nav-item-link" ActiveClass="active" title="ADW Dashboard">
                                        <i class="bi bi-graph-up-arrow"></i>
                                        <span class="nav-label">Dashboard</span>
                                    </NavLink>
                                </li>
                            }
                        }
                    </ul>
                </nav>

                @* Toggle button at bottom *@
                <button class="sidebar-toggle" @onclick="ToggleSidebar" title="@(isSidebarOpen ? "Collapse" : "Expand")">
                    <i class="bi @(isSidebarOpen ? "bi-chevron-double-left" : "bi-chevron-double-right")"></i>
                </button>
            </aside>

            @* ===== MAIN AREA ===== *@
            <div class="main-wrapper @(isSidebarOpen ? "sidebar-open" : "sidebar-closed")">
                @* Top bar *@
                <header class="topbar">
                    <div class="topbar-left">
                        <div class="user-badge">
                            <i class="bi bi-person-circle"></i>
                            <span>@GetDisplayName(auth.User)</span>
                        </div>
                    </div>
                    <div class="topbar-right">
                        <button class="btn-logout" type="button" @onclick="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </button>
                    </div>
                </header>

                @* Page content *@
                <main class="page-content">
                    @Body
                </main>
            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool isSidebarOpen = true;
    private bool configOpen = false;
    private bool memberOpen = false;

    private void ToggleSidebar() => isSidebarOpen = !isSidebarOpen;
    private void ToggleConfig() => configOpen = !configOpen;
    private void ToggleMember() => memberOpen = !memberOpen;

    private bool IsUserInRole(ClaimsPrincipal? user, params string[] roles)
    {
        if (user == null) return false;
        var userRoles = user.FindAll(ClaimTypes.Role)
                            .Concat(user.FindAll("ROLE"))
                            .Select(c => c.Value.Trim().ToLowerInvariant())
                            .ToList();
        return roles.Any(r => userRoles.Contains(r.Trim().ToLowerInvariant()));
    }

    private static string GetDisplayName(ClaimsPrincipal? user)
    {
        if (user is null) return "";
        var name = user.FindFirst("FULLNAME")?.Value ?? user.Identity?.Name ?? "Unknown";
        var role = user.FindFirst("ROLE")?.Value ?? user.FindFirst(ClaimTypes.Role)?.Value ?? "No Role";
        return $"{name} (Role: {role})";
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("miniapp.logout");
    }
}
